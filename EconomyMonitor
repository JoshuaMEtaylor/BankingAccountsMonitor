  row(x + 1, y + 5, w - 2, "Balance / GDP", fmtPct(f.balance_to_gdp), f.balance_to_gdp and valueColour(f.balance_to_gdp, true) or C.muted)
  row(x + 1, y + 7, w - 2, "Status", f.status or "Live", f.revenue and C.good or C.warn)

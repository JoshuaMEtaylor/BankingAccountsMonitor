local function drawScalePolicy(x, y, w, h, snap)
  local sc = (snap and snap.scale) or {}
  local pol = (snap and snap.policy) or {}
  card(x, y, w, h, "NATIONAL SCALE & POLICY", colors.brown)
  row(x + 1, y + 2, w - 2, "Population", tostring(sc.population or "Awaiting data"), sc.population and C.text or C.muted)
  row(x + 1, y + 3, w - 2, "Companies", tostring(sc.companies or "Awaiting data"), sc.companies and C.text or C.muted)
  row(x + 1, y + 4, w - 2, "Transactions", tostring(sc.transactions_recorded or "Awaiting data"), sc.transactions_recorded and C.text or C.muted)
  row(x + 1, y + 6, w - 2, "Base Rate", fmtPct(pol.base_rate), pol.base_rate and C.cyan or C.muted)
  row(x + 1, y + 7, w - 2, "Inflation Target", fmtPct(pol.inflation_target), pol.inflation_target and C.cyan or C.muted)
  row(x + 1, y + 8, w - 2, "Suggested Rate", fmtPct(pol.suggested_rate), pol.suggested_rate and C.warn or C.muted)
  row(x + 1, y + 9, w - 2, "Policy Stance", pol.stance or "Awaiting policy config", pol.stance and C.warn or C.muted)
end

local function drawCompact(snap)
  clear(C.bg)
  drawTop(snap)

  local w, h = getSize()
  local y = 4
  local m = (snap and snap.monetary) or {}
  local p = (snap and snap.prices) or {}
  local o = (snap and snap.output) or {}
  local sc = (snap and snap.scale) or {}

  row(2, y, w - 2, "Issued Supply", money(m.issued_supply), C.good); y = y + 1
  row(2, y, w - 2, "Private Supply", money(m.private_supply), C.text); y = y + 1
  row(2, y, w - 2, "Treasury Reserve", money(m.treasury_reserve), C.cyan); y = y + 1
  row(2, y, w - 2, "Population", tostring(sc.population or "Awaiting data"), C.text); y = y + 1
  row(2, y, w - 2, "CPI", p.cpi and fmtNum(p.cpi, 2) or "Awaiting basket", p.cpi and C.good or C.muted); y = y + 1
  row(2, y, w - 2, "Inflation", fmtPct(p.inflation), p.inflation and C.warn or C.muted); y = y + 1
  row(2, y, w - 2, "Nominal GDP", money(o.nominal_gdp), o.nominal_gdp and C.good or C.muted); y = y + 1
  row(2, y, w - 2, "Real GDP", money(o.real_gdp), o.real_gdp and C.good or C.muted); y = y + 1
  row(2, y, w - 2, "GDP / Capita", money(o.gdp_per_capita), o.gdp_per_capita and C.good or C.muted)

  drawFooter(snap)
end

local function drawDashboard(snap)
  local w, h = getSize()
  if w < 70 or h < 24 then
    drawCompact(snap)
    return
  end

  clear(C.bg)
  drawTop(snap)

  local margin = 2
  local gap = 2
  local top = 4
  local footer = 2
  local usableH = h - top - footer
  local rowH = math.floor((usableH - 2) / 2)
  if rowH < 10 then rowH = 10 end

  local colW = math.floor((w - (margin * 2) - (gap * 2)) / 3)
  local x1 = margin
  local x2 = x1 + colW + gap
  local x3 = x2 + colW + gap
  local y1 = top
  local y2 = y1 + rowH + 1

  drawOutput(x1, y1, colW, rowH, snap)
  drawPrices(x2, y1, colW, rowH, snap)
  drawMonetary(x3, y1, colW, rowH, snap)

  drawFiscal(x1, y2, colW, rowH, snap)
  drawTrade(x2, y2, colW, rowH, snap)
  drawScalePolicy(x3, y2, colW, rowH, snap)

  drawFooter(snap)
end

-- =============================================================================
-- MAIN LOOP
-- =============================================================================
local function refresh()
  if not db_id then
    connectServer()
  end

  local snap = fetchSnapshot()
  if snap then
    previous_snapshot = last_snapshot
    snap = enrichTrends(snap, previous_snapshot)
    last_snapshot = snap
  end

  drawDashboard(last_snapshot)
end

local function mainLoop()
  refresh()
  local timer = os.startTimer(REFRESH_SECONDS)

  while running do
    local ev, p1 = os.pullEvent()

    if ev == "timer" and p1 == timer then
      refresh()
      timer = os.startTimer(REFRESH_SECONDS)

    elseif ev == "key" then
      if p1 == keys.q then
        running = false
      elseif p1 == keys.r then
        refresh()
        timer = os.startTimer(REFRESH_SECONDS)
      end

    elseif ev == "monitor_touch" then
      -- Touching the monitor forces a refresh; no controls, no actions.
      refresh()
      timer = os.startTimer(REFRESH_SECONDS)

    elseif ev == "terminate" then
      running = false
    end
  end
end


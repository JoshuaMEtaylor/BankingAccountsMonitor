-- =============================================================================
local function main()
  selectDisplay()

  if not openModem() then
    clear(colors.black)
    center(3, "NATIONAL ECONOMIC MONITOR", colors.yellow, colors.black)
    center(5, "ERROR: No modem found.", colors.red, colors.black)
    center(7, "Attach an Ender Modem or network modem and reboot.", colors.lightGray, colors.black)
    sleep(5)
    if using_monitor then term.redirect(native_term) end
    return
  end

  connectServer()
  mainLoop()

  clear(colors.black)
  center(3, "National Economic Monitor closed.", colors.lightGray, colors.black)
  sleep(0.5)

  if using_monitor then
    term.redirect(native_term)
    term.setCursorBlink(false)
    term.setBackgroundColor(colors.black)
    term.setTextColor(colors.white)
    term.clear()
    term.setCursorPos(1, 1)
    print("National Economic Monitor closed.")
  end
end

main()

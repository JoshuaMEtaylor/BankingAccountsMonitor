local function drawCpiPanel(x, y, w, h, snap)
  panelTitle(x, y, w, "CPI & PURCHASING POWER", "", C.purple)
  fill(x, y + 1, w, h - 1, C.bg)

  local p = snap and snap.prices or {}
  local line = y + 2
  labelValue(x + 2, line,     "CPI",              p.cpi and formatIndex(p.cpi) or "Awaiting data", p.cpi and C.white or C.warn)
  labelValue(x + 2, line + 1, "Inflation",        p.inflation and formatPercent(p.inflation) or "Awaiting data", p.inflation and C.white or C.warn)
  labelValue(x + 2, line + 2, "Basket Cost",      p.basket_cost and formatQ(p.basket_cost) or "Awaiting data", p.basket_cost and C.white or C.warn)
  labelValue(x + 2, line + 3, "Purchasing Power", p.purchasing_power and formatIndex(p.purchasing_power) or "Awaiting CPI", p.purchasing_power and C.white or C.warn)
  labelValue(x + 2, line + 5, "Official Prices",  tostring(p.official_prices or 0), C.white)

  local status = p.status or "Awaiting official CPI basket"
  at(x + 2, y + h - 1, "Status: " .. status, p.cpi and C.good or C.warn, C.bg)
end

local function drawInequalityPanel(x, y, w, h, snap)
  panelTitle(x, y, w, "WEALTH INEQUALITY", "", C.red)
  fill(x, y + 1, w, h - 1, C.bg)

  local q = snap and snap.inequality or {}
  local gini = q.gini
  local top10 = q.top10_share
  local medMean = q.median_mean
  local obs = q.observations

  local line = y + 2
  labelValue(x + 2, line,     "Gini Coeff.",  gini and string.format("%.3f", gini) or "Awaiting data", gini and C.white or C.warn)
  labelValue(x + 2, line + 1, "Top 10% Share", top10 and formatPercent(top10) or "Awaiting data", top10 and C.white or C.warn)
  labelValue(x + 2, line + 2, "Median/Mean",  medMean and formatPercent(medMean) or "Awaiting data", medMean and C.white or C.warn)
  labelValue(x + 2, line + 3, "Observations", tostring(obs or 0), C.white)

  if gini then
    progressBar(x + 2, y + h - 3, w - 4, gini * 100, C.red, C.bar_bg)
    at(x + 2, y + h - 2, "0 = equal", C.dim, C.bg)
    rightIn(x + 2, y + h - 2, w - 4, "1 = extreme", C.dim, C.bg)
  end

  at(x + 2, y + h - 1, "Status: " .. tostring(q.status or "Awaiting aggregate"), obs and obs > 0 and C.good or C.warn, C.bg)
end

local function drawMonetaryPanel(x, y, w, h, snap)
  panelTitle(x, y, w, "MONETARY CONDITIONS", "", C.green)
  fill(x, y + 1, w, h - 1, C.bg)

  local m = snap and snap.monetary or {}
  local line = y + 2
  labelValue(x + 2, line,     "Issued Supply",    formatQ(m.issued_supply), m.issued_supply and C.good or C.warn)
  labelValue(x + 2, line + 1, "Private Supply",   formatQ(m.private_supply), m.private_supply and C.white or C.warn)
  labelValue(x + 2, line + 2, "Treasury Reserve", formatQ(m.treasury_reserve), m.treasury_reserve and C.white or C.warn)
  labelValue(x + 2, line + 3, "Reserve Share",    formatPercent(m.reserve_share), m.reserve_share and C.white or C.warn)
  labelValue(x + 2, line + 4, "Supply Change",    m.supply_change and formatQ(m.supply_change) or "0 Q", C.white)
  labelValue(x + 2, line + 5, "Supply Growth",    m.supply_growth and formatPercent(m.supply_growth) or "0.00%", C.white)
  labelValue(x + 2, line + 6, "Issued / Capita",  formatQ(m.issued_per_capita), m.issued_per_capita and C.white or C.warn)
  labelValue(x + 2, line + 7, "Private / Capita", formatQ(m.private_per_capita), m.private_per_capita and C.white or C.warn)
end

local function drawScalePolicyPanel(x, y, w, h, snap)
  panelTitle(x, y, w, "NATIONAL SCALE & POLICY", "", C.brown)
  fill(x, y + 1, w, h - 1, C.bg)

  local s = snap and snap.scale or {}
  local p = snap and snap.policy or {}
  local mid = x + math.floor(w / 2) + 2

  labelValue(x + 2, y + 2, "Population",      tostring(s.population or 0), C.white)
  labelValue(x + 2, y + 3, "Companies",       tostring(s.companies or 0), C.white)
  labelValue(x + 2, y + 4, "Transactions",    tostring(s.transactions or 0), C.white)
  labelValue(x + 2, y + 5, "Official Prices", tostring(s.official_prices or 0), C.white)

  labelValue(mid, y + 2, "Base Rate",        p.base_rate and formatPercent(p.base_rate) or "Awaiting data", p.base_rate and C.white or C.warn)
  labelValue(mid, y + 3, "Inflation Target", p.inflation_target and formatPercent(p.inflation_target) or "Awaiting data", p.inflation_target and C.white or C.warn)
  labelValue(mid, y + 4, "Suggested Rate",   p.suggested_rate and formatPercent(p.suggested_rate) or "Awaiting data", p.suggested_rate and C.white or C.warn)
  labelValue(mid, y + 5, "Policy Stance",    tostring(p.stance or "Awaiting policy config"), C.warn)
end

local function drawHeader(snap)
  titleBar("NATIONAL ECONOMIC MONITOR", "v" .. VERSION, C.header)

  local mode = snap and snap.data_mode or "NO DATA"
  local dataStatus = "PARTIAL"
  if snap and snap.output and snap.output.gdp and snap.prices and snap.prices.cpi and snap.prices.inflation then
    dataStatus = "FULL"
  elseif snap and snap.output and snap.output.gdp then
    dataStatus = "GDP PARTIAL"
  elseif snap and snap.prices and snap.prices.cpi then
    dataStatus = "CPI PARTIAL"
  end

  at(2, 2, "Mode: " .. mode, C.text, C.bg)
  at(30, 2, "Data: " .. dataStatus, dataStatus == "FULL" and C.good or C.warn, C.bg)

  local updated = snap and utcTime(snap.time) or "No update"
  centerIn(1, 2, W, "Updated: " .. updated, C.text, C.bg)
  local serverText = "Server: " .. tostring(db_id or "?")
  at(W - #serverText - 2, 2, serverText, C.text, C.bg)
end

local function drawFooter(snap)
  local y = H - 2
  if y < 1 then return end
  hline(y, "-", C.dim, C.bg)

  local source = snap and snap.source or "none"
  at(2, y + 1, "Source: " .. tostring(source) .. "  /  Mode: " .. tostring(snap and snap.data_mode or "none"), C.dim, C.bg)

  local msg = "Refresh: " .. REFRESH_SECONDS .. "s   " .. FIGURE_PATCH .. "   Monitor: " .. tostring(monitor_name or "terminal") .. "   [O] Quit"
  at(2, H, msg, C.dim, C.bg)

  if last_error and last_error ~= "" then
    rightIn(2, H, W - 3, "Error: " .. last_error, C.bad, C.bg)
  end
end

local function drawScreen(snap)
  clear(C.bg)
  drawHeader(snap)

  -- Keep the layout useful on a large monitor, but tolerate smaller screens.
  local margin = 2
  local gap = 2
  local bodyTop = 4
  local bodyBottom = H - 3
  local bodyH = bodyBottom - bodyTop + 1

  local graphH = math.max(13, math.floor(bodyH * 0.45))
  local lowerTop = bodyTop + graphH + 2
  local lowerH = math.max(10, bodyBottom - lowerTop - 7)
  local scaleTop = lowerTop + lowerH + 2
  local scaleH = math.max(6, bodyBottom - scaleTop + 1)

  local colW = math.floor((W - (margin * 2) - (gap * 2)) / 3)
  local x1 = margin
  local x2 = margin + colW + gap
  local x3 = margin + (colW + gap) * 2

  local output = snap and snap.output or {}
  local prices = snap and snap.prices or {}

  drawLineGraph(x1, bodyTop, colW, graphH, "GDP (GRAPH)", history.gdp, output.gdp, "q", C.blue, output.status)
  drawLineGraph(x2, bodyTop, colW, graphH, "GDP / CAPITA (GRAPH)", history.gdp_per_capita, output.gdp_per_capita, "q", C.cyan, output.status)
  drawLineGraph(x3, bodyTop, colW, graphH, "INFLATION (GRAPH)", history.inflation, prices.inflation, "percent", C.purple, prices.status)

  drawCpiPanel(x1, lowerTop, colW, lowerH, snap)
  drawInequalityPanel(x2, lowerTop, colW, lowerH, snap)
  drawMonetaryPanel(x3, lowerTop, colW, lowerH, snap)

  drawScalePolicyPanel(margin, scaleTop, W - (margin * 2), scaleH, snap)

  drawFooter(snap)
end

-- =============================================================================
-- MAIN LOOP
-- =============================================================================
local function showBootError(msg)
  term.redirect(native_term)
  clear(C.bg)
  print("EconomyMonitor error:")
  print(msg)
end

local function main()
  setDisplay()

  if not openModem() then
    showBootError("No modem found. Attach a modem and reboot.")
    return
  end

  while not connectServer() do
    sleep(2)
  end

  local timer = nil
  local running = true

  local snap = getSnapshot()
  drawScreen(snap)
  timer = os.startTimer(REFRESH_SECONDS)

  while running do
    local ev, p1 = os.pullEvent()

    if ev == "timer" and p1 == timer then
      snap = getSnapshot()
      drawScreen(snap)
      timer = os.startTimer(REFRESH_SECONDS)

    elseif ev == "key" then
      if p1 == keys.o or p1 == keys.q then
        running = false
      elseif p1 == keys.r then
        snap = getSnapshot()
        drawScreen(snap)
        if timer then os.cancelTimer(timer) end
        timer = os.startTimer(REFRESH_SECONDS)
      end

    elseif ev == "monitor_touch" then
      -- Touch refreshes the screen. This is intentionally read-only.
      snap = getSnapshot()
      drawScreen(snap)
      if timer then os.cancelTimer(timer) end
      timer = os.startTimer(REFRESH_SECONDS)

    elseif ev == "term_resize" then
      setDisplay()
      drawScreen(last_snapshot)
    end
  end

  term.redirect(native_term)
  clear(C.bg)
  print("Economy Monitor closed.")
end

main()



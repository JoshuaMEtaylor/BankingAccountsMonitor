local function now()
  return os.epoch("utc")
end

local function mcDay()
  if os.day then return math.floor(tonumber(os.day()) or 0) end
  return math.floor(now() / 1200000)
end

local function lower(s)
  return string.lower(tostring(s or ""))
end

local function trim(s)
  return tostring(s or ""):match("^%s*(.-)%s*$")
end

local function setMsg(msg, col)
  last_message = tostring(msg or "")
  last_colour = col or colors.lightGray
end

local function ensureDir(path)
  local dir = fs.getDir(path)
  if dir and dir ~= "" and not fs.exists(dir) then fs.makeDir(dir) end
end

local function readFile(path)
  if not fs.exists(path) then return nil end
  local f = fs.open(path, "r")
  if not f then return nil end
  local text = f.readAll()
  f.close()
  if not text or text == "" then return nil end
  local ok, data = pcall(textutils.unserialize, text)
  if ok then return data end
  return nil
end

local function writeFile(path, data)
  ensureDir(path)
  local f = fs.open(path, "w")
  if not f then return false end
  f.write(textutils.serialize(data))
  f.close()
  return true
end

local function money(n)
  n = tonumber(n) or 0
  local sign = ""
  if n < 0 then sign = "-"; n = math.abs(n) end
  local s = tostring(math.floor(n + 0.5))
  local out = ""
  while #s > 3 do
    out = "," .. s:sub(-3) .. out
    s = s:sub(1, -4)
  end
  return sign .. s .. out .. " Q"
end

local function pct(n)
  n = tonumber(n) or 0
  return string.format("%.2f%%", n * 100)
end

local function normalType(s)
  s = tostring(s or "")
  s = s:gsub("com%.minecolonies%.building%.", "")
  s = s:gsub("com%.minecolonies%.job%.", "")
  s = s:gsub("[^%w_%- ]", "")
  return lower(s)
end

local function locString(loc)
  if type(loc) ~= "table" then return "0,0,0" end
  local x = loc.x or loc[1] or 0
  local y = loc.y or loc[2] or 0
  local z = loc.z or loc[3] or 0
  return tostring(x) .. "," .. tostring(y) .. "," .. tostring(z)
end

local function workKey(w)
  if type(w) ~= "table" then return nil end
  return normalType(w.type or w.name) .. "@" .. locString(w.location)
end

local function citizenStableId(z)
  if type(z) ~= "table" then return nil end
  local id = z.id or z.citizen_id or z.citizenId or z.citizenID or z.uuid
  if id == nil then return nil end
  return tostring(id)
end

local function citizenAccountId(z)
  local id = citizenStableId(z)
  if not id then return nil end
  if id:find("^citizen:") then return id end
  if id:find("^mc_") then return "citizen:" .. id end
  return "citizen:mc_" .. id
end

local function citizenUsername(z)
  local id = citizenStableId(z)
  if not id then return nil end
  if id:find("^citizen:mc_") then return id:gsub("^citizen:", "") end
  if id:find("^citizen:") then return id:gsub("^citizen:", "") end
  if id:find("^mc_") then return id end
  return "mc_" .. id
end

local function jobTextFromCitizen(z)
  if type(z) ~= "table" then return "" end
  local parts = {}
  if z.job then parts[#parts+1] = tostring(z.job) end
  if z.title then parts[#parts+1] = tostring(z.title) end
  if z.role then parts[#parts+1] = tostring(z.role) end
  if z.profession then parts[#parts+1] = tostring(z.profession) end
  if type(z.work) == "table" then
    if z.work.job then parts[#parts+1] = tostring(z.work.job) end
    if z.work.type then parts[#parts+1] = tostring(z.work.type) end
    if z.work.name then parts[#parts+1] = tostring(z.work.name) end
  elseif type(z.work) == "string" then
    parts[#parts+1] = tostring(z.work)
  end
  return table.concat(parts, " ")
end

local function classifyIndustryFromText(text)local function classifyIndustryFromText(text)
  local j = normalType(text)

  if j:find("guard",1,true) or j:find("soldier",1,true) or j:find("knight",1,true)
    or j:find("archer",1,true) or j:find("ranger",1,true) or j:find("combat",1,true)
    or j:find("barracks",1,true) or j:find("tower",1,true) or j:find("defence",1,true)
    or j:find("defense",1,true) then return "defence" end

  if j:find("research",1,true) or j:find("university",1,true) or j:find("library",1,true)
    or j:find("teacher",1,true) or j:find("pupil",1,true) or j:find("student",1,true)
    or j:find("school",1,true) then return "research" end

  if j:find("cook",1,true) or j:find("restaurant",1,true) or j:find("dining",1,true)
    or j:find("waiter",1,true) or j:find("baker",1,true) or j:find("bakery",1,true) then return "hospitality" end

  if j:find("delivery",1,true) or j:find("courier",1,true) or j:find("warehouse",1,true) then return "logistics" end
  if j:find("miner",1,true) or j:find("mine",1,true) or j:find("quarry",1,true) then return "mining" end
  if j:find("lumber",1,true) or j:find("forester",1,true) or j:find("sawmill",1,true) then return "timber" end
  if j:find("farm",1,true) or j:find("fisher",1,true) or j:find("compost",1,true)
    or j:find("shepherd",1,true) or j:find("cowhand",1,true) or j:find("swine",1,true)
    or j:find("chicken",1,true) or j:find("rabbit",1,true) or j:find("beekeeper",1,true) then return "agriculture" end
  if j:find("smith",1,true) or j:find("smelter",1,true) or j:find("smeltery",1,true)
    or j:find("crusher",1,true) or j:find("mechanic",1,true) or j:find("carpenter",1,true)
    or j:find("fletcher",1,true) or j:find("stonemason",1,true) or j:find("brick",1,true)
    or j:find("glass",1,true) or j:find("concrete",1,true) then return "manufacturing" end
  if j:find("builder",1,true) or j:find("construction",1,true) then return "construction" end

  return "general"
end

local function wageBand(jobText)
  local j = normalType(jobText)

  -- Government/public jobs are excluded from this private payroll system.
  if classifyIndustryFromText(j) == "defence" or classifyIndustryFromText(j) == "research" then
    return nil, "public"
  end

  if j:find("builder",1,true) or j:find("miner",1,true) or j:find("nether",1,true)
    or j:find("quarry",1,true) or j:find("crusher",1,true) or j:find("blacksmith",1,true)
    or j:find("smith",1,true) or j:find("carpenter",1,true) or j:find("fletcher",1,true)
    or j:find("mechanic",1,true) or j:find("doctor",1,true) or j:find("alchemist",1,true)
    or j:find("enchant",1,true) then
    return "elite", WAGE.elite
  end

  if j:find("courier",1,true) or j:find("delivery",1,true) or j:find("forester",1,true)
    or j:find("baker",1,true) or j:find("chef",1,true) or j:find("cook",1,true)
    or j:find("beekeeper",1,true) or j:find("dyer",1,true) or j:find("sifter",1,true)
    or j:find("smelter",1,true) or j:find("stonemason",1,true) or j:find("brick",1,true)
    or j:find("glass",1,true) or j:find("concrete",1,true) or j:find("stable",1,true)
    or j:find("undertaker",1,true) then
    return "skilled", WAGE.skilled
  end

  if j:find("waiter",1,true) or j:find("farmer",1,true) or j:find("fisher",1,true)
    or j:find("planter",1,true) or j:find("florist",1,true) or j:find("composter",1,true)
    or j:find("chicken",1,true) or j:find("cowhand",1,true) or j:find("shepherd",1,true)
    or j:find("swine",1,true) or j:find("rabbit",1,true) or j:find("farm",1,true) then
    return "unskilled", WAGE.unskilled
  end

  return nil, "unknown"
end

local function calculateWage(base)
  base = math.floor(tonumber(base) or 0)
  if base <= 0 then return 0 end

  local gdp_bonus = math.floor((tonumber(gdp_per_capita) or 0) / GDP_STEP)
  if gdp_bonus > GDP_BONUS_CAP then gdp_bonus = GDP_BONUS_CAP end
  if gdp_bonus < 0 then gdp_bonus = 0 end

  local inflation_excess = math.max(0, (tonumber(price_index) or 1) - 1)
  local inflation_bonus = math.floor(inflation_excess * base * INFLATION_PASS_THROUGH)
  if inflation_bonus < 0 then inflation_bonus = 0 end

  local wage = base + gdp_bonus + inflation_bonus
  if wage < 1 then wage = 1 end
  return math.floor(wage), gdp_bonus, inflation_bonus
end


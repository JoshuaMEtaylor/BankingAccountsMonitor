-- =============================================================================
-- GOVERNMENT PAYROLL TERMINAL
-- GovernmentPayroll
--
-- Pays state employees once per Minecraft day.
-- Wages scale with the central Quid inflation price index.
--
-- Base daily wages at price_index = 1.00 are loaded from the Quid bank.
-- Defaults if the bank does not provide rates:
--   Researchers: 3 Q / Minecraft day
--   Soldiers:    2 Q / Minecraft day
--   Couriers:    1 Q / Minecraft day
-- =============================================================================

local args = {...}
if args[1] ~= "--updated" then
  print("[ Government Payroll ]")
  print("Deleting old version...")
  fs.delete("startup.lua")
  print("Downloading latest from GitHub...")

local function loadHistory()
  history = readFile(FILE_HISTORY) or { days = {} }
  history.days = history.days or {}
end

local function saveHistory()
  writeFile(FILE_HISTORY, history)
end

local function dayRecord(day)
  local key = tostring(day)
  history.days[key] = history.days[key] or { paid = {}, total = 0, count = 0, created = now() }
  history.days[key].paid = history.days[key].paid or {}
  return history.days[key]
end

local function refreshTodayStats()
  refreshInflation()
  refreshGDP()

  local day = mcDay()
  local rec = dayRecord(day)
  local eligible = eligibleWorkers()
  local paid = 0
  local total = 0

  for _, e in ipairs(eligible) do
    local pay_key = e.account_id .. "@" .. e.company_id
    local p = rec.paid[pay_key]
    if p then
      paid = paid + 1
      total = total + (tonumber(p.amount) or 0)
    end
  end

  stats.paid_today = paid
  stats.total_today = total
end

local function runPayroll()
  if not db_id then discoverBank() end
  if not db_id then return false end

  refreshInflation()
  refreshGDP()

  local day = mcDay()
  local rec = dayRecord(day)
  local eligible = eligibleWorkers()

  local runCount = 0
  local runTotal = 0
  local skipped = 0
  local overdrafts = 0

  for _, e in ipairs(eligible) do
    local pay_key = e.account_id .. "@" .. e.company_id

    if not rec.paid[pay_key] then
      local okAccount, accountErr = ensureCitizenAccount(e.citizen)
      if okAccount then
        local ok, res = bankReq({
          type = "company_payroll",
          company_id = e.company_id,
          citizen_id = e.account_id,
          amount = e.wage,
          memo = "Private payroll day " .. tostring(day) .. ": " .. tostring(e.band) .. " / " .. tostring(e.name),
        }, 5)

        if ok and type(res) == "table" then
          rec.paid[pay_key] = {
            amount = e.wage,
            tx_id = res.tx_id,
            name = e.name,
            citizen_id = e.account_id,
            company_id = e.company_id,
            company_name = e.company_name,
            industry = e.industry,
            band = e.band,
            base = e.base,
            gdp_bonus = e.gdp_bonus,
            inflation_bonus = e.inflation_bonus,
            gdp_per_capita = gdp_per_capita,
            private_gdp = private_gdp,
            price_index = price_index,
            paid_at = now(),
          }

          if type(res.from_balance_after) == "number" and res.from_balance_after < 0 then
            overdrafts = overdrafts + 1
          end

          runCount = runCount + 1
          runTotal = runTotal + e.wage
        else
          skipped = skipped + 1
          setMsg("Failed " .. e.account_id .. ": " .. tostring(res), colors.red)
        end
      else
        skipped = skipped + 1
        setMsg("Account missing " .. tostring(e.account_id) .. ": " .. tostring(accountErr), colors.red)
      end
    end
  end

  rec.total = 0
  rec.count = 0
  for _, p in pairs(rec.paid) do
    rec.total = rec.total + (tonumber(p.amount) or 0)
    rec.count = rec.count + 1
  end
  rec.updated = now()
  saveHistory()

  stats.last_run_day = day
  stats.last_run_total = runTotal
  stats.last_run_count = runCount
  stats.skipped_today = skipped
  stats.overdraft_payments = overdrafts
  refreshTodayStats()

  if runCount > 0 then
    setMsg("Company payroll paid " .. tostring(runCount) .. ": " .. money(runTotal), colors.lime)
  elseif skipped > 0 then
    setMsg("Company payroll had " .. tostring(skipped) .. " skipped payments.", colors.orange)
  else
    setMsg("Company payroll already complete for day " .. tostring(day), colors.lightGray)
  end

  return true
end

local function todayComplete()
  local eligible = eligibleWorkers()
  local rec = dayRecord(mcDay())
  if #eligible == 0 then return false end
  for _, e in ipairs(eligible) do
    local pay_key = e.account_id .. "@" .. e.company_id
    if not rec.paid[pay_key] then return false end
  end
  return true
end

-- =============================================================================
-- DISPLAY
-- =============================================================================
local function cls()
  W, H = term.getSize()
  term.setCursorBlink(false)
  term.setBackgroundColor(colors.black)
  term.setTextColor(colors.white)
  term.clear()
  term.setCursorPos(1, 1)
end

local function at(x, y, text, fg, bg)
  W, H = term.getSize()
  if y < 1 or y > H or x > W then return end
  if x < 1 then x = 1 end
  term.setCursorPos(x, y)
  term.setTextColor(fg or colors.white)
  term.setBackgroundColor(bg or colors.black)
  local maxw = W - x + 1
  if maxw > 0 then term.write(tostring(text or ""):sub(1, maxw)) end
end

local function fill(x, y, w, h, bg)
  W, H = term.getSize()
  term.setBackgroundColor(bg or colors.black)
  local row = string.rep(" ", math.max(0, w))
  for yy = y, y + h - 1 do
    if yy >= 1 and yy <= H then
      term.setCursorPos(math.max(1, x), yy)
      term.write(row:sub(1, math.max(0, W - x + 1)))
    end
  end
end

local function button(x, y, w, label, bg, fg)
  fill(x, y, w, 1, bg or colors.gray)
  local tx = x + math.floor((w - #label) / 2)
  at(tx, y, label, fg or colors.white, bg or colors.gray)
  return { x1=x, x2=x+w-1, y1=y, y2=y }
end

local function hit(b, mx, my)
  return b and mx >= b.x1 and mx <= b.x2 and my >= b.y1 and my <= b.y2
end

local function draw()
  cls()
  fill(1, 1, W, 1, colors.purple)
  at(2, 1, "COMPANY PAYROLL", colors.white, colors.purple)
  at(W - #VERSION, 1, VERSION, colors.lightGray, colors.purple)

  refreshTodayStats()

  at(2, 3, "Colony:       " .. tostring(colony_name), colors.white)
  at(2, 4, "Bank:         " .. tostring(db_id or "not connected"), db_id and colors.lime or colors.red)
  at(2, 5, "Source:       " .. tostring(stats.source), (stats.source == "colony" or stats.source == "bank") and colors.lime or colors.orange)
  at(2, 6, "Citizens seen:" .. tostring(stats.citizens_seen) .. "   Auto: " .. (auto_mode and "ON" or "OFF"), auto_mode and colors.lime or colors.orange)

  at(2, 8,  "Minecraft day:       " .. tostring(mcDay()), colors.white)
  at(2, 9,  "GDP/capita 7d:       " .. money(gdp_per_capita), colors.cyan)
  at(2, 10, "Private GDP 7d:      " .. money(private_gdp), colors.cyan)
  at(2, 11, "Price index:         x" .. string.format("%.3f", price_index), colors.lightGray)
  at(2, 12, "Inflation pressure:  " .. pct(inflation_rate), inflation_rate >= 0 and colors.orange or colors.lime)

  at(2, 14, "Eligible private workers: " .. tostring(stats.eligible), colors.white)
  at(2, 15, "Paid today:               " .. tostring(stats.paid_today), colors.lightGray)
  at(2, 16, "Total paid today:         " .. money(stats.total_today), colors.lightGray)
  at(2, 17, "Skipped public workers:   " .. tostring(stats.public_skipped), colors.gray)
  at(2, 18, "Unmapped / unknown jobs:  " .. tostring(stats.unmapped) .. " / " .. tostring(stats.unknown_jobs), (stats.unmapped + stats.unknown_jobs) > 0 and colors.orange or colors.gray)
  at(2, 19, "Last run:                 " .. tostring(stats.last_run_count) .. " paid / " .. money(stats.last_run_total), colors.lightGray)

  at(2, 21, "Wages: unskilled 3 Q, skilled 4 Q, elite 5 Q + GDP bonus + small inflation pressure.", colors.gray)
  at(2, 22, "Public workers are excluded. Manage them through the FED/GovernmentPayroll console.", colors.gray)

  local bw = math.floor((W - 8) / 3)
  local bRun = button(2, H - 3, bw, "Run Payroll", colors.purple)
  local bAuto = button(4 + bw, H - 3, bw, auto_mode and "Auto Off" or "Auto On", colors.gray)
  local bRecon = button(6 + (bw * 2), H - 3, bw, "Reconnect", colors.gray)

  at(2, H - 1, tostring(last_message):sub(1, W - 2), last_colour)
  return bRun, bAuto, bRecon
end

-- =============================================================================
-- MAIN
-- =============================================================================
local function main()
  loadHistory()
  loadMappings()
  cls()
  fill(1, 1, W, 1, colors.purple)
  at(2, 1, "COMPANY PAYROLL", colors.white, colors.purple)
  at(2, 3, "Starting...", colors.lightGray)

  findColony()

  if not openModem() then
    at(2, 5, "No modem found.", colors.red)
    at(2, 6, "Attach an Ender/Wireless modem.", colors.lightGray)
    return
  end

  discoverBank()
  refreshInflation()
  refreshGDP()

  local bRun, bAuto, bRecon = draw()
  local timer = os.startTimer(2)

  while true do
    local ev, p1, p2, p3 = os.pullEvent()

    if ev == "timer" and p1 == timer then
      if not db_id then discoverBank() end
      if db_id then
        refreshInflation()
        refreshGDP()
      end

      if auto_mode and db_id and not todayComplete() then
        runPayroll()
      end

      bRun, bAuto, bRecon = draw()
      timer = os.startTimer(CHECK_INTERVAL)

    elseif ev == "mouse_click" then
      local mx, my = p2, p3

      if hit(bRun, mx, my) then
        runPayroll()
      elseif hit(bAuto, mx, my) then
        auto_mode = not auto_mode
        setMsg("Auto mode " .. (auto_mode and "enabled" or "disabled"), auto_mode and colors.lime or colors.orange)
      elseif hit(bRecon, mx, my) then
        discoverBank()
        findColony()
        loadMappings()
        refreshInflation()
        refreshGDP()
      end

      bRun, bAuto, bRecon = draw()

    elseif ev == "terminate" then
      saveHistory()
      break
    end
  end
end



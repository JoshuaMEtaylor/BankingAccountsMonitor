local function loadMappings()
  businesses = readFile(FILE_BUSINESSES) or {}
  industry_companies = readFile(FILE_INDUSTRIES) or {}
end

local function liveColonyCitizens()
  if not colony or not colony.getCitizens then return nil end
  local ok, citizens = pcall(colony.getCitizens)
  if ok and type(citizens) == "table" then
    stats.source = "colony"
    return citizens
  end
  return nil
end

local function bankCitizenFallback()
  local ok, res = bankReq({ type = "list_citizens" }, 4)
  if ok and type(res) == "table" and type(res.citizens) == "table" then
    local out = {}
    for _, c in ipairs(res.citizens) do
      if (c.status or "active") == "active" then
        out[#out+1] = {
          citizen_id = c.citizen_id,
          id = c.citizen_id,
          name = c.display_name,
          display_name = c.display_name,
          username = c.username,
          title = c.title,
          job = c.title,
          _bank_only = true,
        }
      end
    end
    stats.source = "bank"
    return out
  end
  return nil
end

local function bankEmploymentMappings()
  local ok, res = bankReq({ type = "list_employee_mappings" }, 4)
  if ok and type(res) == "table" and type(res.employees) == "table" then
    local out = {}
    for _, e in ipairs(res.employees) do
      if e.active ~= false and e.citizen_id and e.company_id then
        out[#out+1] = {
          citizen_id = e.citizen_id,
          id = e.citizen_id,
          name = e.display_name,
          display_name = e.display_name,
          title = e.job_text,
          job = e.job_text,
          industry = e.industry,
          company_id = e.company_id,
          company_name = e.company_name,
          _bank_only = true,
          _employment_map = true,
        }
      end
    end
    stats.source = "employment"
    stats.employment_seen = #out
    return out
  end
  stats.employment_seen = 0
  return nil
end

local function getCitizens()
  local emp = bankEmploymentMappings()
  if emp and #emp > 0 then return emp end

  local live = liveColonyCitizens()
  if live then return live end

  local bank = bankCitizenFallback()
  if bank then return bank end

  stats.source = "none"
  return {}
end

local function resolveCompanyForCitizen(z)
  if type(z) ~= "table" then return nil, "bad citizen" end

  if z._employment_map and z.company_id then
    local industry = z.industry or classifyIndustryFromText(jobTextFromCitizen(z))
    if PUBLIC_INDUSTRIES[industry] then return nil, "public" end
    return {
      company_id = z.company_id,
      name = z.company_name or z.company_id,
      industry = industry,
    }, "central"
  end

  local jobText = jobTextFromCitizen(z)
  local industry = classifyIndustryFromText(jobText)
  if PUBLIC_INDUSTRIES[industry] then return nil, "public" end
  if type(z.work) == "table" then
    local key = workKey(z.work)
    if key and businesses[key] and businesses[key].company_id then
      local b = businesses[key]
      if PUBLIC_INDUSTRIES[b.industry] then return nil, "public" end
      return b, "building"
    end
  end
  if industry_companies[industry] and industry_companies[industry].company_id then
    return industry_companies[industry], "industry"
  end
  if industry == "general" then return nil, "unknown_job" end
  return nil, "unmapped"
end

local function ensureCitizenAccount(z)
  local account_id = citizenAccountId(z)
  if not account_id then return false, "missing account id" end
  if z._bank_only or z._employment_map then return true, account_id end
  local username = citizenUsername(z)
  local display = tostring(z.name or z.display_name or account_id)
  local jobText = jobTextFromCitizen(z)
  local title = trim(jobText)
  if title == "" then title = "Citizen" end
  local ok, res = bankReq({
    type = "register_citizen",
    display_name = display,
    username = username,
    password = "mc" .. tostring(citizenStableId(z)),
    title = title,
  }, 4)
  if ok then return true, account_id end
  local msg = tostring(res or "")
  if msg:find("Username already exists", 1, true) or msg:find("Account already exists", 1, true) then return true, account_id end
  return false, msg
end

local function eligibleWorkers()
  loadMappings()
  local out = {}
  stats.unmapped = 0
  stats.public_skipped = 0
  stats.unknown_jobs = 0
  stats.missing_mappings = 0
  local citizens = getCitizens()
  stats.citizens_seen = #citizens
  for _, z in ipairs(citizens) do
    local account_id = citizenAccountId(z)
    local name = tostring(z.name or z.display_name or account_id or "Citizen")
    local jobText = jobTextFromCitizen(z)
    local band, baseOrReason = wageBand(jobText)
    if band and account_id then
      local company, reason = resolveCompanyForCitizen(z)
      if company and company.company_id then
        local wage, gdp_bonus, inflation_bonus = calculateWage(baseOrReason)
        out[#out+1] = {
          citizen = z,
          account_id = account_id,
          name = name,
          job_text = jobText,
          band = band,
          base = baseOrReason,
          wage = wage,
          gdp_bonus = gdp_bonus,
          inflation_bonus = inflation_bonus,
          company_id = company.company_id,
          company_name = company.name or company.company_id,
          industry = company.industry or classifyIndustryFromText(jobText),
          mapped_by = reason or "unknown",
        }
      elseif reason == "public" then
        stats.public_skipped = stats.public_skipped + 1
      elseif reason == "unknown_job" then
        stats.unknown_jobs = stats.unknown_jobs + 1
      else
        stats.unmapped = stats.unmapped + 1
        stats.missing_mappings = stats.missing_mappings + 1
      end
    elseif baseOrReason == "public" then
      stats.public_skipped = stats.public_skipped + 1
    elseif account_id then
      stats.unknown_jobs = stats.unknown_jobs + 1
    end
  end
  table.sort(out, function(a, b) return tostring(a.name) < tostring(b.name) end)
  stats.eligible = #out
  return out
end


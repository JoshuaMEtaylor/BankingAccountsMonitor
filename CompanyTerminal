-- =============================================================================
-- HELPERS
-- =============================================================================
local function refreshSize() W, H = term.getSize() end

local function trim(s)
  s = tostring(s or "")
  return s:match("^%s*(.-)%s*$")
end

local function cleanTicker(s)
  s = trim(s):upper()
  s = s:gsub("%s+", "")
  s = s:gsub("[^A-Z0-9_%-]", "")
  return s
end

local function companyIdFromTicker(ticker)
  ticker = cleanTicker(ticker)
  if ticker == "" then return "" end
  return "company:" .. string.lower(ticker)
end

local function normaliseCompanyId(s)
  s = trim(s)
  if s == "" then return "" end
  if s:find(":") then return s end
  return companyIdFromTicker(s)
end

local function positiveInt(s)
  local n = tonumber(s)
  if not n then return nil end
  n = math.floor(n)
  if n <= 0 then return nil end
  return n
end

local function money(n)
  n = tonumber(n) or 0
  local sign = ""
  if n < 0 then sign = "-"; n = math.abs(n) end
  local s = tostring(math.floor(n + 0.5))
  local out = ""
  while #s > 3 do
    out = "," .. s:sub(-3) .. out
    s = s:sub(1, -4)
  end
  return sign .. s .. out .. " Q"
end

local function shortText(s, maxLen)
  s = tostring(s or "")
  maxLen = maxLen or 30
  if #s <= maxLen then return s end
  return s:sub(1, maxLen - 3) .. "..."
end

local function setMessage(msg, colour)
  last_message = tostring(msg or "")
  last_message_colour = colour or C.dim
end

local function isOwner()
  return active_company and (active_company.owner_id == session.citizen_id or active_company.account_owner_id == session.citizen_id)
end

-- =============================================================================
-- DRAWING
-- =============================================================================
local function cls()
  refreshSize()
  term.setCursorBlink(false)
  term.setBackgroundColor(C.bg)
  term.setTextColor(C.body)
  term.clear()
  term.setCursorPos(1, 1)
end

local function at(x, y, text, fg, bg)
  refreshSize()
  if y < 1 or y > H or x > W then return end
  if x < 1 then x = 1 end
  term.setCursorPos(x, y)
  if bg then term.setBackgroundColor(bg) end
  if fg then term.setTextColor(fg) end
  local maxw = W - x + 1
  if maxw > 0 then term.write(tostring(text or ""):sub(1, maxw)) end
end

local function fill(x, y, w, h, bg)
  refreshSize()
  if w <= 0 or h <= 0 then return end
  if x < 1 then x = 1 end
  term.setBackgroundColor(bg or C.card)
  local row = string.rep(" ", math.max(0, w))
  for yy = y, y + h - 1 do
    if yy >= 1 and yy <= H then
      term.setCursorPos(x, yy)
      term.write(row:sub(1, math.max(0, W - x + 1)))
    end
  end
end

local function centre(y, text, fg, bg)
  text = tostring(text or "")
  at(math.max(1, math.floor((W - #text) / 2) + 1), y, text, fg, bg)
end

local function topBar()
  fill(1, 1, W, 1, C.header)
  at(2, 1, "QUID COMPANY TERMINAL", C.hdr_fg, C.header)
  at(W - #VERSION, 1, VERSION, C.dim, C.header)
end

local function card(x, y, w, h) fill(x, y, w, h, C.card) end

local function button(x, y, w, label, bg, fg)
  bg = bg or C.btn_pri
  fg = fg or C.btn_fg
  fill(x, y, w, 1, bg)
  local tx = x + math.floor((w - #label) / 2)
  at(tx, y, label, fg, bg)
  return {x1=x, x2=x+w-1, y1=y, y2=y}
end

local function hit(b, mx, my)
  return b and mx >= b.x1 and mx <= b.x2 and my >= b.y1 and my <= b.y2
end

local function buttonRow(y, specs)
  -- specs = { {key="clear", label="Clear", bg=..., fg=...}, ... }
  local buttons = {}
  local n = #specs
  if n <= 0 then return buttons end
  local gap = 1
  local x0 = 4
  local total = W - 7
  local bw = math.floor((total - ((n - 1) * gap)) / n)
  if bw < 7 then bw = 7 end
  for i, spec in ipairs(specs) do
    local x = x0 + ((i - 1) * (bw + gap))
    local ww = bw
    if i == n then ww = math.max(7, W - x - 2) end
    buttons[spec.key] = button(x, y, ww, spec.label, spec.bg, spec.fg)
  end
  return buttons
end


local function inputField(x, y, w, value, masked)
  value = tostring(value or "")
  local display = masked and string.rep("*", #value) or value
  fill(x, y, w, 1, C.input_bg)
  at(x, y, (display .. string.rep(" ", w)):sub(1, w), C.input_fg, C.input_bg)
  return {x1=x, x2=x+w-1, y1=y, y2=y, cursor_x=x + math.min(#display, w-1), cursor_y=y}
end

local function placeCursor(fields)
  local active = fields and fields[focused]
  if active then
    term.setCursorPos(active.cursor_x, active.cursor_y)
    term.setCursorBlink(true)
  else
    term.setCursorBlink(false)
  end
end

local function statusBar()
  fill(1, H, W, 1, C.bg)
  if last_message ~= "" then at(2, H, last_message:sub(1, W - 2), last_message_colour, C.bg) end
end

local function accountStrip()
  fill(1, 2, W, 2, C.card)
  at(3, 2, session.username or "", C.card_fg, C.card)
  at(3, 3, session.title or "Account Holder", C.label, C.card)
  local id = session.citizen_id or ""
  if id ~= "" then at(W - #id - 1, 2, id, C.label, C.card) end

  local company = active_company_id or "No active company"
  at(3, 4, "Active: " .. shortText(company, W - 12), active_company_id and C.ok or C.warn, C.bg)
end

local function tabStrip(y)
  -- Fixed-width tabs with a blank column between each tab. This avoids the
  -- old "CapitalContracts" visual merge on small ComputerCraft monitors.
  local tabs = {"Register", "Company", "Capital", "Contracts", "Ops"}
  local mode_to_tab = {register=1, company=2, capital=3, contracts=4, ops=5}
  local active = mode_to_tab[mode] or 1
  local buttons = {}
  local gap = 1
  local available = W - 2 - ((#tabs - 1) * gap)
  local tw = math.floor(available / #tabs)
  if tw < 8 then tw = 8 end
  fill(1, y, W, 1, C.bg)
  local x = 2
  for i, label in ipairs(tabs) do
    if x > W then break end
    local ww = math.min(tw, W - x + 1)
    local is_active = i == active
    local bg = is_active and C.tab_act or C.tab_inact
    local fg = is_active and C.tab_fg_a or C.tab_fg_i
    fill(x, y, ww, 1, bg)
    local text = shortText(label, ww)
    at(x + math.max(0, math.floor((ww - #text) / 2)), y, text, fg, bg)
    buttons[i] = {x1=x, x2=math.min(W, x+ww-1), y1=y, y2=y}
    x = x + ww + gap
  end
  return buttons
end

-- =============================================================================
-- NETWORK
-- =============================================================================
local function openModem()
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      local m = peripheral.wrap(name)
      if m and m.isWireless and m.isWireless() then
        rednet.open(name); modem_name = name; return true
      end
    end
  end
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then rednet.open(name); modem_name = name; return true end
  end
  return false
end

local function bankRequest(request, timeout)
  timeout = timeout or DB_TIMEOUT
  if not bank_id then return false, "No bank server connected" end
  rednet.send(bank_id, request, BANK_PROTOCOL)
  local deadline = os.clock() + timeout
  while true do
    local remaining = deadline - os.clock()
    if remaining <= 0 then return false, "No response from bank server" end
    local sender, msg = rednet.receive(BANK_PROTOCOL, remaining)
    if sender == bank_id and type(msg) == "table" and msg.success ~= nil then
      return msg.success, msg.response
    end
  end
end

local function refreshOwnedCompanies(silent)
  owned_companies = {}
  owned_company_count = 0

  if not session.logged_in or not session.username or not session.password then
    if not silent then setMessage("Log in first.", C.err) end
    return false
  end

  local ok, res = bankRequest({
    type = "list_my_companies",
    username = session.username,
    password = session.password,
  })

  if not ok then
    if not silent then setMessage("Owned company scan failed: " .. tostring(res), C.warn) end
    return false
  end

  if type(res) == "table" and type(res.companies) == "table" then
    owned_companies = res.companies
    owned_company_count = tonumber(res.count) or #owned_companies

    if not active_company_id and #owned_companies > 0 then
      local c = owned_companies[1]
      active_company_id = tostring(c.company_id or "")
      active_company = c
      company_lookup.company = active_company_id
      if active_company_id ~= "" then
        if not silent then setMessage("Selected owned company " .. active_company_id, C.ok) end
        return true
      end
    end

    if not silent then
      setMessage("Owned companies: " .. tostring(owned_company_count), owned_company_count > 0 and C.ok or C.warn)
    end
    return true
  end

  if not silent then setMessage("Owned company scan returned no company list.", C.warn) end
  return false
end

local function contractRequest(request, timeout)
  timeout = timeout or DB_TIMEOUT
  if not contract_id then return false, "No contract server connected" end
  rednet.send(contract_id, request, CONTRACT_PROTOCOL)
  local deadline = os.clock() + timeout
  while true do
    local remaining = deadline - os.clock()
    if remaining <= 0 then return false, "No response from contract server" end
    local sender, msg = rednet.receive(CONTRACT_PROTOCOL, remaining)
    if sender == contract_id and type(msg) == "table" and msg.success ~= nil then
      return msg.success, msg.response
    end
  end
end

local function connectBank()
  cls(); topBar(); centre(math.floor(H / 2) - 1, "Connecting to Quid Bank...", C.dim, C.bg)
  for attempt = 1, 8 do
    fill(1, math.floor(H / 2) + 1, W, 1, C.bg)
    centre(math.floor(H / 2) + 1, "Bank attempt " .. attempt .. " of 8", C.dim, C.bg)
    rednet.broadcast({type="ping"}, BANK_PROTOCOL)
    local sender, msg = rednet.receive(BANK_PROTOCOL, 4)
    if sender and type(msg) == "table" then
      if msg.type == "treasury_online" or (msg.success == true and type(msg.response) == "table") then
        bank_id = sender; centre(math.floor(H / 2) + 1, "Bank connected.", C.ok, C.bg); sleep(0.3); return true
      end
    end
  end
  centre(math.floor(H / 2) + 1, "Bank connection failed.", C.err, C.bg); sleep(2); return false
end

local function connectContracts(silent)
  contract_id = nil
  rednet.broadcast({type="ping"}, CONTRACT_PROTOCOL)
  local sender, msg = rednet.receive(CONTRACT_PROTOCOL, 2)
  if sender and type(msg) == "table" then
    if msg.type == "contract_server_online" or (msg.success == true and type(msg.response) == "table") then
      contract_id = sender
      if not silent then setMessage("Contract server connected: " .. tostring(contract_id), C.ok) end
      return true
    end
  end
  if not silent then setMessage("No contract server found.", C.warn) end
  return false
end


local function resultScreen(title, lines, colour)
  cls(); topBar(); card(2, 4, W - 2, H - 5)
  at(4, 5, title, colour or C.card_fg, C.card)
  local y = 7
  for _, line in ipairs(lines or {}) do
    if y > H - 3 then break end
    at(4, y, tostring(line), colour or C.card_fg, C.card)
    y = y + 1
  end
  local b = button(4, H - 2, W - 6, "Continue", C.btn_pri, C.btn_fg)
  term.setCursorBlink(false)
  while true do
    local ev, p1, p2, p3 = os.pullEvent()
    if ev == "mouse_click" and hit(b, p2, p3) then return end
  end
end

local function confirmScreen(title, lines, yesLabel)
  cls(); topBar(); card(2, 4, W - 2, H - 5)
  at(4, 5, title, C.card_fg, C.card)
  local y = 7
  for _, line in ipairs(lines or {}) do at(4, y, tostring(line), C.card_fg, C.card); y = y + 1 end
  local bw = math.floor((W - 8) / 2)
  local b_yes = button(4, H - 2, bw, yesLabel or "Confirm", C.btn_pri, C.btn_fg)
  local b_no = button(5 + bw, H - 2, bw, "Back", C.btn_sec, C.card_fg)
  term.setCursorBlink(false)
  while true do
    local ev, p1, p2, p3 = os.pullEvent()
    if ev == "mouse_click" then
      if hit(b_yes, p2, p3) then return true end
      if hit(b_no, p2, p3) then return false end
    end
  end
end


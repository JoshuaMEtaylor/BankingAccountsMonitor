local function clearCurrentForm()
  if mode == "register" then reg.name, reg.ticker = "", ""
  elseif mode == "company" then company_lookup.company = ""; active_company_id = nil; active_company = nil
  elseif mode == "capital" then capital.amount = ""; capital.memo = "Owner capital injection"
  elseif mode == "contracts" then post.title, post.reward, post.item, post.display, post.count, post.description = "", "", "", "", "", ""
  elseif mode == "ops" then ops.contract_id = ""; ops.note = "Delivered / fulfilled" end
  focused = 1
end

local function appendChar(ch)
  if mode == "register" then
    if focused == 1 and #reg.name < 32 then reg.name = reg.name .. ch end
    if focused == 2 and #reg.ticker < 8 then reg.ticker = reg.ticker .. ch end
  elseif mode == "company" then
    if focused == 1 and #company_lookup.company < 40 then company_lookup.company = company_lookup.company .. ch end
  elseif mode == "capital" then
    if focused == 1 and #capital.amount < 10 then capital.amount = capital.amount .. ch end
    if focused == 2 and #capital.memo < 48 then capital.memo = capital.memo .. ch end
  elseif mode == "contracts" then
    if focused == 1 and #post.title < 40 then post.title = post.title .. ch end
    if focused == 2 and #post.reward < 10 then post.reward = post.reward .. ch end
    if focused == 3 and #post.item < 48 then post.item = post.item .. ch end
    if focused == 4 and #post.count < 10 then post.count = post.count .. ch end
    if focused == 5 and #post.display < 48 then post.display = post.display .. ch end
    if focused == 6 and #post.description < 64 then post.description = post.description .. ch end
  elseif mode == "ops" then
    if focused == 1 and #ops.contract_id < 20 then ops.contract_id = ops.contract_id .. ch end
    if focused == 2 and #ops.note < 64 then ops.note = ops.note .. ch end
  end
end

local function backspaceField()
  if mode == "register" then
    if focused == 1 then reg.name = reg.name:sub(1, -2) end
    if focused == 2 then reg.ticker = reg.ticker:sub(1, -2) end
  elseif mode == "company" then
    company_lookup.company = company_lookup.company:sub(1, -2)
  elseif mode == "capital" then
    if focused == 1 then capital.amount = capital.amount:sub(1, -2) end
    if focused == 2 then capital.memo = capital.memo:sub(1, -2) end
  elseif mode == "contracts" then
    if focused == 1 then post.title = post.title:sub(1, -2) end
    if focused == 2 then post.reward = post.reward:sub(1, -2) end
    if focused == 3 then post.item = post.item:sub(1, -2) end
    if focused == 4 then post.count = post.count:sub(1, -2) end
    if focused == 5 then post.display = post.display:sub(1, -2) end
    if focused == 6 then post.description = post.description:sub(1, -2) end
  elseif mode == "ops" then
    if focused == 1 then ops.contract_id = ops.contract_id:sub(1, -2) end
    if focused == 2 then ops.note = ops.note:sub(1, -2) end
  end
end

local function signOut()
  session.logged_in = false
  session.username = nil
  session.password = nil
  session.citizen_id = nil
  session.title = nil
  login.password = ""
  active_company_id = nil
  active_company = nil
  mode = "register"
  focused = 1
  setMessage("Signed out.", C.dim)
end

local function doPrimary()
  if mode == "register" then doRegister()
  elseif mode == "company" then loadCompany(company_lookup.company)
  elseif mode == "capital" then doCapitalise()
  elseif mode == "contracts" then doPostContract()
  end
end

local function screenMain()
  focused = 1
  local tabs, fields, buttons = drawMain()
  while true do
    local ev, p1, p2, p3 = os.pullEvent()
    if ev == "mouse_click" then
      local mx, my = p2, p3
      if hit(tabs[1], mx, my) then mode = "register"; focused = 1
      elseif hit(tabs[2], mx, my) then mode = "company"; focused = 1
      elseif hit(tabs[3], mx, my) then mode = "capital"; focused = 1
      elseif hit(tabs[4], mx, my) then mode = "contracts"; focused = 1; if not contract_id then connectContracts(true) end
      elseif hit(tabs[5], mx, my) then mode = "ops"; focused = 1; if not contract_id then connectContracts(true) end
      elseif buttons.primary and hit(buttons.primary, mx, my) then doPrimary()
      elseif buttons.payout and hit(buttons.payout, mx, my) then doPayout()
      elseif buttons.clear and hit(buttons.clear, mx, my) then clearCurrentForm(); setMessage("Form cleared.", C.dim)
      elseif buttons.list and hit(buttons.list, mx, my) then showMyContracts()
      elseif buttons.fulfil and hit(buttons.fulfil, mx, my) then doFulfil()
      elseif buttons.cancel and hit(buttons.cancel, mx, my) then doCancel()
      elseif buttons.signout and hit(buttons.signout, mx, my) then signOut(); return "login"
      else
        for i, box in ipairs(fields or {}) do if hit(box, mx, my) then focused = i; break end end
      end
      tabs, fields, buttons = drawMain()
    elseif ev == "char" then
      appendChar(p1); tabs, fields, buttons = drawMain()
    elseif ev == "key" then
      if p1 == keys.backspace then backspaceField(); tabs, fields, buttons = drawMain() end
    end
  end
end


local function main()
  if not openModem() then
    cls(); print("ERROR: No modem found."); print("Attach an Ender Modem and reboot."); return
  end
  while not connectBank() do sleep(2) end
  setMessage("Connected.", C.ok)
  local screen = "login"
  while true do
    if screen == "login" then screen = screenLogin() end
    if screen == "main" then screen = screenMain() end
    if screen == "quit" then break end
  end
  cls(); print("Company Terminal closed.")
end

main()

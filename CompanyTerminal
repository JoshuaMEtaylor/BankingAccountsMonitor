  cls()
  topBar()
  accountStrip()

  local tabs = tabStrip(4)

  local card_y = 6
  local card_h = H - 7
  card(2, card_y, W - 2, card_h)

  local fields = {}
  local b_primary = nil
  local b_clear = nil
  local b_signout = nil

  local btn_y = H - 2
  local third = math.floor((W - 10) / 3)
  if third < 10 then third = 10 end

  if mode == "register" then
    at(4, card_y + 1, "Register a player-made corporation.", C.label, C.card)

    at(4, card_y + 3, "Company Name", C.card_fg, C.card)
    fields[1] = inputField(4, card_y + 4, W - 6, reg.name, false)

    at(4, card_y + 6, "Ticker", C.card_fg, C.card)
    fields[2] = inputField(4, card_y + 7, W - 6, reg.ticker, false)

    local preview = companyIdFromTicker(reg.ticker)
    if preview == "" then preview = "company:<ticker>" end

    at(4, card_y + 9,  "Account: " .. preview, C.label, C.card)
    at(4, card_y + 10, "Owner:   " .. tostring(session.citizen_id or "?"), C.label, C.card)

    b_clear   = button(4, btn_y, third, "Clear", C.btn_sec, C.card_fg)
    b_primary = button(5 + third, btn_y, third + 4, "Register", C.btn_pri, C.btn_fg)
    b_signout = button(10 + (third * 2), btn_y, third, "Sign Out", C.btn_dan, C.btn_fg)

  else
    at(4, card_y + 1, "Look up a registered company.", C.label, C.card)

    at(4, card_y + 3, "Ticker or Company ID", C.card_fg, C.card)
    fields[1] = inputField(4, card_y + 4, W - 6, lookup.company, false)

    b_clear   = button(4, btn_y, third, "Clear", C.btn_sec, C.card_fg)
    b_primary = button(5 + third, btn_y, third + 4, "Lookup", C.btn_pri, C.btn_fg)
    b_signout = button(10 + (third * 2), btn_y, third, "Sign Out", C.btn_dan, C.btn_fg)
  end

  statusBar()
  placeCursor(fields)

  return tabs, fields, b_primary, b_clear, b_signout
end

-- =============================================================================
-- ACTIONS
-- =============================================================================
local function clearRegister()
  reg.name = ""
  reg.ticker = ""
  focused = 1
end

local function clearLookup()
  lookup.company = ""
  focused = 1
end

local function doRegister()
  local name = trim(reg.name)
  local ticker = cleanTicker(reg.ticker)
  local owner_id = session.citizen_id
  local company_id = companyIdFromTicker(ticker)

  if not session.logged_in or not owner_id then
    setMessage("You must be logged in.", C.err)
    return
  end
  if name == "" then setMessage("Missing company name.", C.err); return end
  if ticker == "" then setMessage("Invalid ticker.", C.err); return end

  local summary = {
    name = name,
    ticker = ticker,
    owner_id = owner_id,
    company_id = company_id,
  }

  if not confirmRegister(summary) then
    setMessage("Registration cancelled.", C.dim)
    return
  end

  local ok, res = dbRequest({
    type = "register_company",
    name = name,
    ticker = ticker,
    biz_type = "general",
    owner_id = owner_id,
    shares_total = 1000,
    shares_public = 0,
  })

  if ok and type(res) == "table" then
    local id = tostring(res.company_id or company_id)
    setMessage("Registered " .. id, C.ok)
    resultScreen("COMPANY REGISTERED", {
      "Name:    " .. tostring(res.name or name),
      "Ticker:  " .. tostring(res.ticker or ticker),
      "Account: " .. id,
      "Owner:   " .. owner_id,
      "",
      "Citizens can now transfer funds to:",
      id,
    }, C.ok)
    clearRegister()
  else
    setMessage("Registration failed: " .. tostring(res), C.err)
    resultScreen("REGISTRATION FAILED", {
      tostring(res or "Unknown error"),
      "",
      "Check whether that ticker already exists.",
    }, C.err)
  end
end

local function doLookup()
  local company_id = trim(lookup.company)
  if company_id == "" then
    setMessage("Enter a ticker or company ID.", C.err)
    return
  end

  if not company_id:find(":") then
    company_id = companyIdFromTicker(company_id)
  end

  local ok, res = dbRequest({
    type = "company_info",
    company_id = company_id,
  })

  if ok and type(res) == "table" then
    setMessage("Loaded " .. company_id, C.ok)
    resultScreen("COMPANY INFO", {
      "Name:      " .. tostring(res.name or "?"),
      "Ticker:    " .. tostring(res.ticker or "?"),
      "Account:   " .. tostring(res.company_id or company_id),
      "Owner:     " .. tostring(res.owner_id or "?"),
      "Type:      " .. tostring(res.biz_type or "?"),
      "Status:    " .. tostring(res.status or "?"),
      "Balance:   " .. money(res.cash_balance or 0),
      "Shares:    " .. tostring(res.shares_total or 0),
    }, C.card_fg)
  else
    setMessage("Lookup failed: " .. tostring(res), C.err)
    resultScreen("LOOKUP FAILED", {
      tostring(res or "Unknown error"),
    }, C.err)
  end
end


local function appendChar(ch)
  if mode == "register" then
    if focused == 1 and #reg.name < 32 then reg.name = reg.name .. ch end
    if focused == 2 and #reg.ticker < 8 then reg.ticker = reg.ticker .. ch end
  else
    if focused == 1 and #lookup.company < 40 then lookup.company = lookup.company .. ch end
  end
end

local function backspaceField()
  if mode == "register" then
    if focused == 1 then reg.name = reg.name:sub(1, -2) end
    if focused == 2 then reg.ticker = reg.ticker:sub(1, -2) end
  else
    lookup.company = lookup.company:sub(1, -2)
  end
end

local function signOut()
  session.logged_in = false
  session.username = nil
  session.citizen_id = nil
  session.title = nil
  login.password = ""
  mode = "register"
  focused = 1
  setMessage("Signed out.", C.dim)
end

-- =============================================================================
-- MAIN LOOP
-- =============================================================================
local function screenMain()
  focused = 1
  local tabs, fields, b_primary, b_clear, b_signout = drawMain()

  while true do
    local ev, p1, p2, p3 = os.pullEvent()

    if ev == "mouse_click" then
      local mx, my = p2, p3

      if hit(tabs[1], mx, my) then
        mode = "register"
        focused = 1
      elseif hit(tabs[2], mx, my) then
        mode = "lookup"
        focused = 1
      elseif hit(b_primary, mx, my) then
        if mode == "register" then doRegister() else doLookup() end
      elseif hit(b_clear, mx, my) then
        if mode == "register" then
          clearRegister()
          setMessage("Form cleared.", C.dim)
        else
          clearLookup()
          setMessage("Lookup cleared.", C.dim)
        end
      elseif hit(b_signout, mx, my) then
        signOut()
        return "login"
      else
        for i, box in ipairs(fields) do
          if hit(box, mx, my) then
            focused = i
            break
          end
        end
      end

      tabs, fields, b_primary, b_clear, b_signout = drawMain()

    elseif ev == "char" then
      appendChar(p1)
      tabs, fields, b_primary, b_clear, b_signout = drawMain()

    elseif ev == "key" then
      -- Keyboard only edits the selected input field.
      -- Tabs/buttons are mouse-only.
      if p1 == keys.backspace then
        backspaceField()
        tabs, fields, b_primary, b_clear, b_signout = drawMain()
      end
    end
  end
end

-- =============================================================================
-- ENTRY
-- =============================================================================
local function main()
  if not openModem() then
    cls()
    print("ERROR: No modem found.")
    print("Attach an Ender Modem and reboot.")
    return
  end

  while not connectServer() do
    sleep(2)
  end

  setMessage("Connected.", C.ok)

  local screen = "login"
  while true do
    if screen == "login" then screen = screenLogin() end
    if screen == "main" then screen = screenMain() end
    if screen == "quit" then break end
  end

  cls()
  print("Company Terminal closed.")
end

main()

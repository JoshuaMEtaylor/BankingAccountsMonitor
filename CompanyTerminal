-- LOGIN
-- =============================================================================
local function drawLogin()
  cls(); topBar(); card(2, 4, W - 2, H - 5)
  local fields = {}
  at(4, 5, "Log in with your normal bank account.", C.label, C.card)
  at(4, 6, "This unlocks company ownership controls.", C.label, C.card)
  at(4, 8, "Username", C.card_fg, C.card)
  fields[1] = inputField(4, 9, W - 6, login.username, false)
  at(4, 11, "Password", C.card_fg, C.card)
  fields[2] = inputField(4, 12, W - 6, login.password, true)
  local b_login = button(4, 15, W - 6, "Log In", C.btn_pri, C.btn_fg)
  statusBar(); placeCursor(fields)
  return fields, b_login
end

local function doLogin()
  if trim(login.username) == "" or trim(login.password) == "" then setMessage("Enter username and password.", C.err); return false end
  setMessage("Authenticating...", C.dim)
  local ok, res = bankRequest({type="login", username=login.username, password=login.password})
  if ok and type(res) == "table" then
    session.logged_in = true
    session.username = login.username
    session.password = login.password
    session.citizen_id = res.citizen_id
    session.title = res.title or "Account Holder"
    login.password = ""
    setMessage("Logged in as " .. tostring(session.citizen_id), C.ok)
    refreshOwnedCompanies(true)
    if active_company_id then
      setMessage("Logged in. Active company: " .. tostring(active_company_id), C.ok)
    end
    connectContracts(true)
    return true
  end
  setMessage(tostring(res or "Login failed"), C.err)
  return false
end

local function screenLogin()
  focused = 1
  local fields, b_login = drawLogin()
  while true do
    local ev, p1, p2, p3 = os.pullEvent()
    if ev == "mouse_click" then
      local mx, my = p2, p3
      if hit(b_login, mx, my) then if doLogin() then return "main" end
      else for i, box in ipairs(fields) do if hit(box, mx, my) then focused = i; break end end end
      fields, b_login = drawLogin()
    elseif ev == "char" then
      if focused == 1 and #login.username < 32 then login.username = login.username .. p1 end
      if focused == 2 and #login.password < 32 then login.password = login.password .. p1 end
      fields, b_login = drawLogin()
    elseif ev == "key" then
      if p1 == keys.backspace then
        if focused == 1 then login.username = login.username:sub(1, -2) end
        if focused == 2 then login.password = login.password:sub(1, -2) end
        fields, b_login = drawLogin()
      end
    end
  end
end

-- =============================================================================
-- COMPANY ACTIONS
-- =============================================================================
local function loadCompany(company_id)
  company_id = normaliseCompanyId(company_id)
  if company_id == "" then setMessage("Enter ticker or company ID.", C.err); return false end
  local ok, res = bankRequest({type="company_info", company_id=company_id})
  if ok and type(res) == "table" then
    active_company_id = tostring(res.company_id or company_id)
    active_company = res
    company_lookup.company = active_company_id
    if isOwner() then setMessage("Loaded owned company " .. active_company_id, C.ok)
    else setMessage("Loaded company, but you are not owner.", C.warn) end
    return true
  end
  setMessage("Company load failed: " .. tostring(res), C.err)
  return false
end

local function doRegister()
  local name = trim(reg.name)
  local ticker = cleanTicker(reg.ticker)
  local owner_id = session.citizen_id
  local company_id = companyIdFromTicker(ticker)
  if not session.logged_in or not owner_id then setMessage("You must be logged in.", C.err); return end
  if name == "" then setMessage("Missing company name.", C.err); return end
  if ticker == "" then setMessage("Invalid ticker.", C.err); return end
  if not confirmScreen("Confirm company registration", {
    "Name:    " .. name,
    "Ticker:  " .. ticker,
    "Account: " .. company_id,
    "Owner:   " .. owner_id,
    "",
    "Owner comes from your bank login.",
  }, "Register") then setMessage("Registration cancelled.", C.dim); return end

  local ok, res = bankRequest({
    type = "register_company",
    name = name,
    ticker = ticker,
    biz_type = "general",
    owner_id = owner_id,
    shares_total = 1000,
    shares_public = 0,
  })
  if ok and type(res) == "table" then
    local id = tostring(res.company_id or company_id)
    active_company_id = id
    active_company = nil
    loadCompany(id)
    resultScreen("COMPANY REGISTERED", {
      "Name:    " .. tostring(res.name or name),
      "Ticker:  " .. tostring(res.ticker or ticker),
      "Account: " .. id,
      "Owner:   " .. owner_id,
      "",
      "This company is now selected for control.",
    }, C.ok)
    reg.name, reg.ticker = "", ""
    mode = "company"
  else
    resultScreen("REGISTRATION FAILED", {tostring(res or "Unknown error"), "", "Check whether that ticker already exists."}, C.err)
  end
end

local function doCapitalise()
  if not active_company_id then setMessage("Load/select a company first.", C.err); return end
  if not isOwner() then setMessage("Only the owner can capitalise from this terminal.", C.err); return end
  local amount = positiveInt(capital.amount)
  if not amount then setMessage("Enter a valid amount.", C.err); return end
  if not confirmScreen("Confirm capital injection", {
    "From: " .. tostring(session.citizen_id),
    "To:   " .. tostring(active_company_id),
    "Amt:  " .. money(amount),
    "Memo: " .. trim(capital.memo),
  }, "Transfer") then setMessage("Capital injection cancelled.", C.dim); return end

  local ok, res = bankRequest({
    type = "transfer",
    username = session.username,
    password = session.password,
    to_id = active_company_id,
    amount = amount,
    memo = trim(capital.memo) ~= "" and trim(capital.memo) or "Owner capital injection",
  })
  if ok then
    setMessage("Transferred " .. money(amount) .. " to " .. active_company_id, C.ok)
    capital.amount = ""
    loadCompany(active_company_id)
  else
    setMessage("Transfer failed: " .. tostring(res), C.err)
  end
end

local function doPayout()
  if not active_company_id then setMessage("Load/select a company first.", C.err); return end
  if not isOwner() then setMessage("Only the registered owner can take company payouts.", C.err); return end
  local amount = positiveInt(capital.amount)
  if not amount then setMessage("Enter a valid amount.", C.err); return end
  local memo = trim(capital.memo)
  if memo == "" or memo == "Owner capital injection" then memo = "Owner company payout" end

  if not confirmScreen("Confirm company payout", {
    "From: " .. tostring(active_company_id),
    "To:   " .. tostring(session.citizen_id),
    "Amt:  " .. money(amount),
    "Memo: " .. memo,
    "",
    "This pays company funds back to your personal citizen account.",
  }, "Pay Out") then setMessage("Company payout cancelled.", C.dim); return end

  local ok, res = bankRequest({
    type = "company_withdraw",
    username = session.username,
    password = session.password,
    company_id = active_company_id,
    amount = amount,
    memo = memo,
  })
  if ok then
    setMessage("Paid out " .. money(amount) .. " to " .. tostring(session.citizen_id), C.ok)
    capital.amount = ""
    capital.memo = "Owner capital injection"
    loadCompany(active_company_id)
  else
    setMessage("Payout failed: " .. tostring(res), C.err)
  end
end

-- =============================================================================
-- CONTRACT ACTIONS
-- =============================================================================
local function ensureContracts()
  if contract_id then return true end
  return connectContracts(false)
end

local function doPostContract()
  if not active_company_id then setMessage("Load/select a company first.", C.err); return end
  if not isOwner() then setMessage("Only the owner can post company contracts.", C.err); return end
  if not ensureContracts() then return end

  local title = trim(post.title)
  local reward = positiveInt(post.reward)
  local item = trim(post.item)
  local count = positiveInt(post.count)
  local display = trim(post.display)
  if title == "" then setMessage("Missing contract title.", C.err); return end
  if not reward then setMessage("Invalid reward.", C.err); return end
  if item == "" then setMessage("Missing item id.", C.err); return end
  if not count then setMessage("Invalid item count.", C.err); return end

  if not confirmScreen("Post company contract", {
    "Company: " .. active_company_id,
    "Title:   " .. title,
    "Reward:  " .. money(reward),
    "Item:    " .. tostring(count) .. "x " .. (display ~= "" and display or item),
    "",
    "No escrow is locked yet. ContractServer payment hooks are next.",
  }, "Post") then setMessage("Post cancelled.", C.dim); return end

  local ok, res = contractRequest({
    type = "post_contract",
    title = title,
    description = trim(post.description),
    poster = active_company_id,
    source_account = active_company_id,
    source_company = active_company_id,
    source_type = "company_terminal",
    reward = reward,
    items = {{item=item, display=display ~= "" and display or item, count=count}},
    escrow_status = "not_locked",
  })

  if ok and type(res) == "table" then
    local c = res.contract or {}
    setMessage("Posted " .. tostring(c.contract_id or "contract"), C.ok)
    resultScreen("CONTRACT POSTED", {
      "ID:      " .. tostring(c.contract_id or "?"),
      "Company: " .. active_company_id,
      "Reward:  " .. money(reward),
      "Status:  " .. tostring(c.status or "open"),
    }, C.ok)
    post.title, post.reward, post.item, post.display, post.count, post.description = "", "", "", "", "", ""
  else
    setMessage("Post failed: " .. tostring(res), C.err)
  end
end

local function showMyContracts()
  if not active_company_id then setMessage("Load/select a company first.", C.err); return end
  if not ensureContracts() then return end
  local ok, res = contractRequest({type="list_contracts", status="all"})
  if not ok or type(res) ~= "table" then setMessage("Contract list failed: " .. tostring(res), C.err); return end
  local rows = {}
  for _, c in ipairs(res.contracts or {}) do
    if c.poster == active_company_id or c.claimed_by == active_company_id or c.source_company == active_company_id then
      rows[#rows + 1] = tostring(c.contract_id or "?") .. " | " .. tostring(c.status or "?") .. " | " .. money(c.reward or 0) .. " | " .. shortText(c.title or "", 20)
      if #rows >= 14 then break end
    end
  end
  if #rows == 0 then rows = {"No contracts found for " .. active_company_id} end
  resultScreen("COMPANY CONTRACTS", rows, C.card_fg)
  setMessage("Loaded company contracts.", C.ok)
end

local function doFulfil()
  if not active_company_id then setMessage("Load/select a company first.", C.err); return end
  if not ensureContracts() then return end
  local id = trim(ops.contract_id)
  if id == "" then setMessage("Enter contract ID.", C.err); return end
  if not confirmScreen("Mark fulfilled", {"Contract: " .. id, "Company:  " .. active_company_id, "Note:     " .. trim(ops.note)}, "Fulfil") then return end
  local ok, res = contractRequest({type="mark_fulfilled", contract_id=id, note=trim(ops.note)})
  if ok then setMessage("Marked fulfilled: " .. id, C.ok) else setMessage("Fulfil failed: " .. tostring(res), C.err) end
end

local function doCancel()
  if not active_company_id then setMessage("Load/select a company first.", C.err); return end
  if not isOwner() then setMessage("Only the owner can cancel company-posted contracts here.", C.err); return end
  if not ensureContracts() then return end
  local id = trim(ops.contract_id)
  if id == "" then setMessage("Enter contract ID.", C.err); return end
  if not confirmScreen("Cancel contract", {"Contract: " .. id, "Reason:   Company cancelled from terminal"}, "Cancel") then return end
  local ok, res = contractRequest({type="cancel_contract", contract_id=id, reason="Cancelled from CompanyTerminal by " .. tostring(session.citizen_id)})
  if ok then setMessage("Cancelled: " .. id, C.ok) else setMessage("Cancel failed: " .. tostring(res), C.err) end
end


-- SCREEN: Welcome / Login / Create Account
-- -----------------------------------------------------------------------
local function screenLogin()
  resetSession()

  local mode = "login"  -- "login" or "create"
  local error_msg = ""
  local success_msg = ""

  local function draw()
    cls()
    drawHeader(mode == "login" and "Welcome" or "Create Account")

    -- Bank logo area
    centreText(5, "QUID BANK", COL.title_txt)
    centreText(6, "of Plenty", COL.dim_txt)

    -- Tab buttons
    local tab_w = math.floor(W / 2) - 2
    local btn_login  = drawButton(2,       8, tab_w, "  Log In  ",  mode=="login"  and COL.btn_blue or COL.btn_gray)
    local btn_create = drawButton(tab_w+3, 8, tab_w, "  Register",  mode=="create" and COL.btn_blue or COL.btn_gray)

    -- Divider
    drawRect(1, 9, W, 1, COL.panel)
    writeAt(1, 9, string.rep("-", W), COL.border, COL.bg)

    if mode == "login" then
      writeAt(3, 11, "Username:", COL.dim_txt, COL.bg)
      drawRect(3, 12, W-4, 1, COL.input_bg)

      writeAt(3, 14, "Password:", COL.dim_txt, COL.bg)
      drawRect(3, 15, W-4, 1, COL.input_bg)

      local btn_go = drawButton(math.floor(W/2)-5, 17, 12, "[ Log In ]", COL.btn_green)
    else
      writeAt(3, 11, "Display Name:", COL.dim_txt, COL.bg)
      drawRect(3, 12, W-4, 1, COL.input_bg)

      writeAt(3, 14, "Username:", COL.dim_txt, COL.bg)
      drawRect(3, 15, W-4, 1, COL.input_bg)

      writeAt(3, 17, "Password:", COL.dim_txt, COL.bg)
      drawRect(3, 18, W-4, 1, COL.input_bg)

      local btn_go = drawButton(math.floor(W/2)-6, 20, 14, "[ Create Account ]", COL.btn_green)
    end

    -- Messages
    if error_msg ~= "" then
      centreText(H-2, error_msg, COL.error_txt, COL.bg)
    end
    if success_msg ~= "" then
      centreText(H-2, success_msg, COL.success_txt, COL.bg)
    end
  end

  draw()

  -- Field input loop
  while true do
    -- Redraw tabs + layout fresh each time so clicks register
    cls()
    drawHeader(mode == "login" and "Welcome" or "Create Account")
    centreText(5, "QUID BANK", COL.title_txt)
    centreText(6, "of Plenty", COL.dim_txt)

    local tab_w    = math.floor(W / 2) - 2
    local btn_login  = drawButton(2,       8, tab_w, "  Log In  ", mode=="login"  and COL.btn_blue or COL.btn_gray)
    local btn_create = drawButton(tab_w+3, 8, tab_w, "  Register", mode=="create" and COL.btn_blue or COL.btn_gray)
    drawRect(1, 9, W, 1, COL.bg)
    writeAt(1, 9, string.rep("-", W), COL.border, COL.bg)

    if error_msg ~= "" then centreText(H-2, error_msg, COL.error_txt, COL.bg) end
    if success_msg ~= "" then centreText(H-2, success_msg, COL.success_txt, COL.bg) end

    local display_name, username, password = "", "", ""

    if mode == "login" then
      writeAt(3, 11, "Username:", COL.dim_txt, COL.bg)
      drawRect(3, 12, W-4, 1, COL.input_bg)
      writeAt(3, 14, "Password:", COL.dim_txt, COL.bg)
      drawRect(3, 15, W-4, 1, COL.input_bg)
      local btn_go = drawButton(math.floor(W/2)-5, 17, 12, "[ Log In ]", COL.btn_green)

      -- Get username
      writeAt(3, 12, "", nil, nil)
      username = inputField(3, 12, W-4, false)
      error_msg = ""; success_msg = ""
      centreText(H-2, "", nil, COL.bg)

      -- Check for tab click during input
      if username == "" then
        -- Possible mouse click handled inside inputField, redraw
        goto continue
      end

      -- Get password
      password = inputField(3, 15, W-4, true)

      -- Wait for button click or enter
      local btn_go2 = drawButton(math.floor(W/2)-5, 17, 12, "[ Log In ]", COL.btn_green)
      local ev, btn, mx, my = os.pullEvent("mouse_click")
      if clicked(btn_login, mx, my) then mode="login"; goto continue end
      if clicked(btn_create, mx, my) then mode="create"; goto continue end

      -- Attempt login
      if username ~= "" and password ~= "" then
        centreText(H-2, "Authenticating...", COL.dim_txt, COL.bg)
        local ok, res = dbRequest({
          type     = "login",
          username = username,
          password = password,
        })
        if ok and type(res) == "table" then
          session.logged_in    = true
          session.citizen_id   = res.citizen_id
          session.display_name = res.display_name
          session.username     = username
          session._password    = password
          session.balance      = res.balance
          session.title        = res.title
          session.last_activity = os.clock()
          return "dashboard"
        else
          error_msg = tostring(res or "Login failed")
          success_msg = ""
        end
      end

    else  -- create mode
      writeAt(3, 11, "Display Name:", COL.dim_txt, COL.bg)
      drawRect(3, 12, W-4, 1, COL.input_bg)
      writeAt(3, 14, "Username:", COL.dim_txt, COL.bg)
      drawRect(3, 15, W-4, 1, COL.input_bg)
      writeAt(3, 17, "Password:", COL.dim_txt, COL.bg)
      drawRect(3, 18, W-4, 1, COL.input_bg)
      local btn_go = drawButton(math.floor(W/2)-6, 20, 14, "[ Create Account ]", COL.btn_green)

      display_name = inputField(3, 12, W-4, false)
      if display_name == "" then goto continue end

      username = inputField(3, 15, W-4, false)
      if username == "" then goto continue end

      password = inputField(3, 18, W-4, true)

      local btn_go2 = drawButton(math.floor(W/2)-6, 20, 14, "[ Create Account ]", COL.btn_green)
      local ev, btn, mx, my = os.pullEvent("mouse_click")
      if clicked(btn_login, mx, my)  then mode="login";  goto continue end
      if clicked(btn_create, mx, my) then mode="create"; goto continue end

      if display_name ~= "" and username ~= "" and password ~= "" then
        centreText(H-2, "Creating account...", COL.dim_txt, COL.bg)
        local ok, res = dbRequest({
          type         = "create_account",
          display_name = display_name,
          username     = username,
          password     = password,
        })
        if ok and type(res) == "table" then
          -- Auto-login
          session.logged_in    = true
          session.citizen_id   = res.citizen_id
          session.display_name = res.display_name
          session.username     = username
          session._password    = password
          session.balance      = res.balance or 0
          session.title        = res.title
          session.last_activity = os.clock()
          return "dashboard"
        else
          error_msg = tostring(res or "Registration failed")
          success_msg = ""
        end
      end
    end

    ::continue::
  end
end


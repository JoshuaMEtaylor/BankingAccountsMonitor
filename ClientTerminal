local function screenHistory()
  cls()
  drawHeader("Transaction History")
  centreText(7, "Loading...", COL.dim_txt)

  local ok, res = dbRequest({
    type     = "ledger_history",
    username = session.username,
    password = session._password,
    limit    = 12,
  })

  cls()
  drawHeader("Transaction History")

  local btn_back = drawButton(math.floor(W/2)-4, H-2, 10, "< Back", COL.btn_gray)

  if not ok or type(res) ~= "table" then
    centreText(8, "Could not load history", COL.error_txt)
    os.pullEvent("mouse_click")
    return "dashboard"
  end

  local history = res.history or {}

  -- Header row
  writeAt(2,  5, "TX ID",     COL.dim_txt)
  writeAt(12, 5, "Type",      COL.dim_txt)
  writeAt(22, 5, "Amount",    COL.dim_txt)
  writeAt(32, 5, "Dir",       COL.dim_txt)
  writeAt(37, 5, "Memo",      COL.dim_txt)
  writeAt(1,  6, string.rep("-", W-1), COL.border)

  if #history == 0 then
    centreText(10, "No transactions yet", COL.dim_txt)
  else
    for i, tx in ipairs(history) do
      local row = 6 + i
      if row >= H - 2 then break end
      local col = tx.direction == "IN" and COL.money_txt or COL.error_txt
      local dir = tx.direction == "IN" and "+ " or "- "
      writeAt(2,  row, tostring(tx.tx_id or ""):sub(1,9),         COL.dim_txt)
      writeAt(12, row, tostring(tx.type or ""):sub(1,9),           COL.dim_txt)
      writeAt(22, row, dir .. tostring(tx.amount or 0) .. "q",     col)
      writeAt(32, row, tostring(tx.direction or ""):sub(1,4),      col)
      writeAt(37, row, tostring(tx.memo or ""):sub(1, W-37),       COL.dim_txt)
    end
  end

  writeAt(2, H-2, "Balance: " .. (res.balance or 0) .. " Quid", COL.money_txt)

  while true do
    touchActivity()
    local ev, b, mx, my = os.pullEvent("mouse_click")
    if clicked(btn_back, mx, my) then return "dashboard" end
  end
end

-- -----------------------------------------------------------------------
-- SCREEN: Timeout notice
-- -----------------------------------------------------------------------
local function screenTimeout()
  cls()
  drawHeader("Session Expired")
  centreText(8,  "You have been logged out", COL.dim_txt)
  centreText(9,  "due to inactivity.", COL.dim_txt)
  centreText(12, "Press any key to continue", COL.body_txt)
  os.pullEvent("mouse_click")
  resetSession()
  return "login"
end

-- =============================================================================
-- MAIN LOOP
-- =============================================================================
local function main()
  if not openModem() then
    cls()
    print("ERROR: No modem found.")
    print("Attach an Ender Modem and reboot.")
    return
  end

  -- Connect to DB
  local connected = false
  while not connected do
    connected = screenConnecting()
  end

  -- Start idle timer
  local idle_timer = os.startTimer(5)

  local screen = "login"

  while true do
    if screen == "login"     then screen = screenLogin()     end
    if screen == "dashboard" then screen = screenDashboard() end
    if screen == "transfer"  then screen = screenTransfer()  end
    if screen == "history"   then screen = screenHistory()   end
    if screen == "timeout"   then screen = screenTimeout()   end
    if screen == "logout"    then resetSession(); screen = "login" end
    if screen == "quit"      then break end
  end

  cls()
  print("Terminal closed.")
end

main()

-- =============================================================================
-- MAIN PROGRAM
-- =============================================================================

local VERSION      = "1.2.4"
local PROTOCOL     = "quid_bank"
local DB_TIMEOUT   = 5
local IDLE_TIMEOUT = 60

local W, H = term.getSize()

-- =============================================================================
-- COLOUR PALETTE  — professional banking aesthetic
-- =============================================================================
local C = {
  bg       = colors.lightGray,   -- page background (light, like a website)
  card     = colors.white,       -- card/panel background
  card_fg  = colors.black,       -- text on cards
  accent   = colors.purple,      -- primary brand colour
  accent_fg= colors.white,
  header   = colors.purple,      -- top bar (NatWest purple)
  hdr_fg   = colors.white,
  label    = colors.gray,        -- muted label text (readable on white)
  body     = colors.black,       -- normal body text
  dim      = colors.gray,
  in_bg    = colors.lightGray,   -- input fill - distinct from white card
  in_fg    = colors.black,
  in_act   = colors.white,       -- focused input - white with accent cursor
  in_border= colors.gray,        -- input border marker
  btn_pri  = colors.purple,      -- primary button
  btn_sec  = colors.lightGray,   -- secondary button
  btn_dan  = colors.red,         -- destructive button
  btn_fg   = colors.white,
  err      = colors.red,
  ok       = colors.green,
  money    = colors.black,       -- balance in black like real banking
  money_pos= colors.green,
  sep      = colors.lightGray,   -- separator lines
  tab_act  = colors.white,       -- active tab
  tab_bg   = colors.gray,        -- inactive tab
  tab_fg_a = colors.purple,      -- active tab text
  tab_fg_i = colors.white,       -- inactive tab text
  caps     = colors.orange,      -- caps lock warning
}

-- =============================================================================
-- STATE
-- =============================================================================
local db_id     = nil
local modemName = nil
local capsLock  = false   -- tracked manually

local session = {
  logged_in = false,
  citizen_id   = nil,
  display_name = nil,
  username     = nil,
  _password    = nil,
  balance      = 0,
  title        = nil,
  last_act     = 0,
}

-- =============================================================================
-- DRAWING PRIMITIVES
-- =============================================================================
local function cls()
  term.setBackgroundColor(C.bg)
  term.setTextColor(C.body)
  term.clear()
  term.setCursorPos(1,1)
end

local function at(x, y, text, fg, bg)
  if x < 1 or y < 1 or y > H then return end
  term.setCursorPos(x, y)
  if bg then term.setBackgroundColor(bg) end
  if fg then term.setTextColor(fg) end
  local maxw = W - x + 1
  if maxw <= 0 then return end
  term.write(tostring(text):sub(1, maxw))
end

local function fill(x, y, w, h, bg)
  term.setBackgroundColor(bg or C.card)
  local row_str = string.rep(" ", math.max(0, w))
  for row = y, y+h-1 do
    if row >= 1 and row <= H then
      term.setCursorPos(x, row)
      term.write(row_str)
    end
  end
end

local function centre(y, text, fg, bg)
  local x = math.max(1, math.floor((W - #text) / 2) + 1)
  at(x, y, text, fg, bg)
end

local function hline(y, fg, bg)
  at(1, y, string.rep("-", W), fg or C.sep, bg or C.bg)
end

-- =============================================================================
-- UI COMPONENTS
-- =============================================================================

-- Top bar: bank name left, version right
local function topBar()
  fill(1, 1, W, 1, C.header)
  at(2,       1, "QUID BANK OF PLENTY",           C.hdr_fg, C.header)
  at(W-#VERSION, 1, VERSION,                       C.dim,    C.header)
end

-- Section card: a labelled white panel
local function card(x, y, w, h)
  fill(x, y, w, h, C.card)
end

-- Label above, value below (inside a card)
local function labelValue(x, y, label, value, val_col)
  at(x, y,   label, C.label, C.card)
  at(x, y+1, value, val_col or C.card_fg, C.card)
end

-- Thin separator
local function sep(y)
  fill(1, y, W, 1, C.bg)
  at(1, y, string.rep("\140", W), C.sep, C.bg)
end

-- Button: returns hit-test table
local function btn(x, y, w, label, col, fg)
  col = col or C.btn_pri
  fg  = fg  or C.btn_fg
  if col == C.card then fg = C.card_fg end
  fill(x, y, w, 1, col)
  local tx = x + math.floor((w - #label) / 2)
  at(tx, y, label, fg, col)
  return {x1=x, y1=y, x2=x+w-1, y2=y}
end

local function hit(b, mx, my)
  return b and mx>=b.x1 and mx<=b.x2 and my==b.y1
end

-- Input field: light-grey fill on white card so it's clearly visible,
-- with a left accent marker when focused. Caps indicator on the right.
local function inputField(x, y, w, value, masked, focused)
  local bg = focused and C.in_act or C.in_bg
  fill(x, y, w, 1, bg)
  -- Left edge marker shows focus
  at(x, y, focused and "\149" or " ", focused and C.accent or C.in_border, bg)
  local display = masked and string.rep("*", #value) or value
  local inner_w = w - 2
  local padded  = display .. string.rep(" ", math.max(0, inner_w - #display))
  at(x+1, y, padded:sub(1, inner_w), C.in_fg, bg)
  if focused then
    if capsLock then
      at(x + w - 5, y, "CAPS", C.caps, bg)
    end
    local cap = capsLock and 6 or 1
    term.setCursorPos(x + 1 + math.min(#value, inner_w - (capsLock and 5 or 0)), y)
    term.setCursorBlink(true)
  end
  return {x1=x, y1=y, x2=x+w-1, y2=y}
end

-- Tab strip: returns list of hit-test tables
local function tabStrip(y, tabs, active)
  fill(1, y, W, 1, C.bg)
  local tw = math.floor(W / #tabs)
  local btns = {}
  for i, label in ipairs(tabs) do
    local x  = (i-1)*tw + 1
    local is_active = (i == active)
    local col = is_active and C.tab_act or C.tab_bg
    local fg  = is_active and C.tab_fg_a or C.tab_fg_i
    fill(x, y, tw, 1, col)
    local tx = x + math.floor((tw - #label)/2)
    at(tx, y, label, fg, col)
    btns[i] = {x1=x, y1=y, x2=x+tw-1, y2=y}
  end
  return btns
end

-- Status bar at bottom
local function statusBar(msg, col)
  fill(1, H, W, 1, C.bg)
  if msg and msg ~= "" then
    at(2, H, msg, col or C.dim, C.bg)
  end
  if session.logged_in then
    local idle = math.max(0, IDLE_TIMEOUT - math.floor(os.clock() - session.last_act))
    local idle_str = "Logout in " .. idle .. "s"
    at(W - #idle_str, H, idle_str, C.dim, C.bg)
  end
end

-- =============================================================================
-- NETWORK
-- =============================================================================
local function openModem()
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      local m = peripheral.wrap(name)
      if m and m.isWireless and m.isWireless() then
        rednet.open(name)
        modemName = name
        return true
      end
    end
  end
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      rednet.open(name)
      modemName = name
      return true
    end
  end
  return false
end

local function dbRequest(req)
  if not db_id then return false, "Not connected" end
  rednet.send(db_id, req, PROTOCOL)
  local sender, msg = rednet.receive(PROTOCOL, DB_TIMEOUT)
  if not sender or type(msg) ~= "table" then
    return false, "No response from server"
  end
  return msg.success, msg.response
end


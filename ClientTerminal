-- SCREEN: Transfer
-- -----------------------------------------------------------------------
local function screenTransfer()
  local error_msg = ""

  local function draw()
    cls()
    drawHeader("Transfer Funds")

    writeAt(3, 5,  "From:", COL.dim_txt)
    writeAt(9, 5,  session.citizen_id or "", COL.body_txt)
    writeAt(3, 6,  "Balance:", COL.dim_txt)
    writeAt(11, 6, (session.balance or 0) .. " Quid", COL.money_txt)

    writeAt(3, 9,  "Recipient (username or account ID):", COL.dim_txt)
    drawRect(3, 10, W-4, 1, COL.input_bg)

    writeAt(3, 12, "Amount (Quid):", COL.dim_txt)
    drawRect(3, 13, W-4, 1, COL.input_bg)

    writeAt(3, 15, "Memo (optional):", COL.dim_txt)
    drawRect(3, 16, W-4, 1, COL.input_bg)

    local bw = math.floor((W-6)/2)
    local btn_confirm = drawButton(3,    18, bw, "Confirm Transfer", COL.btn_green)
    local btn_back    = drawButton(bw+4, 18, bw, "< Back",           COL.btn_gray)

    if error_msg ~= "" then centreText(H-2, error_msg, COL.error_txt, COL.bg) end

    return btn_confirm, btn_back
  end

  local btn_confirm, btn_back = draw()

  while true do
    touchActivity()

    -- Get recipient
    local to_id = inputField(3, 10, W-4, false)
    if to_id == "" then
      local ev, b, mx, my = os.pullEvent("mouse_click")
      if clicked(btn_back, mx, my) then return "dashboard" end
      goto continue
    end

    -- Get amount
    local amount_str = inputField(3, 13, W-4, false)
    local amount = tonumber(amount_str)
    if not amount or amount <= 0 then
      error_msg = "Enter a valid amount"
      btn_confirm, btn_back = draw()
      goto continue
    end

    -- Get memo
    local memo = inputField(3, 16, W-4, false)

    -- Confirm button
    btn_confirm, btn_back = draw()
    -- Show summary above button
    writeAt(3, 17, string.format("Send %d Quid to %s", amount, to_id), COL.body_txt)
    local ev, b, mx, my = os.pullEvent("mouse_click")
    if clicked(btn_back, mx, my) then return "dashboard" end

    if clicked(btn_confirm, mx, my) then
      centreText(H-2, "Processing...", COL.dim_txt, COL.bg)
      local ok, res = dbRequest({
        type     = "transfer",
        username = session.username,
        password = session._password,
        to_id    = to_id,
        amount   = amount,
        memo     = memo,
      })
      if ok and type(res) == "table" then
        -- Success screen
        cls()
        drawHeader("Transfer Complete")
        centreText(8,  "Transfer Successful!", COL.success_txt)
        centreText(10, res.tx_id or "TX confirmed", COL.dim_txt)
        centreText(11, amount .. " Quid sent to " .. to_id, COL.body_txt)
        refreshBalance()
        centreText(13, "New balance: " .. (session.balance or 0) .. " Quid", COL.money_txt)
        local btn_ok = drawButton(math.floor(W/2)-5, 15, 12, "[ OK ]", COL.btn_blue)
        os.pullEvent("mouse_click")
        return "dashboard"
      else
        error_msg = tostring(res or "Transfer failed")
        btn_confirm, btn_back = draw()
      end
    end

    ::continue::
  end
end


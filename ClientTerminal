-- =============================================================================
local C = {
  bg       = colors.black,
  panel    = colors.gray,
  hdr_bg   = colors.yellow,
  hdr_fg   = colors.black,
  title    = colors.yellow,
  body     = colors.white,
  dim      = colors.lightGray,
  in_bg    = colors.white,
  in_fg    = colors.black,
  green    = colors.green,
  red      = colors.red,
  blue     = colors.blue,
  gray     = colors.gray,
  btn_fg   = colors.white,
  err      = colors.red,
  ok       = colors.lime,
  money    = colors.lime,
  border   = colors.yellow,
}

-- =============================================================================
-- STATE
-- =============================================================================
local db_id     = nil
local modemName = nil

local session = {
  logged_in    = false,
  citizen_id   = nil,
  display_name = nil,
  username     = nil,
  _password    = nil,
  balance      = 0,
  title        = nil,
  last_act     = 0,

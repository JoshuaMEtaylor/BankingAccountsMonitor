-- =============================================================================
-- DRAWING HELPERS
-- =============================================================================
local function cls()
  term.setBackgroundColor(COL.bg)
  term.setTextColor(COL.body_txt)
  term.clear()
  term.setCursorPos(1, 1)
end

local function setColor(fg, bg)
  if fg then term.setTextColor(fg) end
  if bg then term.setBackgroundColor(bg) end
end

local function drawRect(x, y, w, h, bg)
  term.setBackgroundColor(bg or COL.panel)
  for row = y, y + h - 1 do
    term.setCursorPos(x, row)
    term.write(string.rep(" ", w))
  end
end

local function writeAt(x, y, text, fg, bg)
  term.setCursorPos(x, y)
  if bg then term.setBackgroundColor(bg) end
  if fg then term.setTextColor(fg) end
  term.write(text)
end

local function centreText(y, text, fg, bg)
  local x = math.floor((W - #text) / 2) + 1
  writeAt(x, y, text, fg, bg)
end

local function drawHeader(title)
  -- Top bar
  drawRect(1, 1, W, 3, COL.header_bg)
  writeAt(1, 1, string.rep(" ", W), nil, COL.header_bg)
  writeAt(1, 2, string.rep(" ", W), nil, COL.header_bg)
  writeAt(1, 3, string.rep(" ", W), nil, COL.header_bg)
  centreText(1, "QUID BANK OF PLENTY", COL.header_txt, COL.header_bg)
  centreText(2, title, COL.header_txt, COL.header_bg)
  -- Footer with version + update status
  drawRect(1, H, W, 1, COL.panel)
  writeAt(1, H, string.rep(" ", W), nil, COL.panel)
  local footer = "v" .. VERSION
  if clientVersionInfo and clientVersionInfo.last_updated then
    local t    = math.floor(clientVersionInfo.last_updated / 1000)
    local secs = t % 60;  t = math.floor(t/60)
    local mins = t % 60;  t = math.floor(t/60)
    local hrs  = t % 24
    footer = footer .. string.format("  |  Updated %02d:%02d:%02d", hrs, mins, secs)
  else
    footer = footer .. "  |  No update this session"
  end
  centreText(H, footer, COL.dim_txt, COL.panel)
end

-- Draw a clickable button, returns {x1,y1,x2,y2,label}
local function drawButton(x, y, w, label, col)
  col = col or COL.btn_blue
  drawRect(x, y, w, 1, col)
  local tx = x + math.floor((w - #label) / 2)
  writeAt(tx, y, label, COL.btn_txt, col)
  return { x1=x, y1=y, x2=x+w-1, y2=y, label=label }
end

local function clicked(btn, mx, my)
  return mx >= btn.x1 and mx <= btn.x2 and my >= btn.y1 and my <= btn.y2
end

-- Masked or plain input field, returns typed string
local function inputField(x, y, w, mask)
  term.setCursorPos(x, y)
  term.setBackgroundColor(COL.input_bg)
  term.setTextColor(COL.input_txt)
  term.write(string.rep(" ", w))
  term.setCursorPos(x, y)
  term.setCursorBlink(true)
  local buf = ""
  while true do
    local ev, p1, p2, p3 = os.pullEvent()
    if ev == "char" then
      if #buf < w - 1 then
        buf = buf .. p1
        term.setCursorPos(x, y)
        term.setBackgroundColor(COL.input_bg)
        term.setTextColor(COL.input_txt)
        local display = mask and string.rep("*", #buf) or buf
        term.write(display .. string.rep(" ", w - #display))
        term.setCursorPos(x + #buf, y)
      end
    elseif ev == "key" then
      if p1 == keys.enter then break
      elseif p1 == keys.backspace and #buf > 0 then
        buf = buf:sub(1, -2)
        term.setCursorPos(x, y)
        term.setBackgroundColor(COL.input_bg)
        term.setTextColor(COL.input_txt)
        local display = mask and string.rep("*", #buf) or buf
        term.write(display .. string.rep(" ", w - #display))
        term.setCursorPos(x + #buf, y)
      end
    elseif ev == "mouse_click" then
      break
    end
  end
  term.setCursorBlink(false)
  return buf
end

-- =============================================================================
-- NETWORK
-- =============================================================================
local modemName     = nil
local modemWireless = false

local function openModem()
  -- First pass: prefer wireless/ender modem
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      local modem = peripheral.wrap(name)
      if modem and modem.isWireless and modem.isWireless() then
        rednet.open(name)
        modemName = name
        modemWireless = true
        return true
      end
    end
  end
  -- Second pass: fallback to any modem
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      rednet.open(name)
      modemName = name
      modemWireless = false
      return true
    end
  end
  return false
end

local function dbRequest(req)
  if not db_id then return false, "Not connected to bank server" end
  rednet.send(db_id, req, PROTOCOL)
  local sender, msg, proto = rednet.receive(PROTOCOL, DB_TIMEOUT)
  if not sender or not msg then
    return false, "No response from server (timeout)"
  end
  if type(msg) ~= "table" then
    return false, "Invalid server response"
  end
  return msg.success, msg.response
end

-- =============================================================================
-- SESSION
-- =============================================================================
local function resetSession()
  session.logged_in    = false
  session.citizen_id   = nil
  session.display_name = nil
  session.username     = nil
  session.balance      = nil
  session.title        = nil
  session.last_activity = nil
end

local function touchActivity()
  session.last_activity = os.clock()
end

local function checkIdleTimeout()
  if not session.logged_in then return false end
  if not session.last_activity then return false end
  return (os.clock() - session.last_activity) >= IDLE_TIMEOUT
end

local function refreshBalance()
  if not session.logged_in then return end
  local ok, res = dbRequest({
    type     = "balance",
    username = session.username,
    password = session._password,
  })
  if ok and type(res) == "table" then
    session.balance = res.balance
  end
end


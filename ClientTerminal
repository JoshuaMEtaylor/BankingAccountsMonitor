-- -----------------------------------------------------------------------
-- SCREEN: Connecting
-- -----------------------------------------------------------------------
local function screenConnecting()
  cls()
  drawHeader("Connecting...")
  centreText(7, "Locating Quid Bank server...", COL.dim_txt)

  for attempt = 1, 5 do
    drawRect(1, 10, W, 1, COL.bg)
    centreText(10, "Attempt " .. attempt .. " of 5...", COL.dim_txt)

    rednet.broadcast({ type = "ping" }, PROTOCOL)

    local sender, msg = rednet.receive(PROTOCOL, 3)

    if sender and type(msg) == "table" then
      -- Accept a direct ping reply from the server
      if msg.success and type(msg.response) == "table" then
        db_id = sender
        centreText(10, "Connected to server " .. sender, COL.success_txt)
        sleep(0.5)
        return true
      end
      -- Also accept the treasury_online broadcast if server sent it on this protocol
      if msg.type == "treasury_online" then
        db_id = sender
        centreText(10, "Connected to server " .. sender, COL.success_txt)
        sleep(0.5)
        return true
      end
    end
  end

  cls()
  drawHeader("Connection Failed")
  centreText(7,  "Could not reach bank server.", COL.error_txt)
  local modemLine = "Modem: " .. tostring(modemName or "NONE") ..
    (modemWireless and " (wireless)" or " (WIRED - wrong type!)")
  centreText(9, modemLine, modemWireless and COL.dim_txt or COL.error_txt)
  centreText(11, "Is the Treasury DB computer running?", COL.dim_txt)
  centreText(13, "Retrying in 5 seconds...", COL.dim_txt)
  sleep(5)
  return false
end


local DB_TIMEOUT = 5
local IDLE_TIMEOUT = 60  -- seconds before auto-logout

-- Tracks last successful update for display
local CLIENT_VERSION_FILE = "client_version.db"

local function saveClientVersion(info)
  local f = fs.open(CLIENT_VERSION_FILE, "w")
  if f then f.write(textutils.serialize(info)); f.close() end
end

local function loadClientVersion()
  if not fs.exists(CLIENT_VERSION_FILE) then return nil end
  local f = fs.open(CLIENT_VERSION_FILE, "r")
  if not f then return nil end
  local text = f.readAll(); f.close()
  local ok, data = pcall(textutils.unserialize, text)
  return ok and data or nil
end

local clientVersionInfo = loadClientVersion()


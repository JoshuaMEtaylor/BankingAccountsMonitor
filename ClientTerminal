-- SCREEN: Dashboard
-- -----------------------------------------------------------------------
local function screenDashboard()
  refreshBalance()

  local function draw()
    cls()
    drawHeader("Account Dashboard")

    -- Welcome
    writeAt(3, 5, "Welcome back,", COL.dim_txt)
    writeAt(17, 5, session.display_name or "Unknown", COL.title_txt)
    writeAt(3, 6, session.title or "Account Holder", COL.dim_txt)

    -- Balance card
    drawRect(3, 8, W-4, 4, COL.panel)
    writeAt(3, 8, string.rep(" ", W-4), COL.border, COL.panel)
    centreText(9, "BALANCE", COL.dim_txt, COL.panel)
    centreText(10, (session.balance or 0) .. " Quid", COL.money_txt, COL.panel)
    writeAt(3, 11, string.rep(" ", W-4), COL.border, COL.panel)

    -- Account ID
    writeAt(3, 13, "Account ID:", COL.dim_txt)
    writeAt(15, 13, session.citizen_id or "", COL.dim_txt)

    -- Buttons
    local bw = math.floor((W-6) / 2)
    local btn_transfer = drawButton(3,      15, bw, "Transfer Funds", COL.btn_blue)
    local btn_history  = drawButton(bw+4,   15, bw, "Transaction History", COL.panel)
    local btn_refresh  = drawButton(3,      17, bw, "Refresh Balance", COL.panel)
    local btn_logout   = drawButton(bw+4,   17, bw, "Log Out", COL.btn_red)

    -- Idle timer hint
    writeAt(3, H-1, "Auto-logout in " .. IDLE_TIMEOUT .. "s of inactivity", COL.dim_txt)

    return btn_transfer, btn_history, btn_refresh, btn_logout
  end

  local btn_transfer, btn_history, btn_refresh, btn_logout = draw()

  while true do
    -- Check idle timeout
    if checkIdleTimeout() then
      return "timeout"
    end

    local ev, p1, p2, p3 = os.pullEventRaw()

    if ev == "mouse_click" then
      local mx, my = p2, p3
      touchActivity()
      if clicked(btn_transfer, mx, my) then return "transfer" end
      if clicked(btn_history,  mx, my) then return "history"  end
      if clicked(btn_logout,   mx, my) then return "logout"   end
      if clicked(btn_refresh,  mx, my) then
        refreshBalance()
        btn_transfer, btn_history, btn_refresh, btn_logout = draw()
      end
    elseif ev == "timer" then
      if checkIdleTimeout() then return "timeout" end
    elseif ev == "terminate" then
      return "quit"
    end

    -- Refresh display every 15s
    if os.clock() % 15 < 0.1 then
      btn_transfer, btn_history, btn_refresh, btn_logout = draw()
    end
  end
end


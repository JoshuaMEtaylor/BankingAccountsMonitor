-- -----------------------------------------------------------------------
-- CONNECTING
-- -----------------------------------------------------------------------
local function screenConnecting()
  cls()
  topBar()
  fill(1, 2, W, H-1, C.bg)
  centre(math.floor(H/2)-1, "Connecting to Quid Bank...", C.dim, C.bg)

  for attempt = 1, 5 do
    fill(1, math.floor(H/2)+1, W, 1, C.bg)
    centre(math.floor(H/2)+1, "Attempt " .. attempt .. " of 5", C.dim, C.bg)
    rednet.broadcast({ type = "ping" }, PROTOCOL)
    local sender, msg = rednet.receive(PROTOCOL, 3)
    if sender and type(msg) == "table" then
      if (msg.success and type(msg.response) == "table") or msg.type == "treasury_online" then
        db_id = sender
        centre(math.floor(H/2)+1, "Connected.", C.ok, C.bg)
        sleep(0.5)
        return true
      end
    end
  end

  cls()
  topBar()
  centre(math.floor(H/2)-2, "Connection Failed", C.err, C.bg)
  centre(math.floor(H/2),   "Could not reach the bank server.", C.dim, C.bg)
  centre(math.floor(H/2)+1, "Modem: " .. tostring(modemName or "none"), C.dim, C.bg)
  centre(math.floor(H/2)+3, "Retrying in 5 seconds...", C.dim, C.bg)
  sleep(5)
  return false
end

-- -----------------------------------------------------------------------
-- LOGIN / REGISTER
-- -----------------------------------------------------------------------
local function screenLogin()
  session.logged_in = false
  local mode    = "login"
  local focused = 1
  local fields  = { "", "" }   -- login: [1]=user [2]=pass
                               -- register: [1]=user [2]=pass
  local err     = ""

  local function numFields()
    return 2
  end

  local function draw()
    cls()
    topBar()
    term.setCursorBlink(false)

    -- Tab strip
    local tabs = tabStrip(3, {"  Log In  ", "  Register  "}, mode=="login" and 1 or 2)

    -- Card
    local card_y = 5
    local card_h = H - card_y - 1
    card(2, card_y, W-2, card_h)

    -- Fields
    local b_submit
    if mode == "login" then
      at(4, card_y+1, "Username", C.label, C.card)
      inputField(4, card_y+2, W-6, fields[1], false, focused==1)
      at(4, card_y+4, "Password", C.label, C.card)
      inputField(4, card_y+5, W-6, fields[2], true, focused==2)
      b_submit = btn(4, card_y+7, W-6, "Log In", C.btn_pri)
    else
      at(4, card_y+1, "Username", C.label, C.card)
      inputField(4, card_y+2, W-6, fields[1], false, focused==1)
      at(4, card_y+4, "Password", C.label, C.card)
      inputField(4, card_y+5, W-6, fields[2], true, focused==2)
      b_submit = btn(4, card_y+7, W-6, "Create Account", C.btn_pri)
    end

    -- Error
    if err ~= "" then
      local ecol = (err:find("ing%.%.%.") or err:find("Creating")) and C.dim or C.err
      at(4, card_y + 9, err:sub(1, W-6), ecol, C.card)
    end

    statusBar()

    -- Reposition cursor
    local cy = focused==1 and (card_y+2) or (card_y+5)
    local v  = fields[focused] or ""
    term.setCursorPos(4 + math.min(#v, W-7), cy)
    term.setCursorBlink(true)

    return tabs, b_submit, card_y
  end

  local tabs, b_submit, card_y = draw()

  local function fieldY(my, cy)
    if my == card_y+2 then return 1 end
    if my == card_y+5 then return 2 end
    return nil
  end

  local function doSubmit()
    if fields[1]=="" or fields[2]=="" then err="Please fill in all fields"; return nil end
    if mode == "login" then
      err = "Authenticating..."
      draw()
      local ok, res = dbRequest({ type="login", username=fields[1], password=fields[2] })
      if ok and type(res)=="table" then
        session.logged_in    = true
        session.citizen_id   = res.citizen_id
        session.display_name = res.display_name
        session.username     = fields[1]
        session._password    = fields[2]
        session.balance      = res.balance or 0
        session.title        = res.title
        session.last_act     = os.clock()
        return "dashboard"
      else
        err = tostring(res or "Incorrect username or password")
      end
    else
      if #fields[2] < 4 then err="Password must be 4+ characters"; return nil end
      err = "Creating account..."
      draw()
      local ok, res = dbRequest({ type="create_account", display_name=fields[1], username=fields[1], password=fields[2] })
      if ok and type(res)=="table" then
        session.logged_in    = true
        session.citizen_id   = res.citizen_id
        session.display_name = res.display_name
        session.username     = fields[1]
        session._password    = fields[2]
        session.balance      = res.balance or 0
        session.title        = res.title
        session.last_act     = os.clock()
        return "dashboard"
      else
        err = tostring(res or "Registration failed")
      end
    end
    return nil
  end

  while true do
    local ev, p1, p2, p3 = os.pullEvent()

    if ev == "key" then
      if p1 == keys.capsLock then
        capsLock = not capsLock
        local cy = focused==1 and (card_y+2) or (card_y+5)
        local masked = focused==2
        inputField(4, cy, W-6, fields[focused], masked, true)

      elseif p1 == keys.backspace then
        if #fields[focused] > 0 then
          fields[focused] = fields[focused]:sub(1,-2)
          local cy = focused==1 and (card_y+2) or (card_y+5)
          local masked = focused==2
          inputField(4, cy, W-6, fields[focused], masked, true)
        end

      elseif p1 == keys.tab then
        focused = focused % numFields() + 1
        tabs, b_submit, card_y = draw()

      elseif p1 == keys.enter then
        if focused < numFields() then
          focused = focused + 1
          tabs, b_submit, card_y = draw()
        else
          local next = doSubmit()
          if next then return next end
          tabs, b_submit, card_y = draw()
        end
      end

    elseif ev == "char" then
      if #fields[focused] < W-7 then
        local ch = capsLock and p1:upper() or p1
        fields[focused] = fields[focused] .. ch
        local cy = focused==1 and (card_y+2) or (card_y+5)
        local masked = focused==2
        inputField(4, cy, W-6, fields[focused], masked, true)
      end

    elseif ev == "mouse_click" then
      local mx, my = p2, p3
      -- Tab clicks
      if hit(tabs[1], mx, my) and mode ~= "login" then
        mode="login"; fields={"",""}; focused=1; err=""
        tabs, b_submit, card_y = draw()
      elseif hit(tabs[2], mx, my) and mode ~= "register" then
        mode="register"; fields={"",""}; focused=1; err=""
        tabs, b_submit, card_y = draw()
      -- Submit
      elseif hit(b_submit, mx, my) then
        local next = doSubmit()
        if next then return next end
        tabs, b_submit, card_y = draw()
      -- Field focus
      else
        local f = fieldY(my, card_y)
        if f then
          focused = f
          tabs, b_submit, card_y = draw()
        end
      end
    end
  end
end

-- -----------------------------------------------------------------------
-- DASHBOARD
-- -----------------------------------------------------------------------
local function screenDashboard()
  -- Refresh balance on entry
  local ok, res = dbRequest({ type="balance", username=session.username, password=session._password })
  if ok and type(res)=="table" then session.balance = res.balance end

  local err = ""

  local function draw()
    cls()
    topBar()
    term.setCursorBlink(false)

    -- Account header strip
    fill(1, 2, W, 2, C.card)
    at(3, 2, session.username or "", C.card_fg, C.card)
    at(3, 3, session.title or "Account Holder", C.label, C.card)
    at(W - #(session.citizen_id or "") - 1, 2, session.citizen_id or "", C.label, C.card)

    sep(4)

    -- Balance card
    card(2, 5, W-2, 4)
    at(4, 5, "CURRENT BALANCE", C.label, C.card)
    local bal_str = tostring(session.balance or 0) .. " Quid"
    at(4, 6, bal_str, C.money, C.card)
    at(4, 7, "Available to spend", C.label, C.card)

    sep(9)

    -- Action buttons — 2x2 grid
    local bw = math.floor((W-3)/2)
    local b_transfer = btn(2,      10, bw, "New Transfer",   C.btn_pri)
    local b_history  = btn(bw+3,   10, bw, "View History",   C.btn_pri)
    local b_refresh  = btn(2,      12, bw, "Refresh",        C.btn_sec, C.card_fg)
    local b_logout   = btn(bw+3,   12, bw, "Sign Out",       C.btn_dan)

    sep(14)

    -- Account info strip
    fill(1, 15, W, H-15, C.bg)
    at(3, 15, "Bank:   Quid Bank of Plenty",   C.dim, C.bg)
    at(3, 16, "Server: " .. tostring(db_id),   C.dim, C.bg)

    statusBar(err, C.err)
    return b_transfer, b_history, b_refresh, b_logout
  end

  local b_transfer, b_history, b_refresh, b_logout = draw()

  while true do
    if (os.clock() - session.last_act) >= IDLE_TIMEOUT then return "timeout" end

    local ev, p1, p2, p3 = os.pullEvent()

    if ev == "mouse_click" then
      session.last_act = os.clock()
      local mx, my = p2, p3
      if hit(b_transfer, mx, my) then return "transfer" end
      if hit(b_history,  mx, my) then return "history"  end
      if hit(b_logout,   mx, my) then return "logout"   end
      if hit(b_refresh,  mx, my) then return "dashboard" end
    elseif ev == "key" then
      session.last_act = os.clock()
    elseif ev == "terminate" then
      return "quit"
    end
  end
end

-- -----------------------------------------------------------------------
-- TRANSFER
-- -----------------------------------------------------------------------
local function screenTransfer()
  local fields  = { "", "" }  -- [1]=recipient [2]=amount
  local memo    = ""
  local focused = 1
  local err     = ""

  local function draw()
    cls()
    topBar()
    term.setCursorBlink(false)

    -- From strip
    fill(1, 2, W, 2, C.card)
    at(3, 2, "From",            C.label, C.card)
    at(3, 3, session.citizen_id or "", C.card_fg, C.card)
    local bal_str = tostring(session.balance) .. " Quid"
    at(W - #bal_str - 1, 2, "Balance",  C.label, C.card)
    at(W - #bal_str - 1, 3, bal_str,    C.money, C.card)

    sep(4)

    card(2, 5, W-2, H-6)

    at(4, 6,  "Recipient", C.label, C.card)
    inputField(4, 7,  W-6, fields[1], false, focused==1)

    at(4, 9,  "Amount (Quid)", C.label, C.card)
    inputField(4, 10, W-6, fields[2], false, focused==2)

    at(4, 12, "Memo (optional)", C.label, C.card)
    inputField(4, 13, W-6, memo,      false, focused==3)

    local bw     = math.floor((W-6)/2)
    local b_send = btn(4,      15, bw, "Send Transfer", C.btn_pri)
    local b_back = btn(bw+5,   15, bw, "Cancel",        C.btn_sec, C.card_fg)

    if err ~= "" then
      local ecol = err:find("ing%.%.%.") and C.dim or C.err
      at(4, 17, err:sub(1,W-6), ecol, C.card)
    end

    statusBar()

    local cy = focused==1 and 7 or (focused==2 and 10 or 13)
    local v  = focused==3 and memo or fields[focused]
    term.setCursorPos(4 + math.min(#v, W-7), cy)
    term.setCursorBlink(true)

    return b_send, b_back
  end

  local b_send, b_back = draw()

  local function fieldAt(my)
    if my==7  then return 1 end
    if my==10 then return 2 end
    if my==13 then return 3 end
  end

  local function getField(f) return f==3 and memo or fields[f] end
  local function setField(f, v) if f==3 then memo=v else fields[f]=v end end

  while true do
    session.last_act = os.clock()
    local ev, p1, p2, p3 = os.pullEvent()

    if ev == "key" then
      if p1 == keys.capsLock then
        capsLock = not capsLock
        local cy = focused==1 and 7 or (focused==2 and 10 or 13)
        inputField(4, cy, W-6, getField(focused), false, true)

      elseif p1 == keys.backspace then
        local v = getField(focused)
        if #v > 0 then
          setField(focused, v:sub(1,-2))
          local cy = focused==1 and 7 or (focused==2 and 10 or 13)
          inputField(4, cy, W-6, getField(focused), false, true)
        end

      elseif p1 == keys.tab or p1 == keys.enter then
        if p1 == keys.enter and focused == 3 then
          -- treat as submit
          goto do_submit
        end
        focused = focused % 3 + 1
        b_send, b_back = draw()
      end

    elseif ev == "char" then
      local v = getField(focused)
      if #v < W-7 then
        local ch = capsLock and p1:upper() or p1
        setField(focused, v .. ch)
        local cy = focused==1 and 7 or (focused==2 and 10 or 13)
        inputField(4, cy, W-6, getField(focused), false, true)
      end

    elseif ev == "mouse_click" then
      local mx, my = p2, p3
      if hit(b_back, mx, my) then return "dashboard" end
      if hit(b_send, mx, my) then goto do_submit end
      local f = fieldAt(my)
      if f then focused = f; b_send, b_back = draw() end
    end

    goto continue
    ::do_submit::
    do
      local amount = tonumber(fields[2])
      if fields[1]=="" then err="Enter a recipient"
      elseif not amount or amount<=0 then err="Enter a valid amount"
      else
        err = "Processing..."
        draw()
        local ok, res = dbRequest({ type="transfer", username=session.username, password=session._password, to_id=fields[1], amount=amount, memo=memo })
        if ok and type(res)=="table" then
          -- Success screen
          cls()
          topBar()
          fill(1, 2, W, H-2, C.bg)
          card(3, 4, W-4, 9)
          centre(5,  "Transfer Complete", C.ok, C.card)
          at(5,  7,  "To:     ", C.label, C.card)
          at(14, 7,  fields[1],  C.card_fg, C.card)
          at(5,  8,  "Amount: ", C.label, C.card)
          at(14, 8,  tostring(amount) .. " Quid", C.money, C.card)
          at(5,  9,  "Ref:    ", C.label, C.card)
          at(14, 9,  tostring(res.tx_id or ""), C.label, C.card)
          if memo ~= "" then
            at(5, 10, "Memo:   ", C.label, C.card)
            at(14,10, memo:sub(1,W-15), C.card_fg, C.card)
          end
          -- Refresh balance
          local ok2, res2 = dbRequest({ type="balance", username=session.username, password=session._password })
          if ok2 and type(res2)=="table" then session.balance = res2.balance end
          at(5, 11, "Balance:", C.label, C.card)
          at(14,11, tostring(session.balance) .. " Quid", C.money, C.card)
          btn(math.floor(W/2)-5, 14, 12, "Back to Home", C.btn_pri)
          statusBar()
          os.pullEvent("mouse_click")
          return "dashboard"
        else
          err = tostring(res or "Transfer failed")
          b_send, b_back = draw()
        end
      end
    end
    ::continue::
    b_send, b_back = draw()
  end
end

-- -----------------------------------------------------------------------
-- HISTORY
-- -----------------------------------------------------------------------
local function screenHistory()
  cls()
  topBar()
  fill(1, 2, W, H-2, C.bg)
  centre(math.floor(H/2), "Loading transactions...", C.dim, C.bg)

  local ok, res = dbRequest({ type="ledger_history", username=session.username, password=session._password, limit=10 })

  cls()
  topBar()

  -- Balance strip
  fill(1, 2, W, 2, C.card)
  at(3, 2, "Transaction History",          C.card_fg, C.card)
  local bal_str = tostring(res and res.balance or session.balance) .. " Quid"
  at(W - #bal_str - 1, 2, bal_str,         C.money,   C.card)
  at(3, 3, session.citizen_id or "",        C.label,   C.card)

  sep(4)

  local b_back = btn(2, H-1, math.floor(W/2)-1, "< Back to Dashboard", C.btn_sec, C.card_fg)

  if not ok or type(res) ~= "table" then
    centre(8, "Could not load transactions.", C.err, C.bg)
  else
    local history = res.history or {}
    session.balance = res.balance or session.balance

    -- Column headers
    fill(1, 5, W, 1, C.bg)
    at(2,  5, "Reference",  C.dim, C.bg)
    at(13, 5, "Type",       C.dim, C.bg)
    at(22, 5, "Amount",     C.dim, C.bg)
    at(33, 5, "Note",       C.dim, C.bg)

    hline(6, C.sep, C.bg)

    if #history == 0 then
      centre(9, "No transactions yet.", C.dim, C.bg)
    else
      for i, tx in ipairs(history) do
        local row = 6 + i
        if row >= H-1 then break end
        local col = tx.direction=="IN" and C.ok or C.err
        local dir = tx.direction=="IN" and "+" or "-"
        fill(1, row, W, 1, i%2==0 and C.card or C.bg)
        local rbg = i%2==0 and C.card or C.bg
        at(2,  row, tostring(tx.tx_id or ""):sub(1,10),         C.dim,    rbg)
        at(13, row, tostring(tx.type  or ""):sub(1,8),          C.dim,    rbg)
        at(22, row, dir .. tostring(tx.amount or 0) .. "q",     col,      rbg)
        at(33, row, tostring(tx.memo  or ""):sub(1, W-33),      C.dim,    rbg)
      end
    end
  end

  statusBar()

  while true do
    local ev, p1, p2, p3 = os.pullEvent("mouse_click")
    if hit(b_back, p2, p3) then return "dashboard" end
  end
end

-- -----------------------------------------------------------------------
-- TIMEOUT
-- -----------------------------------------------------------------------
local function screenTimeout()
  cls()
  topBar()
  fill(1, 2, W, H-2, C.bg)
  centre(math.floor(H/2)-1, "Session Expired", C.err, C.bg)
  centre(math.floor(H/2)+1, "You were signed out due to inactivity.", C.dim, C.bg)
  centre(math.floor(H/2)+3, "Click anywhere to continue.", C.body, C.bg)
  os.pullEvent("mouse_click")
  session.logged_in = false
  return "login"
end

-- =============================================================================
-- MAIN
-- =============================================================================
local function main()
  if not openModem() then
    cls()
    print("ERROR: No modem found.")
    print("Attach an Ender Modem and reboot.")
    return
  end

  while not screenConnecting() do end

  local screen = "login"
  while true do
    if screen == "login"     then screen = screenLogin()     end
    if screen == "dashboard" then screen = screenDashboard() end
    if screen == "transfer"  then screen = screenTransfer()  end
    if screen == "history"   then screen = screenHistory()   end
    if screen == "timeout"   then screen = screenTimeout()   end
    if screen == "logout"    then session.logged_in=false; screen="login" end
    if screen == "quit"      then break end
  end
  cls()
  print("Goodbye.")
end

main()

local function accountTypeRank(acc)
  local t = tostring(acc and acc.type or "")
  if t == "treasury" then return 1 end
  if t == "citizen" then return 2 end
  if t == "company" then return 3 end
  if t == "escrow" then return 4 end
  return 9
end

local function accountDisplayName(acc)
  if type(acc) ~= "table" then return "Unknown account" end
  local name = trim(acc.display_name or "")
  if name ~= "" then return name end
  return tostring(acc.account_id or "Unknown account")
end

local function screenAccounts()
  local ok, accounts = requestAccounts()
  if not ok then accounts = last_accounts or {} end

  local page = 1

  while true do
    local w, h = getSize()

    -- Each account gets two rows now:
    --   readable display name + balance
    --   raw account id as small/reference text underneath
    -- This keeps citizen:mc_5 accurate internally without presenting it as the name.
    local rowsAvailable = h - 8
    if rowsAvailable < 6 then rowsAvailable = 6 end
    local perPage = math.floor(rowsAvailable / 2)
    if perPage < 3 then perPage = 3 end

    table.sort(accounts, function(a, b)
      local ar, br = accountTypeRank(a), accountTypeRank(b)
      if ar ~= br then return ar < br end
      local an = string.lower(accountDisplayName(a))
      local bn = string.lower(accountDisplayName(b))
      if an ~= bn then return an < bn end
      return tostring(a.account_id or "") < tostring(b.account_id or "")
    end)

    local totalPages = math.max(1, math.ceil(#accounts / perPage))
    if page > totalPages then page = totalPages end

    clear(colors.black)
    drawTop("STATE ACCOUNTS")

    local balanceX = math.floor(w * 0.66)
    if balanceX < 28 then balanceX = math.max(20, w - 14) end

    writeAt(2, 3, "Name / Account ID", colors.cyan, colors.black)
    writeAt(balanceX, 3, "Balance", colors.cyan, colors.black)

    local start = ((page - 1) * perPage) + 1
    local y = 4
    for i = start, math.min(#accounts, start + perPage - 1) do
      local acc = accounts[i]
      local display = accountDisplayName(acc)
      local id = tostring(acc.account_id or "?")
      local bal = money(acc.balance or 0)

      local nameWidth = math.max(10, balanceX - 4)
      local idWidth = math.max(10, w - 6)

      writeAt(2, y, display:sub(1, nameWidth), colors.white, colors.black)
      writeAt(balanceX, y, bal, colors.lime, colors.black)
      writeAt(4, y + 1, id:sub(1, idWidth), colors.lightGray, colors.black)
      y = y + 2
    end

    writeAt(2, h - 3, "Page " .. page .. " / " .. totalPages, colors.lightGray, colors.black)
    local bw = math.floor((w - 8) / 3)
    local bPrev = button(2, h - 1, bw, "Prev", colors.gray, colors.white)
    local bNext = button(3 + bw, h - 1, bw, "Next", colors.gray, colors.white)
    local bBack = button(4 + (bw * 2), h - 1, bw, "Back", colors.gray, colors.white)

    local ev, p1, p2, p3 = os.pullEvent()
    if ev == "mouse_click" then
      if hit(bBack, p2, p3) then return end
      if hit(bPrev, p2, p3) then page = math.max(1, page - 1) end
      if hit(bNext, p2, p3) then page = math.min(totalPages, page + 1) end
    elseif ev == "key" then
      if p1 == keys.b or p1 == keys.escape or p1 == keys.backspace or p1 == keys.enter then
        return
      elseif p1 == keys.left or p1 == keys.p then
        page = math.max(1, page - 1)
      elseif p1 == keys.right or p1 == keys.n then
        page = math.min(totalPages, page + 1)
      end
    end
  end
end



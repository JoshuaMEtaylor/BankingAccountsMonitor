-- =============================================================================
-- BASIC UTILS
-- =============================================================================
local function refreshSize()
  W, H = term.getSize()
end

local function clamp(n, minv, maxv)
  if n < minv then return minv end
  if n > maxv then return maxv end
  return n
end

local function trim(s)
  return tostring(s or ""):match("^%s*(.-)%s*$")
end

local function compactSpaces(s)
  return trim(tostring(s or "")):gsub("%s+", "_")
end

local function normaliseAccountId(raw)
  raw = trim(raw)
  if raw == "" then return raw end
  if raw:find(":") then return raw end
  return "citizen:" .. string.lower(compactSpaces(raw))
end

local function parseAmount(raw)
  raw = trim(raw)
  local n = tonumber(raw)
  if not n then return nil end
  n = math.floor(n)
  if n <= 0 then return nil end
  return n
end

local function fmtQ(n)
  n = tonumber(n) or 0
  local sign = ""
  if n < 0 then sign = "-"; n = -n end
  local s = tostring(math.floor(n))
  local left, num, right = string.match(s, "^([^%d]*%d)(%d*)(.-)$")
  if not left then return sign .. s .. " Q" end
  return sign .. left .. (num:reverse():gsub("(%d%d%d)", "%1,"):reverse()) .. right .. " Q"
end

local function short(s, width)
  s = tostring(s or "")
  if #s <= width then return s end
  if width <= 3 then return s:sub(1, width) end
  return s:sub(1, width-3) .. "..."
end

local function contains(list, value)
  if type(list) ~= "table" then return false end
  for _, v in ipairs(list) do
    if tonumber(v) == tonumber(value) then return true end
  end
  return false
end

local function statusText()
  if lastError and lastError ~= "" then return lastError end
  if db_id then return "Server " .. tostring(db_id) .. " via " .. tostring(modemName or "modem") end
  return "Not connected"
end

-- =============================================================================
-- DRAWING PRIMITIVES
-- =============================================================================
local function set(fg, bg)
  if fg then term.setTextColor(fg) end
  if bg then term.setBackgroundColor(bg) end
end

local function cls(bg)
  refreshSize()
  set(C.body, bg or C.bg)
  term.clear()
  term.setCursorPos(1, 1)
  term.setCursorBlink(false)
end

local function at(x, y, text, fg, bg)
  if y < 1 or y > H or x > W then return end
  x = math.max(1, x)
  local maxw = W - x + 1
  if maxw <= 0 then return end
  set(fg or C.body, bg)
  term.setCursorPos(x, y)
  term.write(tostring(text):sub(1, maxw))
end

local function fill(x, y, w, h, bg)
  if w <= 0 or h <= 0 then return end
  set(nil, bg or C.bg)
  local row = string.rep(" ", math.max(0, w))
  for yy = y, y+h-1 do
    if yy >= 1 and yy <= H then
      term.setCursorPos(math.max(1, x), yy)
      term.write(row:sub(1, W - math.max(1, x) + 1))
    end
  end
end

local function centre(y, text, fg, bg)
  text = tostring(text or "")
  local x = math.floor((W - #text) / 2) + 1
  at(math.max(1, x), y, text, fg, bg)
end

local function topBar()
  fill(1, 1, W, 1, C.header)
  at(2, 1, TERMINAL_NAME, C.hdr_fg, C.header)
  local right = "v" .. VERSION
  at(W - #right, 1, right, C.dim, C.header)
end

local function bottomBar(msg, col)
  fill(1, H, W, 1, C.panel)
  at(2, H, short(msg or statusText(), W-3), col or C.dim, C.panel)
end

local function panel(x, y, w, h, title)
  fill(x, y, w, h, C.panel)
  if title and title ~= "" then
    at(x+1, y, " " .. title .. " ", C.accent, C.panel)
  end
end

local function card(x, y, w, h, title)
  fill(x, y, w, h, C.card)
  if title and title ~= "" then
    at(x+1, y, title, C.label, C.card)
  end
end

local function btn(x, y, w, label, bg, fg)
  bg = bg or C.btn
  fg = fg or C.btn_fg
  fill(x, y, w, 1, bg)
  local tx = x + math.floor((w - #label) / 2)
  at(tx, y, label, fg, bg)
  return {x1=x, y1=y, x2=x+w-1, y2=y, label=label}
end

local function hit(b, mx, my)
  return b and mx >= b.x1 and mx <= b.x2 and my >= b.y1 and my <= (b.y2 or b.y1)
end

local function inputBox(x, y, w, value, focused, masked)
  local bg = C.input_bg
  local display = masked and string.rep("*", #tostring(value or "")) or tostring(value or "")
  fill(x, y, w, 1, bg)
  at(x, y, short(display, w), C.input_fg, bg)
  if focused then
    if capsLock and w > 8 then
      at(x+w-5, y, "CAPS", C.warn, bg)
    end
    term.setCursorPos(x + math.min(#display, w-1), y)
    term.setCursorBlink(true)
  end
  return {x1=x, y1=y, x2=x+w-1, y2=y}
end

local function labelValue(x, y, label, value, valCol)
  at(x, y, label, C.label, C.panel)
  at(x, y+1, tostring(value or ""), valCol or C.body, C.panel)
end

-- =============================================================================
-- NETWORK
-- =============================================================================
local function openModem()
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      local m = peripheral.wrap(name)
      if m and m.isWireless and m.isWireless() then
        rednet.open(name)
        modemName = name
        return true
      end
    end
  end
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      rednet.open(name)
      modemName = name
      return true
    end
  end
  return false
end

local function dbRequest(req, timeout)
  timeout = timeout or DB_TIMEOUT
  if not db_id then return false, "Not connected" end

  rednet.send(db_id, req, PROTOCOL)
  local timer = os.startTimer(timeout)

  while true do
    local ev, a, b, c = os.pullEvent()
    if ev == "rednet_message" and a == db_id and c == PROTOCOL and type(b) == "table" then
      return b.success, b.response
    elseif ev == "timer" and a == timer then
      return false, "No response from server"
    elseif ev == "terminate" then
      error("Terminated", 0)
    end
  end
end

local function discoverServer()
  db_id = nil
  for attempt = 1, 8 do
    cls()
    topBar()
    centre(math.floor(H/2)-2, "Connecting to Quid Bank server...", C.body, C.bg)
    centre(math.floor(H/2), "Attempt " .. attempt .. " of 8", C.dim, C.bg)
    if modemName then centre(math.floor(H/2)+1, "Modem: " .. modemName, C.dim, C.bg) end
    rednet.broadcast({ type = "ping" }, PROTOCOL)

    local timer = os.startTimer(4)
    while true do
      local ev, a, b, c = os.pullEvent()
      if ev == "rednet_message" and c == PROTOCOL and type(b) == "table" then
        if (b.success and type(b.response) == "table") or b.type == "treasury_online" then
          db_id = a
          centre(math.floor(H/2)+3, "Connected to server " .. tostring(db_id), C.ok, C.bg)
          sleep(0.4)
          return true
        end
      elseif ev == "timer" and a == timer then
        break
      elseif ev == "terminate" then
        error("Terminated", 0)
      end
    end
  end
  return false
end

local function refreshStatus()
  local ok, res = dbRequest({ type = "status" }, DB_TIMEOUT)
  if ok and type(res) == "table" then
    lastStatus = res
    lastError = ""
    return true, res
  end
  lastError = tostring(res or "Status request failed")
  return false, res
end

local function requireAuthority()
  cls()
  topBar()
  centre(math.floor(H/2)-1, "Checking treasury authority...", C.dim, C.bg)
  local ok, res = refreshStatus()
  if ok then return true end

  while true do
    cls()
    topBar()
    centre(4, "UNAUTHORISED TREASURY TERMINAL", C.err, C.bg)
    centre(6, "This computer is not registered as management.", C.body, C.bg)
    centre(8, "Computer ID: " .. tostring(os.getComputerID()), C.accent, C.bg)
    centre(10, "Register this ID on the bank server first.", C.dim, C.bg)
    centre(12, "Server reply: " .. short(tostring(res), W-16), C.err, C.bg)
    local b_retry = btn(math.floor(W/2)-13, H-3, 12, "Retry", C.btn, C.btn_fg)
    local b_exit  = btn(math.floor(W/2)+2,  H-3, 12, "Exit",  C.btn2, C.btn2_fg)
    bottomBar("Physical access alone is not enough. Server must trust this computer ID.")

    local ev, _, x, y = os.pullEvent()
    if ev == "mouse_click" then
      if hit(b_retry, x, y) then
        local ok2 = refreshStatus()
        if ok2 then return true end
      elseif hit(b_exit, x, y) then
        return false
      end
    elseif ev == "key" then
      return false
    elseif ev == "terminate" then
      error("Terminated", 0)
    end
  end
end


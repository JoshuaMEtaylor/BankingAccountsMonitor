  local ok, res = dbRequest({
    type="register_company",
    name=vals.name,
    ticker=vals.ticker,
    biz_type=vals.biz_type ~= "" and vals.biz_type or "general",
    owner_id=owner,
    shares_total=shares,
    shares_public=public

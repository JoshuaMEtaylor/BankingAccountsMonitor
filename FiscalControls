local function defaultSectorRates()
  local out = {}
  for _, s in ipairs(WORKER_PAY_SECTORS) do
    out[s.key] = {}
    for _, tier in ipairs(s.tiers) do
      out[s.key][tier] = s.defaults[tier]
    end
  end
  return out
end

local function normaliseRatesForUI(rates)
  rates = type(rates) == "table" and rates or {}
  local out = defaultSectorRates()

  -- Backwards compatibility with old flat worker rates.
  if rates.researcher then out.research.skilled = tonumber(rates.researcher) or out.research.skilled end
  if rates.soldier then out.defence.skilled = tonumber(rates.soldier) or out.defence.skilled end
  if rates.courier then out.logistics.unskilled = tonumber(rates.courier) or out.logistics.unskilled end

  for _, s in ipairs(WORKER_PAY_SECTORS) do
    if type(rates[s.key]) == "table" then
      for _, tier in ipairs(s.tiers) do
        local n = tonumber(rates[s.key][tier])
        if n and n > 0 then out[s.key][tier] = math.floor(n) end
      end
    end
  end

  return out
end


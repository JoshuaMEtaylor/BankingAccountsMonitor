local function actionSetPrice()
  local vals = formScreen("SET STATE PRICE", {
    { label="Item",  key="item", max=40 },
    { label="Price", key="price", max=12 },
  }, "Set Price", false)
  if not vals then return "dashboard" end

  local price = parseAmount(vals.price)
  if vals.item == "" or not price then
    messageScreen("Invalid Price", {"Enter an item name and a whole-number price."}, C.err)
    return "dashboard"
  end

  local okConfirm = confirmScreen("CONFIRM PRICE UPDATE", {
    "Item: " .. vals.item,
    "New price: " .. fmtQ(price),
  }, false)
  if not okConfirm then return "dashboard" end

  local ok, res = dbRequest({ type="set_price", item=vals.item, price=price })
  if ok and type(res) == "table" then
    messageScreen("Price Updated", {vals.item .. " = " .. fmtQ(price), "Old price: " .. tostring(res.old_price or "none")}, C.ok)
  else
    messageScreen("Price Update Failed", {tostring(res or "Unknown error")}, C.err)
  end
  return "dashboard"
end


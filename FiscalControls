local function actionRegisterCitizen()
  local vals = formScreen("REGISTER CITIZEN ACCOUNT", {
    { label="Username", key="username", max=32 },
    { label="Password", key="password", value="changeme", max=32 },
    { label="Title",    key="title", value="Account Holder", max=32 },
  }, "Create Citizen", false)
  if not vals then return "dashboard" end

  if vals.username == "" then
    messageScreen("Missing Username", {"Citizen username is required."}, C.err)
    return "dashboard"
  end
  if #vals.password < 4 then
    messageScreen("Weak Password", {"Password must be at least 4 characters."}, C.err)
    return "dashboard"
  end

  local okConfirm = confirmScreen("CONFIRM CITIZEN REGISTRATION", {
    "Username: " .. vals.username,
    "Account ID: citizen:" .. string.lower(compactSpaces(vals.username)),
    "Temporary Password: " .. vals.password,
  }, false)
  if not okConfirm then return "dashboard" end

  local ok, res = dbRequest({
    type="register_citizen",
    display_name=vals.username, -- server currently requires this field; we mirror username
    username=vals.username,
    password=vals.password,
    title=vals.title ~= "" and vals.title or "Account Holder"
  })

  if ok and type(res) == "table" then
    refreshStatus()
    messageScreen("Citizen Registered", {tostring(res.citizen_id or "created"), tostring(res.message or "")}, C.ok)
  else
    messageScreen("Registration Failed", {tostring(res or "Unknown error")}, C.err)
  end
  return "dashboard"
end


  if ok and type(res) == "table" then
    refreshStatus()
    messageScreen("Company Registered", {tostring(res.company_id or "created"), tostring(res.message or "")}, C.ok)
  else
    messageScreen("Company Registration Failed", {tostring(res or "Unknown error")}, C.err)
  end
  return "dashboard"

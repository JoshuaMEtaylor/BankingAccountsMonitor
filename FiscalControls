local function actionPrintMoney()
  local data = formScreen(
    "PRINT MONEY",
    "Creates new Quid into " .. TREASURY_ACCOUNT,
    {
      { label = "Amount", key = "amount", required = true, max = 12 },
      { label = "Memo", key = "memo", required = false, max = 48, value = "Treasury monetary issue" },
    },
    "Review"
  )

  if not data then
    setMessage("Print cancelled.", colors.lightGray)
    return
  end

  local amount = positiveInt(data.amount)
  if not amount then
    setMessage("Invalid print amount.", colors.red)
    return
  end

  local memo = data.memo ~= "" and data.memo or "Treasury monetary issue"
  local okConfirm = confirmScreen("CONFIRM PRINT", {
    "This creates new money.",
    "",
    "Amount:      " .. money(amount),
    "Destination: " .. TREASURY_ACCOUNT,
    "Memo:        " .. memo,
    "",
    "Ledger: SYSTEM -> " .. TREASURY_ACCOUNT,
  }, "Print Money", true)

  if not okConfirm then
    setMessage("Print cancelled.", colors.lightGray)
    return
  end

  local ok, res = dbRequest({
    type = "mint",
    to_id = TREASURY_ACCOUNT,
    amount = amount,
    memo = memo,
  })

  if ok then
    setMessage("Printed " .. money(amount) .. " into treasury.", colors.lime)
    refreshStatus()
  else
    setMessage("Print failed: " .. tostring(res), colors.red)
  end
end

local function grantAccountName(acc)
  if type(acc) ~= "table" then return "Unknown account" end
  local name = trim(acc.display_name or "")
  if name ~= "" then return name end
  return tostring(acc.account_id or "Unknown account")
end

local function grantAccountTypeLabel(t)
  t = tostring(t or "")
  if t == "citizen" then return "Citizen" end
  if t == "company" then return "Company" end
  return t
end

local function matchesGrantSearch(acc, query)
  query = string.lower(trim(query or ""))
  if query == "" then return true end
  local hay = string.lower(
    tostring(acc.account_id or "") .. " " ..
    tostring(acc.display_name or "") .. " " ..
    tostring(acc.owner_id or "")
  )
  return hay:find(query, 1, true) ~= nil
end

local function filteredGrantAccounts(accounts, selectedType, query)
  local out = {}
  for _, acc in ipairs(accounts or {}) do
    if tostring(acc.type or "") == selectedType and tostring(acc.status or "active") == "active" then
      if matchesGrantSearch(acc, query) then
        out[#out + 1] = acc
      end
    end
  end
  table.sort(out, function(a, b)
    local an = string.lower(grantAccountName(a))
    local bn = string.lower(grantAccountName(b))
    if an ~= bn then return an < bn end
    return tostring(a.account_id or "") < tostring(b.account_id or "")
  end)
  return out
end

local function selectGrantRecipient()
  local ok, accounts = requestAccounts()
  if not ok then accounts = last_accounts or {} end

  local selectedType = "citizen"
  local query = ""
  local page = 1

  while true do
    local w, h = getSize()
    local results = filteredGrantAccounts(accounts, selectedType, query)
    local rowTop = 9
    local rowBottom = h - 4
    local perPage = math.floor(math.max(2, rowBottom - rowTop + 1) / 2)
    if perPage < 2 then perPage = 2 end

    local totalPages = math.max(1, math.ceil(#results / perPage))
    if page > totalPages then page = totalPages end
    if page < 1 then page = 1 end

    clear(colors.black)
    drawTop("GRANT RECIPIENT")

    writeAt(2, 3, "Choose the account to receive treasury funds.", colors.lightGray, colors.black)

    local tw = math.floor((w - 6) / 2)
    local bCitizen = button(2, 5, tw, "Citizens", selectedType == "citizen" and colors.blue or colors.gray, colors.white)
    local bCompany = button(4 + tw, 5, tw, "Companies", selectedType == "company" and colors.blue or colors.gray, colors.white)

    writeAt(2, 7, "Search", colors.white, colors.black)
    local searchBox = inputBox(10, 7, w - 11, query, true)

    local summary = grantAccountTypeLabel(selectedType) .. " results: " .. tostring(#results)
    writeAt(2, 8, summary .. "   Page " .. tostring(page) .. "/" .. tostring(totalPages), colors.yellow, colors.black)

    local resultHits = {}
    local startIndex = ((page - 1) * perPage) + 1
    local y = rowTop

    if #results == 0 then
      writeAt(2, y, "No matching " .. selectedType .. " accounts found.", colors.orange, colors.black)
    else
      for i = startIndex, math.min(#results, startIndex + perPage - 1) do
        local acc = results[i]
        local display = grantAccountName(acc)
        local id = tostring(acc.account_id or "?")
        local bal = money(acc.balance or 0)
        local idx = #resultHits + 1

        fill(2, y, w - 3, 1, colors.gray)
        writeAt(3, y, display:sub(1, math.max(6, w - 18)), colors.white, colors.gray)
        writeAt(math.max(3, w - #bal - 1), y, bal, colors.lime, colors.gray)

        fill(2, y + 1, w - 3, 1, colors.black)
        writeAt(4, y + 1, id:sub(1, w - 5), colors.lightGray, colors.black)

        resultHits[idx] = { x1 = 2, x2 = w - 2, y1 = y, y2 = y + 1, account = acc }
        y = y + 2
      end
    end

    local bw = math.floor((w - 8) / 3)
    local bPrev = button(2, h - 1, bw, "Prev", colors.gray, colors.white)
    local bNext = button(3 + bw, h - 1, bw, "Next", colors.gray, colors.white)
    local bBack = button(4 + (bw * 2), h - 1, bw, "Back", colors.gray, colors.white)

    term.setCursorPos(searchBox.cursor_x, searchBox.cursor_y)
    term.setCursorBlink(true)

    local ev, p1, p2, p3 = os.pullEvent()

    if ev == "char" then
      if #query < 40 then query = query .. p1 end
      page = 1

    elseif ev == "key" then
      if p1 == keys.backspace then
        query = query:sub(1, -2)
        page = 1
      end

    elseif ev == "mouse_click" then
      local mx, my = p2, p3

      if hit(bBack, mx, my) then
        term.setCursorBlink(false)
        return nil

      elseif hit(bCitizen, mx, my) then
        selectedType = "citizen"
        page = 1

      elseif hit(bCompany, mx, my) then
        selectedType = "company"
        page = 1

      elseif hit(bPrev, mx, my) then
        page = math.max(1, page - 1)

      elseif hit(bNext, mx, my) then
        page = math.min(totalPages, page + 1)

      else
        for _, box in ipairs(resultHits) do
          if hit(box, mx, my) then
            term.setCursorBlink(false)
            return box.account
          end
        end
      end

    elseif ev == "mouse_scroll" then
      local dir = p1
      if dir and dir > 0 then
        page = math.min(totalPages, page + 1)
      else
        page = math.max(1, page - 1)
      end
    end
  end
end

local function actionGrantFunds()
  local recipient = selectGrantRecipient()

  if not recipient then
    setMessage("Grant cancelled.", colors.lightGray)
    return
  end

  local recipient_id = tostring(recipient.account_id or "")
  local recipient_name = grantAccountName(recipient)
  local recipient_type = grantAccountTypeLabel(recipient.type)

  if recipient_id == "" then
    setMessage("Invalid recipient.", colors.red)
    return
  end

  local data = formScreen(
    "GRANT FUNDS",
    recipient_type .. ": " .. recipient_name .. " -> " .. recipient_id,
    {
      { label = "Amount", key = "amount", required = true, max = 12 },
      { label = "Memo", key = "memo", required = false, max = 48, value = "Treasury grant" },
    },
    "Review"
  )

  if not data then
    setMessage("Grant cancelled.", colors.lightGray)
    return
  end

  local amount = positiveInt(data.amount)
  if not amount then
    setMessage("Invalid grant amount.", colors.red)
    return
  end

  local memo = data.memo ~= "" and data.memo or "Treasury grant"
  local okConfirm = confirmScreen("CONFIRM GRANT", {
    "This spends existing treasury funds.",
    "",
    "Type:    " .. recipient_type,
    "Name:    " .. recipient_name,
    "From:    " .. TREASURY_ACCOUNT,
    "To:      " .. recipient_id,
    "Balance: " .. money(recipient.balance or 0),
    "Amount:  " .. money(amount),
    "Memo:    " .. memo,
  }, "Grant Funds", false)

  if not okConfirm then
    setMessage("Grant cancelled.", colors.lightGray)
    return
  end

  local ok, res = dbRequest({
    type = "grant",
    to_id = recipient_id,
    amount = amount,
    memo = memo,
  })

  if ok then
    setMessage("Granted " .. money(amount) .. " to " .. recipient_name .. ".", colors.lime)
    refreshStatus()
  else
    setMessage("Grant failed: " .. tostring(res), colors.red)
  end
end


local function activeAccountsOfType(accounts, targetType)
  local out = {}
  targetType = tostring(targetType or "")

  for _, acc in ipairs(accounts or {}) do
    if type(acc) == "table"
      and tostring(acc.type or "") == targetType
      and tostring(acc.status or "active") == "active" then
      out[#out + 1] = acc
    end
  end

  table.sort(out, function(a, b)
    local an = string.lower(grantAccountName(a))
    local bn = string.lower(grantAccountName(b))
    if an ~= bn then return an < bn end
    return tostring(a.account_id or "") < tostring(b.account_id or "")
  end)

  return out
end

local function stimulusTargetLabel(targetType)
  if targetType == "citizen" then return "Citizens" end
  if targetType == "company" then return "Businesses" end
  return tostring(targetType or "Accounts")
end

local function actionStimulus(targetType)
  local label = stimulusTargetLabel(targetType)
  local ok, accounts = requestAccounts()
  if not ok then accounts = last_accounts or {} end

  local recipients = activeAccountsOfType(accounts, targetType)
  if #recipients == 0 then
    setMessage("No active " .. string.lower(label) .. " found.", colors.orange)
    return
  end

  local defaultMemo = label .. " stimulus payment"
  local data = formScreen(
    string.upper(label) .. " STIMULUS",
    "Pays every active " .. string.lower(label) .. " account from the treasury.",
    {
      { label = "Amount per account", key = "amount", required = true, max = 12 },
      { label = "Memo", key = "memo", required = false, max = 48, value = defaultMemo },
    },
    "Review"
  )

  if not data then
    setMessage(label .. " stimulus cancelled.", colors.lightGray)
    return
  end

  local amount = positiveInt(data.amount)
  if not amount then
    setMessage("Invalid stimulus amount.", colors.red)
    return
  end

  local memo = data.memo ~= "" and data.memo or defaultMemo
  local total = amount * #recipients

  -- Refresh status for a current treasury warning, but do not block the flow if
  -- the status endpoint is unavailable. The grant calls themselves remain
  -- authoritative.
  refreshStatus()
  local treasuryBalance = nil
  if type(last_status) == "table" and type(last_status.supply) == "table" then
    treasuryBalance = tonumber(last_status.supply.treasury_balance)
  end

  local lines = {
    "This spends existing treasury funds.",
    "",
    "Target:       " .. label,
    "Recipients:   " .. tostring(#recipients),
    "Each payment: " .. money(amount),
    "Total cost:   " .. money(total),
    "From:         " .. TREASURY_ACCOUNT,
    "Memo:         " .. memo,
  }

  if treasuryBalance then
    lines[#lines + 1] = "Treasury now: " .. money(treasuryBalance)
    if treasuryBalance < total then
      lines[#lines + 1] = ""
      lines[#lines + 1] = "WARNING: Treasury may not cover the full run."
      lines[#lines + 1] = "Payments stop only when the bank rejects a grant."
    end
  end

  local okConfirm = confirmScreen("CONFIRM " .. string.upper(label) .. " STIMULUS", lines, "Issue Stimulus", treasuryBalance and treasuryBalance < total)
  if not okConfirm then
    setMessage(label .. " stimulus cancelled.", colors.lightGray)
    return
  end

  local w, h = getSize()
  clear(colors.black)
  drawTop(string.upper(label) .. " STIMULUS")
  writeAt(2, 3, "Issuing " .. money(amount) .. " to " .. tostring(#recipients) .. " accounts...", colors.white, colors.black)
  writeAt(2, 4, "Do not close until complete.", colors.orange, colors.black)

  local paid = 0
  local failed = 0
  local firstError = nil

  for i, acc in ipairs(recipients) do
    local accountId = tostring(acc.account_id or "")
    local name = grantAccountName(acc)

    fill(2, 6, w - 3, 4, colors.black)
    writeAt(2, 6, "Progress: " .. tostring(i) .. " / " .. tostring(#recipients), colors.lightGray, colors.black)
    writeAt(2, 7, "Paying: " .. shortText(name, w - 12), colors.white, colors.black)
    writeAt(2, 8, accountId:sub(1, w - 3), colors.gray, colors.black)
    writeAt(2, 9, "Paid: " .. tostring(paid) .. "   Failed: " .. tostring(failed), failed > 0 and colors.orange or colors.lime, colors.black)

    if accountId ~= "" then
      local okGrant, res = dbRequest({
        type = "grant",
        to_id = accountId,
        amount = amount,
        memo = memo,
      })

      if okGrant then
        paid = paid + 1
      else
        failed = failed + 1
        if not firstError then firstError = tostring(res) end
      end
    else
      failed = failed + 1
      if not firstError then firstError = "Missing account id" end
    end
  end

  refreshStatus()

  local resultLines = {
    "Stimulus run complete.",
    "",
    "Target: " .. label,
    "Paid:   " .. tostring(paid) .. " / " .. tostring(#recipients),
    "Failed: " .. tostring(failed),
    "Each:   " .. money(amount),
    "Total:  " .. money(paid * amount),
  }
  if firstError then
    resultLines[#resultLines + 1] = ""
    resultLines[#resultLines + 1] = "First error: " .. tostring(firstError)
  end

  confirmScreen(string.upper(label) .. " STIMULUS COMPLETE", resultLines, "Back", false)

  if failed > 0 then
    setMessage(label .. " stimulus partly complete: " .. tostring(paid) .. " paid, " .. tostring(failed) .. " failed.", colors.orange)
  else
    setMessage(label .. " stimulus complete: " .. tostring(paid) .. " payments, " .. money(paid * amount) .. ".", colors.lime)
  end
end



local function screenDashboard()
  refreshStatus()
  local buttons = drawDashboard(lastStatus)
  local timer = os.startTimer(REFRESH_SECS)

  while true do
    local ev, p1, p2, p3 = os.pullEvent()
    if ev == "timer" and p1 == timer then
      refreshStatus()
      buttons = drawDashboard(lastStatus)
      timer = os.startTimer(REFRESH_SECS)
    elseif ev == "mouse_click" then
      local x, y = p2, p3
      if hit(buttons.print, x, y) then return "print" end
      if hit(buttons.grant, x, y) then return "grant" end
      if hit(buttons.burn,  x, y) then return "burn" end
      if buttons.accounts and hit(buttons.accounts, x, y) then return "accounts" end
      if buttons.citizens and hit(buttons.citizens, x, y) then return "citizens" end
      if buttons.companies and hit(buttons.companies, x, y) then return "companies" end
      if buttons.tools and hit(buttons.tools, x, y) then return "tools" end
      if buttons.refresh and hit(buttons.refresh, x, y) then return "dashboard" end
      if buttons.exit and hit(buttons.exit, x, y) then return "exit" end
      if buttons.menu and hit(buttons.menu, x, y) then return "more" end
    elseif ev == "key" then
      if p1 == keys.r then return "dashboard" end
      if p1 == keys.q then return "exit" end
    elseif ev == "terminate" then
      error("Terminated", 0)
    end
  end
end

-- =============================================================================
-- MAIN
-- =============================================================================
local function main()
  cls()
  topBar()
  centre(math.floor(H/2)-1, "Booting treasury controller...", C.dim, C.bg)

  if os.getComputerLabel() ~= "QuidTreasury" then
    os.setComputerLabel("QuidTreasury")
  end

  if not openModem() then
    cls()
    topBar()
    centre(math.floor(H/2)-1, "ERROR: No modem found.", C.err, C.bg)
    centre(math.floor(H/2)+1, "Attach an Ender Modem and reboot.", C.body, C.bg)
    return
  end

  while not discoverServer() do
    cls()
    topBar()
    centre(math.floor(H/2)-1, "Connection Failed", C.err, C.bg)
    centre(math.floor(H/2)+1, "Could not reach the bank server.", C.body, C.bg)
    centre(math.floor(H/2)+2, "Retrying in 5 seconds...", C.dim, C.bg)
    sleep(5)
  end

  if not requireAuthority() then
    cls()
    topBar()
    centre(math.floor(H/2), "Treasury terminal closed.", C.dim, C.bg)
    return
  end

  local screen = "dashboard"
  while true do
    if screen == "dashboard" then screen = screenDashboard() end
    if screen == "print"     then screen = actionPrintMoney() end
    if screen == "grant"     then screen = actionGrantFunds() end
    if screen == "burn"      then screen = actionBurnMoney() end
    if screen == "accounts"  then screen = screenAccounts() end
    if screen == "citizens"  then screen = screenCitizens() end
    if screen == "companies" then screen = screenCompanies() end
    if screen == "tools"     then screen = screenTools() end
    if screen == "more"      then screen = screenCompactMore() end
    if screen == "exit"      then break end
  end

  cls()
  print("Treasury control terminal closed.")
end

main()

local function messageScreen(title, lines, colour)
  cls()
  topBar()
  centre(3, title, colour or C.body, C.bg)
  local y = 5
  for _, line in ipairs(lines or {}) do
    centre(y, tostring(line), C.body, C.bg)
    y = y + 1
  end
  local b = btn(math.floor(W/2)-7, H-2, 14, "Continue", C.btn, C.btn_fg)
  bottomBar()
  while true do
    local ev, _, x, yy = os.pullEvent()
    if ev == "mouse_click" and hit(b, x, yy) then return end
    if ev == "key" then return end
    if ev == "terminate" then error("Terminated", 0) end
  end
end

local function confirmScreen(title, lines, danger)
  while true do
    cls()
    topBar()
    centre(3, title, danger and C.err or C.accent, C.bg)
    local y = 5
    for _, line in ipairs(lines or {}) do
      centre(y, tostring(line), C.body, C.bg)
      y = y + 1
    end
    local bw = math.min(20, math.floor((W-8)/2))
    local b_yes = btn(math.floor(W/2)-bw-2, H-3, bw, "Confirm", danger and C.danger or C.btn, danger and C.body or C.btn_fg)
    local b_no  = btn(math.floor(W/2)+2,    H-3, bw, "Cancel", C.btn2, C.btn2_fg)
    bottomBar(danger and "Dangerous state action: confirmation required." or "Confirm action.")

    local ev, p1, x, yy = os.pullEvent()
    if ev == "mouse_click" then
      if hit(b_yes, x, yy) then return true end
      if hit(b_no,  x, yy) then return false end
    elseif ev == "key" then
      if p1 == keys.enter then return true end
      if p1 == keys.backspace or p1 == keys.escape then return false end
    elseif ev == "terminate" then
      error("Terminated", 0)
    end
  end
end

local function formScreen(title, fields, submitLabel, danger)
  local focused = 1
  local err = ""
  for _, f in ipairs(fields) do
    if f.value == nil then f.value = "" end
  end

  local function draw()
    cls()
    topBar()
    term.setCursorBlink(false)
    centre(3, title, C.accent, C.bg)

    local startY = 5
    local boxes = {}
    for i, f in ipairs(fields) do
      local y = startY + (i-1)*2
      at(4, y, f.label, C.label, C.bg)
      boxes[i] = inputBox(22, y, W-25, f.value, focused == i, f.masked)
    end

    local b_submit = btn(4, H-3, math.floor((W-10)/2), submitLabel or "Submit", danger and C.danger or C.btn, danger and C.body or C.btn_fg)
    local b_cancel = btn(6 + math.floor((W-10)/2), H-3, math.floor((W-10)/2), "Cancel", C.btn2, C.btn2_fg)
    if err ~= "" then at(4, H-5, short(err, W-6), C.err, C.bg) end
    bottomBar("Tab/Enter moves fields. Click fields and buttons normally.")
    return boxes, b_submit, b_cancel
  end

  local boxes, b_submit, b_cancel = draw()

  local function values()
    local out = {}
    for _, f in ipairs(fields) do out[f.key] = trim(f.value) end
    return out
  end

  while true do
    local ev, p1, p2, p3 = os.pullEvent()
    if ev == "char" then
      local f = fields[focused]
      if #(f.value or "") < (f.max or 48) then
        local ch = capsLock and p1:upper() or p1
        f.value = (f.value or "") .. ch
        boxes, b_submit, b_cancel = draw()
      end
    elseif ev == "key" then
      if keys.capsLock and p1 == keys.capsLock then
        capsLock = not capsLock
        boxes, b_submit, b_cancel = draw()
      elseif p1 == keys.backspace then
        local f = fields[focused]
        if #(f.value or "") > 0 then
          f.value = f.value:sub(1, -2)
          boxes, b_submit, b_cancel = draw()
        end
      elseif p1 == keys.tab then
        focused = focused % #fields + 1
        boxes, b_submit, b_cancel = draw()
      elseif p1 == keys.enter then
        if focused < #fields then
          focused = focused + 1
          boxes, b_submit, b_cancel = draw()
        else
          return values()
        end
      elseif p1 == keys.escape then
        return nil
      end
    elseif ev == "mouse_click" then
      local mx, my = p2, p3
      if hit(b_cancel, mx, my) then return nil end
      if hit(b_submit, mx, my) then return values() end
      for i, box in ipairs(boxes) do
        if hit(box, mx, my) then
          focused = i
          boxes, b_submit, b_cancel = draw()
          break
        end
      end
    elseif ev == "terminate" then
      error("Terminated", 0)
    end
  end
end

-- =============================================================================
-- TREASURY ACTIONS
-- =============================================================================
local function actionPrintMoney()
  local vals = formScreen("PRINT MONEY INTO TREASURY", {
    { label="Amount", key="amount", max=12 },
    { label="Memo",   key="memo", value="Treasury monetary issue", max=48 },
  }, "Review Print", true)
  if not vals then return "dashboard" end

  local amount = parseAmount(vals.amount)
  if not amount then
    messageScreen("Invalid Amount", {"Enter a whole number greater than zero."}, C.err)
    return "dashboard"
  end

  local okConfirm = confirmScreen("CONFIRM MONETARY ISSUE", {
    "This will create new Quid.",
    "Destination: treasury:quid_bank",
    "Amount: " .. fmtQ(amount),
    "Memo: " .. short(vals.memo, W-14),
  }, true)
  if not okConfirm then return "dashboard" end

  local ok, res = dbRequest({ type="mint", to_id="treasury:quid_bank", amount=amount, memo=vals.memo })
  if ok and type(res) == "table" then
    refreshStatus()
    messageScreen("Money Printed", {"Treasury credited: " .. fmtQ(amount), "Transaction: " .. tostring(res.tx_id or "unknown")}, C.ok)
  else
    messageScreen("Print Failed", {tostring(res or "Unknown error")}, C.err)
  end
  return "dashboard"
end

local function actionGrantFunds(prefill)
  local vals = formScreen("GRANT TREASURY FUNDS", {
    { label="Recipient", key="to_id", value=prefill or "", max=48 },
    { label="Amount",    key="amount", max=12 },
    { label="Memo",      key="memo", value="Treasury grant", max=48 },
  }, "Review Grant", false)
  if not vals then return "dashboard" end

  local to_id = normaliseAccountId(vals.to_id)
  local amount = parseAmount(vals.amount)
  if to_id == "" then
    messageScreen("Missing Recipient", {"Enter citizen:josh, company:ticker, or a username."}, C.err)
    return "dashboard"
  end
  if not amount then
    messageScreen("Invalid Amount", {"Enter a whole number greater than zero."}, C.err)
    return "dashboard"
  end

  local okConfirm = confirmScreen("CONFIRM TREASURY GRANT", {
    "This spends existing treasury funds.",
    "From: treasury:quid_bank",
    "To: " .. to_id,
    "Amount: " .. fmtQ(amount),
    "Memo: " .. short(vals.memo, W-14),
  }, false)
  if not okConfirm then return "dashboard" end

  local ok, res = dbRequest({ type="grant", to_id=to_id, amount=amount, memo=vals.memo })
  if ok and type(res) == "table" then
    refreshStatus()
    messageScreen("Grant Complete", {"Recipient: " .. to_id, "Amount: " .. fmtQ(amount), "Transaction: " .. tostring(res.tx_id or "unknown")}, C.ok)
  else
    messageScreen("Grant Failed", {tostring(res or "Unknown error")}, C.err)
  end
  return "dashboard"
end


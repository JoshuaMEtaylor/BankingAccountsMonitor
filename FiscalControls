local function pagedList(title, rows, columns, onSelect, backScreen)
  local page = 1
  local rowsPerPage = math.max(4, H - 9)
  local maxPage = math.max(1, math.ceil(#rows / rowsPerPage))

  while true do
    page = clamp(page, 1, maxPage)
    cls()
    topBar()
    centre(3, title, C.accent, C.bg)

    local y = 5
    fill(1, y, W, 1, C.panel)
    for _, col in ipairs(columns) do
      at(col.x, y, col.label, C.accent, C.panel)
    end

    local hitRows = {}
    local start = (page-1) * rowsPerPage + 1
    for i = 0, rowsPerPage-1 do
      local row = rows[start+i]
      local yy = y + 1 + i
      if row and yy <= H-4 then
        local bg = (i % 2 == 0) and C.row_a or C.row_b
        fill(1, yy, W, 1, bg)
        for _, col in ipairs(columns) do
          local val = col.get(row)
          local fg = col.colour and col.colour(row) or C.body
          at(col.x, yy, short(val, col.w or 12), fg, bg)
        end
        hitRows[#hitRows+1] = { x1=1, x2=W, y1=yy, y2=yy, row=row }
      end
    end

    local b_prev = btn(2, H-2, 10, "Prev", C.btn2, C.btn2_fg)
    local b_next = btn(14, H-2, 10, "Next", C.btn2, C.btn2_fg)
    local b_back = btn(W-12, H-2, 10, "Back", C.btn, C.btn_fg)
    centre(H-2, "Page " .. page .. "/" .. maxPage, C.dim, C.bg)
    bottomBar("Click a row to manage it.")

    local ev, _, x, yy = os.pullEvent()
    if ev == "mouse_click" then
      if hit(b_prev, x, yy) then page = page - 1
      elseif hit(b_next, x, yy) then page = page + 1
      elseif hit(b_back, x, yy) then return backScreen or "dashboard"
      else
        for _, hr in ipairs(hitRows) do
          if hit(hr, x, yy) then
            return onSelect(hr.row)
          end
        end
      end
    elseif ev == "key" then
      return backScreen or "dashboard"
    elseif ev == "terminate" then
      error("Terminated", 0)
    end
  end
end


local function mainLoop()
  refreshStatus()
  local buttons = drawMain()

  while true do
    local ev, p1, p2, p3 = os.pullEvent()

    if ev == "mouse_click" then
      local mx, my = p2, p3

      if hit(buttons.refresh, mx, my) then
        refreshStatus()
      elseif hit(buttons.print, mx, my) then
        actionPrintMoney()
      elseif hit(buttons.grant, mx, my) then
        actionGrantFunds()
      elseif hit(buttons.burn, mx, my) then
        actionBurnMoney()
      elseif hit(buttons.accounts, mx, my) then
        screenAccounts()
      elseif hit(buttons.history, mx, my) then
        screenFiscalHistory()
      elseif hit(buttons.stim_citizens, mx, my) then
        actionStimulus("citizen")
      elseif hit(buttons.stim_business, mx, my) then
        actionStimulus("company")
      elseif hit(buttons.workerpay, mx, my) then
        actionWorkerPay()
      elseif buttons.reconnect and hit(buttons.reconnect, mx, my) then
        connectServer()
        refreshStatus()
      end

      buttons = drawMain()
    end
  end
end

-- =============================================================================
-- ENTRY
-- =============================================================================
local function main()
  if not openModem() then
    clear(colors.black)
    print("ERROR: No modem found.")
    print("Attach an Ender Modem and reboot.")
    return
  end

  while not connectServer() do
    sleep(2)
  end

  -- No blocking rejection screen. Open the controller either way.
  -- If the server refuses fiscal actions, the error appears in the bottom bar.
  refreshStatus()
  mainLoop()

  clear(colors.black)
  print("Fiscal Controls closed.")
end

main()

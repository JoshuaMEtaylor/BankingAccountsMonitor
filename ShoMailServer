-- HELPERS
-- =============================================================================
local function ensureDir(path)
  local parts = {}
  for part in string.gmatch(path, "[^/]+") do parts[#parts + 1] = part end
  table.remove(parts)

  local current = ""
  for _, part in ipairs(parts) do
    current = current == "" and part or (current .. "/" .. part)
    if not fs.exists(current) then fs.makeDir(current) end
  end
end

local function writeFile(path, data)
  ensureDir(path)
  local f = fs.open(path, "w")
  if not f then return false end
  f.write(textutils.serialize(data))
  f.close()
  return true
end

local function readFile(path, fallback)
  if not fs.exists(path) then return fallback end
  local f = fs.open(path, "r")
  if not f then return fallback end
  local text = f.readAll()
  f.close()

  local ok, data = pcall(textutils.unserialize, text)
  if ok and data ~= nil then return data end
  return fallback
end

local function appendAudit(line)
  ensureDir(FILE.audit)
  local f = fs.open(FILE.audit, "a")
  if f then
    f.writeLine(tostring(os.epoch("utc")) .. " | " .. tostring(line))
    f.close()
  end
end

local function saveDeals() return writeFile(FILE.deals, deals) end
local function saveState() return writeFile(FILE.state, state) end
local function saveNotifications() return writeFile(FILE.notifications, notifications) end

local function trim(s)
  return tostring(s or ""):match("^%s*(.-)%s*$")
end

local function lower(s)
  return string.lower(tostring(s or ""))
end

local function nextDealId()
  state.counter = (tonumber(state.counter) or 0) + 1
  saveState()
  return "DEAL-" .. string.format("%06d", state.counter)
end

local function copyTable(t)
  local out = {}
  if type(t) ~= "table" then return out end
  for k, v in pairs(t) do
    if type(v) == "table" then
      out[k] = copyTable(v)
    else
      out[k] = v
    end
  end
  return out
end

local function parseDate(value)
  if type(value) == "table" then
    return {
      year = tonumber(value.year) or tonumber(value.y) or 1,
      month = tonumber(value.month) or tonumber(value.m) or 1,
      day = tonumber(value.day) or tonumber(value.d) or 1,
    }
  end

  value = trim(value)
  if value == "" then return nil end

  local y, m, d = value:match("^(%d+)%D+(%d+)%D+(%d+)$")
  if not y then return nil end

  return {
    year = tonumber(y) or 1,
    month = tonumber(m) or 1,
    day = tonumber(d) or 1,
  }
end

local function dateKey(d)
  if type(d) ~= "table" then return 0 end
  return ((tonumber(d.year) or 0) * 372) + ((tonumber(d.month) or 0) * 31) + (tonumber(d.day) or 0)
end

local function isDue(d)
  return dateKey(state.world_date) >= dateKey(d)
end

local function dateLabel(d)
  if type(d) ~= "table" then return "" end
  return "Y" .. tostring(d.year or 1) .. " M" .. tostring(d.month or 1) .. " D" .. tostring(d.day or 1)
end

local function advanceDate(d, frequency)
  d = copyTable(d or state.world_date)
  frequency = lower(frequency)

  if frequency == "daily" or frequency == "day" then
    d.day = (tonumber(d.day) or 1) + 1

  elseif frequency == "weekly" or frequency == "week" then
    d.day = (tonumber(d.day) or 1) + 7

  elseif frequency == "yearly" or frequency == "annual" or frequency == "annually" or frequency == "year" then
    d.year = (tonumber(d.year) or 1) + 1

  else
    d.month = (tonumber(d.month) or 1) + 1
  end

  while d.day > 30 do
    d.day = d.day - 30
    d.month = (tonumber(d.month) or 1) + 1
  end

  while d.month > 12 do
    d.month = d.month - 12
    d.year = (tonumber(d.year) or 1) + 1
  end

  return d
end

local function publicDeal(deal)
  local d = copyTable(deal)
  d.payer_auth = nil
  return d
end

local function accountMatches(account_id, citizen_id, username)
  account_id = tostring(account_id or "")
  citizen_id = tostring(citizen_id or "")
  username = tostring(username or "")

  if account_id == citizen_id then return true end
  if account_id == ("citizen:" .. lower(username):gsub("%s+", "_")) then return true end
  return false
end


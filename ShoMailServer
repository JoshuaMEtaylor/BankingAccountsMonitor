local function openModem()
  if modem_name and rednet.isOpen(modem_name) then return true end

  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      local m = peripheral.wrap(name)
      if m and m.isWireless and m.isWireless() then
        rednet.open(name)
        modem_name = name
        return true
      end
    end
  end

  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      rednet.open(name)
      modem_name = name
      return true
    end
  end

  return false
end

local function findBank()
  if state.bank_id then return state.bank_id end

  rednet.broadcast({ type = "ping" }, BANK_PROTOCOL)
  local sender, msg = rednet.receive(BANK_PROTOCOL, 3)

  if sender and type(msg) == "table" then
    if msg.type == "treasury_online" or (msg.success == true and type(msg.response) == "table") then
      state.bank_id = sender
      saveState()
      return sender
    end
  end

  return nil
end

local function bankRequest(payload, timeout)
  timeout = timeout or DB_TIMEOUT

  local bank_id = findBank()
  if not bank_id then return false, "No bank server found" end

  rednet.send(bank_id, payload, BANK_PROTOCOL)

  local deadline = os.clock() + timeout
  while true do
    local remaining = deadline - os.clock()
    if remaining <= 0 then
      state.bank_id = nil
      saveState()
      return false, "No response from bank"
    end

    local sender, msg = rednet.receive(BANK_PROTOCOL, remaining)
    if sender == bank_id and type(msg) == "table" and msg.success ~= nil then
      return msg.success, msg.response
    end
  end
end

local function auth(username, password)
  local ok, res = bankRequest({
    type = "login",
    username = username,
    password = password,
  })

  if ok and type(res) == "table" then
    return true, {
      username = username,
      password = password,
      citizen_id = res.citizen_id,
      display_name = res.display_name,
      title = res.title,
    }
  end

  return false, tostring(res or "Authentication failed")
end


local function notifyAccount(account_id, event_type, title, body, deal_id)
  account_id = tostring(account_id or "")
  if account_id == "" then return false end

  notifications[account_id] = notifications[account_id] or {
    unread = 0,
    items = {},
  }

  local box = notifications[account_id]
  box.unread = (tonumber(box.unread) or 0) + 1

  box.items[#box.items + 1] = {
    id = "NOTIF-" .. tostring(os.epoch("utc")) .. "-" .. tostring(#box.items + 1),
    event_type = tostring(event_type or "message"),
    title = tostring(title or "ShoMail"),
    body = tostring(body or ""),
    deal_id = deal_id,
    read = false,
    created_at = os.epoch("utc"),
  }

  while #box.items > 50 do table.remove(box.items, 1) end

  saveNotifications()
  appendAudit("NOTIFY " .. account_id .. " " .. tostring(event_type) .. " " .. tostring(deal_id or ""))
  return true
end

local function unreadFor(account_id)
  local box = notifications[tostring(account_id or "")]
  if type(box) ~= "table" then return 0 end
  return tonumber(box.unread) or 0
end

local function markSeen(account_id)
  local box = notifications[tostring(account_id or "")]
  if type(box) ~= "table" then return 0 end

  local previous = tonumber(box.unread) or 0
  box.unread = 0

  for _, item in ipairs(box.items or {}) do
    item.read = true
  end

  saveNotifications()
  return previous
end

local function otherParty(deal, user_id)
  if not deal then return nil end
  if deal.from_id == user_id then return deal.to_id end
  return deal.from_id
end


local function executePayment(deal)
  local amount = tonumber(deal.amount) or 0
  if amount <= 0 then return false, "Invalid deal amount" end

  if type(deal.payer_auth) ~= "table" then
    return false, "No payer authorisation stored"
  end

  local ok, res

  -- Citizen payer: use normal transfer with stored payer login.
  if tostring(deal.from_id or ""):find("^citizen:") then
    ok, res = bankRequest({
      type = "transfer",
      username = deal.payer_auth.username,
      password = deal.payer_auth.password,
      to_id = deal.to_id,
      amount = amount,
      memo = "ShoMail recurring: " .. tostring(deal.title or deal.deal_id),
    }, 10)

  -- Company payer: use company_withdraw if the payer auth belongs to the owner.
  elseif tostring(deal.from_id or ""):find("^company:") then
    ok, res = bankRequest({
      type = "company_withdraw",
      username = deal.payer_auth.username,
      password = deal.payer_auth.password,
      company_id = deal.from_id,
      amount = amount,
      memo = "ShoMail recurring: " .. tostring(deal.title or deal.deal_id),
      to_id = deal.to_id,
    }, 10)

  else
    return false, "Unsupported payer account: " .. tostring(deal.from_id)
  end

  if ok and type(res) == "table" then
    deal.last_payment = {
      tx_id = res.tx_id,
      amount = amount,
      paid_at = copyTable(state.world_date),
    }
    deal.payment_count = (tonumber(deal.payment_count) or 0) + 1
    deal.next_due = advanceDate(deal.next_due or state.world_date, deal.frequency)

    notifyAccount(deal.from_id, "payment_sent", "Payment sent", tostring(deal.title or deal.deal_id) .. " paid " .. tostring(amount) .. " Q", deal.deal_id)
    notifyAccount(deal.to_id, "payment_received", "Payment received", tostring(deal.title or deal.deal_id) .. " paid " .. tostring(amount) .. " Q", deal.deal_id)

    appendAudit("PAID " .. tostring(deal.deal_id) .. " tx=" .. tostring(res.tx_id))
    return true, res
  end

  deal.last_error = tostring(res or "Payment failed")

  notifyAccount(deal.from_id, "payment_failed", "Payment failed", tostring(deal.title or deal.deal_id) .. ": " .. tostring(deal.last_error), deal.deal_id)
  notifyAccount(deal.to_id, "payment_failed", "Payment failed", tostring(deal.title or deal.deal_id) .. ": " .. tostring(deal.last_error), deal.deal_id)

  appendAudit("PAYMENT_FAILED " .. tostring(deal.deal_id) .. " " .. tostring(deal.last_error))
  return false, deal.last_error
end

local function processDueDeals()
  local paid = 0
  local failed = 0

  for _, deal in pairs(deals) do
    if type(deal) == "table" and deal.status == "active" and deal.recurring ~= false then
      if deal.next_due and isDue(deal.next_due) then
        local ok = executePayment(deal)
        if ok then paid = paid + 1 else failed = failed + 1 end
      end
    end
  end

  if paid > 0 or failed > 0 then saveDeals() end
  return paid, failed
end


local function addSuggestion(out, seen, account_id, label, kind)
  account_id = tostring(account_id or "")
  if account_id == "" or seen[account_id] then return end
  seen[account_id] = true
  out[#out + 1] = {
    account_id = account_id,
    label = tostring(label or account_id),
    kind = tostring(kind or "account"),
  }
end


local function handleSuggest(req)
  local ok, user = auth(req.username, req.password)
  if not ok then return false, user end

  local q_raw = trim(req.query or "")
  local q = lower(q_raw)
  local limit = tonumber(req.limit) or 6
  if limit < 1 then limit = 6 end
  if limit > 12 then limit = 12 end

  if q == "" then
    return true, { suggestions = {}, count = 0 }
  end

  local suggestions = {}
  local seen = {}

  local function startsWith(value, prefix)
    value = lower(value or "")
    prefix = lower(prefix or "")
    return value:sub(1, #prefix) == prefix
  end

  local function stripAccountPrefix(id)
    id = tostring(id or "")
    return id:gsub("^citizen:", ""):gsub("^company:", "")
  end

  local function add(account_id, label, kind)
    account_id = tostring(account_id or "")
    label = tostring(label or account_id)
    if account_id == "" or seen[account_id] then return end

    local short = stripAccountPrefix(account_id)
    local hay1 = lower(short)
    local hay2 = lower(account_id)
    local hay3 = lower(label)

    -- Prefix matching only. Typing A shows accounts beginning A.
    -- Typing AK narrows to accounts beginning AK.
    if not (startsWith(hay1, q) or startsWith(hay2, q) or startsWith(hay3, q)) then
      return
    end

    seen[account_id] = true
    suggestions[#suggestions + 1] = {
      account_id = account_id,
      label = label,
      kind = tostring(kind or "account"),
    }
  end

  local function absorbAccountList(list)
    if type(list) ~= "table" then return end

    for _, a in ipairs(list) do
      if type(a) == "table" then
        local account_id =
          a.account_id or a.id or a.citizen_id or a.company_id or a.username or a.name

        local label =
          a.display_name or a.name or a.username or a.ticker or account_id

        if a.ticker and a.name then
          label = tostring(a.ticker) .. " - " .. tostring(a.name)
        end

        add(account_id, label, a.kind or a.type or "account")

      else
        add(a, a, "account")
      end

      if #suggestions >= limit then return end
    end
  end

  local bankQueries = {
    { type = "list_accounts" },
    { type = "list_all_accounts" },
    { type = "admin_list_accounts" },
    { type = "view_accounts" },
    { type = "list_citizens" },
    { type = "list_companies" },
  }

  for _, query in ipairs(bankQueries) do
    local ok2, res = bankRequest(query, 4)
    if ok2 and type(res) == "table" then
      absorbAccountList(res.accounts)
      absorbAccountList(res.citizens)
      absorbAccountList(res.companies)
      absorbAccountList(res)

      if #suggestions >= limit then break end
    end
  end

  table.sort(suggestions, function(a, b)
    local aa = stripAccountPrefix(a.account_id)
    local bb = stripAccountPrefix(b.account_id)
    return lower(aa) < lower(bb)
  end)

  while #suggestions > limit do
    table.remove(suggestions)
  end

  return true, {
    suggestions = suggestions,
    count = #suggestions,
  }
end
local function handleList(req)
  local ok, user = auth(req.username, req.password)
  if not ok then return false, user end

  local mode = tostring(req.mode or "inbox")
  local out = {}

  for _, deal in pairs(deals) do
    if type(deal) == "table" then
      local involved = deal.from_id == user.citizen_id or deal.to_id == user.citizen_id
      local sent = deal.proposer_id == user.citizen_id

      if mode == "active" then
        if involved and deal.status == "active" then out[#out + 1] = publicDeal(deal) end

      elseif mode == "sent" then
        if sent then out[#out + 1] = publicDeal(deal) end

      else
        -- inbox: pending/countered proposals aimed at this user
        if deal.to_id == user.citizen_id and deal.status ~= "active" and deal.status ~= "declined" and deal.status ~= "cancelled" then
          out[#out + 1] = publicDeal(deal)
        end
      end
    end
  end

  table.sort(out, function(a, b)
    return tostring(a.updated_at or a.created_at or "") > tostring(b.updated_at or b.created_at or "")
  end)

  return true, {
    deals = out,
    count = #out,
    world_date = copyTable(state.world_date),
  }
end

local function handlePropose(req)
  local ok, user = auth(req.username, req.password)
  if not ok then return false, user end

  local to_id = trim(req.to_id)
  local title = trim(req.title)
  local amount = tonumber(req.amount)

  if to_id == "" then return false, "Missing recipient" end
  if not to_id:find(":") then to_id = "citizen:" .. lower(to_id):gsub("%s+", "_") end
  if title == "" then return false, "Missing deal title" end
  if not amount or amount <= 0 then return false, "Invalid amount" end

  local from_id = trim(req.from_id)
  if from_id == "" then from_id = user.citizen_id end
  if not from_id:find(":") then from_id = "citizen:" .. lower(from_id):gsub("%s+", "_") end

  local start_date = parseDate(req.start_date or req.start or req.next_due) or copyTable(state.world_date)

  local deal_id = nextDealId()
  local deal = {
    deal_id = deal_id,
    title = title,
    from_id = from_id,
    to_id = to_id,
    proposer_id = user.citizen_id,
    amount = math.floor(amount),
    frequency = lower(req.frequency or req.interval or "monthly"),
    start_date = copyTable(start_date),
    next_due = copyTable(start_date),
    note = trim(req.note or req.memo or ""),
    status = "pending",
    recurring = true,
    created_at = os.epoch("utc"),
    updated_at = os.epoch("utc"),
    history = {
      {
        action = "proposed",
        actor = user.citizen_id,
        amount = math.floor(amount),
        frequency = lower(req.frequency or req.interval or "monthly"),
        at = os.epoch("utc"),
      }
    }
  }

  -- Store payer auth when the proposer is the payer. This lets due recurring
  -- payments execute automatically later.
  if accountMatches(from_id, user.citizen_id, user.username) then
    deal.payer_auth = {
      username = user.username,
      password = user.password,
      citizen_id = user.citizen_id,
    }
  end

  deals[deal_id] = deal
  saveDeals()

  notifyAccount(deal.to_id, "deal_proposed", "New deal proposed", tostring(deal.title) .. " from " .. tostring(deal.from_id), deal_id)

  appendAudit("PROPOSE " .. deal_id .. " " .. deal.from_id .. "->" .. deal.to_id)

  return true, { deal = publicDeal(deal) }
end

local function getDeal(req)
  local id = trim(req.deal_id or req.id)
  if id == "" then return nil, "Missing deal_id" end
  local deal = deals[id]
  if type(deal) ~= "table" then return nil, "Deal not found" end
  return deal
end

local function handleAccept(req)
  local ok, user = auth(req.username, req.password)
  if not ok then return false, user end

  local deal, err = getDeal(req)
  if not deal then return false, err end

  if deal.to_id ~= user.citizen_id and deal.from_id ~= user.citizen_id then
    return false, "You are not part of this deal"
  end

  if deal.status == "declined" or deal.status == "cancelled" then
    return false, "Deal is closed"
  end

  -- If the accepter is the payer, store their auth for future recurring payment execution.
  if accountMatches(deal.from_id, user.citizen_id, user.username) then
    deal.payer_auth = {
      username = user.username,
      password = user.password,
      citizen_id = user.citizen_id,
    }
  end

  deal.status = "active"
  deal.accepted_by = user.citizen_id
  deal.accepted_at = os.epoch("utc")
  deal.updated_at = os.epoch("utc")
  deal.next_due = deal.next_due or deal.start_date or copyTable(state.world_date)
  deal.history = deal.history or {}
  deal.history[#deal.history + 1] = { action = "accepted", actor = user.citizen_id, at = os.epoch("utc") }

  saveDeals()

  local other = otherParty(deal, user.citizen_id)
  notifyAccount(other, "deal_accepted", "Deal accepted", tostring(deal.title or deal.deal_id) .. " was accepted", deal.deal_id)

  appendAudit("ACCEPT " .. deal.deal_id .. " by " .. user.citizen_id)

  return true, { deal = publicDeal(deal) }
end

local function handleDecline(req)
  local ok, user = auth(req.username, req.password)
  if not ok then return false, user end

  local deal, err = getDeal(req)
  if not deal then return false, err end

  if deal.to_id ~= user.citizen_id and deal.from_id ~= user.citizen_id then
    return false, "You are not part of this deal"
  end

  deal.status = "declined"
  deal.declined_by = user.citizen_id
  deal.updated_at = os.epoch("utc")
  deal.history = deal.history or {}
  deal.history[#deal.history + 1] = { action = "declined", actor = user.citizen_id, at = os.epoch("utc") }

  saveDeals()

  local other = otherParty(deal, user.citizen_id)
  notifyAccount(other, "deal_declined", "Deal declined", tostring(deal.title or deal.deal_id) .. " was declined", deal.deal_id)

  appendAudit("DECLINE " .. deal.deal_id .. " by " .. user.citizen_id)

  return true, { deal = publicDeal(deal) }
end

local function handleCounter(req)
  local ok, user = auth(req.username, req.password)
  if not ok then return false, user end

  local deal, err = getDeal(req)
  if not deal then return false, err end

  if deal.to_id ~= user.citizen_id and deal.from_id ~= user.citizen_id then
    return false, "You are not part of this deal"
  end

  local terms = req.terms or {}
  local amount = tonumber(terms.amount or req.amount or deal.amount)
  if not amount or amount <= 0 then return false, "Invalid counter amount" end

  -- Counter flips attention to the other party.
  local other
  if deal.to_id == user.citizen_id then other = deal.from_id else other = deal.to_id end

  deal.amount = math.floor(amount)
  deal.frequency = lower(terms.frequency or req.frequency or deal.frequency or "monthly")
  deal.note = trim(terms.note or req.note or deal.note or "")
  deal.status = "countered"
  deal.to_id = other
  deal.proposer_id = user.citizen_id
  deal.updated_at = os.epoch("utc")
  deal.history = deal.history or {}
  deal.history[#deal.history + 1] = {
    action = "countered",
    actor = user.citizen_id,
    amount = deal.amount,
    frequency = deal.frequency,
    at = os.epoch("utc"),
  }

  -- If countering user is payer, update payer auth.
  if accountMatches(deal.from_id, user.citizen_id, user.username) then
    deal.payer_auth = {
      username = user.username,
      password = user.password,
      citizen_id = user.citizen_id,
    }
  end

  saveDeals()

  notifyAccount(deal.to_id, "deal_countered", "Counter offer", tostring(deal.title or deal.deal_id) .. " has new terms", deal.deal_id)

  appendAudit("COUNTER " .. deal.deal_id .. " by " .. user.citizen_id)

  return true, { deal = publicDeal(deal) }
end

local function handleCancel(req)
  local ok, user = auth(req.username, req.password)
  if not ok then return false, user end

  local deal, err = getDeal(req)
  if not deal then return false, err end

  if deal.to_id ~= user.citizen_id and deal.from_id ~= user.citizen_id and deal.proposer_id ~= user.citizen_id then
    return false, "You are not part of this deal"
  end

  deal.status = "cancelled"
  deal.cancelled_by = user.citizen_id
  deal.updated_at = os.epoch("utc")
  deal.history = deal.history or {}
  deal.history[#deal.history + 1] = { action = "cancelled", actor = user.citizen_id, at = os.epoch("utc") }

  saveDeals()

  local other = otherParty(deal, user.citizen_id)
  notifyAccount(other, "deal_cancelled", "Deal cancelled", tostring(deal.title or deal.deal_id) .. " was cancelled", deal.deal_id)

  appendAudit("CANCEL " .. deal.deal_id .. " by " .. user.citizen_id)

  return true, { deal = publicDeal(deal) }
end

local function handleClock(req)
  local d = parseDate(req.date or req.world_date or req)
  if not d then return false, "Invalid world date. Use year/month/day." end

  state.world_date = d
  saveState()

  local paid, failed = processDueDeals()

  return true, {
    world_date = copyTable(state.world_date),
    paid = paid,
    failed = failed,
  }
end

local function handleRunDue()
  local paid, failed = processDueDeals()
  return true, {
    world_date = copyTable(state.world_date),
    paid = paid,
    failed = failed,
  }
end


local function handleNotificationCount(req)
  local ok, user = auth(req.username, req.password)
  if not ok then return false, user end

  local count = unreadFor(user.citizen_id)
  return true, {
    unread = count,
    count = count,
  }
end

local function handleMarkNotificationsSeen(req)
  local ok, user = auth(req.username, req.password)
  if not ok then return false, user end

  local cleared = markSeen(user.citizen_id)
  return true, {
    cleared = cleared,
    unread = 0,
  }
end

local function handleRequest(req, sender)
  if type(req) ~= "table" then return false, "Bad request" end

  if req.type == "ping" then
    return true, {
      type = "deal_server_online",
      version = VERSION,
      world_date = copyTable(state.world_date),
    }
  elseif req.type == "notification_count" then
    return handleNotificationCount(req)
  elseif req.type == "mark_notifications_seen" then
    return handleMarkNotificationsSeen(req)
  elseif req.type == "get_world_date" then
    return true, { world_date = copyTable(state.world_date), label = dateLabel(state.world_date) }
  elseif req.type == "suggest_recipients" then
    return handleSuggest(req)
  elseif req.type == "list_deals" then
    return handleList(req)
  elseif req.type == "propose_deal" then
    return handlePropose(req)
  elseif req.type == "accept_deal" then
    return handleAccept(req)
  elseif req.type == "decline_deal" then
    return handleDecline(req)
  elseif req.type == "counter_deal" then
    return handleCounter(req)
  elseif req.type == "cancel_deal" then
    return handleCancel(req)
  elseif req.type == "update_clock" or req.type == "set_world_date" then
    return handleClock(req)
  elseif req.type == "run_due_deals" or req.type == "tick_deals" then
    return handleRunDue()
  end

  return false, "Unknown request type: " .. tostring(req.type)
end


local function load()
  deals = readFile(FILE.deals, {})
  notifications = readFile(FILE.notifications, {})
  state = readFile(FILE.state, state) or state
  if type(state.world_date) ~= "table" then
    state.world_date = { year = 1, month = 1, day = 1 }
  end
end

local function main()
  term.setBackgroundColor(colors.black)
  term.setTextColor(colors.white)
  term.clear()
  term.setCursorPos(1, 1)

  print("ShoMail Deal Server " .. VERSION)
  print("Protocol: " .. DEAL_PROTOCOL)

  if not openModem() then
    print("ERROR: No modem found.")
    return
  end

  load()
  findBank()

  print("Modem: " .. tostring(modem_name))
  print("Bank:  " .. tostring(state.bank_id or "not found yet"))
  print("Deals: " .. tostring(#(deals or {})))
  print("Date:  " .. dateLabel(state.world_date))
  print("")
  print("Listening...")

  local lastDueCheck = os.clock()

  while true do
    local sender, req = rednet.receive(DEAL_PROTOCOL, 1)

    if sender then
      local ok, res = handleRequest(req, sender)
      rednet.send(sender, { success = ok, response = res }, DEAL_PROTOCOL)
    end

    -- Passive safety check every 10 seconds in case a world-clock updater has
    -- changed state or due deals are pending.
    if os.clock() - lastDueCheck >= 10 then
      lastDueCheck = os.clock()
      processDueDeals()
    end
  end
end

main()

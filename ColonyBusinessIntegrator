-- SCAN LOOP
-- =============================================================================
local function scanOnce()
  if not colony then setMsg("No Colony Integrator found.", colors.red); return false end
  if not bank_id or not contract_id then reconnect() end
  if not bank_id or not contract_id then return false end

  refreshPrices()
  refreshInflation()
  local okB, buildings = safeCall(colony, "getBuildings")
  local okC, citizens = safeCall(colony, "getCitizens")
  local okR, requests = safeCall(colony, "getRequests")
  if not okB then buildings = {} end
  if not okC then citizens = {} end
  if not okR then requests = {} end

  stats.buildings_seen = #buildings
  stats.requests_seen = 0
  stats.skipped_unmapped = 0
  stats.skipped_unfunded = 0

  scanCitizens(citizens)
  scanBusinesses(buildings)
  syncEmployeeMappings(citizens)
  scanRequests(requests, citizens)

  stats.last_scan = now()
  writeFile(FILE_BUSINESSES, businesses)
  writeFile(FILE_POSTED, posted)
  return true
end

local function loadState()
  businesses = readFile(FILE_BUSINESSES) or {}
  industry_companies = readFile(FILE_INDUSTRIES) or {}
  migrateIndustryMappings()
  posted = readFile(FILE_POSTED) or {}
  citizens_map = readFile(FILE_CITIZENS) or {}
  config = readFile(FILE_CONFIG) or {}
  if config.price_index then PRICE_INDEX = tonumber(config.price_index) or PRICE_INDEX end
  if config.inflation_multiplier then PRICE_INDEX = tonumber(config.inflation_multiplier) or PRICE_INDEX end
  if config.inflation then PRICE_INDEX = tonumber(config.inflation) or PRICE_INDEX end
  if config.starting_capital then STARTING_CAPITAL = tonumber(config.starting_capital) or STARTING_CAPITAL end
end

local function main()
  math.randomseed((now() + os.getComputerID()) % 2147483647)
  loadState()
  cls()
  fill(1, 1, W, 1, colors.purple)
  at(2, 1, "COLONY BUSINESS INTEGRATOR", colors.white, colors.purple)
  at(2, 3, "Starting...", colors.lightGray)

  if not findColony() then
    at(2, 5, "No Colony Integrator found.", colors.red)
    at(2, 6, "Attach this computer to the integrator.", colors.lightGray)
    return
  end
  if not openModem() then
    at(2, 5, "No modem found.", colors.red)
    at(2, 6, "Attach an Ender/Wireless modem.", colors.lightGray)
    return
  end

  reconnect()
  local bScan, bAuto, bRecon = draw()
  local timer = os.startTimer(2)

  while true do
    local ev, p1, p2, p3 = os.pullEvent()
    if ev == "timer" and p1 == timer then
      if auto_mode then scanOnce() end
      bScan, bAuto, bRecon = draw()
      timer = os.startTimer(SCAN_INTERVAL)
    elseif ev == "mouse_click" then
      local mx, my = p2, p3
      if hit(bScan, mx, my) then scanOnce()
      elseif hit(bAuto, mx, my) then auto_mode = not auto_mode; setMsg("Auto mode " .. (auto_mode and "enabled" or "disabled"), auto_mode and colors.lime or colors.orange)
      elseif hit(bRecon, mx, my) then reconnect() end
      bScan, bAuto, bRecon = draw()
    end
  end
end

main()

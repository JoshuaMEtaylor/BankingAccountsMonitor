  local memo       = req.memo or "Owner company payout"

  if not company_id or company_id == "" then return false, "Missing company_id" end
  if not amount or amount <= 0 then return false, "Invalid amount" end
  if not companies[company_id] then return false, "Company not found: " .. tostring(company_id) end
  if not accountExists(company_id) then return false, "Company account not found: " .. tostring(company_id) end

  if not isCompanyOwner(company_id, citizen_id) then
    return false, "Only the registered owner can withdraw company funds"
  end

  return transfer(company_id, citizen_id, amount, "COMPANY_WITHDRAW", memo, citizen_id)
end

-- COMPANY_TRANSFER
-- Owner-authorised company spending to another account. This is the controlled
-- version of company transactions: the logged-in owner can spend from their
-- company, but only after ownership and balance checks.
handlers["company_transfer"] = function(sender_id, req)
  local ok, citizen_id, citizen = authenticateUser(req.username, req.password)
  if not ok then return false, citizen_id end

  local company_id = req.company_id
  local to_id      = req.to_id
  local amount     = tonumber(req.amount)
  local memo       = req.memo or "Company payment"

  if not company_id or company_id == "" then return false, "Missing company_id" end
  if not to_id or to_id == "" then return false, "Missing destination account" end
  if not amount or amount <= 0 then return false, "Invalid amount" end
  if not companies[company_id] then return false, "Company not found: " .. tostring(company_id) end
  if not accountExists(company_id) then return false, "Company account not found: " .. tostring(company_id) end

  if not isCompanyOwner(company_id, citizen_id) then
    return false, "Only the registered owner can spend company funds"
  end

  -- Resolve friendly citizen usernames.
  if not to_id:find(":") then
    local citizen_target = "citizen:" .. string.lower(to_id):gsub("%s+", "_")
    local company_target = "company:" .. string.lower(to_id):gsub("%s+", "_")
    if accountExists(citizen_target) then
      to_id = citizen_target
    elseif accountExists(company_target) then
      to_id = company_target
    end
  end

  if not accountExists(to_id) then
    return false, "Destination account not found: " .. tostring(to_id)
  end
  if to_id == company_id then
    return false, "Cannot transfer company funds to the same company"
  end

  return transfer(company_id, to_id, amount, "COMPANY_TRANSFER", memo, citizen_id)
end


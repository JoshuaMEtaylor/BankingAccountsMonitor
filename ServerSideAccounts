-- CREATE_ACCOUNT — self-registration, instant activation
handlers["create_account"] = function(sender_id, req)
  local display_name = req.display_name
  local username     = req.username
  local password     = req.password

  if not display_name or not username or not password then
    return false, "Missing display_name, username, or password"
  end
  if #username < 3 then
    return false, "Username must be at least 3 characters"
  end
  if #password < 4 then
    return false, "Password must be at least 4 characters"
  end

  local key        = string.lower(username):gsub("%s+", "_")
  local citizen_id = "citizen:" .. key

  if citizens[citizen_id] then
    return false, "Username already taken"
  end

  -- Create citizen record
  citizens[citizen_id] = {
    display_name  = display_name,
    username      = key,
    password_hash = simpleHash(password),
    joined        = timestamp(),
    status        = "active",
    title         = "Account Holder"
  }
  saveCitizens()

  -- Create bank account
  local ok, result = createAccount(citizen_id, "citizen", display_name, citizen_id)
  if not ok then
    citizens[citizen_id] = nil
    saveCitizens()
    return false, "Account creation failed: " .. tostring(result)
  end

  audit("ACTION", citizen_id, sender_id, "CREATE_ACCOUNT", citizen_id)

  -- Return same payload as login so client can auto-login
  return true, {
    citizen_id   = citizen_id,
    display_name = display_name,
    username     = key,
    title        = "Account Holder",
    balance      = 0,
    message      = "Account created successfully"
  }
end

-- BALANCE
handlers["balance"] = function(sender_id, req)
  local ok, citizen_id, citizen = authenticateUser(req.username, req.password)
  if not ok then return false, citizen_id end

  local target = req.account_id or citizen_id
  if target ~= citizen_id and not isTrustedManagement(sender_id) then
    return false, "Unauthorised"
  end
  if not accountExists(target) then return false, "Account not found" end

  local balance = deriveBalance(target)
  audit("ACTION", citizen_id, sender_id, "BALANCE:" .. target, "ok:" .. balance)
  return true, {
    account_id   = target,
    display_name = accounts[target] and accounts[target].display_name or target,
    balance      = balance,
    time         = timestamp()
  }
end

-- TRANSFER
handlers["transfer"] = function(sender_id, req)
  local ok, citizen_id, citizen = authenticateUser(req.username, req.password)
  if not ok then return false, citizen_id end

  local from_id = citizen_id
  local to_id   = req.to_id
  local amount  = tonumber(req.amount)
  local memo    = req.memo or ""

  if not to_id   then return false, "Missing destination account" end
  if not amount or amount <= 0 then return false, "Invalid amount" end

  -- Resolve friendly username to account id if needed
  -- Accepts either "citizen:josh" or just "josh"
  if not to_id:find(":") then
    local resolved = "citizen:" .. string.lower(to_id):gsub("%s+","_")
    if accountExists(resolved) then
      to_id = resolved
    end
  end

  if not accountExists(to_id) then
    return false, "Recipient account not found: " .. tostring(to_id)
  end
  if to_id == from_id then
    return false, "Cannot transfer to yourself"
  end

  return transfer(from_id, to_id, amount, "TRANSFER", memo, citizen_id)
end

-- LEDGER_HISTORY
handlers["ledger_history"] = function(sender_id, req)
  local ok, citizen_id, citizen = authenticateUser(req.username, req.password)
  if not ok then return false, citizen_id end

  local target = citizen_id
  local limit  = tonumber(req.limit) or 20

  local lines   = readLines(FILE.ledger)
  local results = {}
  for _, line in ipairs(lines) do
    local tx_id, ts, tx_type, from_id, to_id, amount, memo, status =
      line:match("(TX%-%d+)%s*|%s*(%d+)%s*|%s*(%S+)%s*|%s*([^|]+)%s*|%s*([^|]+)%s*|%s*(%d+)%s*|%s*([^|]+)%s*|%s*(.+)")
    if tx_id then
      from_id = from_id:match("^%s*(.-)%s*$")
      to_id   = to_id:match("^%s*(.-)%s*$")
      if from_id == target or to_id == target then
        results[#results+1] = {
          tx_id     = tx_id,
          time      = tonumber(ts),
          type      = tx_type:match("^%s*(.-)%s*$"),
          from      = from_id,
          to        = to_id,
          amount    = tonumber(amount) or 0,
          memo      = memo:match("^%s*(.-)%s*$"),
          status    = status:match("^%s*(.-)%s*$"),
          direction = (to_id == target) and "IN" or "OUT"
        }
      end
    end
  end

  local out   = {}
  local start = math.max(1, #results - limit + 1)
  for i = #results, start, -1 do out[#out+1] = results[i] end

  return true, {
    account_id = target,
    balance    = deriveBalance(target),
    history    = out,
    count      = #out
  }
end

-- TREASURY_HISTORY
-- State-facing read-only transaction feed for expenditure/income monitors.
-- No citizen login required because this is treasury-wide public state accounting.
handlers["treasury_history"] = function(sender_id, req)
  local target = (req and req.account_id) or "treasury:quid_bank"
  local limit  = tonumber(req and req.limit) or 250
  if limit < 1 then limit = 1 end
  if limit > 1000 then limit = 1000 end

  local lines   = readLines(FILE.ledger)
  local results = {}

  for _, line in ipairs(lines) do
    local tx_id, ts, tx_type, from_id, to_id, amount, memo, status =
      line:match("(TX%-%d+)%s*|%s*(%d+)%s*|%s*(%S+)%s*|%s*([^|]+)%s*|%s*([^|]+)%s*|%s*(%d+)%s*|%s*([^|]+)%s*|%s*(.+)")

    if tx_id then
      from_id = from_id:match("^%s*(.-)%s*$")
      to_id   = to_id:match("^%s*(.-)%s*$")
      tx_type = tx_type:match("^%s*(.-)%s*$")

      if from_id == target or to_id == target or (target == "treasury:quid_bank" and (from_id == "SYSTEM" or to_id == "SYSTEM")) then
        local direction = "OTHER"
        if to_id == target then
          direction = "IN"
        elseif from_id == target then
          direction = "OUT"
        elseif from_id == "SYSTEM" and tx_type == "MINT" then
          direction = "MINT"
        elseif to_id == "SYSTEM" and tx_type == "BURN" then
          direction = "BURN"
        end

        results[#results+1] = {
          tx_id     = tx_id,
          time      = tonumber(ts),
          type      = tx_type,
          from      = from_id,
          to        = to_id,
          amount    = tonumber(amount) or 0,
          memo      = memo:match("^%s*(.-)%s*$"),
          status    = status:match("^%s*(.-)%s*$"),
          direction = direction
        }
      end
    end
  end

  local out   = {}
  local start = math.max(1, #results - limit + 1)
  for i = #results, start, -1 do
    out[#out+1] = results[i]
  end

  return true, {
    account_id = target,
    balance    = deriveBalance(target),
    history    = out,
    count      = #out,
    total_seen = #results
  }
end


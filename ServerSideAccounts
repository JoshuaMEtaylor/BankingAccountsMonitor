  if os.getComputerLabel() ~= DB_LABEL then os.setComputerLabel(DB_LABEL) end
  print("QUID BANK OF PLENTY v" .. VERSION)
  print("Booting...")
  initFiles()
  initCounters()
  initSystemAccounts()
  if not openModem() then print("FATAL: No modem. Halting."); return end
  versionInfo = loadVersionInfo()
  saveConfig()
  audit("SYSTEM", "SYSTEM", os.getComputerID(), "BOOT", "v" .. VERSION)
  print("Boot complete.")
  sleep(1)
  drawStatus()
  rednet.broadcast({ type="treasury_online", version=VERSION, id=os.getComputerID() }, PROTOCOL)
  rednet.broadcast({ type="treasury_online", version=VERSION, id=os.getComputerID() }, PROTOCOL_BROADCAST)
  serverLoop()
end


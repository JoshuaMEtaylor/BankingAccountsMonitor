-- SUSPEND_ACCOUNT / UNSUSPEND_ACCOUNT
handlers["suspend_account"] = function(sender_id, req)
  local citizen_id = req.citizen_id
  if not citizens[citizen_id] then return false, "Citizen not found" end
  citizens[citizen_id].status = "suspended"
  saveCitizens()
  if accounts[citizen_id] then accounts[citizen_id].status = "suspended"; saveAccounts() end
  audit("ACTION", "STATE", sender_id, "SUSPEND", citizen_id)
  return true, { message = "Account suspended: " .. citizen_id }
end

handlers["unsuspend_account"] = function(sender_id, req)
  local citizen_id = req.citizen_id
  if not citizens[citizen_id] then return false, "Citizen not found" end
  citizens[citizen_id].status = "active"
  saveCitizens()
  if accounts[citizen_id] then accounts[citizen_id].status = "active"; saveAccounts() end
  audit("ACTION", "STATE", sender_id, "UNSUSPEND", citizen_id)
  return true, { message = "Account reinstated: " .. citizen_id }
end

-- =============================================================================
-- BALANCE SNAPSHOT MIGRATION / RECOVERY
-- =============================================================================
local function migrateBalancesFromLedgerIfNeeded()
  if monetary_state.migrated and type(balances) == "table" and next(balances) ~= nil then
    -- Ensure all registered accounts have a balance entry.
    local changed = false
    for id, _ in pairs(accounts) do
      if balances[id] == nil then balances[id] = 0; changed = true end
    end
    if changed then saveBalances() end
    return
  end

  print("  Migrating ledger-derived balances to balance snapshot...")

  local new_balances = {}
  for id, _ in pairs(accounts) do new_balances[id] = 0 end

  local total_minted = 0
  local total_burned = 0

  for _, line in ipairs(readLines(FILE.ledger)) do
    local tx_id, ts, tx_type, from_id, to_id, amount, memo, status =
      line:match("(TX%-%d+)%s*|%s*(%d+)%s*|%s*(%S+)%s*|%s*([^|]+)%s*|%s*([^|]+)%s*|%s*(%d+)%s*|%s*([^|]+)%s*|%s*(.+)")
    if tx_id then
      tx_type = trim(tx_type)
      from_id = trim(from_id)
      to_id   = trim(to_id)
      status  = trim(status)
      amount  = tonumber(amount) or 0
      if status == "settled" then
        if to_id ~= "SYSTEM" then new_balances[to_id] = (new_balances[to_id] or 0) + amount end
        if from_id ~= "SYSTEM" then new_balances[from_id] = (new_balances[from_id] or 0) - amount end
        if tx_type == "MINT" then total_minted = total_minted + amount end
        if tx_type == "BURN" then total_burned = total_burned + amount end
      end
    end
  end

  balances = new_balances
  monetary_state = {
    total_minted = total_minted,
    total_burned = total_burned,
    migrated = true,
    migrated_at = timestamp(),
    source = "ledger_snapshot",
  }

  saveBalances()
  saveMonetary()
  writeFile(FILE.checkpoint, {
    migrated_at = timestamp(),
    source = "ledger_snapshot",
    note = "Initial migration from full ledger to authoritative balance snapshot."
  })
end

local function recoverPendingTx()
  if not fs.exists(FILE.pending_tx) then return end
  local p = readFile(FILE.pending_tx)
  if type(p) ~= "table" or not p.tx_id then
    fs.delete(FILE.pending_tx)
    return
  end

  print("  Recovering pending transaction " .. tostring(p.tx_id) .. "...")

  local from_id = p.from
  local to_id   = p.to

  local after_matches = true
  if from_id ~= "SYSTEM" and tonumber(balances[from_id]) ~= tonumber(p.from_after) then after_matches = false end
  if to_id   ~= "SYSTEM" and tonumber(balances[to_id])   ~= tonumber(p.to_after)   then after_matches = false end

  local before_matches = true
  if from_id ~= "SYSTEM" and tonumber(balances[from_id]) ~= tonumber(p.from_before) then before_matches = false end
  if to_id   ~= "SYSTEM" and tonumber(balances[to_id])   ~= tonumber(p.to_before)   then before_matches = false end

  if after_matches then
    -- Transaction was applied. Make sure monetary state and recent ledger catch up.
    monetary_state.total_minted = tonumber(p.minted_after) or monetary_state.total_minted or 0
    monetary_state.total_burned = tonumber(p.burned_after) or monetary_state.total_burned or 0
    monetary_state.migrated = true
    saveMonetary()

    if not ledgerHasTx(p.tx_id) then
      writeTx(p.tx_id, p.tx_type or "TRANSFER", p.from, p.to, tonumber(p.amount) or 0, p.memo or "", "settled")
    end
    fs.delete(FILE.pending_tx)
    print("  Pending transaction completed.")
    return
  end

  if before_matches then
    -- Transaction never applied. Safe to discard pending request.
    fs.delete(FILE.pending_tx)
    print("  Pending transaction rolled back.")
    return
  end

  print("  WARNING: pending transaction state ambiguous.")
  print("  Leaving " .. FILE.pending_tx .. " in place for manual inspection.")
end


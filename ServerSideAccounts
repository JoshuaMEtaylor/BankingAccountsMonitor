-- GET_PRICE_INDICES
handlers["get_price_indices"] = function(sender_id, req)
  ensureInflationState()
  ensurePriceOracle()

  -- IMPORTANT: read-only endpoints must stay lightweight.
  -- Do not scan/import the full ledger here; frequent monitor/terminal polling
  -- would stall the bank server and make unrelated scripts time out.
  -- Historical mint shock import remains available through import_mint_shocks.
  local imported, skipped = 0, 0

  local okSnap, snapOrErr = pcall(sectorIndexSnapshot)
  if not okSnap then
    audit("ERROR", "SYSTEM", sender_id, "GET_PRICE_INDICES", "snapshot error: " .. tostring(snapOrErr))
    return false, "Price oracle snapshot error: " .. tostring(snapOrErr)
  end

  return true, {
    model = price_oracle.model,
    sectors = snapOrErr,
    inflation = inflation_state,
    shock_pressure = tonumber(price_oracle.shock_pressure) or 0,
    sticky_floor_from_ath = tonumber(price_oracle.sticky_floor_from_ath) or 0.75,
    max_daily_deflation = tonumber(price_oracle.max_daily_deflation) or 0.03,
    last_money_print = price_oracle.last_money_print,
    imported_mint_shocks = imported or 0,
    skipped_mint_shocks = skipped or 0,
    time = timestamp(),
    note = "Zero baseline inflation. Sector CPI rises easily under pressure, falls slowly at max_daily_deflation, and cannot fall below sticky_floor_from_ath of ATH."
  }
end

handlers["import_mint_shocks"] = function(sender_id, req)
  local processed, skipped = processUnprocessedMintLedgerShocks()
  audit("ACTION", "STATE", sender_id, "IMPORT_MINT_SHOCKS", "processed=" .. tostring(processed) .. " skipped=" .. tostring(skipped))
  return true, { processed = processed, skipped = skipped, sectors = sectorIndexSnapshot(), last_money_print = price_oracle.last_money_print }
end

handlers["rebase_price_oracle_ath"] = function(sender_id, req)
  ensurePriceOracle()
  local snap = sectorIndexSnapshot()
  for sector, rec in pairs(price_oracle.sectors or {}) do
    local cur = snap[sector] and tonumber(snap[sector].index) or tonumber(rec.current_index) or 1
    rec.ath_index = math.max(1, cur)
    rec.raw_index = tonumber(rec.raw_index) or cur
    rec.current_index = cur
    rec.sticky_floor_index = math.max(1, cur * (tonumber(price_oracle.sticky_floor_from_ath) or 0.75))
    rec.sticky_active = false
  end
  price_oracle.rebased_at = timestamp()
  price_oracle.rebased_by = "terminal:" .. tostring(sender_id)
  savePriceOracle()
  audit("ACTION", "STATE", sender_id, "REBASE_PRICE_ORACLE_ATH", "ok")
  return true, { sectors = sectorIndexSnapshot(), note = "ATHs rebased to current live indices." }
end


    time             = timestamp(),
    uptime           = os.clock(),
    economy_status   = (type(config) == "table" and config.economy_status) or "active",
    account_count    = count(accounts),
    citizen_count    = count(citizens),
    company_count    = count(companies),
    tx_count         = tx_counter,
    audit_count      = audit_counter,

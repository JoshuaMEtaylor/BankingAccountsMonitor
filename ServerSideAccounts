local function nextShId()
  sh_counter = sh_counter + 1
  return "SH-" .. pad(sh_counter, 6)
end

local function writeShareTx(sh_id, company_id, from_id, to_id, shares, tx_type, memo)
  local line = string.format("%s | %d | %-20s | %-25s | %-25s | %d | %-20s | %s",
    sh_id, timestamp(), tostring(company_id), tostring(from_id),
    tostring(to_id), shares, tostring(tx_type), tostring(memo))
  appendLine(FILE.share_ledger, line)
end

local function deriveShareHoldings(company_id)
  if not fs.exists(FILE.share_ledger) then return {} end
  local lines    = readLines(FILE.share_ledger)
  local holdings = {}
  for _, line in ipairs(lines) do
    local sh_id, ts, cid, from_id, to_id, shares =
      line:match("(SH%-%d+)%s*|%s*(%d+)%s*|%s*([^|]+)%s*|%s*([^|]+)%s*|%s*([^|]+)%s*|%s*(%d+)")
    if sh_id then
      cid     = cid:match("^%s*(.-)%s*$")
      if cid == company_id then
        from_id = from_id:match("^%s*(.-)%s*$")
        to_id   = to_id:match("^%s*(.-)%s*$")
        shares  = tonumber(shares) or 0
        if to_id   ~= "SYSTEM" then holdings[to_id]   = (holdings[to_id]   or 0) + shares end
        if from_id ~= "SYSTEM" then holdings[from_id] = (holdings[from_id] or 0) - shares end
      end
    end
  end
  return holdings
end


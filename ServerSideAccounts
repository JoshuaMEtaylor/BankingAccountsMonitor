-- =============================================================================
-- AUTH  — username + password, works from any terminal
-- =============================================================================
local function authenticateUser(username, password)
  if not username or not password then
    return false, "Missing username or password"
  end
  local key = string.lower(username):gsub("%s+", "_")
  local citizen_id = "citizen:" .. key
  local citizen = citizens[citizen_id]
  if not citizen then
    return false, "Account not found"
  end
  if citizen.status ~= "active" then
    return false, "Account suspended"
  end
  if citizen.password_hash ~= simpleHash(password) then
    return false, "Incorrect password"
  end
  return true, citizen_id, citizen
end


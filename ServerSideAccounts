-- =============================================================================
-- SIMPLE HASH
-- Not cryptographic, but stops plaintext passwords sitting in files.
-- =============================================================================
local function simpleHash(str)
  local h = 5381
  for i = 1, #str do
    h = ((h * 33) + string.byte(str, i)) % 2147483647
  end
  return tostring(h)
end

-- =============================================================================
-- UTILITIES
-- =============================================================================
local function pad(n, width)
  local s = tostring(n)
  while #s < width do s = "0" .. s end
  return s
end

local function timestamp()
  return os.epoch("utc")
end

local function ensureDir(path)
  local parts = {}
  for part in string.gmatch(path, "[^/]+") do parts[#parts+1] = part end
  table.remove(parts)
  local current = ""
  for _, part in ipairs(parts) do
    current = current == "" and part or (current .. "/" .. part)
    if not fs.exists(current) then fs.makeDir(current) end
  end
end

local function writeFile(path, data)
  ensureDir(path)
  local f = fs.open(path, "w")
  if f then f.write(textutils.serialize(data)); f.close(); return true end
  return false
end

local function readFile(path)
  if not fs.exists(path) then return nil end
  local f = fs.open(path, "r")
  if not f then return nil end
  local text = f.readAll(); f.close()
  if not text or text == "" then return nil end
  local ok, data = pcall(textutils.unserialize, text)
  if ok then return data end
  return nil
end

local function appendLine(path, line)
  ensureDir(path)
  local f = fs.open(path, "a")
  if f then f.writeLine(line); f.close(); return true end
  return false
end

local function readLines(path)
  if not fs.exists(path) then return {} end
  local f = fs.open(path, "r")
  if not f then return {} end
  local lines = {}
  local line = f.readLine()
  while line do
    if line ~= "" then lines[#lines+1] = line end
    line = f.readLine()
  end
  f.close()
  return lines
end

-- =============================================================================
-- AUDIT
-- =============================================================================
local function audit(action_type, actor, terminal, action, result)
  audit_counter = audit_counter + 1
  local id   = "AUDIT-" .. pad(audit_counter, 6)
  local line = string.format("%s | %d | %-8s | %-20s | %-15s | %-20s | %s",
    id, timestamp(), action_type, tostring(actor),
    tostring(terminal), tostring(action), tostring(result))
  appendLine(FILE.audit, line)
end

-- =============================================================================
-- LEDGER
-- =============================================================================
local function nextTxId()
  tx_counter = tx_counter + 1
  return "TX-" .. pad(tx_counter, 6)
end

local function writeTx(tx_id, tx_type, from_id, to_id, amount, memo, status)
  local line = string.format("%s | %d | %-12s | %-25s | %-25s | %d | %s | %s",
    tx_id, timestamp(), tx_type, tostring(from_id), tostring(to_id),
    amount, tostring(memo), tostring(status))
  appendLine(FILE.ledger, line)
end

local function deriveBalance(account_id)
  if not fs.exists(FILE.ledger) then return 0 end
  local lines   = readLines(FILE.ledger)
  local balance = 0
  for _, line in ipairs(lines) do
    local tx_id, ts, tx_type, from_id, to_id, amount, memo, status =
      line:match("(TX%-%d+)%s*|%s*(%d+)%s*|%s*(%S+)%s*|%s*([^|]+)%s*|%s*([^|]+)%s*|%s*(%d+)%s*|%s*([^|]+)%s*|%s*(.+)")
    if tx_id then
      status  = status:match("^%s*(.-)%s*$")
      from_id = from_id:match("^%s*(.-)%s*$")
      to_id   = to_id:match("^%s*(.-)%s*$")
      amount  = tonumber(amount) or 0
      if status == "settled" then
        if to_id   == account_id then balance = balance + amount end
        if from_id == account_id then balance = balance - amount end
      end
    end
  end
  return balance
end

local function deriveMonetarySupply()
  local lines          = readLines(FILE.ledger)
  local total_minted   = 0
  local total_burned   = 0
  for _, line in ipairs(lines) do
    local tx_id, ts, tx_type, from_id, to_id, amount, memo, status =
      line:match("(TX%-%d+)%s*|%s*(%d+)%s*|%s*(%S+)%s*|%s*([^|]+)%s*|%s*([^|]+)%s*|%s*(%d+)%s*|%s*([^|]+)%s*|%s*(.+)")
    if tx_id then
      tx_type = tx_type:match("^%s*(.-)%s*$")
      status  = status:match("^%s*(.-)%s*$")
      amount  = tonumber(amount) or 0
      if status == "settled" then
        if tx_type == "MINT" then total_minted = total_minted + amount end
        if tx_type == "BURN" then total_burned = total_burned + amount end
      end
    end
  end
  local citizen_holdings = 0
  local company_holdings = 0
  local escrow_held      = 0
  for id, acc in pairs(accounts) do
    if acc.status == "active" then
      local bal = deriveBalance(id)
      if acc.type == "citizen"  then citizen_holdings = citizen_holdings + bal
      elseif acc.type == "company" then company_holdings = company_holdings + bal
      elseif acc.type == "escrow"  then escrow_held      = escrow_held      + bal
      end
    end
  end
  return {
    total_minted     = total_minted,
    total_burned     = total_burned,
    in_circulation   = total_minted - total_burned,
    treasury_balance = deriveBalance("treasury:quid_bank"),
    citizen_holdings = citizen_holdings,
    company_holdings = company_holdings,
    escrow_held      = escrow_held,
  }
end

-- =============================================================================
-- SHARE LEDGER
-- =============================================================================
local function nextShId()
  sh_counter = sh_counter + 1
  return "SH-" .. pad(sh_counter, 6)
end

local function writeShareTx(sh_id, company_id, from_id, to_id, shares, tx_type, memo)
  local line = string.format("%s | %d | %-20s | %-25s | %-25s | %d | %-20s | %s",
    sh_id, timestamp(), tostring(company_id), tostring(from_id),
    tostring(to_id), shares, tostring(tx_type), tostring(memo))
  appendLine(FILE.share_ledger, line)
end

local function deriveShareHoldings(company_id)
  if not fs.exists(FILE.share_ledger) then return {} end
  local lines    = readLines(FILE.share_ledger)
  local holdings = {}
  for _, line in ipairs(lines) do
    local sh_id, ts, cid, from_id, to_id, shares =
      line:match("(SH%-%d+)%s*|%s*(%d+)%s*|%s*([^|]+)%s*|%s*([^|]+)%s*|%s*([^|]+)%s*|%s*(%d+)")
    if sh_id then
      cid     = cid:match("^%s*(.-)%s*$")
      if cid == company_id then
        from_id = from_id:match("^%s*(.-)%s*$")
        to_id   = to_id:match("^%s*(.-)%s*$")
        shares  = tonumber(shares) or 0
        if to_id   ~= "SYSTEM" then holdings[to_id]   = (holdings[to_id]   or 0) + shares end
        if from_id ~= "SYSTEM" then holdings[from_id] = (holdings[from_id] or 0) - shares end
      end
    end
  end
  return holdings
end


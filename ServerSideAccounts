-- =============================================================================
-- SIMPLE HASH
-- Not cryptographic, but stops plaintext passwords sitting in files.
-- =============================================================================
local function simpleHash(str)
  local h = 5381
  for i = 1, #str do
    h = ((h * 33) + string.byte(str, i)) % 2147483647
  end
  return tostring(h)
end

-- =============================================================================
-- UTILITIES
-- =============================================================================
local function pad(n, width)
  local s = tostring(n)
  while #s < width do s = "0" .. s end
  return s
end

local function timestamp()
  return os.epoch("utc")
end

local function ensureDir(path)
  local parts = {}
  for part in string.gmatch(path, "[^/]+") do parts[#parts+1] = part end
  table.remove(parts)
  local current = ""
  for _, part in ipairs(parts) do
    current = current == "" and part or (current .. "/" .. part)
    if not fs.exists(current) then fs.makeDir(current) end
  end
end

local function writeFile(path, data)
  ensureDir(path)
  local f = fs.open(path, "w")
  if f then f.write(textutils.serialize(data)); f.close(); return true end
  return false
end

local function readFile(path)
  if not fs.exists(path) then return nil end
  local f = fs.open(path, "r")
  if not f then return nil end
  local text = f.readAll(); f.close()
  if not text or text == "" then return nil end
  local ok, data = pcall(textutils.unserialize, text)
  if ok then return data end
  return nil
end

local function appendLine(path, line)
  ensureDir(path)
  local f = fs.open(path, "a")
  if not f then return false, "open failed" end
  local ok, err = pcall(function() f.writeLine(line) end)
  f.close()
  if not ok then return false, tostring(err) end
  return true
end

local function writeLines(path, lines)
  ensureDir(path)
  local f = fs.open(path, "w")
  if not f then return false, "open failed" end
  local ok, err = pcall(function()
    for _, line in ipairs(lines or {}) do
      f.writeLine(line)
    end
  end)
  f.close()
  if not ok then return false, tostring(err) end
  return true
end

local function trim(s)
  return tostring(s or ""):match("^%s*(.-)%s*$")
end

local function readLines(path)
  if not fs.exists(path) then return {} end
  local f = fs.open(path, "r")
  if not f then return {} end
  local lines = {}
  local line = f.readLine()
  while line do
    if line ~= "" then lines[#lines+1] = line end
    line = f.readLine()
  end
  f.close()
  return lines
end

-- =============================================================================
-- AUDIT
-- =============================================================================
local function capAuditLog()
  if not fs.exists(FILE.audit) then return end
  local size = fs.getSize(FILE.audit) or 0
  if size <= AUDIT_MAX_SIZE then return end

  local lines = readLines(FILE.audit)
  local keep = {}
  local start = math.max(1, #lines - 200)
  for i = start, #lines do keep[#keep+1] = lines[i] end

  -- Audit is debug evidence only. If trimming fails, delete it rather than
  -- allowing audit growth to kill the bank.
  if not writeLines(FILE.audit, keep) then
    fs.delete(FILE.audit)
  end
end

local function audit(action_type, actor, terminal, action, result)
  audit_counter = audit_counter + 1
  local id   = "AUDIT-" .. pad(audit_counter, 6)
  local line = string.format("%s | %d | %-8s | %-20s | %-15s | %-20s | %s",
    id, timestamp(), action_type, tostring(actor),
    tostring(terminal), tostring(action), tostring(result))
  appendLine(FILE.audit, line)
  if audit_counter % 25 == 0 then capAuditLog() end
end


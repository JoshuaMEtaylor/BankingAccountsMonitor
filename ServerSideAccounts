local function nextTxId()
  tx_counter = tx_counter + 1
  return "TX-" .. pad(tx_counter, 6)
end

local function archiveLines(lines)
  if not fs.exists("disk") then return false, "no disk" end
  if not fs.isDir("disk") then return false, "disk unavailable" end
  if not fs.exists(ARCHIVE_DIR) then fs.makeDir(ARCHIVE_DIR) end

  local archive_name = ARCHIVE_DIR .. "/ledger_archive_" .. tostring(timestamp()) .. ".log"
  local ok, err = writeLines(archive_name, lines)
  if ok then return true, archive_name end
  return false, err
end

local function compactLedgerIfNeeded(force)
  if not fs.exists(FILE.ledger) then return true end

  local size = fs.getSize(FILE.ledger) or 0
  if not force and size < LEDGER_COMPACT_SIZE then return true end

  local lines = readLines(FILE.ledger)
  if #lines <= LEDGER_KEEP_RECENT_TX then return true end

  local split_at = #lines - LEDGER_KEEP_RECENT_TX
  local old_lines = {}
  local keep_lines = {}

  for i = 1, split_at do old_lines[#old_lines+1] = lines[i] end
  for i = split_at + 1, #lines do keep_lines[#keep_lines+1] = lines[i] end

  -- Archive is best-effort. It preserves old detail when a permanent floppy is
  -- installed, but the balance snapshot remains authoritative even without it.
  archiveLines(old_lines)

  local ok = writeLines(FILE.ledger, keep_lines)
  if ok then
    local checkpoint = {
      last_compacted_time = timestamp(),
      kept_recent = #keep_lines,
      archived_or_discarded = #old_lines,
      balance_snapshot = true,
      note = "Balances are authoritative; compacted ledger is recent history only."
    }
    writeFile(FILE.checkpoint, checkpoint)
  end
  return ok
end

local function writeTx(tx_id, tx_type, from_id, to_id, amount, memo, status)
  local line = string.format("%s | %d | %-12s | %-25s | %-25s | %d | %s | %s",
    tx_id, timestamp(), tx_type, tostring(from_id), tostring(to_id),
    amount, tostring(memo), tostring(status))

  -- Try compaction before appending if the ledger is already large.
  compactLedgerIfNeeded(false)

  local ok, err = appendLine(FILE.ledger, line)
  if not ok then
    compactLedgerIfNeeded(true)
    ok, err = appendLine(FILE.ledger, line)
  end
  return ok, err
end

local function deriveBalance(account_id)
  return tonumber(balances[account_id]) or 0
end

local function deriveMonetarySupply()
  local total_minted   = tonumber(monetary_state.total_minted) or 0
  local total_burned   = tonumber(monetary_state.total_burned) or 0

  local citizen_holdings = 0
  local company_holdings = 0
  local escrow_held      = 0

  for id, acc in pairs(accounts) do
    if acc.status == "active" then
      local bal = deriveBalance(id)
      if acc.type == "citizen"  then citizen_holdings = citizen_holdings + bal
      elseif acc.type == "company" then company_holdings = company_holdings + bal
      elseif acc.type == "escrow"  then escrow_held      = escrow_held      + bal
      end
    end
  end

  return {
    total_minted     = total_minted,
    total_burned     = total_burned,
    in_circulation   = total_minted - total_burned,
    treasury_balance = deriveBalance("treasury:quid_bank"),
    citizen_holdings = citizen_holdings,
    company_holdings = company_holdings,
    escrow_held      = escrow_held,
  }
end


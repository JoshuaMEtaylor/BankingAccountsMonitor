local function escapePattern(s)
  return (tostring(s or ""):gsub("([^%w])", "%%%1"))
end

local function rewriteShareLedgerCompanyId(old_company_id, new_company_id)
  if old_company_id == new_company_id then return true end
  if not fs.exists(FILE.share_ledger) then return true end
  local old_pat = escapePattern(old_company_id)
  local lines = readLines(FILE.share_ledger)
  local changed = false
  for i, line in ipairs(lines) do
    local new_line = line:gsub(old_pat, new_company_id)
    if new_line ~= line then
      lines[i] = new_line
      changed = true
    end
  end
  if changed then return writeLines(FILE.share_ledger, lines) end
  return true
end

local function rewriteBankContractCompanyId(old_company_id, new_company_id)
  if old_company_id == new_company_id or type(contracts) ~= "table" then return end
  local changed = false
  for _, c in pairs(contracts) do
    if type(c) == "table" then
      for _, field in ipairs({"poster", "source_account", "source_company", "claimed_by"}) do
        if c[field] == old_company_id then c[field] = new_company_id; changed = true end
      end
    end
  end
  if changed then writeFile(FILE.contracts, contracts) end
end

local function ledgerHasTx(tx_id)
  for _, line in ipairs(readLines(FILE.ledger)) do
    if line:match("^" .. tostring(tx_id) .. "%s*|") then return true end
  end
  return false
end

local function clearPendingTx()
  if fs.exists(FILE.pending_tx) then fs.delete(FILE.pending_tx) end
end

local function transfer(from_id, to_id, amount, tx_type, memo, actor)
  amount = tonumber(amount)
  tx_type = tx_type or "TRANSFER"

  if not amount or amount <= 0 then return false, "Invalid amount" end
  if not accountExists(from_id) and from_id ~= "SYSTEM" then
    return false, "Source account does not exist"
  end
  if not accountExists(to_id) and to_id ~= "SYSTEM" then
    return false, "Destination account does not exist"
  end

  local from_before = from_id ~= "SYSTEM" and deriveBalance(from_id) or nil
  local to_before   = to_id   ~= "SYSTEM" and deriveBalance(to_id)   or nil

  if from_id ~= "SYSTEM" and tx_type ~= "MINT" then
    if from_before < amount then
      return false, "Insufficient funds. Balance: " .. from_before .. " Quid, Required: " .. amount .. " Quid"
    end
  end

  local minted_before = tonumber(monetary_state.total_minted) or 0
  local burned_before = tonumber(monetary_state.total_burned) or 0

  local tx_id = nextTxId()

  local pending = {
    tx_id = tx_id,
    tx_type = tx_type,
    from = from_id,
    to = to_id,
    amount = amount,
    memo = memo or "",
    actor = actor or "SYSTEM",
    from_before = from_before,
    to_before = to_before,
    minted_before = minted_before,
    burned_before = burned_before,
    created = timestamp(),
  }

  if not writeFile(FILE.pending_tx, pending) then
    return false, "Could not create pending transaction file"
  end

  -- Apply debit/credit to authoritative balances.
  if from_id ~= "SYSTEM" then balances[from_id] = from_before - amount end
  if to_id   ~= "SYSTEM" then balances[to_id]   = to_before + amount end

  if tx_type == "MINT" then
    monetary_state.total_minted = minted_before + amount
  elseif tx_type == "BURN" then
    monetary_state.total_burned = burned_before + amount
  end
  monetary_state.migrated = true

  pending.from_after = from_id ~= "SYSTEM" and balances[from_id] or nil
  pending.to_after = to_id ~= "SYSTEM" and balances[to_id] or nil
  pending.minted_after = monetary_state.total_minted
  pending.burned_after = monetary_state.total_burned
  pending.applied = true
  writeFile(FILE.pending_tx, pending)

  if not saveBalances() then
    -- Roll back in-memory if balances could not be written.
    if from_id ~= "SYSTEM" then balances[from_id] = from_before end
    if to_id   ~= "SYSTEM" then balances[to_id]   = to_before end
    monetary_state.total_minted = minted_before
    monetary_state.total_burned = burned_before
    clearPendingTx()
    return false, "Could not save balances"
  end

  if not saveMonetary() then
    -- Balances are already saved. Keep pending tx for startup repair and report
    -- success because account balances are authoritative and already changed.
    audit("ERROR", actor or "SYSTEM", "db", tx_type, "monetary save failed for " .. tx_id)
  end

  local ledger_ok, ledger_err = writeTx(tx_id, tx_type, from_id, to_id, amount, memo or "", "settled")
  if ledger_ok then
    clearPendingTx()
  else
    -- Keep the pending file. On next boot the bank will try to write the missing
    -- ledger line from this settled transaction, without applying balances again.
    audit("ERROR", actor or "SYSTEM", "db", tx_type, "ledger write deferred for " .. tx_id .. ": " .. tostring(ledger_err))
  end

  audit("ACTION", actor or "SYSTEM", "db", tx_type,
    tx_id .. " " .. amount .. "q " .. tostring(from_id) .. "->" .. tostring(to_id))

  return true, {
    tx_id  = tx_id,
    from   = from_id,
    to     = to_id,
    amount = amount,
    type   = tx_type,
    memo   = memo,
    status = "settled",
    ledger = ledger_ok and "written" or "deferred"
  }
end


-- =============================================================================
-- INFLATION ENGINE
-- Inflation is now a daily price-change rate, not a direct permanent markup.
--
-- price_index:
--   The accumulated price multiplier used by payroll/contracts.
--
-- inflation_rate:
--   The daily Minecraft-day price movement rate.
--   0.04 means prices rise 4% this Minecraft day.
--  -0.01 means prices fall 1% this Minecraft day.
-- =============================================================================
local DEFAULT_INFLATION_POLICY = {
  decay = 0.65,                 -- old inflation pressure retained each Minecraft day
  print_sensitivity = 0.50,     -- supply growth -> daily inflation pressure
  no_print_deflation = 0.005,   -- -0.5% daily drag when no new money is issued
  max_daily_inflation = 0.10,   -- +10% cap per Minecraft day
  max_daily_deflation = -0.03,  -- -3% cap per Minecraft day
  min_price_index = 0.25,
  max_price_index = 10.00,
}

local function clamp(n, lo, hi)
  n = tonumber(n) or 0
  if n < lo then return lo end
  if n > hi then return hi end
  return n
end

local function copyPolicy(src)
  local out = {}
  for k, v in pairs(DEFAULT_INFLATION_POLICY) do
    out[k] = tonumber(src and src[k]) or v
  end
  return out
end

local function currentMinecraftDay()
  if os.day then
    return math.floor(tonumber(os.day()) or 0)
  end
  return math.floor(timestamp() / 1200000)
end

local function ensureInflationState()
  local supply = deriveMonetarySupply()
  local issued = tonumber(supply and supply.in_circulation) or 0
  inflation_state = type(inflation_state) == "table" and inflation_state or {}

  inflation_state.policy = copyPolicy(inflation_state.policy)
  inflation_state.price_index = tonumber(inflation_state.price_index) or 1.00
  inflation_state.inflation_rate = tonumber(inflation_state.inflation_rate) or 0.00

  if not inflation_state.last_day then
    inflation_state.last_day = currentMinecraftDay()
  end

  if not inflation_state.last_issued_supply then
    inflation_state.last_issued_supply = issued
  end

  inflation_state.updated = inflation_state.updated or timestamp()
  inflation_state.model = "daily_rate_price_index"
  inflation_state.note = "Inflation is a daily price-change rate. Price index compounds upward or downward over Minecraft days."
  return inflation_state
end

local function tickInflation(target_day)
  ensureInflationState()

  local supply = deriveMonetarySupply()
  local currentIssued = tonumber(supply and supply.in_circulation) or 0
  local day = math.floor(tonumber(target_day) or currentMinecraftDay())
  local lastDay = math.floor(tonumber(inflation_state.last_day) or day)

  if day <= lastDay then
    inflation_state.current_issued_supply = currentIssued
    inflation_state.updated = timestamp()
    saveInflation()
    return false, inflation_state, 0
  end

  local elapsed = math.max(1, math.min(30, day - lastDay))
  local policy = copyPolicy(inflation_state.policy)
  local rate = tonumber(inflation_state.inflation_rate) or 0
  local index = tonumber(inflation_state.price_index) or 1
  local lastIssued = tonumber(inflation_state.last_issued_supply) or currentIssued

  for i = 1, elapsed do
    local growth = 0
    if lastIssued and lastIssued > 0 then
      growth = (currentIssued - lastIssued) / lastIssued
    elseif currentIssued > 0 then
      growth = 1
    end

    local noPrintDrag = 0
    if growth <= 0 then
      noPrintDrag = policy.no_print_deflation
    end

    rate = (rate * policy.decay) + (growth * policy.print_sensitivity) - noPrintDrag
    rate = clamp(rate, policy.max_daily_deflation, policy.max_daily_inflation)

    index = index * (1 + rate)
    index = clamp(index, policy.min_price_index, policy.max_price_index)

    -- If several days elapsed, only the first missed day gets the supply jump.
    lastIssued = currentIssued
  end

  inflation_state.price_index = index
  inflation_state.inflation_rate = rate
  inflation_state.last_issued_supply = currentIssued
  inflation_state.current_issued_supply = currentIssued
  inflation_state.last_day = day
  inflation_state.updated = timestamp()
  inflation_state.policy = policy
  inflation_state.model = "daily_rate_price_index"
  inflation_state.inflation_percent = rate * 100
  inflation_state.price_index_percent = (index - 1) * 100
  saveInflation()

  return true, inflation_state, elapsed
end



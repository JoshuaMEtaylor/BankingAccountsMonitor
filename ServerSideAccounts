-- COMPANY_WITHDRAW
-- Owner-authorised payout from a company account back to the logged-in owner citizen account.
-- This is deliberately narrow: company -> owner only, not arbitrary company spending.
handlers["company_withdraw"] = function(sender_id, req)
  local ok, citizen_id, citizen = authenticateUser(req.username, req.password)
  if not ok then return false, citizen_id end


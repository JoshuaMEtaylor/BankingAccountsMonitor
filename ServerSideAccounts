local function ensureAccountRecord(account_id, acc_type, display_name, owner_id)
  if not account_id or account_id == "" then return false, "missing account_id" end
  local changedAccounts = false
  local changedBalances = false

  if type(accounts[account_id]) ~= "table" then
    accounts[account_id] = {
      type = acc_type or "general",
      display_name = display_name or account_id,
      owner_id = owner_id or "SYSTEM",
      created = timestamp(),
      status = "active",
      recovered = true,
      recovered_at = timestamp(),
    }
    changedAccounts = true
  else
    local acc = accounts[account_id]
    if not acc.type and acc_type then acc.type = acc_type; changedAccounts = true end
    if (not acc.display_name or acc.display_name == "") and display_name then acc.display_name = display_name; changedAccounts = true end
    if (not acc.owner_id or acc.owner_id == "") and owner_id then acc.owner_id = owner_id; changedAccounts = true end
    if not acc.status then acc.status = "active"; changedAccounts = true end
  end

  if balances[account_id] == nil then
    balances[account_id] = 0
    changedBalances = true
  end

  if changedAccounts then saveAccounts() end
  if changedBalances then saveBalances() end
  return true, { account_id = account_id, account_created = changedAccounts, balance_created = changedBalances }
end

local function repairRegistryAccounts()
  local repaired = { treasury = 0, citizens = 0, companies = 0, balances = 0 }

  local function bump(res)
    if type(res) == "table" then
      if res.account_created then repaired.balances = repaired.balances + 1 end
      if res.balance_created then repaired.balances = repaired.balances + 1 end
    end
  end

  local ok, res = ensureAccountRecord("treasury:quid_bank", "treasury", "Quid Treasury", "STATE")
  if ok then repaired.treasury = repaired.treasury + 1; bump(res) end
  ensureAccountRecord("market:escrow", "escrow", "Market Escrow", "SYSTEM")
  ensureAccountRecord("contract:escrow", "escrow", "Contract Escrow", "SYSTEM")

  for citizen_id, citizen in pairs(citizens or {}) do
    if type(citizen) == "table" then
      local name = citizen.display_name or citizen.name or citizen_id
      local ok2, res2 = ensureAccountRecord(citizen_id, "citizen", name, citizen_id)
      if ok2 then repaired.citizens = repaired.citizens + 1; bump(res2) end
    end
  end

  for company_id, company in pairs(companies or {}) do
    if type(company) == "table" then
      local name = company.name or company.display_name or company_id
      local owner = company.owner_id or "treasury:quid_bank"
      local ok3, res3 = ensureAccountRecord(company_id, "company", name, owner)
      if ok3 then repaired.companies = repaired.companies + 1; bump(res3) end
    end
  end

  saveAccounts()
  saveBalances()
  return repaired
end

local function isCompanyOwner(company_id, citizen_id)
  local company = companies[company_id]
  local account = accounts[company_id]
  if not company or not citizen_id then return false end
  local company_owner_id = company.owner_id
  local account_owner_id = account and account.owner_id or nil
  return company_owner_id == citizen_id or account_owner_id == citizen_id
end

local function companyOwnerFields(company_id)

local function accountExists(account_id)
  return accounts[account_id] ~= nil
end

local function createAccount(account_id, acc_type, display_name, owner_id)
  if accountExists(account_id) then return false, "Account already exists" end
  accounts[account_id] = {
    type         = acc_type,
    display_name = display_name,
    owner_id     = owner_id or "SYSTEM",
    created      = timestamp(),
    status       = "active"
  }
  if balances[account_id] == nil then balances[account_id] = 0 end
  saveAccounts()
  saveBalances()
  return true, account_id
end

local function isCompanyOwner(company_id, citizen_id)
  local company = companies[company_id]
  local account = accounts[company_id]
  if not company or not citizen_id then return false end
  local company_owner_id = company.owner_id
  local account_owner_id = account and account.owner_id or nil
  return company_owner_id == citizen_id or account_owner_id == citizen_id
end

local function companyOwnerFields(company_id)
  local company = companies[company_id]
  local account = accounts[company_id]
  return company and company.owner_id or nil, account and account.owner_id or nil
end



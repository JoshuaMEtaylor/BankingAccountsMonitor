-- SYNC_EMPLOYEE_MAPPINGS
-- ColonyBusinessIntegrator is the live source of truth for citizen -> employer mapping.
-- This lets CompanyPayroll run on a separate terminal without a colony integrator
-- or local mapping files.
handlers["sync_employee_mappings"] = function(sender_id, req)
  local incoming = req and (req.employees or req.mappings) or {}
  if type(incoming) ~= "table" then return false, "Missing employees table" end

  local now_ts = timestamp()
  local seen = {}
  local updated = 0
  local active = 0

  for _, e in ipairs(incoming) do
    if type(e) == "table" and e.citizen_id and e.company_id then
      local citizen_id = tostring(e.citizen_id)
      local company_id = tostring(e.company_id)
      if accountExists(citizen_id) and accountExists(company_id) and companies[company_id] then
        local rec = employment_mappings[citizen_id] or {}
        rec.citizen_id = citizen_id
        rec.display_name = e.display_name or e.name or rec.display_name or citizen_id
        rec.job_text = e.job_text or e.title or e.job or rec.job_text or ""
        rec.industry = e.industry or rec.industry or "general"
        rec.company_id = company_id
        rec.company_name = e.company_name or rec.company_name or company_id
        rec.building_key = e.building_key or rec.building_key
        rec.work_type = e.work_type or rec.work_type
        rec.work_name = e.work_name or rec.work_name
        rec.work_location = e.work_location or rec.work_location
        rec.active = e.active ~= false
        rec.source = "ColonyBusinessIntegrator:" .. tostring(sender_id)
        rec.updated_at = now_ts
        employment_mappings[citizen_id] = rec
        seen[citizen_id] = true
        updated = updated + 1
        if rec.active then active = active + 1 end
      end
    end
  end

  local source_prefix = "ColonyBusinessIntegrator:" .. tostring(sender_id)
  for citizen_id, rec in pairs(employment_mappings) do
    if rec.source == source_prefix and not seen[citizen_id] then
      rec.active = false
      rec.missing_since = rec.missing_since or now_ts
    end
  end

  saveEmployment()
  audit("ACTION", "STATE", sender_id, "SYNC_EMPLOYEE_MAPPINGS", tostring(updated))
  return true, { updated = updated, active = active, total = updated }

local function transfer(from_id, to_id, amount, tx_type, memo, actor, allow_overdraft)
  amount = tonumber(amount)
  tx_type = tx_type or "TRANSFER"

  if not amount or amount <= 0 then return false, "Invalid amount" end
  if not accountExists(from_id) and from_id ~= "SYSTEM" then
    return false, "Source account does not exist"
  end
  if not accountExists(to_id) and to_id ~= "SYSTEM" then
    return false, "Destination account does not exist"
  end

  local from_before = from_id ~= "SYSTEM" and deriveBalance(from_id) or nil
  local to_before   = to_id   ~= "SYSTEM" and deriveBalance(to_id)   or nil

  if from_id ~= "SYSTEM" and tx_type ~= "MINT" and not allow_overdraft then
    if from_before < amount then
      return false, "Insufficient funds. Balance: " .. from_before .. " Quid, Required: " .. amount .. " Quid"
    end
  end

  local minted_before = tonumber(monetary_state.total_minted) or 0
  local burned_before = tonumber(monetary_state.total_burned) or 0

  local tx_id = nextTxId()

  local pending = {
    tx_id = tx_id,
    tx_type = tx_type,
    from = from_id,
    to = to_id,
    amount = amount,
    memo = memo or "",
    actor = actor or "SYSTEM",
    from_before = from_before,
    to_before = to_before,
    minted_before = minted_before,
    burned_before = burned_before,
    created = timestamp(),
  }

  if not writeFile(FILE.pending_tx, pending) then
    return false, "Could not create pending transaction file"
  end

  -- Apply debit/credit to authoritative balances.
  if from_id ~= "SYSTEM" then balances[from_id] = from_before - amount end
  if to_id   ~= "SYSTEM" then balances[to_id]   = to_before + amount end

  if tx_type == "MINT" then
    monetary_state.total_minted = minted_before + amount
    if recordMoneyPrintShock then
      local issued_before = minted_before - burned_before
      local issued_after = monetary_state.total_minted - burned_before
      pcall(recordMoneyPrintShock, amount, issued_before, issued_after, tx_id)
    end
  elseif tx_type == "BURN" then
    monetary_state.total_burned = burned_before + amount
  end
  monetary_state.migrated = true

  pending.from_after = from_id ~= "SYSTEM" and balances[from_id] or nil
  pending.to_after = to_id ~= "SYSTEM" and balances[to_id] or nil
  pending.minted_after = monetary_state.total_minted
  pending.burned_after = monetary_state.total_burned
  pending.applied = true
  writeFile(FILE.pending_tx, pending)

  if not saveBalances() then
    -- Roll back in-memory if balances could not be written.
    if from_id ~= "SYSTEM" then balances[from_id] = from_before end
    if to_id   ~= "SYSTEM" then balances[to_id]   = to_before end
    monetary_state.total_minted = minted_before
    monetary_state.total_burned = burned_before
    clearPendingTx()
    return false, "Could not save balances"
  end

  if not saveMonetary() then
    -- Balances are already saved. Keep pending tx for startup repair and report
    -- success because account balances are authoritative and already changed.
    audit("ERROR", actor or "SYSTEM", "db", tx_type, "monetary save failed for " .. tx_id)
  end

  local ledger_ok, ledger_err = writeTx(tx_id, tx_type, from_id, to_id, amount, memo or "", "settled")
  if ledger_ok then
    clearPendingTx()
  else
    -- Keep the pending file. On next boot the bank will try to write the missing
    -- ledger line from this settled transaction, without applying balances again.
    audit("ERROR", actor or "SYSTEM", "db", tx_type, "ledger write deferred for " .. tx_id .. ": " .. tostring(ledger_err))
  end

  audit("ACTION", actor or "SYSTEM", "db", tx_type,
    tx_id .. " " .. amount .. "q " .. tostring(from_id) .. "->" .. tostring(to_id))

  return true, {
    tx_id  = tx_id,
    from   = from_id,
    to     = to_id,
    amount = amount,
    type   = tx_type,
    memo   = memo,
    status = "settled",
    ledger = ledger_ok and "written" or "deferred"
  }
end


-- =============================================================================
-- INFLATION ENGINE
-- Inflation is now a daily price-change rate, not a direct permanent markup.
--
-- price_index:
--   The accumulated price multiplier used by payroll/contracts.
--
-- inflation_rate:
--   The daily Minecraft-day price movement rate.
--   0.04 means prices rise 4% this Minecraft day.
--  -0.01 means prices fall 1% this Minecraft day.
-- =============================================================================
local DEFAULT_INFLATION_POLICY = {
  decay = 0.65,                 -- old inflation pressure retained each Minecraft day
  print_sensitivity = 0.50,     -- supply growth -> daily inflation pressure
  no_print_deflation = 0.005,   -- -0.5% daily drag when no new money is issued
  max_daily_inflation = 0.10,   -- +10% cap per Minecraft day
  max_daily_deflation = -0.03,  -- -3% cap per Minecraft day
  min_price_index = 0.25,
  max_price_index = 10.00,
}

local function clamp(n, lo, hi)
  n = tonumber(n) or 0
  if n < lo then return lo end
  if n > hi then return hi end
  return n
end

local function pow(base, exp)
  base = tonumber(base) or 0
  exp = tonumber(exp) or 0
  if math.pow then return math.pow(base, exp) end
  return base ^ exp
end

local function copyPolicy(src)
  local out = {}
  for k, v in pairs(DEFAULT_INFLATION_POLICY) do
    out[k] = tonumber(src and src[k]) or v
  end
  return out
end

local function currentMinecraftDay()
  if os.day then
    return math.floor(tonumber(os.day()) or 0)
  end
  return math.floor(timestamp() / 1200000)
end

local function ensureInflationState()
  local supply = deriveMonetarySupply()
  local issued = tonumber(supply and supply.in_circulation) or 0
  inflation_state = type(inflation_state) == "table" and inflation_state or {}

  inflation_state.policy = copyPolicy(inflation_state.policy)
  inflation_state.price_index = tonumber(inflation_state.price_index) or 1.00
  inflation_state.inflation_rate = tonumber(inflation_state.inflation_rate) or 0.00

  if not inflation_state.last_day then
    inflation_state.last_day = currentMinecraftDay()
  end

  if not inflation_state.last_issued_supply then
    inflation_state.last_issued_supply = issued
  end

  inflation_state.updated = inflation_state.updated or timestamp()
  inflation_state.model = "daily_rate_price_index"
  inflation_state.note = "Inflation is a daily price-change rate. Price index compounds upward or downward over Minecraft days."
  return inflation_state
end

local function tickInflation(target_day)
  ensureInflationState()

  local supply = deriveMonetarySupply()
  local currentIssued = tonumber(supply and supply.in_circulation) or 0
  local day = math.floor(tonumber(target_day) or currentMinecraftDay())
  local lastDay = math.floor(tonumber(inflation_state.last_day) or day)

  if day <= lastDay then
    inflation_state.current_issued_supply = currentIssued
    inflation_state.updated = timestamp()
    saveInflation()
    return false, inflation_state, 0
  end

  local elapsed = math.max(1, math.min(30, day - lastDay))
  local policy = copyPolicy(inflation_state.policy)
  local rate = tonumber(inflation_state.inflation_rate) or 0
  local index = tonumber(inflation_state.price_index) or 1
  local lastIssued = tonumber(inflation_state.last_issued_supply) or currentIssued

  for i = 1, elapsed do
    local growth = 0
    if lastIssued and lastIssued > 0 then
      growth = (currentIssued - lastIssued) / lastIssued
    elseif currentIssued > 0 then
      growth = 1
    end

    local noPrintDrag = 0
    if growth <= 0 then
      noPrintDrag = policy.no_print_deflation
    end

    rate = (rate * policy.decay) + (growth * policy.print_sensitivity) - noPrintDrag
    rate = clamp(rate, policy.max_daily_deflation, policy.max_daily_inflation)

    index = index * (1 + rate)
    index = clamp(index, policy.min_price_index, policy.max_price_index)

    -- If several days elapsed, only the first missed day gets the supply jump.
    lastIssued = currentIssued
  end

  inflation_state.price_index = index
  inflation_state.inflation_rate = rate
  inflation_state.last_issued_supply = currentIssued
  inflation_state.current_issued_supply = currentIssued
  inflation_state.last_day = day
  inflation_state.updated = timestamp()
  inflation_state.policy = policy
  inflation_state.model = "daily_rate_price_index"
  inflation_state.inflation_percent = rate * 100
  inflation_state.price_index_percent = (index - 1) * 100
  saveInflation()

  return true, inflation_state, elapsed
end


-- =============================================================================
-- WIDE SECTOR PRICE ORACLE
--
-- This is deliberately broad rather than deep. MineColonies citizens are not
-- real economic agents, so this system does not try to make them change
-- behaviour. It simply gives the Quid economy width: food, construction,
-- logistics, fuel, tools/arms, research, defence, and general services all get
-- their own visible price pressure.
--
-- Important design choice:
--   There is no built-in starter inflation. The oracle starts at x1.00 and only
--   moves from actual bank inflation, money-print shock, or an admin-set floor.
--   Prices rise easily but fall slowly: max 3% per Minecraft day, and never
--   below 75% of the sector ATH unless the oracle is deliberately rebased.
-- =============================================================================
local DEFAULT_PRICE_ORACLE = {
  model = "wide_sector_price_oracle_v2_zero_base_sticky_deflation",
  min_index = 1.00,
  max_index = 8.00,
  immediate_pass_through = 1.00,
  -- No built-in starter inflation. Prices begin at x1.00 unless money-print
  -- shock, bank inflation, or a deliberate admin floor moves them.
  price_pressure_floor = 0.00,
  -- Downward price stickiness. Sector prices can make new ATHs, but deflation
  -- can only pull them down to 75% of that ATH unless an admin deliberately
  -- rebases the oracle. This makes money-printing damage persistent.
  sticky_floor_from_ath = 0.75,
  -- When target prices fall, the visible CPI can only fall this much per
  -- Minecraft day. Sellers cut prices slowly, even if conditions improve.
  max_daily_deflation = 0.03,
  shock_pressure = 0.00,
  money_print_sensitivity = 0.45,
  max_shock_pressure = 3.00,
  shock_decay_per_mc_day = 0.82,
  default_markup = 1.00,
  sectors = {
    general =      { label="General CPI",       sensitivity=1.00, bias=0.00 },
    food =         { label="Food CPI",          sensitivity=1.40, bias=0.05 },
    construction = { label="Construction CPI",  sensitivity=1.30, bias=0.03 },
    fuel =         { label="Fuel CPI",          sensitivity=1.25, bias=0.03 },
    logistics =    { label="Logistics CPI",     sensitivity=1.15, bias=0.02 },
    tools =        { label="Tools/Arms CPI",    sensitivity=1.25, bias=0.03 },
    defence =      { label="Defence CPI",       sensitivity=1.20, bias=0.03 },
    research =     { label="Research CPI",      sensitivity=1.10, bias=0.02 },
    hospitality =  { label="Hospitality CPI",   sensitivity=1.35, bias=0.04 },
  },
  service_prices = {
    dining_meal = { label="Dining Hall meal", sector="food", base=2.00, min_price=2 },
    courier_job = { label="Courier service", sector="logistics", base=4.00, min_price=4 },
    guard_service = { label="Guard service", sector="defence", base=5.00, min_price=5 },
  },
  item_base_prices = {
    bread=1, baked_potato=1, potato=1, carrot=1, wheat=1,
    cooked_beef=3, steak=3, cooked_porkchop=3, cooked_chicken=2,
    cooked_mutton=2, cooked_cod=2, cooked_salmon=2, fish=2,
    oak_log=1, spruce_log=1, birch_log=1, jungle_log=1, acacia_log=1, dark_oak_log=1,
    oak_planks=1, spruce_planks=1, birch_planks=1, cobblestone=1, stone=1,
    glass=2, torch=1, brick=2, iron_ingot=5, gold_ingot=8, diamond=20,
    coal=2, charcoal=2, coal_block=18,
  },
  observations = {},
}

local function cloneTable(src)
  local out = {}
  if type(src) ~= "table" then return out end
  for k, v in pairs(src) do
    if type(v) == "table" then out[k] = cloneTable(v) else out[k] = v end
  end
  return out
end

local function simpleItemName(name)
  name = lower(name or "")
  name = name:gsub("^minecraft:", "")
  name = name:gsub("^minecolonies:", "")
  name = name:gsub("^%w+:", "")
  return name
end

local function ensurePriceOracle()
  price_oracle = type(price_oracle) == "table" and price_oracle or {}

  local previous_model = tostring(price_oracle.model or "")
  if previous_model ~= DEFAULT_PRICE_ORACLE.model then
    price_oracle.model = DEFAULT_PRICE_ORACLE.model
  end

  price_oracle.min_index = tonumber(price_oracle.min_index) or DEFAULT_PRICE_ORACLE.min_index
  price_oracle.max_index = tonumber(price_oracle.max_index) or DEFAULT_PRICE_ORACLE.max_index
  price_oracle.immediate_pass_through = tonumber(price_oracle.immediate_pass_through) or DEFAULT_PRICE_ORACLE.immediate_pass_through

  price_oracle.price_pressure_floor = tonumber(price_oracle.price_pressure_floor)
  if price_oracle.price_pressure_floor == nil then
    price_oracle.price_pressure_floor = DEFAULT_PRICE_ORACLE.price_pressure_floor
  end
  -- v1.4.6 migration: remove the old hardcoded +26% starter floor. Inflation
  -- should start at 0 unless printing/real pressure creates it.
  if price_oracle.zero_base_floor_migrated ~= true then
    if math.abs((tonumber(price_oracle.price_pressure_floor) or 0) - 0.26) < 0.0001 then
      price_oracle.price_pressure_floor = 0.00
    end
    price_oracle.zero_base_floor_migrated = true
  end

  price_oracle.sticky_floor_from_ath = tonumber(price_oracle.sticky_floor_from_ath) or DEFAULT_PRICE_ORACLE.sticky_floor_from_ath
  if price_oracle.sticky_floor_from_ath < 0 then price_oracle.sticky_floor_from_ath = DEFAULT_PRICE_ORACLE.sticky_floor_from_ath end
  if price_oracle.sticky_floor_from_ath > 1 then price_oracle.sticky_floor_from_ath = 1 end

  price_oracle.max_daily_deflation = tonumber(price_oracle.max_daily_deflation) or DEFAULT_PRICE_ORACLE.max_daily_deflation
  if price_oracle.max_daily_deflation < 0 then price_oracle.max_daily_deflation = DEFAULT_PRICE_ORACLE.max_daily_deflation end
  if price_oracle.max_daily_deflation > 0.25 then price_oracle.max_daily_deflation = 0.25 end

  price_oracle.shock_pressure = tonumber(price_oracle.shock_pressure) or DEFAULT_PRICE_ORACLE.shock_pressure
  if price_oracle.shock_pressure < 0 then price_oracle.shock_pressure = 0 end
  price_oracle.money_print_sensitivity = tonumber(price_oracle.money_print_sensitivity) or DEFAULT_PRICE_ORACLE.money_print_sensitivity
  price_oracle.max_shock_pressure = tonumber(price_oracle.max_shock_pressure) or DEFAULT_PRICE_ORACLE.max_shock_pressure
  price_oracle.shock_decay_per_mc_day = tonumber(price_oracle.shock_decay_per_mc_day) or DEFAULT_PRICE_ORACLE.shock_decay_per_mc_day
  if price_oracle.shock_decay_per_mc_day < 0 then price_oracle.shock_decay_per_mc_day = DEFAULT_PRICE_ORACLE.shock_decay_per_mc_day end
  if price_oracle.shock_decay_per_mc_day > 1 then price_oracle.shock_decay_per_mc_day = 1 end
  price_oracle.default_markup = tonumber(price_oracle.default_markup) or DEFAULT_PRICE_ORACLE.default_markup

  price_oracle.sectors = type(price_oracle.sectors) == "table" and price_oracle.sectors or {}
  for key, def in pairs(DEFAULT_PRICE_ORACLE.sectors) do
    price_oracle.sectors[key] = type(price_oracle.sectors[key]) == "table" and price_oracle.sectors[key] or {}
    local rec = price_oracle.sectors[key]
    rec.label = rec.label or def.label
    rec.sensitivity = tonumber(rec.sensitivity) or def.sensitivity
    rec.bias = tonumber(rec.bias) or def.bias
    rec.ath_index = math.max(1, tonumber(rec.ath_index) or 1)
    rec.current_index = math.max(1, tonumber(rec.current_index) or 1)
    rec.raw_index = math.max(1, tonumber(rec.raw_index) or rec.current_index or 1)
    rec.sticky_floor_index = math.max(1, tonumber(rec.sticky_floor_index) or (rec.ath_index * (tonumber(price_oracle.sticky_floor_from_ath) or 0.75)))
    rec.last_index_day = tonumber(rec.last_index_day) or currentMinecraftDay()
  end

  price_oracle.service_prices = type(price_oracle.service_prices) == "table" and price_oracle.service_prices or {}
  for key, def in pairs(DEFAULT_PRICE_ORACLE.service_prices) do
    price_oracle.service_prices[key] = type(price_oracle.service_prices[key]) == "table" and price_oracle.service_prices[key] or cloneTable(def)
    local rec = price_oracle.service_prices[key]
    rec.label = rec.label or def.label
    rec.sector = rec.sector or def.sector
    rec.base = tonumber(rec.base) or def.base
    rec.min_price = tonumber(rec.min_price) or def.min_price
  end

  price_oracle.item_base_prices = type(price_oracle.item_base_prices) == "table" and price_oracle.item_base_prices or {}
  for key, val in pairs(DEFAULT_PRICE_ORACLE.item_base_prices) do
    if tonumber(price_oracle.item_base_prices[key]) == nil then price_oracle.item_base_prices[key] = val end
  end
  price_oracle.observations = type(price_oracle.observations) == "table" and price_oracle.observations or {}
  price_oracle.updated = timestamp()
  return price_oracle
end

local function inflationPressure()
  ensureInflationState()
  ensurePriceOracle()
  local rate = tonumber(inflation_state.inflation_rate) or 0
  local idx = tonumber(inflation_state.price_index) or 1
  local by_index = idx - 1
  if by_index < 0 then by_index = 0 end
  if rate < 0 then rate = 0 end

  -- Immediate visible inflation pressure. This is intentionally broad: NPCs are
  -- not real consumers, so we reflect inflation through sector-wide prices.
  local floor = tonumber(price_oracle.price_pressure_floor) or 0
  if floor < 0 then floor = 0 end

  local shock = tonumber(price_oracle.shock_pressure) or 0
  if shock < 0 then shock = 0 end

  local pressure = math.max(rate, by_index, floor, shock)
  pressure = pressure * (tonumber(price_oracle.immediate_pass_through) or 1)
  if pressure < 0 then pressure = 0 end
  if pressure > (tonumber(price_oracle.max_shock_pressure) or 3) then pressure = tonumber(price_oracle.max_shock_pressure) or 3 end
  return pressure, rate, idx, floor, shock
end

local function sectorIndex(sector)
  sector = lower(sector or "general")
  ensurePriceOracle()
  if not price_oracle.sectors[sector] then sector = "general" end
  local rec = price_oracle.sectors[sector] or price_oracle.sectors.general or {}
  local pressure, rate, bank_index, floor, shock = inflationPressure()

  local target_idx = 1 + (pressure * (tonumber(rec.sensitivity) or 1)) + (pressure > 0 and (tonumber(rec.bias) or 0) or 0)
  target_idx = clamp(target_idx, tonumber(price_oracle.min_index) or 1, tonumber(price_oracle.max_index) or 8)

  -- Sticky ATH + slow deflation rule:
  -- Prices can rise instantly when pressure/shock appears. When pressure eases,
  -- sellers only cut prices slowly: at most max_daily_deflation per Minecraft
  -- day, and never below sticky_floor_from_ath of the sector ATH.
  local sticky_ratio = tonumber(price_oracle.sticky_floor_from_ath) or 0.75
  if sticky_ratio < 0 then sticky_ratio = 0.75 end
  if sticky_ratio > 1 then sticky_ratio = 1 end

  local old_ath = tonumber(rec.ath_index) or 1
  local current = tonumber(rec.current_index) or 1
  current = clamp(current, tonumber(price_oracle.min_index) or 1, tonumber(price_oracle.max_index) or 8)

  local ath = math.max(1, old_ath, target_idx, current)
  local sticky_floor = math.max(tonumber(price_oracle.min_index) or 1, ath * sticky_ratio)

  local today = currentMinecraftDay()
  local lastDay = math.floor(tonumber(rec.last_index_day) or today)
  local elapsedDays = math.max(0, math.min(30, today - lastDay))
  local maxDeflation = tonumber(price_oracle.max_daily_deflation) or 0.03
  if maxDeflation < 0 then maxDeflation = 0.03 end
  if maxDeflation > 0.25 then maxDeflation = 0.25 end

  local idx = current
  local deflation_limited = false
  local sticky_active = false

  if target_idx >= current then
    -- Inflation is easy: raise immediately.
    idx = target_idx
  else
    -- Deflation is slow and sticky. If this is the same MC day as the last
    -- update, do not let repeated quote calls keep ratcheting prices down.
    local allowed_floor_today = current
    if elapsedDays > 0 then
      allowed_floor_today = current * pow(1 - maxDeflation, elapsedDays)
    end
    idx = math.max(target_idx, allowed_floor_today)
    if idx > target_idx + 0.0001 then deflation_limited = true end
  end

  if idx < sticky_floor then
    idx = sticky_floor
    sticky_active = true
  end
  idx = clamp(idx, tonumber(price_oracle.min_index) or 1, tonumber(price_oracle.max_index) or 8)

  -- A post-limit price can also become the new ATH if current/target was higher.
  ath = math.max(ath, idx)
  sticky_floor = math.max(tonumber(price_oracle.min_index) or 1, ath * sticky_ratio)
  if idx < sticky_floor then
    idx = sticky_floor
    sticky_active = true
  end

  local changed = false
  if math.abs((tonumber(rec.ath_index) or 0) - ath) > 0.0001 then rec.ath_index = ath; changed = true end
  if math.abs((tonumber(rec.current_index) or 0) - idx) > 0.0001 then rec.current_index = idx; changed = true end
  if math.abs((tonumber(rec.raw_index) or 0) - target_idx) > 0.0001 then rec.raw_index = target_idx; changed = true end
  if math.abs((tonumber(rec.sticky_floor_index) or 0) - sticky_floor) > 0.0001 then rec.sticky_floor_index = sticky_floor; changed = true end
  if rec.last_index_day ~= today then rec.last_index_day = today; changed = true end
  rec.sticky_active = sticky_active
  rec.deflation_limited = deflation_limited
  rec.last_pressure = pressure
  rec.last_updated = timestamp()
  if changed then savePriceOracle() end

  return idx, {
    sector = sector,
    label = rec.label or sector,
    monetary_pressure = pressure,
    bank_inflation_rate = rate,
    old_bank_price_index = bank_index,
    price_pressure_floor = floor,
    shock_pressure = shock,
    sensitivity = tonumber(rec.sensitivity) or 1,
    bias = tonumber(rec.bias) or 0,
    raw_index = target_idx,
    target_index = target_idx,
    ath_index = ath,
    current_index = idx,
    sticky_floor_index = sticky_floor,
    sticky_floor_from_ath = sticky_ratio,
    max_daily_deflation = maxDeflation,
    elapsed_days = elapsedDays,
    sticky_active = sticky_active,
    deflation_limited = deflation_limited,
  }
end

local function classifyItemSector(id)
  id = simpleItemName(id)
  if id == "" then return "general" end

  if id:find("bread",1,true) or id:find("potato",1,true) or id:find("carrot",1,true)
    or id:find("wheat",1,true) or id:find("beef",1,true) or id:find("pork",1,true)
    or id:find("chicken",1,true) or id:find("mutton",1,true) or id:find("rabbit",1,true)
    or id:find("cod",1,true) or id:find("salmon",1,true) or id:find("fish",1,true)
    or id:find("stew",1,true) or id:find("soup",1,true) or id:find("food",1,true) then
    return "food"
  end

  if id:find("coal",1,true) or id:find("charcoal",1,true) or id:find("lava",1,true)
    or id:find("blaze",1,true) or id:find("fuel",1,true) then
    return "fuel"
  end

  if id:find("sword",1,true) or id:find("bow",1,true) or id:find("crossbow",1,true)
    or id:find("armor",1,true) or id:find("helmet",1,true) or id:find("chestplate",1,true)
    or id:find("leggings",1,true) or id:find("boots",1,true) or id:find("shield",1,true) then
    return "defence"
  end

  if id:find("pickaxe",1,true) or id:find("shovel",1,true) or id:find("axe",1,true)
    or id:find("hoe",1,true) or id:find("tool",1,true) then
    return "tools"
  end

  if id:find("book",1,true) or id:find("paper",1,true) or id:find("redstone",1,true)
    or id:find("lapis",1,true) or id:find("experience",1,true) then
    return "research"
  end

  if id:find("log",1,true) or id:find("plank",1,true) or id:find("slab",1,true)
    or id:find("stair",1,true) or id:find("stone",1,true) or id:find("cobble",1,true)
    or id:find("glass",1,true) or id:find("brick",1,true) or id:find("sand",1,true)
    or id:find("gravel",1,true) or id:find("dirt",1,true) or id:find("door",1,true)
    or id:find("fence",1,true) or id:find("torch",1,true) or id:find("block",1,true) then
    return "construction"
  end

  return "general"
end

local function manualBasePrice(id)
  local key = simpleItemName(id)
  ensurePriceOracle()

  local p = prices[key] or prices["minecraft:" .. key]
  if type(p) == "table" then p = p.unit_price or p.price or p.value end
  p = tonumber(p)
  if p and p > 0 then return p, "manual_price" end

  p = tonumber(price_oracle.item_base_prices[key])
  if p and p > 0 then return p, "oracle_base" end

  -- Fallbacks are broad and chunky on purpose. NPCs will not bargain; the goal
  -- is visible price width across sectors.
  if key:find("netherite",1,true) then return 40, "fallback" end
  if key:find("diamond",1,true) then return 20, "fallback" end
  if key:find("emerald",1,true) then return 12, "fallback" end
  if key:find("gold",1,true) then return 8, "fallback" end
  if key:find("iron",1,true) then return 5, "fallback" end
  if classifyItemSector(key) == "food" then return 1, "fallback" end
  if classifyItemSector(key) == "fuel" then return 2, "fallback" end
  if classifyItemSector(key) == "tools" then return 6, "fallback" end
  if classifyItemSector(key) == "defence" then return 8, "fallback" end
  if classifyItemSector(key) == "construction" then return 1, "fallback" end
  return 1, "fallback"
end

local function roundPrice(n)
  n = tonumber(n) or 0
  if n <= 0 then return 0 end
  return math.max(1, math.floor(n + 0.5))
end

local function quoteItemPrice(item, count, sector_override)
  ensurePriceOracle()
  item = simpleItemName(item)
  count = math.max(1, math.floor(tonumber(count) or 1))
  local base, base_source = manualBasePrice(item)
  local sector = sector_override and lower(sector_override) or classifyItemSector(item)
  local idx, meta = sectorIndex(sector)
  local unit_raw = (tonumber(base) or 1) * idx * (tonumber(price_oracle.default_markup) or 1)
  local total = roundPrice(unit_raw * count)
  local unit_display = total / count
  return {
    item = item,
    count = count,
    sector = sector,
    sector_label = meta.label,
    base_unit_price = base,
    base_source = base_source,
    sector_index = idx,
    raw_sector_index = meta.raw_index,
    ath_index = meta.ath_index,
    sticky_floor_index = meta.sticky_floor_index,
    sticky_active = meta.sticky_active,
    shock_pressure = meta.shock_pressure,
    monetary_pressure = meta.monetary_pressure,
    bank_inflation_rate = meta.bank_inflation_rate,
    old_bank_price_index = meta.old_bank_price_index,
    unit_price = unit_display,
    total = total,
    source = "wide_sector_price_oracle",
  }
end

local function serviceTierMultiplier(service, tier, gain)
  service = lower(service or "")
  tier = lower(tier or "")
  gain = tonumber(gain) or nil

  if service == "dining_meal" then
    if gain then
      if gain >= 13 then return 2.00, "full refill" end
      if gain >= 9 then return 1.50, "large meal" end
      if gain >= 5 then return 1.00, "normal meal" end
      if gain >= 2 then return 0.50, "snack" end
      return 0, "none"
    end
    if tier:find("full",1,true) then return 2.00, "full refill" end
    if tier:find("large",1,true) then return 1.50, "large meal" end
    if tier:find("snack",1,true) or tier:find("small",1,true) then return 0.50, "snack" end
    return 1.00, "normal meal"
  end

  return tonumber(tier) or 1.00, tier ~= "" and tier or "standard"
end

local function quoteServicePrice(service, tier, gain, sector_override)
  ensurePriceOracle()
  service = lower(service or "")
  local def = price_oracle.service_prices[service] or { label=service, sector="general", base=1, min_price=1 }
  local mult, tier_label = serviceTierMultiplier(service, tier, gain)
  local sector = sector_override or def.sector or "general"
  local idx, meta = sectorIndex(sector)
  local raw = (tonumber(def.base) or 1) * idx * (tonumber(mult) or 1)
  local min_price = tonumber(def.min_price) or 1
  local total = raw > 0 and math.max(min_price, roundPrice(raw)) or 0

  return {
    service = service,
    label = def.label or service,
    tier = tier_label,
    tier_multiplier = mult,
    sector = sector,
    sector_label = meta.label,
    base_price = tonumber(def.base) or 1,
    sector_index = idx,
    raw_sector_index = meta.raw_index,
    ath_index = meta.ath_index,
    sticky_floor_index = meta.sticky_floor_index,
    sticky_active = meta.sticky_active,
    shock_pressure = meta.shock_pressure,
    monetary_pressure = meta.monetary_pressure,
    bank_inflation_rate = meta.bank_inflation_rate,
    old_bank_price_index = meta.old_bank_price_index,
    raw = raw,
    total = total,
    source = "wide_sector_price_oracle",
  }
end

local function sectorIndexSnapshot()
  ensurePriceOracle()
  local out = {}
  for sector, _ in pairs(price_oracle.sectors or {}) do
    local idx, meta = sectorIndex(sector)
    out[sector] = {
      index = idx,
      label = meta.label,
      monetary_pressure = meta.monetary_pressure,
      bank_inflation_rate = meta.bank_inflation_rate,
      old_bank_price_index = meta.old_bank_price_index,
      price_pressure_floor = meta.price_pressure_floor,
      shock_pressure = meta.shock_pressure,
      raw_index = meta.raw_index,
      ath_index = meta.ath_index,
      sticky_floor_index = meta.sticky_floor_index,
      sticky_floor_from_ath = meta.sticky_floor_from_ath,
      max_daily_deflation = meta.max_daily_deflation,
      deflation_limited = meta.deflation_limited,
      current_index = meta.current_index,
      target_index = meta.target_index,
      sticky_active = meta.sticky_active,
      sensitivity = meta.sensitivity,
      bias = meta.bias,
    }
  end
  return out
end

recordMoneyPrintShock = function(amount, issued_before, issued_after, tx_id)
  amount = tonumber(amount) or 0
  issued_before = tonumber(issued_before) or 0
  issued_after = tonumber(issued_after) or issued_before
  if amount <= 0 then return false end

  ensurePriceOracle()
  tx_id = tx_id and tostring(tx_id) or nil
  price_oracle.processed_mint_tx = type(price_oracle.processed_mint_tx) == "table" and price_oracle.processed_mint_tx or {}
  if tx_id and price_oracle.processed_mint_tx[tx_id] then
    return false, "mint shock already processed"
  end
  local denominator = math.max(1000, issued_before)
  local growth = amount / denominator
  if growth < 0 then growth = 0 end

  -- Log scaling keeps absurd mints from instantly making every item impossible,
  -- but still makes a 250k print from a tiny economy hurt immediately.
  local sensitivity = tonumber(price_oracle.money_print_sensitivity) or 0.45
  local added = math.log(1 + growth) * sensitivity
  local cap = tonumber(price_oracle.max_shock_pressure) or 3.0
  if added > cap then added = cap end

  local old = tonumber(price_oracle.shock_pressure) or 0
  local newShock = old + added
  if newShock > cap then newShock = cap end
  price_oracle.shock_pressure = newShock
  price_oracle.last_money_print = {
    time = timestamp(),
    day = currentMinecraftDay(),
    tx_id = tx_id,
    amount = amount,
    issued_before = issued_before,
    issued_after = issued_after,
    growth_vs_prior_supply = growth,
    added_pressure = added,
    old_shock_pressure = old,
    new_shock_pressure = newShock,
    note = "Money-printing shock. Sector ATH indices update immediately; deflation cannot cut below sticky ATH floor.",
  }

  if tx_id then price_oracle.processed_mint_tx[tx_id] = true end

  -- Force each sector to record the new ATH now rather than waiting for a quote.
  for sector, _ in pairs(price_oracle.sectors or {}) do
    sectorIndex(sector)
  end
  savePriceOracle()
  return true, price_oracle.last_money_print
end

decayPriceOracleShock = function(elapsed_days)
  elapsed_days = math.max(0, math.floor(tonumber(elapsed_days) or 0))
  if elapsed_days <= 0 then return false end
  ensurePriceOracle()
  local old = tonumber(price_oracle.shock_pressure) or 0
  if old <= 0 then return false end
  local decay = tonumber(price_oracle.shock_decay_per_mc_day) or 0.82
  if decay < 0 then decay = 0.82 end
  if decay > 1 then decay = 1 end
  local newShock = old * pow(decay, elapsed_days)
  if newShock < 0.001 then newShock = 0 end
  price_oracle.shock_pressure = newShock
  price_oracle.last_shock_decay = {
    time = timestamp(),
    day = currentMinecraftDay(),
    elapsed_days = elapsed_days,
    old_shock_pressure = old,
    new_shock_pressure = newShock,
    sticky_note = "Raw shock decays, but live sector indices remain no lower than 75% of ATH by default.",
  }
  for sector, _ in pairs(price_oracle.sectors or {}) do
    sectorIndex(sector)
  end
  savePriceOracle()
  return true, price_oracle.last_shock_decay
end

local function processUnprocessedMintLedgerShocks()
  ensurePriceOracle()
  price_oracle.processed_mint_tx = type(price_oracle.processed_mint_tx) == "table" and price_oracle.processed_mint_tx or {}

  local issued = 0
  local processed = 0
  local skipped = 0
  for _, line in ipairs(readLines(FILE.ledger)) do
    local tx_id, ts, tx_type, from_id, to_id, amount, memo, status =
      line:match("(TX%-%d+)%s*|%s*(%d+)%s*|%s*([^|]+)%s*|%s*([^|]+)%s*|%s*([^|]+)%s*|%s*(%-?%d+)%s*|%s*([^|]+)%s*|%s*(.+)")
    if tx_id then
      tx_type = trim(tx_type)
      status = trim(status)
      amount = tonumber(amount) or 0
      if status == "settled" and tx_type == "MINT" and amount > 0 then
        if not price_oracle.processed_mint_tx[tx_id] then
          recordMoneyPrintShock(amount, issued, issued + amount, tx_id)
          processed = processed + 1
        else
          skipped = skipped + 1
        end
        issued = issued + amount
      elseif status == "settled" and tx_type == "BURN" and amount > 0 then
        issued = math.max(0, issued - amount)
      end
    end
  end

  price_oracle.last_mint_ledger_import = {
    time = timestamp(),
    processed = processed,
    skipped = skipped,
    note = "Imported unprocessed historical MINT transactions into sticky price oracle.",
  }
  if processed > 0 then savePriceOracle() end
  return processed, skipped
end


-- =============================================================================
-- GOVERNMENT WORKER PAY RATES
-- Stored in config.worker_pay_rates and managed from FiscalControls.
--
-- Public-sector pay is intentionally separate from private company payroll.
-- =============================================================================
local DEFAULT_WORKER_PAY_RATES = {
  defence = {
    unskilled = 2,
    skilled = 3,
    elite = 4,
  },
  research = {
    skilled = 3,
    elite = 5,
  },
  logistics = {
    unskilled = 1,
    skilled = 2,
  },
}

local function copyWorkerPayDefaults()
  local out = {}
  for sector, tiers in pairs(DEFAULT_WORKER_PAY_RATES) do
    out[sector] = {}
    for tier, amount in pairs(tiers) do
      out[sector][tier] = amount
    end
  end
  return out
end

local function normaliseWorkerPayRates(src)
  src = type(src) == "table" and src or {}
  local out = copyWorkerPayDefaults()

  -- Backwards compatibility with the old flat keys.
  if src.researcher then out.research.skilled = math.floor(tonumber(src.researcher) or out.research.skilled) end
  if src.soldier then out.defence.skilled = math.floor(tonumber(src.soldier) or out.defence.skilled) end
  if src.courier then out.logistics.unskilled = math.floor(tonumber(src.courier) or out.logistics.unskilled) end

  for sector, tiers in pairs(DEFAULT_WORKER_PAY_RATES) do
    if type(src[sector]) == "table" then
      for tier, _ in pairs(tiers) do
        local n = tonumber(src[sector][tier])
        if n and n > 0 then out[sector][tier] = math.floor(n) end
      end
    end
  end

  -- Compatibility fields for old payroll terminals.
  out.researcher = out.research.skilled
  out.soldier = out.defence.skilled
  out.courier = out.logistics.unskilled

  return out
end

local function ensureWorkerPayRates()
  config.worker_pay_rates = normaliseWorkerPayRates(config.worker_pay_rates)
  return config.worker_pay_rates
end

-- =============================================================================
-- PRIVATE GDP / ACTIVITY ESTIMATION
-- Company payroll uses this as a simple rolling prosperity signal.
-- =============================================================================
local function isGovernmentAccount(id)
  id = tostring(id or "")
  return id == "SYSTEM"
    or id == "treasury:quid_bank"
    or id == "market:escrow"
    or id == "contract:escrow"
    or id:find("^treasury:") ~= nil
end

local GDP_TX_TYPES = {
  COMPANY_PAYROLL = true,
  COMPANY_TRANSFER = true,
  CONTRACT_PAYOUT = true,
  CONTRACT_REWARD = true,
  PRIVATE_SERVICE = true,
  LIVING_COST = true,
  HOSPITALITY_MEAL = true,
  TRANSFER = true,
}

local function isPrivateGDPTransaction(tx_type, from_id, to_id)
  tx_type = trim(tx_type)
  from_id = trim(from_id)
  to_id = trim(to_id)

  if tx_type == "MINT" or tx_type == "BURN" or tx_type == "GRANT" then return false end
  if tx_type == "COMPANY_DEPOSIT" or tx_type == "COMPANY_WITHDRAW" then return false end
  if isGovernmentAccount(from_id) or isGovernmentAccount(to_id) then return false end

  return GDP_TX_TYPES[tx_type] == true
end

local function calculatePrivateGDP(window_ms)
  window_ms = tonumber(window_ms) or (7 * 1200000)
  local cutoff = timestamp() - window_ms
  local total = 0
  local count = 0
  local by_type = {}

  for _, line in ipairs(readLines(FILE.ledger)) do
    local tx_id, ts, tx_type, from_id, to_id, amount, memo, status =
      line:match("(TX%-%d+)%s*|%s*(%d+)%s*|%s*(%S+)%s*|%s*([^|]+)%s*|%s*([^|]+)%s*|%s*(%-?%d+)%s*|%s*([^|]+)%s*|%s*(.+)")
    if tx_id then
      ts = tonumber(ts) or 0
      amount = tonumber(amount) or 0
      status = trim(status)
      tx_type = trim(tx_type)
      from_id = trim(from_id)
      to_id = trim(to_id)

      if status == "settled" and ts >= cutoff and amount > 0 and isPrivateGDPTransaction(tx_type, from_id, to_id) then
        total = total + amount
        count = count + 1
        by_type[tx_type] = (by_type[tx_type] or 0) + amount
      end
    end
  end

  local population = 0
  for id, c in pairs(citizens or {}) do
    if c.status == "active" then population = population + 1 end
  end
  if population <= 0 then
    for id, acc in pairs(accounts or {}) do
      if acc.type == "citizen" and acc.status == "active" then population = population + 1 end
    end
  end

  local per_capita = 0
  if population > 0 then per_capita = math.floor(total / population) end

  return {
    window_ms = window_ms,
    private_gdp = math.floor(total),
    gdp = math.floor(total),
    gdp_per_capita = per_capita,
    population = population,
    transaction_count = count,
    by_type = by_type,
    note = "Private GDP estimate from recent non-government settled transaction flow."
  }
end


-- SET_PRICE
handlers["set_price"] = function(sender_id, req)
  local item  = req.item
  local price = tonumber(req.price)
  if not item or not price then return false, "Missing item or price" end
  local old_price = prices[item] and prices[item].unit_price or nil
  prices[item] = prices[item] or { history = {} }
  if old_price then
    local h = prices[item].history or {}
    h[#h+1] = { price = old_price, time = timestamp() }
    while #h > 30 do table.remove(h, 1) end
    prices[item].history = h
  end
  prices[item].unit_price   = price
  prices[item].last_updated = timestamp()
  savePrices()
  audit("ACTION", "STATE", sender_id, "SET_PRICE:" .. item, tostring(old_price) .. "->" .. tostring(price))
  return true, { item = item, price = price, old_price = old_price }
end


-- REGISTER_COMPANY (management)
handlers["register_company"] = function(sender_id, req)
  if not isTrustedManagement(sender_id) then return false, "Management terminal required" end
  local name         = req.name
  local ticker       = req.ticker and string.upper(req.ticker)
  local biz_type     = req.biz_type or "general"
  local owner_id     = req.owner_id or "treasury:quid_bank"
  local shares       = tonumber(req.shares_total) or 1000
  local public_float = tonumber(req.shares_public) or 0
  if not name or not ticker then return false, "Missing name or ticker" end
  local company_id = "company:" .. string.lower(ticker)
  if companies[company_id] then return false, "Company already exists" end
  companies[company_id] = {
    name          = name,
    ticker        = ticker,
    biz_type      = biz_type,
    owner_id      = owner_id,
    founded       = timestamp(),
    status        = "active",
    shares_total  = shares,
    shares_public = public_float
  }
  saveCompanies()
  local ok, result = createAccount(company_id, "company", name, owner_id)
  if not ok then return false, "Company registered but account failed: " .. tostring(result) end
  if shares > 0 then
    writeShareTx(nextShId(), company_id, "SYSTEM", owner_id, shares, "FOUNDER_GRANT", "Founding shares")
  end
  audit("ACTION", "MANAGEMENT", sender_id, "REGISTER_COMPANY", company_id)
  return true, { company_id = company_id, name = name, ticker = ticker, message = "Company registered" }
end

-- SET_PRICE (management)
handlers["set_price"] = function(sender_id, req)
  if not isTrustedManagement(sender_id) then return false, "Management terminal required" end
  local item  = req.item
  local price = tonumber(req.price)
  if not item or not price then return false, "Missing item or price" end
  local old_price = prices[item] and prices[item].unit_price or nil
  prices[item] = prices[item] or { history = {} }
  if old_price then
    local h = prices[item].history or {}
    h[#h+1] = { price = old_price, time = timestamp() }
    while #h > 30 do table.remove(h, 1) end
    prices[item].history = h
  end
  prices[item].unit_price   = price
  prices[item].last_updated = timestamp()
  savePrices()
  audit("ACTION", "MANAGEMENT", sender_id, "SET_PRICE:" .. item, tostring(old_price) .. "->" .. tostring(price))
  return true, { item = item, price = price, old_price = old_price }
end


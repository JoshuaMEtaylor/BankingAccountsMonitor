-- =============================================================================
-- AUTH  — username + password, works from any terminal
-- =============================================================================
local function authenticateUser(username, password)
  if not username or not password then
    return false, "Missing username or password"
  end
  local key = string.lower(username):gsub("%s+", "_")
  local citizen_id = "citizen:" .. key
  local citizen = citizens[citizen_id]
  if not citizen then
    return false, "Account not found"
  end
  if citizen.status ~= "active" then
    return false, "Account suspended"
  end
  if citizen.password_hash ~= simpleHash(password) then
    return false, "Incorrect password"
  end
  return true, citizen_id, citizen
end

local function isTrustedManagement(computer_id)
  if not config.management_terminals then return false end
  for _, id in ipairs(config.management_terminals) do
    if tonumber(id) == tonumber(computer_id) then return true end
  end
  return false
end

-- =============================================================================
-- ACCOUNT OPERATIONS
-- =============================================================================
local function accountExists(account_id)
  return accounts[account_id] ~= nil
end

local function createAccount(account_id, acc_type, display_name, owner_id)
  if accountExists(account_id) then return false, "Account already exists" end
  accounts[account_id] = {
    type         = acc_type,
    display_name = display_name,
    owner_id     = owner_id or "SYSTEM",
    created      = timestamp(),
    status       = "active"
  }
  saveAccounts()
  return true, account_id
end

local function transfer(from_id, to_id, amount, tx_type, memo, actor)
  amount = tonumber(amount)
  if not amount or amount <= 0 then return false, "Invalid amount" end
  if not accountExists(from_id) and from_id ~= "SYSTEM" then
    return false, "Source account does not exist"
  end
  if not accountExists(to_id) and to_id ~= "SYSTEM" then
    return false, "Destination account does not exist"
  end
  if from_id ~= "SYSTEM" and tx_type ~= "MINT" then
    local balance = deriveBalance(from_id)
    if balance < amount then
      return false, "Insufficient funds. Balance: " .. balance .. " Quid, Required: " .. amount .. " Quid"
    end
  end
  local tx_id = nextTxId()
  writeTx(tx_id, tx_type or "TRANSFER", from_id, to_id, amount, memo or "", "settled")
  audit("ACTION", actor or "SYSTEM", "db", tx_type or "TRANSFER",
    tx_id .. " " .. amount .. "q " .. tostring(from_id) .. "->" .. tostring(to_id))
  return true, {
    tx_id  = tx_id,
    from   = from_id,
    to     = to_id,
    amount = amount,
    type   = tx_type,
    memo   = memo,
    status = "settled"
  }
end


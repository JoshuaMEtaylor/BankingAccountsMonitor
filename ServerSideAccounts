local function initFiles()
  print("  Loading data files...")
  local function count(t) local n=0; for _ in pairs(t) do n=n+1 end; return n end

  accounts  = readFile(FILE.accounts)  or {}
  balances  = readFile(FILE.balances)  or {}
  monetary_state = readFile(FILE.monetary) or { total_minted = 0, total_burned = 0, migrated = false }
  citizens  = readFile(FILE.citizens)  or {}
  companies = readFile(FILE.companies) or {}
  contracts = readFile(FILE.contracts) or {}
  prices    = readFile(FILE.prices)    or {}
  inflation_state = readFile(FILE.inflation) or {}
  ensureInflationState()
  config    = readFile(FILE.config)    or {
    economy_status       = "active",
    mint_authority       = "locked"
  }

  migrateBalancesFromLedgerIfNeeded()
  recoverPendingTx()
  capAuditLog()
  compactLedgerIfNeeded(false)

  print("  Accounts:  " .. count(accounts))
  print("  Citizens:  " .. count(citizens))
  print("  Companies: " .. count(companies))
end

local function initCounters()
  if fs.exists(FILE.ledger) then
    for _, line in ipairs(readLines(FILE.ledger)) do
      local num = line:match("TX%-(%d+)")
      if num then local n = tonumber(num) or 0; if n > tx_counter then tx_counter = n end end
    end
  end
  if fs.exists(FILE.share_ledger) then
    for _, line in ipairs(readLines(FILE.share_ledger)) do
      local num = line:match("SH%-(%d+)")
      if num then local n = tonumber(num) or 0; if n > sh_counter then sh_counter = n end end
    end
  end
  if fs.exists(FILE.audit) then
    for _, line in ipairs(readLines(FILE.audit)) do
      local num = line:match("AUDIT%-(%d+)")
      if num then local n = tonumber(num) or 0; if n > audit_counter then audit_counter = n end end
    end
  end
  print("  TX counter at: TX-" .. pad(tx_counter, 6))
end


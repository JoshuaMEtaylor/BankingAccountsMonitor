  }

  print("  Accounts:  " .. count(accounts))
  print("  Citizens:  " .. count(citizens))
  print("  Companies: " .. count(companies))
end

local function initCounters()
  if fs.exists(FILE.ledger) then
    for _, line in ipairs(readLines(FILE.ledger)) do
      local num = line:match("TX%-(%d+)")
      if num then local n = tonumber(num) or 0; if n > tx_counter then tx_counter = n end end
    end
  end
  if fs.exists(FILE.share_ledger) then
    for _, line in ipairs(readLines(FILE.share_ledger)) do
      local num = line:match("SH%-(%d+)")
      if num then local n = tonumber(num) or 0; if n > sh_counter then sh_counter = n end end
    end
  end
  if fs.exists(FILE.audit) then
    for _, line in ipairs(readLines(FILE.audit)) do
      local num = line:match("AUDIT%-(%d+)")
      if num then local n = tonumber(num) or 0; if n > audit_counter then audit_counter = n end end
    end
  end
  print("  TX counter at: TX-" .. pad(tx_counter, 6))
end

local function initSystemAccounts()
  if not accountExists("treasury:quid_bank") then
    createAccount("treasury:quid_bank", "treasury", "Quid Bank of Plenty", "SYSTEM")
    print("  Created treasury:quid_bank")
  end
  if not accountExists("market:escrow") then
    createAccount("market:escrow", "escrow", "Market Escrow", "SYSTEM")
    print("  Created market:escrow")
  end
  if not accountExists("contract:escrow") then
    createAccount("contract:escrow", "escrow", "Contract Escrow", "SYSTEM")
    print("  Created contract:escrow")
  end
end

local function openModem()
  -- First pass: prefer wireless/ender modem
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      local modem = peripheral.wrap(name)
      if modem and modem.isWireless and modem.isWireless() then
        rednet.open(name)
        print("  Modem: " .. name .. " (wireless)")
        return true
      end
    end
  end
  -- Second pass: fallback to any modem
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      rednet.open(name)
      print("  Modem: " .. name .. " (wired fallback)")
      return true
    end
  end
  print("  ERROR: No modem found!")
  return false
end


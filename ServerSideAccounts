-- =============================================================================
local function initFiles()
  print("  Initialising data files...")

  -- Load or create accounts
  local loaded_accounts = readFile(FILE.accounts)
  if loaded_accounts then
    accounts = loaded_accounts
    print("  Accounts loaded: " .. (function() local n=0 for _ in pairs(accounts) do n=n+1 end return n end)())
  else
    print("  No accounts file found. Starting fresh.")
  end

  -- Load or create citizens
  local loaded_citizens = readFile(FILE.citizens)
  if loaded_citizens then
    citizens = loaded_citizens
    print("  Citizens loaded: " .. (function() local n=0 for _ in pairs(citizens) do n=n+1 end return n end)())
  else
    print("  No citizens file found.")
  end

  -- Load or create companies
  local loaded_companies = readFile(FILE.companies)
  if loaded_companies then
    companies = loaded_companies
    print("  Companies loaded: " .. (function() local n=0 for _ in pairs(companies) do n=n+1 end return n end)())
  else
    print("  No companies file found.")
  end

  -- Load contracts
  local loaded_contracts = readFile(FILE.contracts)
  if loaded_contracts then contracts = loaded_contracts end

  -- Load prices
  local loaded_prices = readFile(FILE.prices)
  if loaded_prices then
    prices = loaded_prices
    print("  Price index loaded: " .. (function() local n=0 for _ in pairs(prices) do n=n+1 end return n end)() .. " commodities")
  end

  -- Load config
  local loaded_config = readFile(FILE.config)
  if loaded_config then
    config = loaded_config
    print("  Config loaded.")
  else
    config = {
      economy_status       = "active",
      mint_authority       = "locked",
      management_terminals = {}
    }
    saveConfig()
    print("  Default config created.")
  end
end

local function initCounters()
  -- Replay ledger to get current TX counter
  if fs.exists(FILE.ledger) then
    local lines = readLines(FILE.ledger)
    for _, line in ipairs(lines) do
      local num = line:match("TX%-(%d+)")
      if num then
        local n = tonumber(num) or 0
        if n > tx_counter then tx_counter = n end
      end
    end
    print("  Ledger replayed. Last TX: TX-" .. pad(tx_counter, 6))
  end

  -- Replay share ledger counter
  if fs.exists(FILE.share_ledger) then
    local lines = readLines(FILE.share_ledger)
    for _, line in ipairs(lines) do
      local num = line:match("SH%-(%d+)")
      if num then
        local n = tonumber(num) or 0
        if n > sh_counter then sh_counter = n end
      end
    end
  end

  -- Replay audit counter
  if fs.exists(FILE.audit) then
    local lines = readLines(FILE.audit)
    for _, line in ipairs(lines) do
      local num = line:match("AUDIT%-(%d+)")
      if num then
        local n = tonumber(num) or 0
        if n > audit_counter then audit_counter = n end
      end
    end
  end
end

local function initTreasury()
  -- Create the core system accounts if they don't exist
  if not accountExists("treasury:ascendancy") then
    createAccount("treasury:ascendancy", "treasury", "Ascendancy Treasury", "SYSTEM")
    print("  Created treasury:ascendancy account")
  end
  if not accountExists("market:escrow") then
    createAccount("market:escrow", "escrow", "Market Escrow", "SYSTEM")
    print("  Created market:escrow account")
  end
  if not accountExists("contract:escrow") then
    createAccount("contract:escrow", "escrow", "Contract Escrow", "SYSTEM")
    print("  Created contract:escrow account")
  end

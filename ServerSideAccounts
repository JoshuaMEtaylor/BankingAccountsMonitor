-- REGISTER_COMPANY
-- Idempotent/recovery-safe. If the company metadata exists but the account was
-- lost, this recreates the account instead of failing. This is used by the
-- ColonyBusinessIntegrator rebuild tool after data loss.
handlers["register_company"] = function(sender_id, req)
  local name         = req.name
  local ticker       = req.ticker and string.upper(tostring(req.ticker))
  local biz_type     = req.biz_type or req.industry or "general"
  local owner_id     = req.owner_id or "treasury:quid_bank"
  local shares       = tonumber(req.shares_total) or 1000
  local public_float = tonumber(req.shares_public) or 0
  if not name or not ticker then return false, "Missing name or ticker" end

  local company_id = req.company_id or ("company:" .. string.lower(ticker))
  local existed = companies[company_id] ~= nil

  if type(companies[company_id]) ~= "table" then
    companies[company_id] = {
      name          = name,
      ticker        = ticker,
      biz_type      = biz_type,
      owner_id      = owner_id,
      founded       = timestamp(),
      status        = "active",
      shares_total  = shares,
      shares_public = public_float,
      recovered     = req.recovered == true or nil,
    }
  else
    local c = companies[company_id]
    c.name = c.name or name
    c.ticker = c.ticker or ticker
    c.biz_type = c.biz_type or biz_type
    c.owner_id = c.owner_id or owner_id
    c.status = c.status or "active"
    c.shares_total = tonumber(c.shares_total) or shares
    c.shares_public = tonumber(c.shares_public) or public_float
    c.recovered_at = c.recovered_at or (req.recovered == true and timestamp() or nil)
  end
  saveCompanies()

  local ok, result = ensureAccountRecord(company_id, "company", name, owner_id)
  if not ok then return false, "Company registered but account repair failed: " .. tostring(result) end

  if not existed and shares > 0 then
    writeShareTx(nextShId(), company_id, "SYSTEM", owner_id, shares, "FOUNDER_GRANT", "Founding shares")
  end

  audit("ACTION", "STATE", sender_id, existed and "REPAIR_COMPANY" or "REGISTER_COMPANY", company_id)
  return true, {
    company_id = company_id,
    name = name,
    ticker = ticker,
    repaired = existed or (type(result) == "table" and (result.account_created or result.balance_created)) or false,
    message = existed and "Company registry/account repaired" or "Company registered"
  }
end

-- SET_PRICE
handlers["set_price"] = function(sender_id, req)
  local item  = req.item
  local price = tonumber(req.price)
  if not item or not price then return false, "Missing item or price" end
  local old_price = prices[item] and prices[item].unit_price or nil
  prices[item] = prices[item] or { history = {} }
  if old_price then
    local h = prices[item].history or {}
    h[#h+1] = { price = old_price, time = timestamp() }
    while #h > 30 do table.remove(h, 1) end
    prices[item].history = h
  end
  prices[item].unit_price   = price
  prices[item].last_updated = timestamp()
  savePrices()
  audit("ACTION", "STATE", sender_id, "SET_PRICE:" .. item, tostring(old_price) .. "->" .. tostring(price))
  return true, { item = item, price = price, old_price = old_price }
end


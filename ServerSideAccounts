-- REGISTER_CITIZEN
-- Idempotent/recovery-safe. ColonyBusinessIntegrator can resend cached colonists
-- after bank data loss and this will recreate missing records/accounts.
handlers["register_citizen"] = function(sender_id, req)
  local name     = req.display_name
  local username = req.username
  local password = req.password or "changeme"
  local title    = req.title or "Account Holder"
  if not name or not username then return false, "Missing display_name or username" end

  local key        = string.lower(tostring(username)):gsub("%s+", "_")
  local citizen_id = req.citizen_id or ("citizen:" .. key)
  local existed = citizens[citizen_id] ~= nil

  if type(citizens[citizen_id]) ~= "table" then
    citizens[citizen_id] = {
      display_name  = name,
      username      = key,
      password_hash = simpleHash(password),
      joined        = timestamp(),
      status        = "active",
      title         = title,
      recovered     = req.recovered == true or nil,
    }
  else
    local c = citizens[citizen_id]
    c.display_name = c.display_name or name
    c.username = c.username or key
    c.password_hash = c.password_hash or simpleHash(password)
    c.joined = c.joined or timestamp()
    c.status = c.status or "active"
    c.title = c.title or title
    c.recovered_at = c.recovered_at or (req.recovered == true and timestamp() or nil)
  end
  saveCitizens()

  local ok, result = ensureAccountRecord(citizen_id, "citizen", name, citizen_id)
  if not ok then
    if not existed then citizens[citizen_id] = nil; saveCitizens() end
    return false, "Account repair failed: " .. tostring(result)
  end

  audit("ACTION", "STATE", sender_id, existed and "REPAIR_CITIZEN" or "REGISTER_CITIZEN", citizen_id)
  return true, {
    citizen_id   = citizen_id,
    display_name = name,
    username     = key,
    title        = title,
    repaired     = existed or (type(result) == "table" and (result.account_created or result.balance_created)) or false,
    message      = existed and "Citizen registry/account repaired" or ("Citizen registered. Default password: " .. password)
  }
end


-- =============================================================================
-- MAIN SERVER LOOP
-- =============================================================================
local function handleRequest(sender_id, request)
  if type(request) ~= "table" then return false, "Invalid request format" end
  local req_type = request.type
  if not req_type then return false, "Missing request type" end
  local handler = handlers[req_type]
  if not handler then
    audit("ACTION", "UNKNOWN", sender_id, req_type, "unknown request type")
    return false, "Unknown request type: " .. tostring(req_type)
  end
  local ok, result = pcall(handler, sender_id, request)
  if not ok then
    audit("ERROR", "SYSTEM", sender_id, req_type, "handler error: " .. tostring(result))
    return false, "Internal server error"
  end
  return result
end

local function serverLoop()
  local request_count = 0
  while true do
    local sender_id, message, protocol = rednet.receive(PROTOCOL, 30)
    if sender_id then
      request_count = request_count + 1
      local success, response = handleRequest(sender_id, message)
      rednet.send(sender_id, {
        success  = success,
        response = response,
        time     = timestamp(),
        server   = os.getComputerID()
      }, PROTOCOL)
      if request_count % 5 == 0 then drawStatus() end
    else
      drawStatus()
      rednet.broadcast({
        type    = "treasury_online",
        version = VERSION,
        id      = os.getComputerID(),
        time    = timestamp()
      }, PROTOCOL)
      rednet.broadcast({
        type    = "treasury_online",
        version = VERSION,
        id      = os.getComputerID(),
        time    = timestamp()
      }, PROTOCOL_BROADCAST)
    end
  end
end


-- PAYROLL_SOURCE_FOR_CITIZEN
-- Finds the latest company that actually paid this citizen through COMPANY_PAYROLL.
-- This uses the ledger, not employment mappings, because payroll transactions are
-- the authoritative "who actually pays this worker" trail.
handlers["payroll_source_for_citizen"] = function(sender_id, req)
  local citizen_id = tostring(req and req.citizen_id or "")
  local limit = tonumber(req and req.limit) or 1000
  if citizen_id == "" then return false, "Missing citizen_id" end
  if limit < 1 then limit = 1 end
  if limit > 5000 then limit = 5000 end

  local lines = readLines(FILE.ledger)
  local checked = 0

  for i = #lines, 1, -1 do
    local line = lines[i]
    local tx_id, ts, tx_type, from_id, to_id, amount, memo, status =
      line:match("(TX%-%d+)%s*|%s*(%d+)%s*|%s*([^|]+)%s*|%s*([^|]+)%s*|%s*([^|]+)%s*|%s*(%d+)%s*|%s*([^|]+)%s*|%s*(.+)")

    if tx_id then
      checked = checked + 1
      tx_type = tostring(tx_type or ""):match("^%s*(.-)%s*$")
      from_id = tostring(from_id or ""):match("^%s*(.-)%s*$")
      to_id = tostring(to_id or ""):match("^%s*(.-)%s*$")

      if tx_type == "COMPANY_PAYROLL" and to_id == citizen_id then
        local company = companies[from_id] or {}
        return true, {
          citizen_id = citizen_id,
          company_id = from_id,
          company_name = company.name or company.display_name or from_id,
          ticker = company.ticker,
          tx_id = tx_id,
          time = tonumber(ts),
          amount = tonumber(amount) or 0,
          memo = tostring(memo or ""):match("^%s*(.-)%s*$"),
          checked = checked,
        }
      end

      if checked >= limit then break end
    end
  end

  return false, "No COMPANY_PAYROLL transaction found for " .. citizen_id
end

-- LIST_COMPANY_PAYROLL_PAYEES
-- Returns the distinct citizens actually paid by a company through COMPANY_PAYROLL.
handlers["list_company_payroll_payees"] = function(sender_id, req)
  local company_id = tostring(req and req.company_id or "")
  local limit = tonumber(req and req.limit) or 2000
  if company_id == "" then return false, "Missing company_id" end
  if limit < 1 then limit = 1 end
  if limit > 5000 then limit = 5000 end

  local lines = readLines(FILE.ledger)
  local seen = {}
  local rows = {}
  local checked = 0

  for i = #lines, 1, -1 do
    local line = lines[i]
    local tx_id, ts, tx_type, from_id, to_id, amount, memo, status =
      line:match("(TX%-%d+)%s*|%s*(%d+)%s*|%s*([^|]+)%s*|%s*([^|]+)%s*|%s*([^|]+)%s*|%s*(%d+)%s*|%s*([^|]+)%s*|%s*(.+)")

    if tx_id then
      checked = checked + 1
      tx_type = tostring(tx_type or ""):match("^%s*(.-)%s*$")
      from_id = tostring(from_id or ""):match("^%s*(.-)%s*$")
      to_id = tostring(to_id or ""):match("^%s*(.-)%s*$")

      if tx_type == "COMPANY_PAYROLL" and from_id == company_id and to_id ~= "" and not seen[to_id] then
        seen[to_id] = true
        local emp = employment_mappings[to_id] or {}
        rows[#rows+1] = {
          citizen_id = to_id,
          display_name = emp.display_name or to_id,
          job_text = emp.job_text or "",
          company_id = company_id,
          company_name = (companies[company_id] and (companies[company_id].name or companies[company_id].display_name)) or company_id,
          tx_id = tx_id,
          time = tonumber(ts),
          amount = tonumber(amount) or 0,
          memo = tostring(memo or ""):match("^%s*(.-)%s*$"),
          source = "ledger_company_payroll",
        }
      end

      if checked >= limit then break end
    end
  end

  table.sort(rows, function(a, b)
    return tostring(a.display_name or a.citizen_id) < tostring(b.display_name or b.citizen_id)
  end)

  return true, {
    company_id = company_id,
    payees = rows,
    count = #rows,
    checked = checked,
  }
end

-- COMPANY_PAYROLL
-- Private-sector payroll only. Allows company overdraft by design.
handlers["company_payroll"] = function(sender_id, req)
  local company_id = req.company_id
  local citizen_id = req.citizen_id
  local amount = tonumber(req.amount)
  local memo = req.memo or "Company payroll"

  if not company_id or company_id == "" then return false, "Missing company_id" end
  if not citizen_id or citizen_id == "" then return false, "Missing citizen_id" end
  if not amount or amount <= 0 then return false, "Invalid amount" end
  amount = math.floor(amount)
  if amount <= 0 then return false, "Invalid integer amount" end

  if not accountExists(company_id) then return false, "Company account not found: " .. tostring(company_id) end
  if not accountExists(citizen_id) then return false, "Citizen account not found: " .. tostring(citizen_id) end
  if not companies[company_id] then return false, "Company not registered: " .. tostring(company_id) end
  if not citizens[citizen_id] then return false, "Citizen not registered: " .. tostring(citizen_id) end

  local cacc = accounts[company_id]
  local zacc = accounts[citizen_id]
  if not cacc or cacc.type ~= "company" then return false, "Source is not a company account" end
  if not zacc or zacc.type ~= "citizen" then return false, "Destination is not a citizen account" end

  return transfer(company_id, citizen_id, amount, "COMPANY_PAYROLL", memo, "COMPANY_PAYROLL:" .. tostring(sender_id), true)
end



-- HOSPITALITY_MEAL_PAYMENT
-- System-side charge for inferred Dining Hall / Restaurant meal events.
-- Does not overdraft the citizen and does not auto-charge the treasury.
-- If the citizen cannot cover the full meal, the paid amount is transferred and
-- the unpaid shortfall is returned to the POS terminal for local receivables tracking.
handlers["hospitality_meal_payment"] = function(sender_id, req)
  local citizen_id = req.citizen_id
  local company_id = req.company_id
  local amount = tonumber(req.amount)
  local item = tostring(req.item or "meal")
  local memo = req.memo or ("Hospitality meal: " .. item)

  if not citizen_id or citizen_id == "" then return false, "Missing citizen_id" end
  if not company_id or company_id == "" then return false, "Missing company_id" end
  if not amount or amount <= 0 then return false, "Invalid amount" end
  amount = math.floor(amount)
  if amount <= 0 then return false, "Invalid integer amount" end

  if not accountExists(citizen_id) then return false, "Citizen account not found: " .. tostring(citizen_id) end
  if not accountExists(company_id) then return false, "Hospitality company account not found: " .. tostring(company_id) end

  local zacc = accounts[citizen_id]
  local cacc = accounts[company_id]
  if not zacc or zacc.type ~= "citizen" then return false, "Source is not a citizen account" end
  if not cacc or cacc.type ~= "company" then return false, "Destination is not a company account" end

  local bal = deriveBalance(citizen_id)
  local paid = amount
  if bal < paid then paid = bal end
  paid = math.floor(tonumber(paid) or 0)

  local shortfall = amount - paid
  local tx = nil

  if paid > 0 then
    local ok, res = transfer(citizen_id, company_id, paid, "HOSPITALITY_MEAL", memo, "HOSPITALITY:" .. tostring(sender_id), false)
    if not ok then return false, res end
    tx = res
  end

  return true, {
    citizen_id = citizen_id,
    company_id = company_id,
    requested = amount,
    paid = paid,
    shortfall = shortfall,
    item = item,
    tx = tx,
    tx_id = type(tx) == "table" and tx.tx_id or nil,
  }
end



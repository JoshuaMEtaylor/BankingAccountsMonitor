-- =============================================================================
-- MAIN SERVER LOOP
-- =============================================================================
local function handleRequest(sender_id, request)
  if type(request) ~= "table" then
    return false, "Invalid request format"
  end

  local req_type = request.type
  if not req_type then
    return false, "Missing request type"
  end

  local handler = handlers[req_type]
  if not handler then
    audit("ACTION", "UNKNOWN", sender_id, req_type, "rejected: unknown request type")
    return false, "Unknown request type: " .. tostring(req_type)
  end

  local ok, result = pcall(handler, sender_id, request)
  if not ok then
    -- Handler crashed — log it, return safe error
    audit("ERROR", "SYSTEM", sender_id, req_type, "handler error: " .. tostring(result))
    return false, "Internal error processing request"
  end

  return result  -- result here is (success, data) from the handler
end

local function serverLoop()
  local request_count = 0

  while true do
    local sender_id, message, protocol = rednet.receive(PROTOCOL, 30)

    if sender_id then
      request_count = request_count + 1

      local success, response = handleRequest(sender_id, message)

      -- Send reply directly to the sender
      rednet.send(sender_id, {
        success  = success,
        response = response,
        time     = timestamp(),
        server   = os.getComputerID()
      }, PROTOCOL)

      -- Refresh display every 10 requests
      if request_count % 10 == 0 then
        drawStatus()
      end

    else
      -- Timeout: refresh display and broadcast presence
      drawStatus()
      rednet.broadcast({
        type    = "treasury_online",
        version = VERSION,
        id      = os.getComputerID(),
        label   = os.getComputerLabel(),
        time    = timestamp()
      }, PROTOCOL_BROADCAST)
    end
  end
end

-- =============================================================================
-- ENTRY POINT
-- =============================================================================
local function main()
  term.clear()
  term.setCursorPos(1, 1)

  print("ASCENDANCY TREASURY DB v" .. VERSION)
  print("Booting...")
  print("")

  -- Set label
  if os.getComputerLabel() ~= DB_LABEL then
    os.setComputerLabel(DB_LABEL)
  end

  -- Init
  initFiles()
  initCounters()
  initTreasury()

  local modemOk = openModem()
  if not modemOk then
    print("FATAL: Cannot open modem. Halting.")
    return
  end

  -- Log boot
  audit("SYSTEM", "SYSTEM", os.getComputerID(), "BOOT", "Treasury DB online v" .. VERSION)

  print("")
  print("Boot complete.")
  sleep(1)

  drawStatus()

  -- Announce presence
  rednet.broadcast({
    type    = "treasury_online",
    version = VERSION,
    id      = os.getComputerID(),
    label   = os.getComputerLabel(),
    time    = timestamp()
  }, PROTOCOL_BROADCAST)

  serverLoop()
end

main()

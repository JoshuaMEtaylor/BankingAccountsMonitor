-- STATUS (management)
handlers["status"] = function(sender_id, req)
  if not isTrustedManagement(sender_id) then return false, "Management terminal required" end
  local function count(t) local n=0; for _ in pairs(t) do n=n+1 end; return n end
  return true, {
    version          = VERSION,
    computer_id      = os.getComputerID(),
    label            = os.getComputerLabel(),
    time             = timestamp(),
    uptime           = os.clock(),
    economy_status   = config.economy_status or "active",
    account_count    = count(accounts),
    citizen_count    = count(citizens),
    company_count    = count(companies),
    tx_count         = tx_counter,
    audit_count      = audit_counter,
    supply           = deriveMonetarySupply(),
    management_terminals = config.management_terminals or {}
  }
end

-- ADD_MANAGEMENT_TERMINAL
handlers["add_management_terminal"] = function(sender_id, req)
  if not isTrustedManagement(sender_id) and tonumber(sender_id) ~= os.getComputerID() then
    return false, "Unauthorised"
  end
  local terminal_id = tonumber(req.terminal_id)
  if not terminal_id then return false, "Missing terminal_id" end
  config.management_terminals = config.management_terminals or {}
  for _, id in ipairs(config.management_terminals) do
    if id == terminal_id then return false, "Already registered" end
  end
  config.management_terminals[#config.management_terminals+1] = terminal_id
  saveConfig()
  audit("ACTION", "SYSTEM", sender_id, "ADD_MANAGEMENT_TERMINAL", tostring(terminal_id))
  return true, { message = "Management terminal registered: " .. terminal_id }
end

-- REGISTER_CITIZEN (admin path — management terminal registers a citizen manually)
-- Kept alongside self-registration for admin override capability
handlers["register_citizen"] = function(sender_id, req)
  if not isTrustedManagement(sender_id) then
    audit("ACCESS", "UNKNOWN", sender_id, "REGISTER_CITIZEN", "rejected: not management")
    return false, "Management terminal required"
  end
  local name     = req.display_name
  local username = req.username
  local password = req.password or "changeme"
  local title    = req.title or "Account Holder"
  if not name or not username then return false, "Missing display_name or username" end
  local key        = string.lower(username):gsub("%s+", "_")
  local citizen_id = "citizen:" .. key
  if citizens[citizen_id] then return false, "Username already exists: " .. username end
  citizens[citizen_id] = {
    display_name  = name,
    username      = key,
    password_hash = simpleHash(password),
    joined        = timestamp(),
    status        = "active",
    title         = title
  }
  saveCitizens()
  local ok, result = createAccount(citizen_id, "citizen", name, citizen_id)
  if not ok then
    citizens[citizen_id] = nil; saveCitizens()
    return false, "Account creation failed: " .. tostring(result)
  end
  audit("ACTION", "MANAGEMENT", sender_id, "REGISTER_CITIZEN", citizen_id)
  return true, {
    citizen_id   = citizen_id,
    display_name = name,
    username     = key,
    title        = title,
    message      = "Citizen registered. Default password: " .. password
  }
end

-- COMPANY_INFO — get company details + live shareholdings
handlers["company_info"] = function(sender_id, req)
  local company_id = req.company_id
  if not company_id then return false, "Missing company_id" end
  local company = companies[company_id]
  if not company then return false, "Company not found: " .. tostring(company_id) end
  local balance  = deriveBalance(company_id)
  local holdings = deriveShareHoldings(company_id)
  return true, {
    company_id    = company_id,
    name          = company.name,
    ticker        = company.ticker,
    biz_type      = company.biz_type,
    owner_id      = company.owner_id,
    status        = company.status,
    shares_total  = company.shares_total,
    shares_public = company.shares_public,
    cash_balance  = balance,
    shareholders  = holdings,
    founded       = company.founded
  }
end

-- LIST_CITIZENS — management overview of all citizen accounts
handlers["list_citizens"] = function(sender_id, req)
  if not isTrustedManagement(sender_id) then return false, "Management terminal required" end
  local result = {}
  for citizen_id, citizen in pairs(citizens) do
    result[#result+1] = {
      citizen_id   = citizen_id,
      display_name = citizen.display_name,
      username     = citizen.username,
      title        = citizen.title,
      status       = citizen.status,
      joined       = citizen.joined,
      balance      = deriveBalance(citizen_id)
    }
  end
  table.sort(result, function(a,b) return (a.display_name or "") < (b.display_name or "") end)
  return true, { citizens = result, count = #result }
end

-- SUSPEND_ACCOUNT / UNSUSPEND_ACCOUNT — management only
handlers["suspend_account"] = function(sender_id, req)
  if not isTrustedManagement(sender_id) then return false, "Management terminal required" end
  local citizen_id = req.citizen_id
  if not citizens[citizen_id] then return false, "Citizen not found" end
  citizens[citizen_id].status = "suspended"
  saveCitizens()
  if accounts[citizen_id] then accounts[citizen_id].status = "suspended"; saveAccounts() end
  audit("ACTION", "MANAGEMENT", sender_id, "SUSPEND", citizen_id)
  return true, { message = "Account suspended: " .. citizen_id }
end

handlers["unsuspend_account"] = function(sender_id, req)
  if not isTrustedManagement(sender_id) then return false, "Management terminal required" end
  local citizen_id = req.citizen_id
  if not citizens[citizen_id] then return false, "Citizen not found" end
  citizens[citizen_id].status = "active"
  saveCitizens()
  if accounts[citizen_id] then accounts[citizen_id].status = "active"; saveAccounts() end
  audit("ACTION", "MANAGEMENT", sender_id, "UNSUSPEND", citizen_id)
  return true, { message = "Account reinstated: " .. citizen_id }
end


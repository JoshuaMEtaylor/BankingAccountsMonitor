-- RECORD_PRICE_OBSERVATION
-- Optional simple hook for later: contract/server terminals can report what was
-- actually paid. For now this is stored as evidence, not a deep behavioural sim.
handlers["record_price_observation"] = function(sender_id, req)
  ensurePriceOracle()
  local item = req and (req.item or req.service or req.name)
  local sector = req and req.sector or (item and classifyItemSector(item) or "general")
  local total = tonumber(req and (req.total or req.amount or req.price))
  local count = math.max(1, math.floor(tonumber(req and (req.count or req.qty or req.quantity)) or 1))
  if not item or item == "" or not total or total <= 0 then return false, "Missing item/service or total" end
  local obs = {
    time = timestamp(),
    source = "terminal:" .. tostring(sender_id),
    item = simpleItemName(item),
    sector = sector,
    total = total,
    count = count,
    unit = total / count,
    memo = req and req.memo or nil,
  }
  price_oracle.observations[#price_oracle.observations + 1] = obs
  while #price_oracle.observations > 300 do table.remove(price_oracle.observations, 1) end
  savePriceOracle()
  return true, { recorded = obs, observations = #price_oracle.observations }
end


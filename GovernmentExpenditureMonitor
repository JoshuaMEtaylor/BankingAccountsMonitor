local function drawScreen(data, err)
  cls()
  topBar()

  local clock = mcDate() .. "  " .. mcTime()
  at(2, 2, clock, C.dim, C.bg)
  local src = "Bank: " .. tostring(bank_id or "?") .. "  Source: " .. tostring(last_data_source)
  at(math.max(2, W - #src), 2, src, C.dim, C.bg)

  if err then
    at(2, 4, "Unable to load government expenditure.", C.bad, C.bg)
    at(2, 6, tostring(err):sub(1, W - 4), C.dim, C.bg)
    at(2, 8, "The monitor will retry. Touch monitor or press R to retry now.", C.dim, C.bg)
    last_message = "Waiting for valid bank data | " .. tostring(err):sub(1, math.max(1, W - 32))
    last_colour = C.bad
    statusBar()
    return
  end

  data = data or { total = 0, annual_total = 0, observed_total = 0, count = 0, sectors = {}, raw_count = 0, observed_days = 1 }

  local leftW = math.max(36, math.floor(W * 0.50))
  if leftW > W - 24 then leftW = W - 24 end
  local rightX = leftW + 3

  drawBox(2, 4, leftW - 2, H - 5, "ANNUALISED PAYROLL")

  if data.status_only then
    at(4, 6, "Connected, but no history endpoint answered.", C.warn, C.bg)
    at(4, 7, "Bank status works; payroll history endpoint does not.", C.dim, C.bg)
  else
    at(4, 6, "Expense model:", C.label, C.bg)
    at(4, 7, "Government payroll only", C.text, C.bg)
  end

  at(4, 9,  "Annualised payroll: " .. money(data.annual_total or data.total), C.good, C.bg)
  at(4, 10, "Observed payroll:   " .. money(data.observed_total or 0), C.text, C.bg)
  at(4, 11, "Period basis:       " .. tostring(data.observed_days or 1) .. "/365 MCT days", C.dim, C.bg)
  at(4, 12, "Payroll entries:    " .. tostring(data.count or 0), C.text, C.bg)
  at(4, 13, "Rows read/window:   " .. tostring(data.raw_count or 0) .. "/" .. tostring(data.considered_rows or 0), C.dim, C.bg)

  at(4, 15, "Sector", C.label, C.bg)
  at(math.max(20, leftW - 22), 15, "Annual", C.label, C.bg)
  at(math.max(30, leftW - 9), 15, "Share", C.label, C.bg)

  local y = 16
  if #data.sectors == 0 then
    at(4, y, "No payroll expenditure found.", C.dim, C.bg)
    y = y + 1
  else
    for _, s in ipairs(data.sectors) do
      if y >= H - 5 then break end
      fill(4, y, 2, 1, s.color or C.empty)
      at(7, y, s.label:sub(1, 16), C.text, C.bg)
      at(math.max(20, leftW - 22), y, money(s.annual or s.amount), C.good, C.bg)
      at(math.max(30, leftW - 9), y, pct(s.annual or s.amount, data.annual_total or data.total), C.dim, C.bg)
      y = y + 1
    end
  end

  if data.last then
    local memo = tostring(txField(data.last, "memo", "description", "note") or "")
    if memo ~= "" then
      at(4, H - 4, "Last: " .. memo:sub(1, leftW - 10), C.dim, C.bg)
    end
  end

  drawBox(rightX, 4, W - rightX - 1, H - 5, "PAYROLL MIX")

  local pieW = W - rightX - 4
  local rx = math.floor(math.min(14, math.max(4, pieW / 3)))
  local ry = math.floor(math.min(8, math.max(3, (H - 8) / 3)))
  local cx = rightX + math.floor((W - rightX) / 2)
  local cy = 7 + ry

  drawPie(cx, cy, rx, ry, data.sectors, data.annual_total or data.total)
  at(rightX + 2, cy + ry + 2, "Annual: " .. money(data.annual_total or data.total), C.good, C.bg)

  local legendY = cy + ry + 4
  if legendY < H - 7 then
    drawLegend(rightX + 2, legendY, data.sectors, data.annual_total or data.total)
  else
    drawLegend(rightX + 2, 5, data.sectors, data.annual_total or data.total)
  end

  local age = "never"
  if last_refresh > 0 then age = tostring(math.floor((nowMs() - last_refresh) / 1000)) .. "s ago" end
  last_message = "Refresh " .. age .. " | Q quit | R refresh | annualised 365 MCT days"
  last_colour = C.dim
  statusBar()
end

-- =============================================================================
-- MAIN LOOP
-- =============================================================================
local function main()
  useMonitorIfPresent()

  if not openModem() then
    connectScreen("No modem found. Attach modem and reboot.", C.bad)
    return
  end

  while not discoverBank() do
    last_message = "Bank server not found. Retrying..."
    last_colour = C.bad
    connectScreen("Bank server not found. Retrying...", C.bad)
    sleep(3)
  end

  local latest = nil
  local latest_err = nil

  local function refresh()
    loadingScreen("Loading government payroll history...", "Trying fiscal_history, treasury_history, then status fallback.")
    local ok, res = requestTreasuryHistory()
    if ok then
      latest = analyse(res)
      latest_err = nil
      last_refresh = nowMs()
      last_error = nil
    else
      latest_err = res
      latest = nil
      last_error = res
    end
    drawScreen(latest, latest_err)
  end

  refresh()

  local timer = os.startTimer(REFRESH_SECONDS)
  while true do
    local ev, p1 = os.pullEvent()

    if ev == "timer" and p1 == timer then
      refresh()
      timer = os.startTimer(REFRESH_SECONDS)
    elseif ev == "key" then
      if p1 == keys.q then
        cls()
        at(2, 2, "Government Expenditure Monitor closed.", C.dim, C.bg)
        return
      elseif p1 == keys.r then
        refresh()
        timer = os.startTimer(REFRESH_SECONDS)
      end
    elseif ev == "monitor_touch" then
      refresh()
      timer = os.startTimer(REFRESH_SECONDS)
    end
  end
end

local ok, err = pcall(main)
if not ok then
  term.redirect(native_term)
  term.setBackgroundColor(colors.black)
  term.setTextColor(colors.red)
  term.clear()
  term.setCursorPos(1, 1)
  print("GovernmentExpenditureMonitor crashed")
  print(tostring(err))
end

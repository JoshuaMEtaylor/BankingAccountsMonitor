local function drawWatchDashboard(data, startY)
  local bodyY = startY or 4
  local bottom = H - 1

  local treasury = supplyValue(data, "treasury_balance")
  local issued = supplyValue(data, "in_circulation")
  local private = supplyValue(data, "citizen_holdings") + supplyValue(data, "company_holdings") + supplyValue(data, "escrow_held")
  local control = issued > 0 and (treasury / issued) or 0
  local slices = positiveSlices(data)

  local function centreText(y, text, fg)
    text = tostring(text or "")
    at(math.floor((W - #text) / 2) + 1, y, text, fg or C.text, C.bg)
  end

  local function visibleRows()
    local rows = {}
    for _, s in ipairs(data.order or {}) do
      if (s.chart_value or 0) > 0 or s.key == "defence" or s.key == "research" or s.key == "welfare" then
        rows[#rows + 1] = s
      end
    end
    table.sort(rows, function(a, b)
      local av, bv = tonumber(a.chart_value or 0) or 0, tonumber(b.chart_value or 0) or 0
      if av == bv then return tostring(a.label) < tostring(b.label) end
      return av > bv
    end)
    return rows
  end

  -- Header line: keep this light. The chart is the centrepiece.
  centreText(3, "Annual public expenditure mix", C.label)
  at(3, 4, mcTime(), C.dim, C.bg)
  at(W - 38, 4, "Live / read-only / auto refresh", C.dim, C.bg)

  -- Main centred chart panel.
  local chartX = 3
  local chartY = 6
  local chartW = W - 4
  local chartH = math.max(16, H - 12)
  if chartY + chartH > H - 4 then chartH = math.max(14, (H - 4) - chartY) end
  local chartBottom = chartY + chartH - 1

  box(chartX, chartY, chartW, chartH, "Expenditure composition")

  local totalLine = "TOTAL " .. money(data.chart_total)
  local recentLine = "RECENT " .. money(data.actual_total) .. " / " .. tostring(data.observed_days) .. " MC day(s)"
  at(chartX + 3, chartY + 2, totalLine, C.good, C.bg)
  at(W - #recentLine - 3, chartY + 2, recentLine, C.warn, C.bg)

  -- Keep the chart dominant, but leave breathing room for sector labels
  -- and leader lines around the ring.
  local rx = math.max(8, math.min(15, math.floor(chartW * 0.15)))
  local ry = math.max(4, math.min(7, math.floor((chartH - 8) / 2)))
  local cx = math.floor(W / 2)
  local cy = chartY + math.floor(chartH / 2) + 1
  if cy - ry < chartY + 4 then cy = chartY + 4 + ry end
  if cy + ry > chartBottom - 1 then cy = chartBottom - 1 - ry end

  drawPie(cx, cy, rx, ry, slices, data.chart_total)

  -- Sector labels are now outside the donut and connected back to their slice.
  -- Nothing is written in the middle of the chart.
  if slices and #slices > 0 then
    drawPieLabels(cx, cy, rx, ry, slices, data.chart_total, chartX, chartY, chartW, chartH)
  else
    at(cx - 6, cy, "NO SPEND", C.warn, C.bg)
  end

  -- Bottom strip: key state figures, low visual weight.
  local stripY = chartBottom + 1
  if stripY <= H - 3 then
    line(3, stripY, W - 5, "-", C.grid, C.bg)
    local colW = math.max(18, math.floor((W - 6) / 4))
    local y1 = stripY + 1
    at(4, y1, "Treasury", C.dim, C.bg)
    at(14, y1, shortText(money(treasury), colW - 10), C.good, C.bg)
    at(4 + colW, y1, "Payroll/day", C.dim, C.bg)
    at(16 + colW, y1, shortText(money(data.forecast_daily), colW - 12), C.label, C.bg)
    at(4 + (colW * 2), y1, "Private", C.dim, C.bg)
    at(13 + (colW * 2), y1, shortText(money(private), colW - 9), C.label, C.bg)
    at(4 + (colW * 3), y1, "Control", C.dim, C.bg)
    at(13 + (colW * 3), y1, string.format("%.1f%%", control * 100), C.dim, C.bg)
  end

  -- Recent outflow ticker, kept to one line so it does not compete with the chart.
  if H >= 29 then
    local tickerY = H - 2
    local text = "Recent: "
    local shown = 0
    for _, tx in ipairs(data.outflows or {}) do
      if shown >= 3 then break end
      local label = shortText(txField(tx, "memo", "description", "note") or txField(tx, "type", "tx_type") or "Outflow", 18)
      text = text .. label .. " " .. money(amountOf(tx))
      shown = shown + 1
      if shown < 3 then text = text .. "  |  " end
    end
    if shown == 0 then text = text .. "no treasury outflows in current window" end
    at(3, tickerY, shortText(text, W - 5), C.dim, C.bg)
  end
end

local function drawScreen(data, err)
  cls()
  topBar()

  if err then
    at(2, 5, "Unable to load expenditure data: " .. shortText(err, W - 4), C.bad, C.bg)
    at(2, 7, "Diagnostics:", C.label, C.bg)
    local y = 8
    for k, v in pairs(last_diagnostics or {}) do
      if y >= H - 1 then break end
      at(4, y, tostring(k) .. ": " .. shortText(v, W - 8), C.dim, C.bg)
      y = y + 1
    end
  elseif not data then
    at(2, 5, "Awaiting expenditure data...", C.warn, C.bg)
  else
    drawWatchDashboard(data, 5)
  end

  local age = "never"
  if last_refresh_ms > 0 then age = tostring(math.floor((nowMs() - last_refresh_ms) / 1000)) .. "s ago" end
  last_message = "Live refresh " .. age .. " | source " .. tostring(last_data_source) .. " | read-only monitor"
  last_colour = C.dim
  statusBar()
end

-- =============================================================================
-- MAIN
-- =============================================================================
local function main()
  useMonitorIfPresent()

  if not openModem() then
    connectScreen("No modem found. Attach modem and reboot.", C.bad)
    return
  end

  while not discoverBank() do
    connectScreen("Bank server not found. Retrying...", C.bad)
    sleep(3)
  end

  local latest = nil
  local latest_err = nil

  local function refresh()
    connectScreen("Loading live expenditure data...", C.label)
    local ok, res = fetchData()
    if ok then
      latest = res
      latest_err = nil
      last_refresh_ms = nowMs()
    else
      latest = nil
      latest_err = tostring(res)
    end
    drawScreen(latest, latest_err)
  end

  refresh()
  local timer = os.startTimer(REFRESH_SECONDS)

  while true do
    local ev, p1 = os.pullEvent()
    if ev == "timer" and p1 == timer then
      refresh()
      timer = os.startTimer(REFRESH_SECONDS)
    end
  end
end

local ok, err = pcall(main)
if not ok then
  term.redirect(native_term)
  term.setBackgroundColor(colors.black)
  term.setTextColor(colors.red)
  term.clear()
  term.setCursorPos(1, 1)
  print("GovernmentExpenditureMonitor crashed")
  print(tostring(err))
end

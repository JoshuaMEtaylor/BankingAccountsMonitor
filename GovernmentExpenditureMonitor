local function buildTabs(data)
  local tabs = { { key = "overview", label = "OVERVIEW" } }
  if not data then return tabs end

  for _, cat in ipairs(CATEGORY_DEFS) do
    local s = data.sectors[cat.key]
    local mustShow = (cat.key == "defence" or cat.key == "research" or cat.key == "welfare")
    if mustShow or (s and ((s.chart_value or 0) > 0 or (s.actual or 0) > 0 or (s.forecast_annual or 0) > 0)) then
      tabs[#tabs + 1] = { key = cat.key, label = cat.short }
    end
  end
  return tabs
end

local function drawTabs(tabs)
  tab_hits = {}
  local x, y = 2, 2
  local maxw = W - 2
  for _, tab in ipairs(tabs or {}) do
    local label = " " .. tostring(tab.label) .. " "
    local tw = #label
    if x + tw > maxw then
      y = y + 1
      x = 2
    end
    local selected = tab.key == active_tab
    fill(x, y, tw, 1, selected and C.selected or C.tab)
    at(x, y, label, selected and colors.white or colors.lightGray, selected and C.selected or C.tab)
    tab_hits[#tab_hits + 1] = { key = tab.key, x1 = x, x2 = x + tw - 1, y1 = y, y2 = y }
    x = x + tw + 1
  end
  return y + 1
end

local function hitTab(mx, my)
  for _, h in ipairs(tab_hits or {}) do
    if mx >= h.x1 and mx <= h.x2 and my >= h.y1 and my <= h.y2 then return h.key end
  end
  return nil
end

local function nextTab(tabs, dir)
  if not tabs or #tabs == 0 then active_tab = "overview"; return end
  local idx = 1
  for i, t in ipairs(tabs) do if t.key == active_tab then idx = i break end end
  idx = idx + (dir or 1)
  if idx < 1 then idx = #tabs end
  if idx > #tabs then idx = 1 end
  active_tab = tabs[idx].key
end

-- =============================================================================
-- PIE CHART
-- =============================================================================
local function atan2(y, x)
  if math.atan2 then return math.atan2(y, x) end
  if x > 0 then return math.atan(y / x) end
  if x < 0 and y >= 0 then return math.atan(y / x) + math.pi end
  if x < 0 and y < 0 then return math.atan(y / x) - math.pi end
  if x == 0 and y > 0 then return math.pi / 2 end
  if x == 0 and y < 0 then return -math.pi / 2 end
  return 0
end

local function sectorAtShare(slices, share)
  local acc = 0
  for _, s in ipairs(slices or {}) do
    acc = acc + (tonumber(s.value) or 0)
    if share <= acc then return s end
  end
  return slices and slices[#slices] or nil
end

local function positiveSlices(data)
  local slices = {}
  if not data then return slices end
  for _, s in ipairs(data.order or {}) do
    if (s.chart_value or 0) > 0 then
      slices[#slices + 1] = {
        key = s.key,
        label = s.label,
        color = s.color,
        value = s.chart_value,
        actual = s.actual_annual,
        forecast = s.forecast_annual,
      }
    end
  end
  table.sort(slices, function(a, b) return (a.value or 0) > (b.value or 0) end)
  return slices
end

local function drawPie(cx, cy, rx, ry, slices, total)
  total = tonumber(total) or 0
  if total <= 0 or not slices or #slices == 0 then
    at(cx - 8, cy, "No spend yet", C.warn, C.bg)
    return
  end

  for yy = cy - ry, cy + ry do
    for xx = cx - rx, cx + rx do
      local dx = (xx - cx) / math.max(1, rx)
      local dy = (yy - cy) / math.max(1, ry)
      if (dx * dx) + (dy * dy) <= 1 then
        local ang = atan2(dy, dx)
        if ang < 0 then ang = ang + (2 * math.pi) end
        local share = (ang / (2 * math.pi)) * total
        local s = sectorAtShare(slices, share)
        if s then
          at(xx, yy, " ", colors.white, s.color)
        end
      end
    end
  end

  -- small hollow centre, makes the chart look cleaner on monitors
  local irx = math.max(1, math.floor(rx * 0.30))
  local iry = math.max(1, math.floor(ry * 0.30))
  for yy = cy - iry, cy + iry do
    for xx = cx - irx, cx + irx do
      local dx = (xx - cx) / math.max(1, irx)
      local dy = (yy - cy) / math.max(1, iry)
      if (dx * dx) + (dy * dy) <= 1 then at(xx, yy, " ", C.bg, C.bg) end
    end
  end
end

local function clamp(n, lo, hi)
  n = tonumber(n) or 0
  if n < lo then return lo end
  if n > hi then return hi end
  return n
end

local function round(n)
  n = tonumber(n) or 0
  if n >= 0 then return math.floor(n + 0.5) end
  return math.ceil(n - 0.5)
end

local function drawHLine(x1, x2, y, fg)
  if y < 1 or y > H then return end
  x1 = round(x1); x2 = round(x2)
  if x2 < x1 then x1, x2 = x2, x1 end
  x1 = clamp(x1, 1, W)
  x2 = clamp(x2, 1, W)
  if x2 >= x1 then line(x1, y, x2 - x1 + 1, "-", fg or C.grid, C.bg) end
end

local function drawVLine(x, y1, y2, fg)
  x = round(x)
  if x < 1 or x > W then return end
  y1 = round(y1); y2 = round(y2)
  if y2 < y1 then y1, y2 = y2, y1 end
  y1 = clamp(y1, 1, H)
  y2 = clamp(y2, 1, H)
  for yy = y1, y2 do at(x, yy, "|", fg or C.grid, C.bg) end
end

local function resolveLabelColumn(rows, minY, maxY)
  table.sort(rows, function(a, b) return (a.natural_y or 0) < (b.natural_y or 0) end)
  local gap = 3

  for i, r in ipairs(rows) do
    local y = clamp(r.natural_y or minY, minY, maxY)
    if i > 1 and y < rows[i - 1].label_y + gap then
      y = rows[i - 1].label_y + gap
    end
    r.label_y = y
  end

  if #rows > 0 then
    local overflow = (rows[#rows].label_y or maxY) - maxY
    if overflow > 0 then
      for _, r in ipairs(rows) do r.label_y = r.label_y - overflow end
    end

    local underflow = minY - (rows[1].label_y or minY)
    if underflow > 0 then
      for _, r in ipairs(rows) do r.label_y = r.label_y + underflow end
    end
  end
end

local function drawPieLabels(cx, cy, rx, ry, slices, total, chartX, chartY, chartW, chartH)
  total = tonumber(total) or 0
  if total <= 0 or not slices or #slices == 0 then return end

  local chartRight = chartX + chartW - 1
  local minY = chartY + 4
  local maxY = chartY + chartH - 4
  if maxY < minY then maxY = minY end

  local labelW = 26
  local left, right = {}, {}
  local acc = 0
  for _, s in ipairs(slices or {}) do
    local v = tonumber(s.value) or 0
    if v > 0 then
      local mid = ((acc + (v / 2)) / total) * (2 * math.pi)
      local c = math.cos(mid)
      local sn = math.sin(mid)
      local row = {
        sector = s,
        side = c >= 0 and "right" or "left",
        natural_y = round(cy + sn * (ry + 4)),
      }
      if row.side == "right" then right[#right + 1] = row else left[#left + 1] = row end
    end
    acc = acc + v
  end

  resolveLabelColumn(left, minY, maxY)
  resolveLabelColumn(right, minY, maxY)

  -- Fixed far-side columns. No pointers, no leader lines, just lots of room.
  local leftTextX  = chartX + 4
  local rightTextX = chartRight - labelW - 4

  local function drawOne(r)
    local s = r.sector
    local name = shortText(s.label or "Sector", 15)
    local share = pct(s.value, total)
    local value = shortText(money(s.value), 16)
    local y = r.label_y or r.natural_y

    if r.side == "right" then
      at(rightTextX, y, shortText(name .. " " .. share, labelW), C.text, C.bg)
      at(rightTextX, y + 1, value, C.good, C.bg)
    else
      at(leftTextX, y, shortText(name .. " " .. share, labelW), C.text, C.bg)
      at(leftTextX, y + 1, value, C.good, C.bg)
    end
  end

  for _, r in ipairs(left) do drawOne(r) end
  for _, r in ipairs(right) do drawOne(r) end
end

local function drawLegend(x, y, w, slices, total, maxRows)
  maxRows = maxRows or 8
  local row = 0
  for _, s in ipairs(slices or {}) do
    if row >= maxRows then break end
    at(x, y + row, " ", colors.white, s.color)
    at(x + 2, y + row, shortText(s.label, math.max(6, w - 22)), C.text, C.bg)
    at(x + w - 20, y + row, pct(s.value, total), C.dim, C.bg)
    at(x + w - 10, y + row, shortText(money(s.value), 10), C.good, C.bg)
    row = row + 1
  end
end

local function drawTinyBar(x, y, w, value, total, color)
  total = tonumber(total) or 0
  value = tonumber(value) or 0
  local filled = 0
  if total > 0 then filled = math.floor((value / total) * w + 0.5) end
  filled = clamp(filled, 0, w)
  fill(x, y, w, 1, colors.gray)
  if filled > 0 then fill(x, y, filled, 1, color or C.good) end
end


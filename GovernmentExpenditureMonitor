local function consoleLog(text)
  local cur = term.current()
  term.redirect(native_term)
  term.setTextColor(colors.lightGray)
  print("[GovEx] " .. tostring(text))
  term.redirect(cur)
end

local function useMonitorIfPresent()
  local mon = peripheral.find("monitor")
  if mon then
    local okName, name = pcall(peripheral.getName, mon)
    monitor_name = okName and name or "monitor"
    if mon.setTextScale then mon.setTextScale(0.5) end
    term.redirect(mon)
    using_monitor = true
    refreshSize()
    consoleLog("Rendering on monitor: " .. tostring(monitor_name))
    return true
  end
  using_monitor = false
  refreshSize()
  consoleLog("No monitor found; using terminal")
  return false
end

local function openModem()
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      local m = peripheral.wrap(name)
      if m and m.isWireless and m.isWireless() then
        rednet.open(name)
        modem_name = name
        return true
      end
    end
  end
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      rednet.open(name)
      modem_name = name
      return true
    end
  end
  return false
end

local function connectScreen(message, colour)
  cls()
  topBar()
  at(2, 3, mcTime(), C.dim, C.bg)
  at(2, 5, message or "Connecting...", colour or C.dim, C.bg)
  at(2, 7, "Modem: " .. tostring(modem_name or "none"), C.dim, C.bg)
  at(2, 8, "Monitor: " .. tostring(monitor_name or (using_monitor and "attached" or "terminal")), C.dim, C.bg)
  statusBar()
end

local function dbRequest(req, timeout)
  timeout = timeout or DB_TIMEOUT
  if not bank_id then return false, "No bank connected" end

  rednet.send(bank_id, req, BANK_PROTOCOL)
  local deadline = os.clock() + timeout
  while true do
    local remaining = deadline - os.clock()
    if remaining <= 0 then return false, "No response for " .. tostring(req and req.type) end
    local sender, msg = rednet.receive(BANK_PROTOCOL, remaining)
    if sender == bank_id and type(msg) == "table" and msg.success ~= nil then
      return msg.success, msg.response
    end
  end
end

local function validateBank(sender)
  rednet.send(sender, { type = "status" }, BANK_PROTOCOL)
  local deadline = os.clock() + 2
  while true do
    local rem = deadline - os.clock()
    if rem <= 0 then return false end
    local sid, msg = rednet.receive(BANK_PROTOCOL, rem)
    if sid == sender and type(msg) == "table" and msg.success == true and type(msg.response) == "table" then
      local r = msg.response
      if r.supply or r.account_count or r.citizen_count or r.company_count then
        bank_id = sender
        return true
      end
    end
  end
end

local function discoverBank()
  for attempt = 1, 8 do
    connectScreen("Finding Quid bank server... attempt " .. tostring(attempt), C.dim)
    rednet.broadcast({ type = "ping" }, BANK_PROTOCOL)
    local deadline = os.clock() + 3
    while os.clock() < deadline do
      local sid, msg = rednet.receive(BANK_PROTOCOL, deadline - os.clock())
      if sid and type(msg) == "table" then
        if msg.type == "treasury_online" or msg.success ~= nil then
          if validateBank(sid) then
            connectScreen("Connected to Quid bank " .. tostring(bank_id), C.good)
            sleep(0.4)
            return true
          end
        end
      end
    end
  end
  return false
end

local function endpoint(name, req)
  local ok, res = dbRequest(req, DB_TIMEOUT)
  last_diagnostics[name] = ok and "ok" or tostring(res)
  if ok and type(res) == "table" then
    return true, res
  end
  return false, res
end

-- =============================================================================
-- CLASSIFICATION
-- =============================================================================
local function txField(tx, ...)
  for i = 1, select("#", ...) do
    local k = select(i, ...)
    if tx and tx[k] ~= nil then return tx[k] end
  end
  return nil
end

local function txText(tx)
  local parts = {
    txField(tx, "type", "tx_type") or "",
    txField(tx, "memo", "description", "note") or "",
    txField(tx, "sector", "payroll_sector", "department") or "",
    txField(tx, "from", "from_id") or "",
    txField(tx, "to", "to_id") or "",
    txField(tx, "counterparty_id") or "",
    txField(tx, "counterparty_name") or "",
  }
  return lower(table.concat(parts, " "))
end

local function containsAny(text, list)
  text = lower(text or "")
  for _, word in ipairs(list) do
    if text:find(word, 1, true) then return true end
  end
  return false
end

local function txDirection(tx)
  local d = upper(txField(tx, "direction") or "")
  if d ~= "" then return d end
  local from_id = trim(txField(tx, "from", "from_id") or "")
  local to_id = trim(txField(tx, "to", "to_id") or "")
  if from_id == TREASURY_ACCOUNT then return "OUT" end
  if to_id == TREASURY_ACCOUNT then return "IN" end
  return "OTHER"
end

local function isTreasuryOutflow(tx)
  local typ = upper(txField(tx, "type", "tx_type") or "")
  if typ == "MINT" or typ == "BURN" then return false end
  if txDirection(tx) == "OUT" then return true end
  local from_id = trim(txField(tx, "from", "from_id") or "")
  return from_id == TREASURY_ACCOUNT
end

local function classifyTx(tx)
  local explicit = lower(txField(tx, "sector", "payroll_sector", "department") or "")
  if explicit == "defense" then return "defence" end
  if CATEGORY_LOOKUP[explicit] then return explicit end

  local text = txText(tx)

  if containsAny(text, { "welfare", "food", "meal", "dining", "restaurant", "hospitality", "salmon", "subsidy", "benefit", "relief", "care", "service payment", "service_payment", "food service", "food servicing" }) then
    return "welfare"
  end
  if containsAny(text, { "defence", "defense", "soldier", "guard", "archer", "knight", "barracks", "tower", "military", "security", "weapon", "armour", "armor" }) then
    return "defence"
  end
  if containsAny(text, { "research", "university", "library", "school", "education", "teacher", "student", "pupil", "scholar", "science" }) then
    return "research"
  end
  if containsAny(text, { "logistics", "courier", "delivery", "warehouse", "transport", "shipping", "hauling" }) then
    return "logistics"
  end
  if containsAny(text, { "admin", "administration", "fiscal", "treasury", "state office", "bureau", "clerk" }) then
    return "administration"
  end
  if containsAny(text, { "infrastructure", "construction", "builder", "road", "bridge", "public works", "maintenance", "repair", "build project" }) then
    return "infrastructure"
  end
  if containsAny(text, { "grant", "stimulus", "aid", "support payment", "state support" }) then
    return "grants"
  end
  if containsAny(text, { "interest", "loan", "debt", "bond", "finance charge" }) then
    return "finance"
  end

  return "other"
end

local function employeeText(e)
  local parts = {}
  if type(e) ~= "table" then return "" end
  for _, k in ipairs({ "job_text", "job", "title", "role", "profession", "industry", "work_type", "work_name", "company_name" }) do
    if e[k] then parts[#parts + 1] = tostring(e[k]) end
  end
  return lower(table.concat(parts, " "))
end

local function classifyEmployeeSector(e)
  local ind = lower(e and e.industry or "")
  if ind == "defense" then return "defence" end
  if ind == "defence" or ind == "research" or ind == "logistics" then return ind end

  local text = employeeText(e)
  if containsAny(text, { "soldier", "guard", "archer", "knight", "barracks", "tower", "combat", "defence", "defense" }) then return "defence" end
  if containsAny(text, { "research", "university", "library", "teacher", "student", "pupil", "school" }) then return "research" end
  if containsAny(text, { "courier", "delivery", "warehouse", "logistics", "transport" }) then return "logistics" end
  return nil
end

local function wageTierForEmployee(e, sector)
  local text = employeeText(e)
  if sector == "defence" then
    if containsAny(text, { "knight", "captain", "officer", "paladin", "commander" }) then return "elite" end
    if containsAny(text, { "soldier", "guard", "archer", "ranger", "barracks", "tower" }) then return "skilled" end
    return "unskilled"
  elseif sector == "research" then
    if containsAny(text, { "university", "professor", "alchemist", "enchant", "doctor", "scientist" }) then return "elite" end
    return "skilled"
  elseif sector == "logistics" then
    if containsAny(text, { "courier", "warehouse", "manager", "delivery" }) then return "skilled" end
    return "unskilled"
  end
  return "skilled"
end

local function displayName(e)
  return tostring((e and (e.display_name or e.name or e.citizen_id)) or "unknown")
end

-- =============================================================================
-- DATA FETCH / ANALYSIS
-- =============================================================================
local function newSector(cat)
  return {
    key = cat.key,
    label = cat.label,
    short = cat.short,
    color = cat.color,
    actual = 0,
    actual_annual = 0,
    forecast_daily = 0,
    forecast_annual = 0,
    chart_value = 0,
    tx_count = 0,
    employees = 0,
    transactions = {},
    workers = {},
  }
end

local function blankData()
  local sectors = {}
  local order = {}
  for _, cat in ipairs(CATEGORY_DEFS) do
    sectors[cat.key] = newSector(cat)
    order[#order + 1] = sectors[cat.key]
  end
  return {
    sectors = sectors,
    order = order,
    transactions = {},
    outflows = {},
    status = {},
    supply = {},
    history_balance = nil,
    observed_days = 1,
    actual_total = 0,
    actual_daily = 0,
    actual_annual = 0,
    forecast_daily = 0,
    forecast_annual = 0,
    chart_total = 0,
    income_total = 0,
    tx_count = 0,
    source = "none",
  }
end

local function requestTreasuryHistory()
  local ok, res = endpoint("treasury_history", {
    type = "treasury_history",
    account_id = TREASURY_ACCOUNT,
    limit = HISTORY_LIMIT,
  })
  if ok then last_data_source = "treasury_history"; return true, res end

  ok, res = endpoint("fiscal_history", {
    type = "fiscal_history",
    account_id = TREASURY_ACCOUNT,
    limit = HISTORY_LIMIT,
  })
  if ok then last_data_source = "fiscal_history"; return true, res end

  return false, res
end

local function transactionsFromHistory(res)
  if type(res) ~= "table" then return {} end
  if type(res.history) == "table" then return res.history end
  if type(res.transactions) == "table" then return res.transactions end
  if type(res.entries) == "table" then return res.entries end
  return {}
end

local function amountOf(tx)
  return tonumber(txField(tx, "amount", "value", "quid")) or 0
end

local function timeOf(tx)
  return tonumber(txField(tx, "time", "timestamp", "ts", "created", "created_at")) or 0
end

local function analyseTransactions(data, historyRes)
  data.transactions = transactionsFromHistory(historyRes)
  data.history_balance = type(historyRes) == "table" and historyRes.balance or nil

  local minT, maxT = nil, nil

  for _, tx in ipairs(data.transactions or {}) do
    local amt = amountOf(tx)
    local t = timeOf(tx)
    if t > 0 then
      if not minT or t < minT then minT = t end
      if not maxT or t > maxT then maxT = t end
    end

    local dir = txDirection(tx)
    if dir == "IN" and amt > 0 then
      data.income_total = data.income_total + amt
    end

    if isTreasuryOutflow(tx) and amt > 0 then
      local key = classifyTx(tx)
      local s = data.sectors[key] or data.sectors.other
      s.actual = s.actual + amt
      s.tx_count = s.tx_count + 1
      s.transactions[#s.transactions + 1] = tx
      data.actual_total = data.actual_total + amt
      data.outflows[#data.outflows + 1] = tx
    end
  end

  data.tx_count = #(data.transactions or {})
  if minT and maxT and maxT > minT then
    data.observed_days = math.max(1, math.ceil((maxT - minT) / MC_DAY_MS))
  else
    data.observed_days = 1
  end

  data.actual_daily = data.actual_total / data.observed_days
  data.actual_annual = data.actual_daily * FISCAL_YEAR_DAYS

  for _, s in ipairs(data.order) do
    s.actual_annual = (s.actual / data.observed_days) * FISCAL_YEAR_DAYS
  end
end

local function analysePayrollForecast(data, employeesRes, ratesRes)
  local employees = {}
  if type(employeesRes) == "table" then employees = employeesRes.employees or employeesRes.mappings or employeesRes end
  if type(employees) ~= "table" then employees = {} end

  local rates = {}
  if type(ratesRes) == "table" then rates = ratesRes.rates or ratesRes end
  if type(rates) ~= "table" then rates = {} end

  for _, e in ipairs(employees) do
    if type(e) == "table" and e.active ~= false then
      local sector = classifyEmployeeSector(e)
      if sector and data.sectors[sector] then
        local tier = wageTierForEmployee(e, sector)
        local sectorRates = type(rates[sector]) == "table" and rates[sector] or {}
        local wage = tonumber(sectorRates[tier]) or tonumber(sectorRates.skilled) or tonumber(sectorRates.unskilled) or 0
        wage = math.floor(wage)
        if wage > 0 then
          local s = data.sectors[sector]
          s.forecast_daily = s.forecast_daily + wage
          s.forecast_annual = s.forecast_annual + (wage * FISCAL_YEAR_DAYS)
          s.employees = s.employees + 1
          s.workers[#s.workers + 1] = {
            name = displayName(e),
            citizen_id = e.citizen_id,
            job = e.job_text or e.job or e.title or e.work_type or e.industry or "worker",
            tier = tier,
            wage = wage,
            annual = wage * FISCAL_YEAR_DAYS,
          }
          data.forecast_daily = data.forecast_daily + wage
          data.forecast_annual = data.forecast_annual + (wage * FISCAL_YEAR_DAYS)
        end
      end
    end
  end

  for _, s in ipairs(data.order) do
    table.sort(s.workers, function(a, b) return (a.annual or 0) > (b.annual or 0) end)
  end
end

local function finaliseData(data)
  data.chart_total = 0
  for _, s in ipairs(data.order) do
    -- Public payroll forecast fills gaps between real payroll transactions.
    -- Non-payroll categories only use real treasury outflows.
    if s.key == "defence" or s.key == "research" or s.key == "logistics" then
      s.chart_value = math.max(s.actual_annual, s.forecast_annual)
    else
      s.chart_value = s.actual_annual
    end
    data.chart_total = data.chart_total + s.chart_value
  end

  table.sort(data.outflows, function(a, b) return timeOf(a) > timeOf(b) end)
end

local function fetchData()
  last_diagnostics = {}
  local data = blankData()

  local okStatus, statusRes = endpoint("status", { type = "status" })
  if okStatus then
    data.status = statusRes
    data.supply = statusRes.supply or {}
  end

  local okHist, histRes = requestTreasuryHistory()
  if okHist then
    analyseTransactions(data, histRes)
  else
    last_diagnostics.history = tostring(histRes)
  end

  local okRates, ratesRes = endpoint("get_worker_pay_rates", { type = "get_worker_pay_rates" })
  local okEmp, empRes = endpoint("list_employee_mappings", { type = "list_employee_mappings" })
  if okRates and okEmp then
    analysePayrollForecast(data, empRes, ratesRes)
  else
    if not okRates then last_diagnostics.worker_pay_rates = tostring(ratesRes) end
    if not okEmp then last_diagnostics.employee_mappings = tostring(empRes) end
  end

  finaliseData(data)
  data.source = last_data_source

  if not okStatus and not okHist and not okRates and not okEmp then
    return false, "No usable bank data"
  end
  return true, data
end


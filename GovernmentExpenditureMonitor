-- =============================================================================
-- BASIC HELPERS
-- =============================================================================
local function nowMs()
  if os.epoch then return os.epoch("utc") end
  return math.floor(os.clock() * 1000)
end

local function clamp(n, lo, hi)
  n = tonumber(n) or 0
  if n < lo then return lo end
  if n > hi then return hi end
  return n
end

local function lower(s)
  return string.lower(tostring(s or ""))
end

local function upper(s)
  return string.upper(tostring(s or ""))
end

local function trim(s)
  return tostring(s or ""):match("^%s*(.-)%s*$")
end

local function safeNumber(v, fallback)
  local n = tonumber(v)
  if n == nil then return fallback end
  return n
end

local function countTable(t)
  local n = 0
  if type(t) ~= "table" then return 0 end
  for _ in pairs(t) do n = n + 1 end
  return n
end

local function getSize()
  return term.getSize()
end

local function refreshSize()
  return term.getSize()
end

local function clear(bg)
  term.setCursorBlink(false)
  term.setBackgroundColor(bg or C.bg)
  term.setTextColor(C.text)
  term.clear()
  term.setCursorPos(1, 1)
end

local function at(x, y, text, fg, bg)
  local w, h = getSize()
  if y < 1 or y > h or x > w then return end
  if x < 1 then x = 1 end
  term.setCursorPos(x, y)
  term.setTextColor(fg or C.text)
  term.setBackgroundColor(bg or C.bg)
  local maxw = w - x + 1
  if maxw > 0 then
    term.write(tostring(text or ""):sub(1, maxw))
  end
end

local function fill(x, y, w, h, bg)
  local sw, sh = getSize()
  if w <= 0 or h <= 0 then return end
  if x < 1 then x = 1 end
  if x > sw then return end
  term.setBackgroundColor(bg or C.bg)
  local row = string.rep(" ", math.max(0, w))
  for yy = y, y + h - 1 do
    if yy >= 1 and yy <= sh then
      term.setCursorPos(x, yy)
      term.write(row:sub(1, math.max(0, sw - x + 1)))
    end
  end
end

local function short(text, maxLen)
  text = tostring(text or "")
  maxLen = tonumber(maxLen) or 30
  if maxLen < 4 then return text:sub(1, maxLen) end
  if #text <= maxLen then return text end
  return text:sub(1, maxLen - 3) .. "..."
end

local function money(n)
  n = tonumber(n)
  if n == nil then return "n/a" end
  local sign = ""
  if n < 0 then sign = "-"; n = math.abs(n) end
  local s = tostring(math.floor(n + 0.5))
  local out = ""
  while #s > 3 do
    out = "," .. s:sub(-3) .. out
    s = s:sub(1, -4)
  end
  return sign .. s .. out .. " Q"
end

local function pct(part, total)
  part = tonumber(part) or 0
  total = tonumber(total) or 0
  if total <= 0 then return "0.0%" end
  return string.format("%.1f%%", (part / total) * 100)
end

local function ageText(ms)
  if not ms or ms <= 0 then return "never" end
  local age = math.floor((nowMs() - ms) / 1000)
  if age < 60 then return tostring(age) .. "s ago" end
  local m = math.floor(age / 60)
  if m < 60 then return tostring(m) .. "m ago" end
  return tostring(math.floor(m / 60)) .. "h ago"
end

local function currentMcDay()
  if os.day then
    local ok, d = pcall(os.day, "ingame")
    if ok and tonumber(d) then return math.floor(tonumber(d)) end
    ok, d = pcall(os.day)
    if ok and tonumber(d) then return math.floor(tonumber(d)) end
  end
  return math.floor(nowMs() / MC_DAY_MS)
end

local MONTHS = { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec" }

local function isLeapYear(y)
  y = math.floor(tonumber(y) or 0)
  if y % 400 == 0 then return true end
  if y % 100 == 0 then return false end
  return y % 4 == 0
end

local function monthLen(m, y)
  local base = {31,28,31,30,31,30,31,31,30,31,30,31}
  local idx = (math.floor(tonumber(m) or 0) % 12) + 1
  if idx == 2 and isLeapYear(y) then return 29 end
  return base[idx]
end

local function mcDate()
  local d = currentMcDay()
  local year = 0
  while d >= (isLeapYear(year) and 366 or 365) do
    d = d - (isLeapYear(year) and 366 or 365)
    year = year + 1
  end

  local month = 0
  while d >= monthLen(month, year) do
    d = d - monthLen(month, year)
    month = month + 1
  end

  return string.format("%02d %s %04d", d, MONTHS[(month % 12) + 1], year)
end

local function mcTime()
  local t = 0
  if os.time then
    local ok, r = pcall(os.time, "ingame")
    if ok and tonumber(r) then t = tonumber(r) else t = tonumber(os.time()) or 0 end
  end
  t = t % 24
  local hour = math.floor(t)
  local min = math.floor((t - hour) * 60)
  return string.format("%02d:%02dMCT", hour, min)
end


-- =============================================================================
-- BASIC HELPERS
-- =============================================================================
local function nowMs()
  if os.epoch then return os.epoch("utc") end
  return math.floor(os.clock() * 1000)
end

local function refreshSize()
  W, H = term.getSize()
end

local function trim(s)
  return tostring(s or ""):match("^%s*(.-)%s*$")
end

local function lower(s)
  return string.lower(tostring(s or ""))
end

local function upper(s)
  return string.upper(tostring(s or ""))
end

local function clamp(n, lo, hi)
  n = tonumber(n) or 0
  if n < lo then return lo end
  if n > hi then return hi end
  return n
end

local function money(n)
  n = tonumber(n) or 0
  local sign = ""
  if n < 0 then sign = "-"; n = math.abs(n) end
  local s = tostring(math.floor(n + 0.5))
  local out = ""
  while #s > 3 do
    out = "," .. s:sub(-3) .. out
    s = s:sub(1, -4)
  end
  return sign .. s .. out .. " Q"
end

local function pct(part, total)
  part = tonumber(part) or 0
  total = tonumber(total) or 0
  if total <= 0 then return "0.0%" end
  return string.format("%.1f%%", (part / total) * 100)
end

local function shortText(text, maxLen)
  text = tostring(text or "")
  maxLen = tonumber(maxLen) or 30
  if maxLen < 4 then return text:sub(1, maxLen) end
  if #text <= maxLen then return text end
  return text:sub(1, maxLen - 3) .. "..."
end

local function cls()
  refreshSize()
  term.setCursorBlink(false)
  term.setBackgroundColor(C.bg)
  term.setTextColor(C.text)
  term.clear()
  term.setCursorPos(1, 1)
end

local function at(x, y, text, fg, bg)
  refreshSize()
  if y < 1 or y > H or x > W then return end
  if x < 1 then x = 1 end
  term.setCursorPos(x, y)
  term.setTextColor(fg or C.text)
  term.setBackgroundColor(bg or C.bg)
  local maxw = W - x + 1
  if maxw > 0 then term.write(tostring(text or ""):sub(1, maxw)) end
end

local function fill(x, y, w, h, bg)
  refreshSize()
  if w <= 0 or h <= 0 then return end
  if x < 1 then x = 1 end
  term.setBackgroundColor(bg or C.bg)
  local row = string.rep(" ", math.max(0, w))
  for yy = y, y + h - 1 do
    if yy >= 1 and yy <= H then
      term.setCursorPos(x, yy)
      term.write(row:sub(1, math.max(0, W - x + 1)))
    end
  end
end

local function line(x, y, w, ch, fg, bg)
  at(x, y, string.rep(ch or "-", math.max(0, w)), fg or C.grid, bg or C.bg)
end

local function box(x, y, w, h, title)
  fill(x, y, w, h, C.panel)
  line(x, y, w, "=", C.grid, C.panel)
  if title and title ~= "" then at(x + 2, y, " " .. title .. " ", C.label, C.panel) end
end

local function kv(x, y, label, value, colour, width)
  width = width or 34
  at(x, y, shortText(label, math.max(8, width - 14)), C.dim, C.bg)
  at(x + math.max(12, width - 14), y, shortText(value, 14), colour or C.text, C.bg)
end

local function topBar()
  fill(1, 1, W, 1, C.top)
  at(2, 1, "STATE EXPENDITURE", C.title, C.top)
  local right = "v" .. VERSION
  local mid = ""
  if bank_id then mid = "Bank " .. tostring(bank_id) end
  if #mid > 0 then at(math.floor((W - #mid) / 2), 1, mid, C.dim, C.top) end
  at(W - #right, 1, right, C.dim, C.top)
end

local function statusBar()
  fill(1, H, W, 1, C.bg)
  at(2, H, shortText(last_message or "", W - 2), last_colour, C.bg)
end

-- =============================================================================
-- MINECRAFT CLOCK
-- =============================================================================
local function currentMcDay()
  if os.day then return math.max(0, math.floor(tonumber(os.day()) or 0)) end
  return math.floor(nowMs() / MC_DAY_MS)
end

local function mcTime()
  local t = 0
  if os.time then t = tonumber(os.time()) or 0 end
  t = t % 24
  local hour = math.floor(t)
  local minute = math.floor((t - hour) * 60)
  return string.format("Day %d  %02d:%02d MCT", currentMcDay(), hour, minute)
end


  local filled = 0
  if total > 0 and w > 0 then
    filled = math.floor((value / total) * w + 0.5)
    filled = clamp(filled, 0, w)
  end
  fill(x, y, w, 1, colors.gray)
  if filled > 0 then fill(x, y, filled, 1, colour or C.good) end
end


local function openModem()
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      local m = peripheral.wrap(name)
      if m and m.isWireless and m.isWireless() then
        rednet.open(name)
        modem_name = name
        consoleLog("Modem open: " .. name .. " wireless")
        return true
      end
    end
  end

  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      rednet.open(name)
      modem_name = name
      consoleLog("Modem open: " .. name)
      return true
    end
  end

  return false
end

local function waitForResponseFrom(target_id, protocol, timeout)
  local deadline = os.clock() + (timeout or DB_TIMEOUT)
  while true do
    local remaining = deadline - os.clock()
    if remaining <= 0 then return nil end
    local sender, msg = rednet.receive(protocol, remaining)
    if sender == target_id and type(msg) == "table" then
      return msg
    end
  end
end

local function validateBankCandidate(sender)
  rednet.send(sender, { type = "status" }, BANK_PROTOCOL)
  local msg = waitForResponseFrom(sender, BANK_PROTOCOL, 2)
  if type(msg) ~= "table" or msg.success == nil then
    return false
  end
  if msg.success == true and type(msg.response) == "table" then
    local r = msg.response
    if r.supply or r.account_count or r.citizen_count or r.company_count or r.economy_status then
      bank_id = sender
      return true
    end
  end
  return false
end

local function discoverBank()
  last_data_source = "discover"
  for attempt = 1, 8 do
    connectScreen("Finding Quid bank server... attempt " .. tostring(attempt), C.dim)
    rednet.broadcast({ type = "ping" }, BANK_PROTOCOL)

    local deadline = os.clock() + 2
    while true do
      local remaining = deadline - os.clock()
      if remaining <= 0 then break end
      local sender, msg = rednet.receive(BANK_PROTOCOL, remaining)
      if sender and type(msg) == "table" then
        if msg.type == "treasury_online" or msg.success == true then
          if validateBankCandidate(sender) then
            consoleLog("Bank connected: " .. tostring(sender))
            last_data_source = "none"
            return true
          end
        end
      end
    end
  end
  return false
end

local function dbRequest(req, timeout)
  timeout = timeout or DB_TIMEOUT
  if not bank_id then return false, "No bank server connected" end

  rednet.send(bank_id, req, BANK_PROTOCOL)
  local deadline = os.clock() + timeout

  while true do
    local remaining = deadline - os.clock()
    if remaining <= 0 then return false, "No response from bank for " .. tostring(req and req.type) end

    local sender, msg = rednet.receive(BANK_PROTOCOL, remaining)
    if sender == bank_id and type(msg) == "table" and msg.success ~= nil then
      return msg.success, msg.response
    end
  end
end

local function endpointRequest(endpoint, request)
  loadingScreen("Requesting bank data...", endpoint)
  consoleLog("Requesting " .. endpoint)
  local ok, res = dbRequest(request, DB_TIMEOUT)
  last_diagnostics[endpoint] = ok and "ok" or tostring(res)
  if ok and type(res) == "table" then
    last_data_source = endpoint
    return true, res
  end
  return false, res
end

local function requestTreasuryHistory()
  last_diagnostics = {}

  local ok, res = endpointRequest("fiscal_history", {
    type = "fiscal_history",
    account_id = TREASURY_ACCOUNT,
    limit = HISTORY_LIMIT,
  })
  if ok then return true, res end

  ok, res = endpointRequest("treasury_history", {
    type = "treasury_history",
    account_id = TREASURY_ACCOUNT,
    limit = HISTORY_LIMIT,
  })
  if ok then return true, res end

  -- Final fallback: status at least proves the monitor is alive and connected.
  ok, res = endpointRequest("status", { type = "status" })
  if ok then
    last_data_source = "status-only"
    return true, { transactions = {}, summary = {}, status = res, status_only = true }
  end

  last_data_source = "none"
  return false, "No usable bank data. fiscal_history=" .. tostring(last_diagnostics.fiscal_history) .. "; treasury_history=" .. tostring(last_diagnostics.treasury_history) .. "; status=" .. tostring(last_diagnostics.status)
end

-- =============================================================================
-- PAYROLL CLASSIFICATION / ANNUALISATION
-- =============================================================================
local function txField(tx, ...)
  for i = 1, select("#", ...) do
    local k = select(i, ...)
    if tx and tx[k] ~= nil then return tx[k] end
  end
  return nil
end

local function txText(tx)
  local bits = {
    txField(tx, "type", "tx_type") or "",
    txField(tx, "memo", "description", "note") or "",
    txField(tx, "sector", "payroll_sector") or "",
    txField(tx, "from", "from_id") or "",
    txField(tx, "to", "to_id") or "",
    txField(tx, "counterparty_id") or "",
    txField(tx, "counterparty_name") or "",
  }
  return lower(table.concat(bits, " "))
end

local function txDirection(tx)
  local dir = upper(txField(tx, "direction") or "")
  if dir ~= "" then return dir end

  local from_id = trim(txField(tx, "from", "from_id") or "")
  local to_id = trim(txField(tx, "to", "to_id") or "")
  if from_id == TREASURY_ACCOUNT then return "OUT" end
  if to_id == TREASURY_ACCOUNT then return "IN" end
  return "OTHER"
end

local function isTreasuryOutflow(tx)
  local dir = txDirection(tx)
  if dir == "OUT" then return true end

  local from_id = trim(txField(tx, "from", "from_id") or "")
  return from_id == TREASURY_ACCOUNT
end

local function isPayrollTx(tx)
  local text = txText(tx)
  local typ = lower(txField(tx, "type", "tx_type") or "")

  if text:find("payroll", 1, true)
    or text:find("worker pay", 1, true)
    or text:find("wage", 1, true)
    or text:find("salary", 1, true)
    or typ == "payroll" then
    return true
  end

  if isTreasuryOutflow(tx) then
    local to_id = lower(txField(tx, "to", "to_id", "counterparty_id") or "")
    if to_id:find("^citizen:")
      and not text:find("grant", 1, true)
      and not text:find("burn", 1, true)
      and not text:find("mint", 1, true)
      and not text:find("stimulus", 1, true) then
      return true
    end
  end

  return false
end

local function classifySector(tx)
  local explicit = lower(txField(tx, "sector", "payroll_sector", "department") or "")
  if explicit == "defence" or explicit == "defense" then return "defence" end
  if explicit == "research" then return "research" end
  if explicit == "logistics" then return "logistics" end
  if explicit == "administration" or explicit == "admin" then return "administration" end

  local text = txText(tx)

  if text:find("sector:defence", 1, true)
    or text:find("defence", 1, true)
    or text:find("defense", 1, true)
    or text:find("soldier", 1, true)
    or text:find("guard", 1, true)
    or text:find("knight", 1, true)
    or text:find("archer", 1, true)
    or text:find("barracks", 1, true)
    or text:find("combat", 1, true) then
    return "defence"
  end

  if text:find("sector:research", 1, true)
    or text:find("research", 1, true)
    or text:find("researcher", 1, true)
    or text:find("university", 1, true)
    or text:find("library", 1, true)
    or text:find("school", 1, true)
    or text:find("teacher", 1, true)
    or text:find("student", 1, true) then
    return "research"
  end

  if text:find("sector:logistics", 1, true)
    or text:find("logistics", 1, true)
    or text:find("courier", 1, true)
    or text:find("delivery", 1, true)
    or text:find("warehouse", 1, true) then
    return "logistics"
  end

  if text:find("admin", 1, true)
    or text:find("treasury", 1, true)
    or text:find("clerk", 1, true)
    or text:find("civil service", 1, true) then
    return "administration"
  end

  return "other"
end

local function txMcDay(tx)
  local d = txField(tx, "mc_day", "mct_day", "minecraft_day", "day")
  d = tonumber(d)
  if d then return math.floor(d) end
  return nil
end

local function analyse(res)
  local txs = {}
  if type(res) == "table" then
    txs = res.transactions or res.history or res.txs or {}
  end

  local current_day = currentMcDay()
  local window_start = math.max(0, current_day - FISCAL_YEAR_DAYS + 1)
  local world_period_days = math.min(FISCAL_YEAR_DAYS, current_day + 1)
  if world_period_days < 1 then world_period_days = 1 end

  local any_day_fields = false
  for _, tx in ipairs(txs) do
    if txMcDay(tx) ~= nil then any_day_fields = true; break end
  end

  local observed_days = world_period_days
  local by = {}
  for _, s in ipairs(SECTORS) do
    by[s.key] = { key = s.key, label = s.label, color = s.color, observed = 0, annual = 0, count = 0 }
  end

  local observed_total = 0
  local count = 0
  local last = nil
  local considered_rows = 0

  for _, tx in ipairs(txs) do
    local include = true
    local d = txMcDay(tx)
    if any_day_fields then
      include = d ~= nil and d >= window_start and d <= current_day
    end

    if include then
      considered_rows = considered_rows + 1
      if isPayrollTx(tx) then
        local amount = math.floor(tonumber(txField(tx, "amount", "value") or 0) or 0)
        if amount > 0 then
          local key = classifySector(tx)
          by[key] = by[key] or { key = key, label = key, color = colors.lightGray, observed = 0, annual = 0, count = 0 }
          by[key].observed = by[key].observed + amount
          by[key].count = by[key].count + 1
          observed_total = observed_total + amount
          count = count + 1
          last = tx
        end
      end
    end
  end

  if observed_total <= 0 and type(res) == "table" and type(res.summary) == "table" then
    local summary_total = tonumber(res.summary.payroll_total or 0) or 0
    if summary_total <= 0 then
      summary_total = tonumber(res.summary.gov_payroll_total or 0) or 0
    end
    if summary_total > 0 then
      by.other.observed = math.floor(summary_total)
      by.other.count = tonumber(res.summary.payroll_count or 0) or 0
      observed_total = by.other.observed
      count = by.other.count
    end
  end

  local factor = FISCAL_YEAR_DAYS / observed_days
  if current_day >= FISCAL_YEAR_DAYS then factor = 1 end

  local annual_total = math.floor((observed_total * factor) + 0.5)

  local list = {}
  for _, s in ipairs(SECTORS) do
    local row = by[s.key]
    if row and row.observed > 0 then
      row.annual = math.floor((row.observed * factor) + 0.5)
      row.amount = row.annual
      list[#list + 1] = row
    end
  end
  table.sort(list, function(a, b)
    if a.annual ~= b.annual then return a.annual > b.annual end
    return a.label < b.label
  end)

  return {
    observed_total = observed_total,
    annual_total = annual_total,
    total = annual_total,
    factor = factor,
    count = count,
    sectors = list,
    by = by,
    last = last,
    raw_count = #txs,
    considered_rows = considered_rows,
    source = last_data_source,
    status_only = type(res) == "table" and res.status_only or false,
    current_day = current_day,
    window_start = window_start,
    observed_days = observed_days,
    any_day_fields = any_day_fields,
  }
end

-- =============================================================================
-- PIE CHART
-- =============================================================================
local function atan2(y, x)
  if math.atan2 then return math.atan2(y, x) end
  if x > 0 then return math.atan(y / x) end
  if x < 0 and y >= 0 then return math.atan(y / x) + math.pi end
  if x < 0 and y < 0 then return math.atan(y / x) - math.pi end
  if x == 0 and y > 0 then return math.pi / 2 end
  if x == 0 and y < 0 then return -math.pi / 2 end
  return 0
end

local function sectorForFraction(sectors, total, f)
  if total <= 0 or #sectors == 0 then return nil end
  local acc = 0
  for _, s in ipairs(sectors) do
    acc = acc + ((tonumber(s.annual or s.amount) or 0) / total)
    if f <= acc then return s end
  end
  return sectors[#sectors]
end

local function drawPie(cx, cy, rx, ry, sectors, total)
  if rx < 2 or ry < 2 then return end
  local twoPi = math.pi * 2

  for yy = cy - ry, cy + ry do
    for xx = cx - rx, cx + rx do
      local nx = (xx - cx) / rx
      local ny = (yy - cy) / ry
      if (nx * nx) + (ny * ny) <= 1 then
        local bg = C.empty
        if total > 0 and #sectors > 0 then
          local angle = atan2(-(yy - cy), xx - cx)
          if angle < 0 then angle = angle + twoPi end
          local f = angle / twoPi
          local s = sectorForFraction(sectors, total, f)
          if s then bg = s.color or C.empty end
        end
        fill(xx, yy, 1, 1, bg)
      end
    end
  end
end

local function drawLegend(x, y, sectors, total)
  at(x, y, "Legend", C.label, C.bg)
  y = y + 2
  if #sectors == 0 then
    at(x, y, "No payroll yet", C.dim, C.bg)
    return
  end

  for _, s in ipairs(sectors) do
    if y >= H - 1 then break end
    fill(x, y, 2, 1, s.color or C.empty)
    at(x + 3, y, s.label:sub(1, 14), C.text, C.bg)
    at(x + 19, y, pct(s.annual or s.amount, total), C.dim, C.bg)
    y = y + 1
  end
end


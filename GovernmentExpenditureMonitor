local function supplyValue(data, key)
  if not data or type(data.supply) ~= "table" then return 0 end
  return tonumber(data.supply[key]) or 0
end

local function drawRecentFeed(x, y, w, h, transactions, sectorKey)
  box(x, y, w, h, sectorKey and "Recent " .. tostring(CATEGORY_LOOKUP[sectorKey] and CATEGORY_LOOKUP[sectorKey].label or sectorKey) or "Recent treasury outflows")
  local rows = math.max(0, h - 2)
  local printed = 0
  for _, tx in ipairs(transactions or {}) do
    if printed >= rows then break end
    if (not sectorKey) or classifyTx(tx) == sectorKey then
      local label = shortText(txField(tx, "memo", "description", "note") or txField(tx, "type", "tx_type") or "Treasury outflow", math.max(10, w - 18))
      at(x + 2, y + 2 + printed, label, C.text, C.bg)
      at(x + w - 14, y + 2 + printed, shortText(money(amountOf(tx)), 13), C.good, C.bg)
      printed = printed + 1
    end
  end
  if printed == 0 then
    at(x + 2, y + 2, "No matching treasury outflow yet.", C.dim, C.bg)
  end
end

local function drawOverview(data, startY)
  local bodyY = startY + 1
  local bottom = H - 1
  local leftW = math.max(34, math.floor(W * 0.40))
  local rightX = leftW + 2
  local rightW = W - rightX

  local treasury = supplyValue(data, "treasury_balance")
  local issued = supplyValue(data, "in_circulation")
  local private = supplyValue(data, "citizen_holdings") + supplyValue(data, "company_holdings") + supplyValue(data, "escrow_held")
  local control = issued > 0 and (treasury / issued) or 0

  box(2, bodyY, leftW - 2, 10, "State position")
  kv(4, bodyY + 2, "Annual exposure", money(data.chart_total), C.good, leftW - 6)
  kv(4, bodyY + 3, "Recent outflow", money(data.actual_total), C.warn, leftW - 6)
  kv(4, bodyY + 4, "Daily actual avg", money(data.actual_daily), C.text, leftW - 6)
  kv(4, bodyY + 5, "Payroll forecast/day", money(data.forecast_daily), C.text, leftW - 6)
  kv(4, bodyY + 6, "Treasury reserve", money(treasury), C.good, leftW - 6)
  kv(4, bodyY + 7, "Private supply", money(private), C.label, leftW - 6)
  kv(4, bodyY + 8, "Treasury control", string.format("%.1f%%", control * 100), C.dim, leftW - 6)

  box(2, bodyY + 11, leftW - 2, math.max(7, bottom - (bodyY + 11)), "Category bars")
  local rowY = bodyY + 13
  for _, s in ipairs(data.order) do
    if rowY >= bottom - 1 then break end
    if s.chart_value > 0 or s.key == "welfare" or s.key == "defence" or s.key == "research" then
      at(4, rowY, shortText(s.label, 13), C.text, C.bg)
      drawTinyBar(18, rowY, math.max(8, leftW - 33), s.chart_value, math.max(1, data.chart_total), s.color)
      at(leftW - 13, rowY, shortText(money(s.chart_value), 12), C.good, C.bg)
      rowY = rowY + 1
    end
  end

  box(rightX, bodyY, rightW - 1, math.max(17, bottom - bodyY), "Annualised expenditure mix")
  local slices = positiveSlices(data)
  local pieRx = math.max(8, math.min(18, math.floor((rightW - 8) / 4)))
  local pieRy = math.max(4, math.min(9, math.floor((bottom - bodyY - 6) / 2)))
  local cx = rightX + math.floor(rightW * 0.30)
  local cy = bodyY + 3 + pieRy
  drawPie(cx, cy, pieRx, pieRy, slices, data.chart_total)
  at(rightX + 2, bodyY + 2, "Total: " .. money(data.chart_total), C.good, C.bg)
  at(rightX + 2, bodyY + 3, "Actual window: " .. tostring(data.observed_days) .. " MC day(s)", C.dim, C.bg)
  local legendX = math.min(W - 34, cx + pieRx + 4)
  drawLegend(legendX, bodyY + 5, math.max(28, W - legendX), slices, data.chart_total, math.max(5, bottom - bodyY - 7))

  if bottom - bodyY > 22 then
    drawRecentFeed(rightX + 2, bottom - 7, rightW - 4, 7, data.outflows)
  end
end

local function drawSectorTab(data, key, startY)
  local s = data and data.sectors and data.sectors[key]
  if not s then active_tab = "overview"; return drawOverview(data, startY) end

  local bodyY = startY + 1
  local bottom = H - 1
  local cat = CATEGORY_LOOKUP[key] or { label = key, color = C.label }


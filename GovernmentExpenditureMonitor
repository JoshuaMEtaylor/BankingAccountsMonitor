-- =============================================================================
local function emptyCategoryMap()
  return {
    public_payroll = { key="public_payroll", label=CATEGORY_LABELS.public_payroll, amount=0, count=0, colour=CATEGORY_COLOURS.public_payroll },
    citizen_grants = { key="citizen_grants", label=CATEGORY_LABELS.citizen_grants, amount=0, count=0, colour=CATEGORY_COLOURS.citizen_grants },
    business_grants = { key="business_grants", label=CATEGORY_LABELS.business_grants, amount=0, count=0, colour=CATEGORY_COLOURS.business_grants },
    state_contracts = { key="state_contracts", label=CATEGORY_LABELS.state_contracts, amount=0, count=0, colour=CATEGORY_COLOURS.state_contracts },
    currency_burn = { key="currency_burn", label=CATEGORY_LABELS.currency_burn, amount=0, count=0, colour=CATEGORY_COLOURS.currency_burn },
    other = { key="other", label=CATEGORY_LABELS.other, amount=0, count=0, colour=CATEGORY_COLOURS.other },
  }
end

local function listFromMap(map)
  local out = {}
  for _, row in pairs(map or {}) do
    local value = tonumber(row.amount or row.annual or row.daily) or 0
    if value > 0 or (tonumber(row.count) or 0) > 0 then
      out[#out + 1] = row
    end
  end
  table.sort(out, function(a, b)
    local av = tonumber(a.amount or a.annual or a.daily) or 0
    local bv = tonumber(b.amount or b.annual or b.daily) or 0
    return av > bv
  end)
  return out
end

local function analyseTreasuryHistory(history)
  local rows = type(history) == "table" and history.history or {}
  local categories = emptyCategoryMap()
  local outflows = {}
  local inflow_total = 0
  local out_total = 0
  local min_ts = nil
  local max_ts = nil
  local newest = nil

  for _, tx in ipairs(rows or {}) do
    local amount = tonumber(txField(tx, "amount") or 0) or 0
    local ts = tonumber(txField(tx, "time", "timestamp") or 0) or 0
    if ts > 0 then
      if not min_ts or ts < min_ts then min_ts = ts end
      if not max_ts or ts > max_ts then max_ts = ts end
    end

    if isTreasuryOutflow(tx) and amount > 0 then
      local cat = classifyTreasuryOutflow(tx)
      categories[cat] = categories[cat] or { key=cat, label=cat, amount=0, count=0, colour=C.other }
      categories[cat].amount = categories[cat].amount + amount
      categories[cat].count = categories[cat].count + 1
      out_total = out_total + amount
      outflows[#outflows + 1] = tx
      if not newest or (ts > (tonumber(txField(newest, "time") or 0) or 0)) then newest = tx end
    else
      local dir = txDirection(tx)
      if (dir == "IN" or dir == "MINT") and amount > 0 then
        inflow_total = inflow_total + amount
      end
    end
  end

  local observed_days = 1
  if min_ts and max_ts and max_ts > min_ts then
    observed_days = math.max(1, math.ceil((max_ts - min_ts) / MC_DAY_MS))
  end

  local annualised = out_total * (FISCAL_YEAR_DAYS / observed_days)

  return {
    raw_count = #rows,
    total_seen = history and history.total_seen or #rows,
    observed_days = observed_days,
    outflow_total = out_total,
    inflow_total = inflow_total,
    annualised_outflow = annualised,
    categories = listFromMap(categories),
    category_map = categories,
    outflows = outflows,
    newest = newest,
  }
end

local function analysePublicPayroll(employees, rates)
  local sectors = {
    defence = { key="defence", label=WORKER_SECTOR_LABELS.defence, daily=0, annual=0, count=0, colour=WORKER_SECTOR_COLOURS.defence },
    research = { key="research", label=WORKER_SECTOR_LABELS.research, daily=0, annual=0, count=0, colour=WORKER_SECTOR_COLOURS.research },
    logistics = { key="logistics", label=WORKER_SECTOR_LABELS.logistics, daily=0, annual=0, count=0, colour=WORKER_SECTOR_COLOURS.logistics },
  }

  local workers = {}
  local active_count = 0
  local mapped_count = 0

  for _, e in ipairs(employees or {}) do
    if type(e) == "table" and e.active ~= false then
      active_count = active_count + 1
      local daily, sector, tier = rateForEmployee(e, rates)
      if daily and sector then
        local s = sectors[sector]
        if s then
          s.daily = s.daily + daily
          s.annual = s.annual + (daily * FISCAL_YEAR_DAYS)
          s.count = s.count + 1
          mapped_count = mapped_count + 1
          workers[#workers + 1] = {
            name = tostring(e.display_name or e.name or e.citizen_id or "worker"),
            citizen_id = tostring(e.citizen_id or ""),
            sector = sector,
            tier = tier,
            daily = daily,
            annual = daily * FISCAL_YEAR_DAYS,
            job = tostring(e.job_text or e.work_name or e.work_type or ""),
          }
        end
      end
    end
  end

  local list = listFromMap(sectors)
  local daily_total = 0
  local annual_total = 0
  local count = 0
  for _, s in ipairs(list) do
    daily_total = daily_total + (tonumber(s.daily) or 0)
    annual_total = annual_total + (tonumber(s.annual) or 0)
    count = count + (tonumber(s.count) or 0)
  end

  table.sort(workers, function(a, b)
    return (tonumber(a.annual) or 0) > (tonumber(b.annual) or 0)
  end)

  return {
    daily_total = daily_total,
    annual_total = annual_total,
    sectors = list,
    workers = workers,
    public_worker_count = count,
    active_employee_count = active_count,
    mapped_public_count = mapped_count,
  }
end

local function fetchSnapshot()
  local errors = {}

  local okStatus, status = endpoint({ type = "status" }, 4)
  if not okStatus or type(status) ~= "table" then
    errors[#errors + 1] = "status=" .. tostring(status)
    status = {}
  end

  local okSupply, supply = endpoint({ type = "supply" }, 4)
  if not okSupply or type(supply) ~= "table" then
    if type(status.supply) == "table" then
      supply = status.supply
    else
      errors[#errors + 1] = "supply=" .. tostring(supply)
      supply = {}
    end
  end

  local okHist, hist = endpoint({
    type = "treasury_history",
    account_id = TREASURY_ACCOUNT,
    limit = HISTORY_LIMIT,
  }, 6)
  if not okHist or type(hist) ~= "table" then
    errors[#errors + 1] = "treasury_history=" .. tostring(hist)
    hist = { history = {} }
  end

  local okRates, ratesRes = endpoint({ type = "get_worker_pay_rates" }, 4)
  local rates = {}
  if okRates and type(ratesRes) == "table" then
    rates = ratesRes.rates or ratesRes
  else
    errors[#errors + 1] = "worker_pay_rates=" .. tostring(ratesRes)
  end

  local okEmp, empRes = endpoint({ type = "list_employee_mappings", include_inactive = false }, 6)
  local employees = {}
  if okEmp and type(empRes) == "table" then
    employees = empRes.employees or {}
  else
    errors[#errors + 1] = "employee_mappings=" .. tostring(empRes)
  end

  local treasury = {
    issued = tonumber(supply.in_circulation or supply.total_supply or (status.supply and status.supply.in_circulation)) or 0,
    minted = tonumber(supply.total_minted or (status.supply and status.supply.total_minted)) or 0,
    burned = tonumber(supply.total_burned or (status.supply and status.supply.total_burned)) or 0,
    reserve = tonumber(supply.treasury_balance or supply.treasury_reserve or (status.supply and status.supply.treasury_balance)) or 0,
    citizen_holdings = tonumber(supply.citizen_holdings or (status.supply and status.supply.citizen_holdings)) or 0,
    company_holdings = tonumber(supply.company_holdings or (status.supply and status.supply.company_holdings)) or 0,
  }
  treasury.private_supply = treasury.issued - treasury.reserve
  if treasury.private_supply < 0 then treasury.private_supply = 0 end
  treasury.reserve_share = 0
  if treasury.issued > 0 then treasury.reserve_share = (treasury.reserve / treasury.issued) * 100 end

  local actual = analyseTreasuryHistory(hist)
  local payroll = analysePublicPayroll(employees, rates)

  local quality = "LIVE"
  if #errors > 0 then quality = "PARTIAL" end

  return {
    time = nowMs(),
    mc_day = currentMcDay(),
    mc_date = mcDate(),
    mc_time = mcTime(),
    quality = quality,
    errors = errors,
    status = status,
    treasury = treasury,
    actual = actual,
    payroll = payroll,
    bank_version = status.version,
    bank_label = status.label,
  }
end


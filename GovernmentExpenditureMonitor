  local maxRows = math.max(0, bottom - midY - 2)
  for _, tx in ipairs(s.transactions or {}) do
    if row >= maxRows then break end
    local label = shortText(txField(tx, "memo", "description", "note") or txField(tx, "type", "tx_type") or "Outflow", leftW - 18)
    at(4, midY + 2 + row, label, C.text, C.bg)

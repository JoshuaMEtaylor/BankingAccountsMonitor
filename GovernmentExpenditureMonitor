local function openModem()
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      local m = peripheral.wrap(name)
      if m and m.isWireless and m.isWireless() then
        rednet.open(name)
        modem_name = name
        return true
      end
    end
  end

  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      rednet.open(name)
      modem_name = name
      return true
    end
  end

  return false
end

local function waitForBankResponse(target_id, timeout)
  local deadline = os.clock() + (timeout or DB_TIMEOUT)
  while true do
    local remaining = deadline - os.clock()
    if remaining <= 0 then return nil end
    local sender, msg = rednet.receive(BANK_PROTOCOL, remaining)
    if sender == target_id and type(msg) == "table" then
      return msg
    end
  end
end

local function validateBank(sender)
  rednet.send(sender, { type = "status" }, BANK_PROTOCOL)
  local msg = waitForBankResponse(sender, 2)
  if type(msg) == "table" and msg.success == true and type(msg.response) == "table" then
    bank_id = sender
    return true
  end
  return false
end

local function discoverBank()
  bank_id = nil
  for attempt = 1, 8 do
    drawConnect("Finding Quid Bank... attempt " .. tostring(attempt), C.dim)
    rednet.broadcast({ type = "ping" }, BANK_PROTOCOL)

    local deadline = os.clock() + 3
    while os.clock() < deadline do
      local remaining = deadline - os.clock()
      local sender, msg = rednet.receive(BANK_PROTOCOL, remaining)
      if sender and type(msg) == "table" then
        if msg.type == "treasury_online" or msg.success == true then
          if validateBank(sender) then
            last_message = "Connected to bank " .. tostring(bank_id)
            last_colour = C.good
            return true
          end
        end
      end
    end
  end

  last_message = "Bank server not found"
  last_colour = C.bad
  return false
end

local function dbRequest(req, timeout)
  timeout = timeout or DB_TIMEOUT
  if not bank_id then return false, "No bank connected" end
  rednet.send(bank_id, req, BANK_PROTOCOL)
  local deadline = os.clock() + timeout

  while true do
    local remaining = deadline - os.clock()
    if remaining <= 0 then return false, "No response from bank" end
    local sender, msg = rednet.receive(BANK_PROTOCOL, remaining)
    if sender == bank_id and type(msg) == "table" and msg.success ~= nil then
      return msg.success, msg.response
    end
  end
end

local function endpoint(req, timeout)
  local ok, success, response = pcall(dbRequest, req, timeout or DB_TIMEOUT)
  if not ok then return false, tostring(success) end
  return success, response
end

-- =============================================================================
-- DATA CLASSIFICATION
-- =============================================================================
local function txField(tx, ...)
  for i = 1, select("#", ...) do
    local k = select(i, ...)
    if tx and tx[k] ~= nil then return tx[k] end
  end
  return nil
end

local function txText(tx)
  local parts = {
    txField(tx, "type", "tx_type") or "",
    txField(tx, "memo", "description", "note") or "",
    txField(tx, "from", "from_id") or "",
    txField(tx, "to", "to_id") or "",
    txField(tx, "direction") or "",
  }
  return lower(table.concat(parts, " "))
end

local function txDirection(tx)
  local d = upper(txField(tx, "direction") or "")
  if d ~= "" then return d end

  local from_id = trim(txField(tx, "from", "from_id") or "")
  local to_id = trim(txField(tx, "to", "to_id") or "")
  if from_id == TREASURY_ACCOUNT then return "OUT" end
  if to_id == TREASURY_ACCOUNT then return "IN" end
  if from_id == "SYSTEM" then return "MINT" end
  if to_id == "SYSTEM" then return "BURN" end
  return "OTHER"
end

local function isTreasuryOutflow(tx)
  local d = txDirection(tx)
  if d == "OUT" or d == "BURN" then return true end
  local from_id = trim(txField(tx, "from", "from_id") or "")
  return from_id == TREASURY_ACCOUNT
end

local function classifyTreasuryOutflow(tx)
  local text = txText(tx)
  local typ = upper(txField(tx, "type", "tx_type") or "")
  local to_id = lower(txField(tx, "to", "to_id") or "")

  if typ == "BURN" or to_id == "system" or text:find("burn", 1, true) then
    return "currency_burn"
  end

  if text:find("payroll", 1, true)
    or text:find("salary", 1, true)
    or text:find("wage", 1, true)
    or text:find("worker pay", 1, true) then
    return "public_payroll"
  end

  if text:find("contract", 1, true)
    or text:find("project", 1, true)
    or text:find("building", 1, true)
    or text:find("request", 1, true) then
    return "state_contracts"
  end

  if typ == "GRANT" or text:find("grant", 1, true) or text:find("stimulus", 1, true) then
    if to_id:find("^company:") or text:find("business", 1, true) or text:find("company", 1, true) then
      return "business_grants"
    end
    return "citizen_grants"
  end

  return "other"
end

local function workerText(e)
  if type(e) ~= "table" then return "" end
  local parts = {
    e.industry or "",
    e.job_text or "",
    e.work_type or "",
    e.work_name or "",
    e.company_name or "",
    e.company_id or "",
    e.display_name or "",
  }
  return lower(table.concat(parts, " "))
end

local function publicSectorForEmployee(e)
  local text = workerText(e)
  local industry = lower(e and e.industry or "")

  if industry == "defence" or industry == "defense" then return "defence" end
  if industry == "research" then return "research" end
  if industry == "logistics" then return "logistics" end

  if text:find("guard", 1, true) or text:find("soldier", 1, true)
    or text:find("archer", 1, true) or text:find("ranger", 1, true)
    or text:find("knight", 1, true) or text:find("barracks", 1, true)
    or text:find("combat", 1, true) or text:find("tower", 1, true)
    or text:find("defence", 1, true) or text:find("defense", 1, true) then
    return "defence"
  end

  if text:find("research", 1, true) or text:find("university", 1, true)
    or text:find("library", 1, true) or text:find("teacher", 1, true)
    or text:find("student", 1, true) or text:find("pupil", 1, true) then
    return "research"
  end

  if text:find("courier", 1, true) or text:find("delivery", 1, true)
    or text:find("warehouse", 1, true) or text:find("logistics", 1, true) then
    return "logistics"
  end

  return nil
end

local function tierForEmployee(e, sector)
  local text = workerText(e)

  if sector == "defence" then
    if text:find("knight", 1, true) or text:find("captain", 1, true)
      or text:find("officer", 1, true) or text:find("elite", 1, true) then
      return "elite"
    end
    if text:find("guard", 1, true) or text:find("soldier", 1, true)
      or text:find("archer", 1, true) or text:find("ranger", 1, true)
      or text:find("barracks", 1, true) or text:find("tower", 1, true) then
      return "skilled"
    end
    return "unskilled"
  end

  if sector == "research" then
    if text:find("university", 1, true) or text:find("professor", 1, true)
      or text:find("head", 1, true) or text:find("elite", 1, true) then
      return "elite"
    end
    return "skilled"
  end

  if sector == "logistics" then
    if text:find("warehouse", 1, true) or text:find("manager", 1, true)
      or text:find("skilled", 1, true) then
      return "skilled"
    end
    return "unskilled"
  end

  return "unskilled"
end

local function rateForEmployee(e, rates)
  local sector = publicSectorForEmployee(e)
  if not sector then return nil end

  rates = type(rates) == "table" and rates or {}
  local sector_rates = type(rates[sector]) == "table" and rates[sector] or {}
  local tier = tierForEmployee(e, sector)
  local daily = tonumber(sector_rates[tier])

  if not daily then
    if sector == "defence" then daily = tonumber(sector_rates.skilled or sector_rates.unskilled or sector_rates.elite) or 0
    elseif sector == "research" then daily = tonumber(sector_rates.skilled or sector_rates.elite) or 0
    elseif sector == "logistics" then daily = tonumber(sector_rates.unskilled or sector_rates.skilled) or 0
    end
  end

  if not daily or daily <= 0 then return nil end
  return daily, sector, tier
end


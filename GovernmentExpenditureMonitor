  local total = math.max(1, tonumber(data and data.chart_total) or 0)
  at(x + 2, y + 2, "Department", C.label, C.bg)
  at(x + math.max(18, w - 25), y + 2, "Share", C.label, C.bg)
  at(x + w - 11, y + 2, "Annual", C.label, C.bg)

  local rowY = y + 4
  local maxRows = math.max(0, h - 5)
  local rows = {}

  for _, s in ipairs(data.order or {}) do
    rows[#rows + 1] = s
  end

  table.sort(rows, function(a, b)
    local av, bv = tonumber(a.chart_value or 0) or 0, tonumber(b.chart_value or 0) or 0

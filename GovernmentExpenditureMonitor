local function drawBars(x, y, w, rows, total, value_key, max_rows)
  rows = rows or {}
  value_key = value_key or "amount"
  max_rows = max_rows or 8
  if #rows == 0 then
    at(x, y, "No data yet.", C.dim, C.bg)
    return y + 1
  end

  for i = 1, math.min(max_rows, #rows) do
    local r = rows[i]
    local amount = tonumber(r[value_key]) or 0
    local label = tostring(r.label or r.key or "?")
    local colour = r.colour or r.color or C.good
    at(x, y, short(label, 18), C.text, C.bg)
    at(x + 19, y, money(amount), C.good, C.bg)
    at(x + 33, y, pct(amount, total), C.dim, C.bg)
    local bw = math.max(4, w - 2)
    bar(x, y + 1, bw, amount, total, colour)
    y = y + 2
  end
  return y
end

local function drawRecentTransactions(x, y, w, h, rows)
  box(x, y, w, h, "RECENT TREASURY OUTFLOWS", C.label)
  local maxRows = h - 3
  rows = rows or {}

  if #rows == 0 then
    at(x + 2, y + 2, "No recent treasury outflows.", C.dim, C.bg)
    return
  end

  local rowY = y + 2
  for i = 1, math.min(maxRows, #rows) do
    local tx = rows[i]
    local amount = tonumber(txField(tx, "amount") or 0) or 0
    local typ = tostring(txField(tx, "type", "tx_type") or "?")
    local memo = tostring(txField(tx, "memo", "description", "note") or "")
    local to_id = tostring(txField(tx, "to", "to_id") or "")
    local left = short(typ .. " -> " .. to_id, math.max(10, math.floor(w * 0.45)))
    local right = money(amount)
    at(x + 2, rowY, left, C.text, C.bg)
    at(x + w - #right - 2, rowY, right, C.good, C.bg)
    rowY = rowY + 1
    if rowY <= y + h - 1 then
      at(x + 4, rowY, short(memo, w - 6), C.dim, C.bg)
      rowY = rowY + 1
    end
    if rowY > y + h - 1 then break end
  end
end

local function drawCompact(snap)
  clear(C.bg)
  topBar()
  at(2, 3, snap.mc_date .. " " .. snap.mc_time, C.dim, C.bg)

  local t = snap.treasury or {}
  at(2, 5, "Treasury reserve: " .. money(t.reserve), C.good, C.bg)
  at(2, 6, "Issued supply:    " .. money(t.issued), C.text, C.bg)
  at(2, 7, "Recent outflow:   " .. money(snap.actual.outflow_total), C.warn, C.bg)
  at(2, 8, "Annual outflow:   " .. money(snap.actual.annualised_outflow), C.warn, C.bg)
  at(2, 9, "Public payroll:   " .. money(snap.payroll.annual_total) .. "/year", C.good, C.bg)
  at(2, 11, "Need a larger monitor for full breakdown.", C.dim, C.bg)
  footer()
end

local function drawScreen(snap)
  clear(C.bg)
  topBar()

  local w, h = getSize()
  if not snap then
    at(2, 3, "No data loaded yet.", C.warn, C.bg)
    footer()
    return
  end

  if w < 80 or h < 24 then
    drawCompact(snap)
    return
  end

  local clock = snap.mc_date .. " " .. snap.mc_time
  at(2, 2, clock, C.dim, C.bg)
  local right = "Bank " .. tostring(bank_id or "?") .. " | " .. tostring(snap.quality or "?") .. " | " .. ageText(last_refresh_ms)
  at(math.max(2, w - #right), 2, right, snap.quality == "LIVE" and C.good or C.warn, C.bg)

  local margin = 2
  local gap = 2
  local topY = 4
  local topH = 8
  local midY = topY + topH + 1
  local midH = math.floor((h - midY - 2) * 0.52)
  if midH < 10 then midH = 10 end
  local botY = midY + midH + 1
  local botH = h - botY - 1

  local colW = math.floor((w - margin * 2 - gap * 2) / 3)
  local col1 = margin
  local col2 = col1 + colW + gap
  local col3 = col2 + colW + gap

  local t = snap.treasury or {}
  local a = snap.actual or {}
  local p = snap.payroll or {}

  box(col1, topY, colW, topH, "TREASURY", C.treasury)
  metric(col1 + 2, topY + 2, "Reserve", money(t.reserve), C.good)
  metric(col1 + 2, topY + 3, "Issued supply", money(t.issued), C.text)
  metric(col1 + 2, topY + 4, "Private supply", money(t.private_supply), C.text)
  metric(col1 + 2, topY + 5, "Treasury control", string.format("%.2f%%", tonumber(t.reserve_share) or 0), C.dim)
  metric(col1 + 2, topY + 6, "Bank version", short(tostring(snap.bank_version or "?"), colW - 24), C.dim)

  box(col2, topY, colW, topH, "RECENT SPEND", C.warn)
  metric(col2 + 2, topY + 2, "Outflow seen", money(a.outflow_total), C.warn)
  metric(col2 + 2, topY + 3, "Annualised", money(a.annualised_outflow), C.warn)
  metric(col2 + 2, topY + 4, "History window", tostring(a.observed_days or 1) .. " MC days", C.dim)
  metric(col2 + 2, topY + 5, "Rows read", tostring(a.raw_count or 0) .. "/" .. tostring(a.total_seen or 0), C.dim)
  metric(col2 + 2, topY + 6, "Inflow seen", money(a.inflow_total), C.good)

  box(col3, topY, colW, topH, "PUBLIC PAYROLL", C.payroll)
  metric(col3 + 2, topY + 2, "Daily payroll", money(p.daily_total), C.good)
  metric(col3 + 2, topY + 3, "Annual payroll", money(p.annual_total), C.good)
  metric(col3 + 2, topY + 4, "Public workers", tostring(p.public_worker_count or 0), C.text)
  metric(col3 + 2, topY + 5, "Mapped workers", tostring(p.active_employee_count or 0), C.dim)
  local burn = 0
  if p.annual_total and t.reserve and p.annual_total > 0 then
    burn = t.reserve / p.annual_total
  end
  metric(col3 + 2, topY + 6, "Reserve cover", burn > 0 and string.format("%.2f years", burn) or "n/a", C.dim)

  box(col1, midY, colW, midH, "PAYROLL BY PUBLIC SECTOR", C.payroll)
  at(col1 + 2, midY + 2, "Forecast from current worker mappings/rates.", C.dim, C.bg)
  drawBars(col1 + 2, midY + 4, colW - 4, p.sectors, p.annual_total, "annual", math.floor((midH - 5) / 2))

  box(col2, midY, colW, midH, "SPEND CATEGORIES", C.warn)
  at(col2 + 2, midY + 2, "Actual treasury outflows in recent ledger.", C.dim, C.bg)
  drawBars(col2 + 2, midY + 4, colW - 4, a.categories, a.outflow_total, "amount", math.floor((midH - 5) / 2))

  box(col3, midY, colW, midH, "TOP PUBLIC WAGES", C.payroll)
  local workers = p.workers or {}
  if #workers == 0 then
    at(col3 + 2, midY + 2, "No public workers mapped yet.", C.dim, C.bg)
  else
    local rowY = midY + 2
    local maxRows = midH - 3
    for i = 1, math.min(maxRows, #workers) do
      local wr = workers[i]
      local name = short(wr.name or wr.citizen_id or "worker", colW - 18)
      local val = money(wr.annual)
      at(col3 + 2, rowY, name, C.text, C.bg)
      at(col3 + colW - #val - 2, rowY, val, C.good, C.bg)
      rowY = rowY + 1
    end
  end

  drawRecentTransactions(col1, botY, w - (margin * 2), botH, a.outflows)

  if snap.errors and #snap.errors > 0 then
    last_message = "Partial data: " .. short(table.concat(snap.errors, "; "), w - 18)
    last_colour = C.warn
  else
    last_message = "Live expenditure data | refresh " .. tostring(REFRESH_SECONDS) .. "s | R refresh | Q quit"
    last_colour = C.dim
  end

  footer()
end

-- =============================================================================
-- MAIN LOOP
-- =============================================================================
local function refresh()
  if not bank_id then
    if not discoverBank() then
      last_error = "Bank unavailable"
      drawConnect("Bank unavailable. Retrying...", C.bad)
      return false
    end
  end

  last_message = "Refreshing expenditure data..."
  last_colour = C.dim
  local snap = fetchSnapshot()
  last_snapshot = snap
  last_refresh_ms = nowMs()

  if snap.quality == "LIVE" then
    last_error = ""
  else
    last_error = table.concat(snap.errors or {}, "; ")
  end

  drawScreen(snap)
  return true
end

local function main()
  useMonitorIfPresent()

  if not openModem() then
    drawConnect("No modem found. Attach modem and reboot.", C.bad)
    return
  end

  while not discoverBank() do
    drawConnect("Bank not found. Retrying...", C.bad)
    sleep(3)
  end

  refresh()

  local timer = os.startTimer(REFRESH_SECONDS)
  while true do
    local ev, p1 = os.pullEvent()

    if ev == "timer" and p1 == timer then
      refresh()
      timer = os.startTimer(REFRESH_SECONDS)

    elseif ev == "key" then
      if p1 == keys.q then
        break
      elseif p1 == keys.r then
        refresh()
        timer = os.startTimer(REFRESH_SECONDS)
      end

    elseif ev == "monitor_touch" then
      refresh()
      timer = os.startTimer(REFRESH_SECONDS)

    elseif ev == "terminate" then
      break
    end
  end

  restoreTerminal()
  print("Government Expenditure Monitor closed.")
end

local ok, err = pcall(main)
if not ok then
  restoreTerminal()
  term.setTextColor(colors.red)
  print("GovernmentExpenditureMonitor crashed:")
  print(tostring(err))
end

      at(rightX + 2, midY + 3, "Uses bank employee mappings + government pay rates.", C.dim, C.bg)
    else
      at(rightX + 2, midY + 2, "This tab is based on real treasury outflows.", C.dim, C.bg)
      at(rightX + 2, midY + 3, "Future spending appears automatically when ledger memos match.", C.dim, C.bg)
    end
  end
end


local function drawCategoryList(x, y, w, h, data)

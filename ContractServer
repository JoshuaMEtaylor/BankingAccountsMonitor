handlers["retry_company_payment"] = function(sender_id, req)
  local id = req.contract_id
  if not id then return false, "Missing contract_id" end

  local c = contracts[id]
  if not c then return false, "Contract not found: " .. tostring(id) end
  if c.status ~= "pending_payout" then return false, "Contract is not pending payout" end

  local paid_ok, paid_res = payContract(c)
  if paid_ok then
    c.status = "fulfilled"
    c.fulfilled_at = timestamp()
    c.updated = timestamp()
    c.fulfillment_note = "Fulfilled after manual payout retry."
    c.completion_confirmed_by = "retry:" .. tostring(sender_id)
    writeFile(FILE.contracts, contracts)
    audit("MANUAL_PAYOUT_RETRY_SUCCESS", c.claimed_by or "unknown", sender_id, id)
    return true, { contract = publicContract(c), payout = paid_res, message = "Payout retried and paid" }
  end

  c.status = "pending_payout"
  c.updated = timestamp()
  c.payout_status = "failed"
  c.payout_error = tostring(paid_res)
  c.payout_failed_at = timestamp()
  writeFile(FILE.contracts, contracts)
  audit("MANUAL_PAYOUT_RETRY_FAILED", c.claimed_by or "unknown", sender_id, id .. " " .. tostring(paid_res))
  return false, "Payout still failed: " .. tostring(paid_res)
end



local function bootReopenActiveContracts()
  local reopened = 0
  local repaired_cancelled = 0
  local ts = timestamp()

  for id, c in pairs(contracts or {}) do
    if type(c) == "table" then
      local is_minecolonies = c.source_type == "minecolonies_request"
        or tostring(c.source_key or ""):find("^mc_live:")
        or tostring(c.source_family or "") ~= ""

      if is_minecolonies then
        if c.status == "claimed" or c.status == "pending_completion" then
          c.status = "open"
          c.claimed_by = nil
          c.claimed_type = nil
          c.claimed_at = nil
          c.claimed_company_id = nil
          c.claimed_ticker = nil
          c.claimed_name = nil
          c.pending_completion_at = nil
          c.pending_reason = nil
          c.payout_status = nil
          c.payout_error = nil
          c.payout_failed_at = nil
          c.updated = ts
          c.reopened_at = ts
          c.reopen_reason = "Boot reset: active claimed live request reopened"
          reopened = reopened + 1
          audit("BOOT_REOPEN", c.poster or "unknown", "server", id)
        elseif c.status == "pending_payout" then
          -- Fulfilment has already been detected. Preserve claimant and retry
          -- the payout instead of reopening the job.
          local paid_ok, paid_res = payContract(c)
          if paid_ok then
            c.status = "fulfilled"
            c.fulfilled_at = ts
            c.updated = ts
            c.fulfillment_note = "Fulfilled after boot payout retry."
            c.completion_confirmed_by = "boot-retry"
            audit("BOOT_PAYOUT_RETRY_SUCCESS", c.claimed_by or "unknown", "server", id)
          else
            c.status = "pending_payout"
            c.updated = ts
            c.payout_status = "failed"
            c.payout_error = tostring(paid_res)
            c.payout_failed_at = ts
            audit("BOOT_PAYOUT_RETRY_FAILED", c.claimed_by or "unknown", "server", id .. " " .. tostring(paid_res))
          end
        elseif c.status == "cancelled" and (c.reset_by or tostring(c.cancel_reason or ""):find("Manual reset", 1, true)) then
          -- Repair the damage from the removed Reset Live button: those were
          -- live request contracts cancelled by tooling, not fulfilled/cancelled
          -- through real contract state.
          c.status = "open"
          c.claimed_by = nil
          c.claimed_type = nil
          c.claimed_at = nil
          c.claimed_company_id = nil
          c.claimed_ticker = nil
          c.claimed_name = nil
          c.cancelled_at = nil
          c.cancel_reason = nil
          c.reset_by = nil
          c.updated = ts
          c.reopened_at = ts
          c.reopen_reason = "Boot repair: previous reset-live cancellation reopened"
          repaired_cancelled = repaired_cancelled + 1
          audit("BOOT_REPAIR_CANCELLED", c.poster or "unknown", "server", id)
        end
      end
    end
  end

  if reopened > 0 or repaired_cancelled > 0 then
    writeFile(FILE.contracts, contracts)
  end

  return reopened, repaired_cancelled
end


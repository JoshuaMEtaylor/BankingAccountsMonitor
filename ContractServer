  term.setTextColor(colors.yellow)
  print(string.rep("-", w))
  term.setTextColor(colors.lightGray)
  print("  [Running. Ctrl+T to terminate]")
  term.setTextColor(colors.white)
end

local function handleRequest(sender_id, request)
  if type(request) ~= "table" then return false, "Invalid request format" end

  local req_type = request.type
  if not req_type then return false, "Missing request type" end

  local handler = handlers[req_type]
  if not handler then
    audit("UNKNOWN", "UNKNOWN", sender_id, tostring(req_type))
    return false, "Unknown request type: " .. tostring(req_type)
  end

  local ok, success, response = pcall(handler, sender_id, request)
  if not ok then
    audit("ERROR", "SYSTEM", sender_id, tostring(success))
    return false, "Internal contract server error"
  end

  return success, response
end

local function serverLoop()
  local request_count = 0

  while true do
    local sender_id, message, protocol = rednet.receive(PROTOCOL, 5)

    if sender_id then
      request_count = request_count + 1
      local success, response = handleRequest(sender_id, message)
      rednet.send(sender_id, {
        success = success,
        response = response,
        time = timestamp(),
        server = os.getComputerID(),
      }, PROTOCOL)

      if request_count % 5 == 0 then drawStatus() end
    else
      drawStatus()
      rednet.broadcast({
        type = "contract_server_online",
        version = VERSION,
        id = os.getComputerID(),
        time = timestamp(),
      }, PROTOCOL)

      rednet.broadcast({
        type = "contract_server_online",
        version = VERSION,
        id = os.getComputerID(),
        time = timestamp(),
      }, PROTOCOL_BROADCAST)
    end
  end
end

local function main()
  term.clear()
  term.setCursorPos(1, 1)

  if os.getComputerLabel() ~= LABEL then
    os.setComputerLabel(LABEL)
  end

  print("QUID CONTRACT SERVER v" .. VERSION)
  print("Booting...")

  initFiles()
  print("  Contracts: " .. countTable(contracts))
  print("  Next ID:   CON-" .. pad(contract_counter + 1, 6))

  if not openModem() then
    print("FATAL: No modem. Halting.")
    return
  end

  audit("BOOT", "SYSTEM", os.getComputerID(), "v" .. VERSION)

  print("Boot complete.")
  sleep(1)

  drawStatus()
  rednet.broadcast({ type = "contract_server_online", version = VERSION, id = os.getComputerID() }, PROTOCOL)
  rednet.broadcast({ type = "contract_server_online", version = VERSION, id = os.getComputerID() }, PROTOCOL_BROADCAST)

  serverLoop()
end

main()

-- =============================================================================
-- HELPERS
-- =============================================================================
local function timestamp()
  return os.epoch("utc")
end

local function pad(n, width)
  local s = tostring(n)
  while #s < width do s = "0" .. s end
  return s
end

local function ensureDir(path)
  local parts = {}
  for part in string.gmatch(path, "[^/]+") do
    parts[#parts + 1] = part
  end
  table.remove(parts)

  local current = ""
  for _, part in ipairs(parts) do
    current = current == "" and part or (current .. "/" .. part)
    if not fs.exists(current) then fs.makeDir(current) end
  end
end

local function readFile(path)
  if not fs.exists(path) then return nil end
  local f = fs.open(path, "r")
  if not f then return nil end
  local text = f.readAll()
  f.close()
  if not text or text == "" then return nil end

  local ok, data = pcall(textutils.unserialize, text)
  if ok then return data end
  return nil
end

local function writeFile(path, data)
  ensureDir(path)
  local f = fs.open(path, "w")
  if not f then return false end
  f.write(textutils.serialize(data))
  f.close()
  return true
end

local function appendLine(path, line)
  ensureDir(path)
  local f = fs.open(path, "a")
  if not f then return false end
  f.writeLine(line)
  f.close()
  return true
end

local function countTable(t)
  local n = 0
  for _ in pairs(t or {}) do n = n + 1 end
  return n
end

local function trim(s)
  s = tostring(s or "")
  return s:match("^%s*(.-)%s*$")
end

local function nextContractId()
  contract_counter = contract_counter + 1
  return "CON-" .. pad(contract_counter, 6)
end

local function audit(action, actor, terminal, result)
  audit_counter = audit_counter + 1
  local id = "CAUD-" .. pad(audit_counter, 6)
  local line = string.format("%s | %d | %-20s | %-20s | %-10s | %s",
    id, timestamp(), tostring(actor), tostring(action), tostring(terminal), tostring(result))
  appendLine(FILE.audit, line)
end

local function normaliseItems(items)
  if type(items) ~= "table" then return {} end
  local out = {}
  for _, item in ipairs(items) do
    if type(item) == "table" then
      local id = trim(item.item or item.id or item.name or "")
      local display = trim(item.display or item.display_name or item.label or id)
      local count = tonumber(item.count or item.needed or item.amount or item.qty) or 0
      count = math.floor(count)
      if id ~= "" and count > 0 then
        out[#out + 1] = {
          item = id,
          display = display ~= "" and display or id,
          count = count,
        }
      end
    end
  end
  return out
end

local function itemSignature(items)
  local norm = normaliseItems(items or {})
  local parts = {}
  for _, it in ipairs(norm) do
    parts[#parts + 1] = tostring(it.item) .. ":" .. tostring(it.count)
  end
  table.sort(parts)
  return table.concat(parts, ";")
end

local function sameFulfilmentItem(required, supplied)
  if not required or not supplied then return false end
  return trim(required.item or required.id or required.name or "") == trim(supplied.item or supplied.id or supplied.name or "")
    and math.floor(tonumber(required.count or 0) or 0) == math.floor(tonumber(supplied.count or supplied.amount or supplied.qty or 0) or 0)
end

local function fulfilmentMatchesContract(c, supplied_items)
  local required = normaliseItems(c and c.items or {})
  local supplied = normaliseItems(supplied_items or {})

  if #required <= 0 then return false, "Contract has no required items" end
  if #supplied ~= 1 then return false, "Provide exactly one accepted item type for fulfilment" end

  for _, req_item in ipairs(required) do
    if sameFulfilmentItem(req_item, supplied[1]) then
      return true
    end
  end

  return false, "Fulfilment must exactly match one accepted option and the exact quantity"
end

local function sourceKey(req)
  local key = trim(req.source_key or "")
  if key ~= "" then return key end

  local source_type = trim(req.source_type or "manual")
  local source_company = trim(req.source_company or req.poster or req.source_account or "")
  local request_id = trim(req.request_id or req.work_order_id or "")
  local building_id = trim(req.building_id or "")

  if request_id ~= "" then
    return source_type .. "|" .. source_company .. "|" .. building_id .. "|" .. request_id
  end

  return ""
end

local function findLiveContractBySourceKey(key)
  if not key or key == "" then return nil, nil end
  for id, c in pairs(contracts) do
    if c.source_key == key and (c.status == "open" or c.status == "claimed") then
      return id, c
    end
  end
  return nil, nil
end

local function duplicateKey(c)
  if not c then return nil end
  local live_status = c.status == "open" or c.status == "claimed"
  if not live_status then return nil end

  -- Prefer explicit stable source keys from v1.0.7+ integrator.
  if c.source_key and tostring(c.source_key) ~= "" then
    return "source|" .. tostring(c.source_key)
  end

  -- Fallback for old contracts created before source_key existed. This cleans
  -- old duplicate rows already present in data/contracts.db.
  local poster = tostring(c.poster or c.source_company or "")
  local title = tostring(c.title or "")
  local sig = c.item_signature or itemSignature(c.items or {})
  if poster ~= "" and title ~= "" and sig ~= "" then
    return "legacy|" .. poster .. "|" .. title .. "|" .. sig
  end
  return nil
end

local function dedupeLiveContracts(reason)
  local seen = {}
  local cancelled = 0

  local ids = {}
  for id, _ in pairs(contracts or {}) do ids[#ids+1] = id end
  table.sort(ids, function(a,b)
    local ca, cb = contracts[a], contracts[b]
    return tonumber(ca and ca.created or 0) > tonumber(cb and cb.created or 0)
  end)

  for _, id in ipairs(ids) do
    local c = contracts[id]
    local key = duplicateKey(c)
    if key then
      if not seen[key] then
        seen[key] = id
      else
        c.status = "cancelled"
        c.cancelled_at = timestamp()
        c.updated = timestamp()
        c.cancel_reason = reason or ("Duplicate live contract superseded by " .. tostring(seen[key]))
        c.claimed_by = nil
        c.claimed_type = nil
        c.claimed_at = nil
        cancelled = cancelled + 1
        audit("DEDUP_CANCEL", c.poster or "unknown", "server", id)
      end
    end
  end

  if cancelled > 0 then writeFile(FILE.contracts, contracts) end
  return cancelled
end

local function publicContract(c)
  local copy = {}
  for k, v in pairs(c) do
    if k ~= "_internal" then copy[k] = v end
  end
  return copy
end

-- =============================================================================
-- CONTRACT OPERATIONS
-- =============================================================================
local function postContract(sender_id, req)
  local title = trim(req.title or "")
  local poster = trim(req.poster or req.source_account or "")
  local reward = tonumber(req.reward) or 0
  reward = math.floor(reward)

  if title == "" then return false, "Missing title" end
  if poster == "" then return false, "Missing poster/source account" end
  if reward <= 0 then return false, "Invalid reward" end

  local items = normaliseItems(req.items or {})
  if #items <= 0 then return false, "Contract needs at least one item" end

  local src_key = sourceKey(req)
  local sig = itemSignature(items)

  -- Live request upsert mode. MineColonies requests can change while the same
  -- contract is already open/claimed. The contract must mirror the live request
  -- rather than becoming stale and uncompleteable.
  if req.upsert and src_key ~= "" then
    local existing_id, existing = findLiveContractBySourceKey(src_key)
    if existing then
      local old_sig = existing.item_signature or itemSignature(existing.items or {})
      local changed = (
        old_sig ~= sig or
        tonumber(existing.reward or 0) ~= reward or
        trim(existing.title or "") ~= title or
        trim(existing.description or "") ~= trim(req.description or "")
      )

      existing.title = title
      existing.description = trim(req.description or "")
      existing.poster = poster
      existing.reward = reward
      existing.currency = "Q"
      existing.items = items
      existing.updated = timestamp()
      existing.source_type = req.source_type or existing.source_type or "manual"
      existing.source_terminal = sender_id
      existing.source_company = req.source_company or poster
      existing.work_order_id = req.work_order_id
      existing.request_id = req.request_id or existing.request_id
      existing.minecolonies_request_id = req.minecolonies_request_id or existing.minecolonies_request_id
      existing.source_family = req.source_family or existing.source_family
      existing.fixed_quantity = req.fixed_quantity or existing.fixed_quantity
      existing.quantity_min = req.quantity_min or existing.quantity_min
      existing.quantity_max = req.quantity_max or existing.quantity_max
      existing.exact_fulfillment = req.exact_fulfillment or existing.exact_fulfillment
      existing.building_id = req.building_id
      existing.location = req.location
      existing.escrow_status = req.escrow_status or existing.escrow_status or "not_locked"
      existing.source_key = src_key
      existing.item_signature = sig

      if changed and existing.status == "claimed" then
        existing.status = "open"
        existing.claimed_by = nil
        existing.claimed_type = nil
        existing.claimed_at = nil
        existing.reopened_at = timestamp()
        existing.reopen_reason = "Live source request changed; old claim cleared"
      end

      writeFile(FILE.contracts, contracts)
      dedupeLiveContracts("Duplicate after live request refresh")
      audit(changed and "UPDATE" or "REFRESH", poster, sender_id, existing_id)
      return true, {
        contract = publicContract(existing),
        message = changed and "Contract reconciled from live request" or "Contract already current",
        updated = changed
      }
    end
  end

  local contract_id = req.contract_id or nextContractId()
  if contracts[contract_id] then return false, "Contract already exists: " .. contract_id end

  local c = {
    contract_id     = contract_id,
    title           = title,
    description     = trim(req.description or ""),
    poster          = poster,
    reward          = reward,
    currency        = "Q",
    status          = "open",
    items           = items,
    item_signature  = sig,
    created         = timestamp(),
    updated         = timestamp(),
    claimed_by      = nil,
    claimed_type    = nil,
    claimed_at      = nil,

    source_type     = req.source_type or "manual",
    source_terminal = sender_id,
    source_company  = req.source_company or poster,
    source_key      = src_key ~= "" and src_key or nil,
    request_id      = req.request_id,
    minecolonies_request_id = req.minecolonies_request_id,
    source_family   = req.source_family,
    fixed_quantity  = req.fixed_quantity,
    quantity_min    = req.quantity_min,
    quantity_max    = req.quantity_max,
    exact_fulfillment = req.exact_fulfillment,
    work_order_id   = req.work_order_id,
    building_id     = req.building_id,
    location        = req.location,
    escrow_status   = req.escrow_status or "not_locked",
  }

  contracts[contract_id] = c
  writeFile(FILE.contracts, contracts)
  dedupeLiveContracts("Duplicate after live request post")
  audit("POST", poster, sender_id, contract_id)

  return true, { contract = publicContract(c), message = "Contract posted", posted = true }
end

local function listContracts(sender_id, req)
  local status = req.status or "open"
  local source_type = req.source_type
  local source_company = req.source_company
  local out = {}

  for _, c in pairs(contracts) do
    local status_ok = (status == "all" or c.status == status)
    local type_ok = (not source_type or c.source_type == source_type)
    local company_ok = (not source_company or c.source_company == source_company)
    if status_ok and type_ok and company_ok then
      out[#out + 1] = publicContract(c)
    end
  end

  table.sort(out, function(a, b)
    return (a.created or 0) > (b.created or 0)
  end)

  return true, { contracts = out, count = #out }
end

local function getContract(sender_id, req)
  local id = req.contract_id
  if not id then return false, "Missing contract_id" end
  local c = contracts[id]
  if not c then return false, "Contract not found: " .. tostring(id) end
  return true, { contract = publicContract(c) }
end

local function claimContract(sender_id, req)
  local id = req.contract_id
  local claimant = trim(req.claimant or "")
  local claimant_type = req.claimant_type or "company"

  if not id then return false, "Missing contract_id" end
  if claimant == "" then return false, "Missing claimant" end

  local c = contracts[id]
  if not c then return false, "Contract not found: " .. tostring(id) end
  if c.status ~= "open" then return false, "Contract is not open" end

  c.status = "claimed"
  c.claimed_by = claimant
  c.claimed_type = claimant_type
  c.claimed_at = timestamp()
  c.updated = timestamp()

  writeFile(FILE.contracts, contracts)
  audit("CLAIM", claimant, sender_id, id)

  return true, { contract = publicContract(c), message = "Contract claimed" }
end

local function unclaimContract(sender_id, req)
  local id = req.contract_id
  if not id then return false, "Missing contract_id" end

  local c = contracts[id]
  if not c then return false, "Contract not found: " .. tostring(id) end
  if c.status ~= "claimed" then return false, "Contract is not claimed" end

  local old = c.claimed_by or "unknown"

  c.status = "open"
  c.claimed_by = nil
  c.claimed_type = nil
  c.claimed_at = nil
  c.updated = timestamp()

  writeFile(FILE.contracts, contracts)
  audit("UNCLAIM", old, sender_id, id)

  return true, { contract = publicContract(c), message = "Contract reopened" }
end

local function markFulfilled(sender_id, req)
  local id = req.contract_id
  if not id then return false, "Missing contract_id" end

  local c = contracts[id]
  if not c then return false, "Contract not found: " .. tostring(id) end
  if c.status ~= "claimed" and c.status ~= "open" then
    return false, "Contract is not active"
  end

  if c.exact_fulfillment or c.source_type == "minecolonies_request" then
    local ok, err = fulfilmentMatchesContract(c, req.fulfilled_items or req.items or {})
    if not ok then return false, err end
    c.fulfilled_items = normaliseItems(req.fulfilled_items or req.items or {})
  end

  c.status = "fulfilled"
  c.fulfilled_at = timestamp()
  c.updated = timestamp()
  c.fulfillment_note = req.note or ""

  writeFile(FILE.contracts, contracts)
  audit("FULFILLED", c.claimed_by or "unknown", sender_id, id)

  return true, { contract = publicContract(c), message = "Contract marked fulfilled" }
end

local function cancelContract(sender_id, req)
  local id = req.contract_id
  if not id then return false, "Missing contract_id" end

  local c = contracts[id]
  if not c then return false, "Contract not found: " .. tostring(id) end
  if c.status == "fulfilled" then return false, "Cannot cancel fulfilled contract" end

  c.status = "cancelled"
  c.cancelled_at = timestamp()
  c.updated = timestamp()
  c.cancel_reason = req.reason or ""

  writeFile(FILE.contracts, contracts)
  audit("CANCEL", c.poster or "unknown", sender_id, id)

  return true, { contract = publicContract(c), message = "Contract cancelled" }
end

local function syncSourceContracts(sender_id, req)
  local source_type = req.source_type
  local source_company = req.source_company
  local source_terminal = req.source_terminal or sender_id
  local active = {}

  if type(req.active_source_keys) == "table" then
    for _, key in pairs(req.active_source_keys) do
      key = trim(key)
      if key ~= "" then active[key] = true end
    end
  end

  if not source_type then return false, "Missing source_type" end

  local cancelled = 0
  local kept = 0

  for id, c in pairs(contracts) do
    local matches_type = c.source_type == source_type
    local matches_company = (not source_company or c.source_company == source_company)

    -- Scope stale cleanup to the current integrator where possible, but also
    -- clean older MineColonies contracts that were created before source_terminal
    -- was stored. This removes fake board entries automatically after requests
    -- are cancelled in MineColonies.
    local matches_terminal = (not source_terminal)
      or (not c.source_terminal)
      or tostring(c.source_terminal) == tostring(source_terminal)

    local live_status = (c.status == "open" or c.status == "claimed")
    local key = c.source_key

    if matches_type and matches_company and matches_terminal and live_status then
      if not key or not active[key] then
        c.status = "cancelled"
        c.cancelled_at = timestamp()
        c.updated = timestamp()
        c.cancel_reason = req.reason or "Source request no longer exists"
        c.claimed_by = nil
        c.claimed_type = nil
        c.claimed_at = nil
        cancelled = cancelled + 1
        audit("STALE_CANCEL", c.poster or "unknown", sender_id, id)
      else
        kept = kept + 1
      end
    end
  end

  writeFile(FILE.contracts, contracts)
  local deduped = dedupeLiveContracts("Duplicate live request contract")
  return true, { cancelled = cancelled, kept = kept, deduped = deduped }
end


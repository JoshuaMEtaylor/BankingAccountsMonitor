local handlers = {}

handlers["ping"] = function(sender_id, req)
  return true, {
    message = "Quid Contract Server online",
    version = VERSION,
    label = os.getComputerLabel(),
    time = timestamp(),
  }
end

handlers["status"] = function(sender_id, req)
  local open, claimed, fulfilled, cancelled, pending = 0, 0, 0, 0, 0
  for _, c in pairs(contracts) do
    if c.status == "open" then open = open + 1
    elseif c.status == "claimed" then claimed = claimed + 1
    elseif c.status == "fulfilled" then fulfilled = fulfilled + 1
    elseif c.status == "cancelled" then cancelled = cancelled + 1
    elseif c.status == "pending_completion" or c.status == "pending_payout" then pending = pending + 1 end
  end

  return true, {
    version = VERSION,
    label = os.getComputerLabel(),
    time = timestamp(),
    uptime = os.clock(),
    total = countTable(contracts),
    open = open,
    claimed = claimed,
    fulfilled = fulfilled,
    cancelled = cancelled,
    pending = pending,
    boot_reopened = config.boot_reopened or 0,
    boot_repaired_cancelled = config.boot_repaired_cancelled or 0,
    boot_contract_refresh = config.boot_contract_refresh or false,
    boot_contract_refresh_at = config.boot_contract_refresh_at or 0,
    boot_contract_refresh_archived = config.boot_contract_refresh_archived or 0,
    boot_contract_refresh_archive = config.boot_contract_refresh_archive,
    pending_retry_paid = config.pending_retry_paid or 0,
    pending_retry_failed = config.pending_retry_failed or 0,
    last_prune_removed = config.last_prune_removed or 0,
    last_prune_at = config.last_prune_at or 0,
    closed_contract_ttl_ms = CLOSED_CONTRACT_TTL_MS,
    audit_count = audit_counter,
  }
end



local handlers = {}

handlers["ping"] = function(sender_id, req)
  return true, {
    message = "Quid Contract Server online",
    version = VERSION,
    label = os.getComputerLabel(),
    time = timestamp(),
  }
end

handlers["status"] = function(sender_id, req)
  local open, claimed, fulfilled, cancelled, pending = 0, 0, 0, 0, 0
  for _, c in pairs(contracts) do
    if c.status == "open" then open = open + 1
    elseif c.status == "claimed" then claimed = claimed + 1
    elseif c.status == "fulfilled" then fulfilled = fulfilled + 1
    elseif c.status == "cancelled" then cancelled = cancelled + 1
    elseif c.status == "pending_completion" or c.status == "pending_payout" then pending = pending + 1 end
  end

  return true, {
    version = VERSION,
    label = os.getComputerLabel(),
    time = timestamp(),
    uptime = os.clock(),
    total = countTable(contracts),
    open = open,
    claimed = claimed,
    fulfilled = fulfilled,
    cancelled = cancelled,
    pending = pending,
    boot_reopened = config.boot_reopened or 0,
    boot_repaired_cancelled = config.boot_repaired_cancelled or 0,
    audit_count = audit_counter,
  }
end


handlers["post_contract"] = postContract
handlers["list_contracts"] = listContracts
handlers["get_contract"] = getContract
handlers["claim_contract"] = claimContract
handlers["unclaim_contract"] = unclaimContract
handlers["mark_fulfilled"] = markFulfilled
handlers["cancel_contract"] = cancelContract
handlers["sync_source_contracts"] = syncSourceContracts


local function bootReopenActiveContracts()
  local reopened = 0
  local repaired_cancelled = 0
  local ts = timestamp()

  for id, c in pairs(contracts or {}) do
    if type(c) == "table" then
      local is_minecolonies = c.source_type == "minecolonies_request"
        or tostring(c.source_key or ""):find("^mc_live:")
        or tostring(c.source_family or "") ~= ""

      if is_minecolonies then
        if c.status == "claimed" or c.status == "pending_completion" or c.status == "pending_payout" then
          c.status = "open"
          c.claimed_by = nil
          c.claimed_type = nil
          c.claimed_at = nil
          c.pending_completion_at = nil
          c.pending_reason = nil
          c.payout_status = nil
          c.payout_error = nil
          c.payout_failed_at = nil
          c.updated = ts
          c.reopened_at = ts
          c.reopen_reason = "Boot reset: active claimed live request reopened"
          reopened = reopened + 1
          audit("BOOT_REOPEN", c.poster or "unknown", "server", id)
        elseif c.status == "cancelled" and (c.reset_by or tostring(c.cancel_reason or ""):find("Manual reset", 1, true)) then
          -- Repair the damage from the removed Reset Live button: those were
          -- live request contracts cancelled by tooling, not fulfilled/cancelled
          -- through real contract state.
          c.status = "open"
          c.claimed_by = nil
          c.claimed_type = nil
          c.claimed_at = nil
          c.cancelled_at = nil
          c.cancel_reason = nil
          c.reset_by = nil
          c.updated = ts
          c.reopened_at = ts
          c.reopen_reason = "Boot repair: previous reset-live cancellation reopened"
          repaired_cancelled = repaired_cancelled + 1
          audit("BOOT_REPAIR_CANCELLED", c.poster or "unknown", "server", id)
        end
      end
    end
  end

  if reopened > 0 or repaired_cancelled > 0 then
    writeFile(FILE.contracts, contracts)
  end

  return reopened, repaired_cancelled
end


-- =============================================================================
-- HELPERS
-- =============================================================================
local function timestamp()
  return os.epoch("utc")
end

local function pad(n, width)
  local s = tostring(n)
  while #s < width do s = "0" .. s end
  return s
end

local function ensureDir(path)
  local parts = {}
  for part in string.gmatch(path, "[^/]+") do
    parts[#parts + 1] = part
  end
  table.remove(parts)

  local current = ""
  for _, part in ipairs(parts) do
    current = current == "" and part or (current .. "/" .. part)
    if not fs.exists(current) then fs.makeDir(current) end
  end
end

local function readFile(path)
  if not fs.exists(path) then return nil end
  local f = fs.open(path, "r")
  if not f then return nil end
  local text = f.readAll()
  f.close()
  if not text or text == "" then return nil end

  local ok, data = pcall(textutils.unserialize, text)
  if ok then return data end
  return nil
end

local function writeFile(path, data)
  ensureDir(path)
  local f = fs.open(path, "w")
  if not f then return false end
  f.write(textutils.serialize(data))
  f.close()
  return true
end

local function appendLine(path, line)
  ensureDir(path)
  local f = fs.open(path, "a")
  if not f then return false end
  f.writeLine(line)
  f.close()
  return true
end

local function countTable(t)
  local n = 0
  for _ in pairs(t or {}) do n = n + 1 end
  return n
end

local function trim(s)
  s = tostring(s or "")
  return s:match("^%s*(.-)%s*$")
end

local function nextContractId()
  contract_counter = contract_counter + 1
  return "CON-" .. pad(contract_counter, 6)
end

local function audit(action, actor, terminal, result)
  audit_counter = audit_counter + 1
  local id = "CAUD-" .. pad(audit_counter, 6)
  local line = string.format("%s | %d | %-20s | %-20s | %-10s | %s",
    id, timestamp(), tostring(actor), tostring(action), tostring(terminal), tostring(result))
  appendLine(FILE.audit, line)
end

local function normaliseItems(items)
  if type(items) ~= "table" then return {} end
  local out = {}
  for _, item in ipairs(items) do
    if type(item) == "table" then
      local id = trim(item.item or item.id or item.name or "")
      local display = trim(item.display or item.display_name or item.label or id)
      local count = tonumber(item.count or item.needed or item.amount or item.qty) or 0
      count = math.floor(count)
      if id ~= "" and count > 0 then
        out[#out + 1] = {
          item = id,
          display = display ~= "" and display or id,
          count = count,
        }
      end
    end
  end
  return out
end

local function itemSignature(items)
  local norm = normaliseItems(items or {})
  local parts = {}
  for _, it in ipairs(norm) do
    parts[#parts + 1] = tostring(it.item) .. ":" .. tostring(it.count)
  end
  table.sort(parts)
  return table.concat(parts, ";")
end

local function sameFulfilmentItem(required, supplied)
  if not required or not supplied then return false, "Missing fulfilment item" end

  local required_item = trim(required.item or required.id or required.name or "")
  local supplied_item = trim(supplied.item or supplied.id or supplied.name or "")
  local required_count = math.floor(tonumber(required.count or 0) or 0)
  local supplied_count = math.floor(tonumber(supplied.count or supplied.amount or supplied.qty or 0) or 0)

  if required_item ~= supplied_item then
    return false, "Wrong item type"
  end
  if supplied_count < required_count then
    return false, "Insufficient quantity. Required at least " .. tostring(required_count) .. ", supplied " .. tostring(supplied_count)
  end

  -- Over-delivery is allowed because MineColonies fulfilment is a bit finicky.
  -- The contract pays the fixed contract reward only; excess items do not earn
  -- extra Quid.
  return true
end

local function fulfilmentMatchesContract(c, supplied_items)
  local required = normaliseItems(c and c.items or {})
  local supplied = normaliseItems(supplied_items or {})

  if #required <= 0 then return false, "Contract has no required items" end
  if #supplied ~= 1 then return false, "Provide exactly one accepted item type for fulfilment" end

  local last_error = "Fulfilment must use one accepted item and meet or exceed the required quantity"
  for _, req_item in ipairs(required) do
    local ok, err = sameFulfilmentItem(req_item, supplied[1])
    if ok then
      return true
    end
    last_error = err or last_error
  end

  return false, last_error
end

local function sourceKey(req)
  local key = trim(req.source_key or "")
  if key ~= "" then return key end

  local source_type = trim(req.source_type or "manual")
  local source_company = trim(req.source_company or req.poster or req.source_account or "")
  local request_id = trim(req.request_id or req.work_order_id or "")
  local building_id = trim(req.building_id or "")

  if request_id ~= "" then
    return source_type .. "|" .. source_company .. "|" .. building_id .. "|" .. request_id
  end

  return ""
end

local function findLiveContractBySourceKey(key)
  if not key or key == "" then return nil, nil end
  for id, c in pairs(contracts) do
    if c.source_key == key and (c.status == "open" or c.status == "claimed" or c.status == "pending_completion") then
      return id, c
    end
  end
  return nil, nil
end

local function duplicateKey(c)
  if not c then return nil end
  local live_status = c.status == "open" or c.status == "claimed"
  if not live_status then return nil end

  -- Prefer explicit stable source keys from v1.0.7+ integrator.
  if c.source_key and tostring(c.source_key) ~= "" then
    return "source|" .. tostring(c.source_key)
  end

  -- Fallback for old contracts created before source_key existed. This cleans
  -- old duplicate rows already present in data/contracts.db.
  local poster = tostring(c.poster or c.source_company or "")
  local title = tostring(c.title or "")
  local sig = c.item_signature or itemSignature(c.items or {})
  if poster ~= "" and title ~= "" and sig ~= "" then
    return "legacy|" .. poster .. "|" .. title .. "|" .. sig
  end
  return nil
end

local function dedupeLiveContracts(reason)
  local seen = {}
  local cancelled = 0

  local ids = {}
  for id, _ in pairs(contracts or {}) do ids[#ids+1] = id end
  table.sort(ids, function(a,b)
    local ca, cb = contracts[a], contracts[b]
    return tonumber(ca and ca.created or 0) > tonumber(cb and cb.created or 0)
  end)

  for _, id in ipairs(ids) do
    local c = contracts[id]
    local key = duplicateKey(c)
    if key then
      if not seen[key] then
        seen[key] = id
      else
        c.status = "cancelled"
        c.cancelled_at = timestamp()
        c.updated = timestamp()
        c.cancel_reason = reason or ("Duplicate live contract superseded by " .. tostring(seen[key]))
        c.claimed_by = nil
        c.claimed_type = nil
        c.claimed_at = nil
        cancelled = cancelled + 1
        audit("DEDUP_CANCEL", c.poster or "unknown", "server", id)
      end
    end
  end

  if cancelled > 0 then writeFile(FILE.contracts, contracts) end
  return cancelled
end

local function publicContract(c)
  local copy = {}
  for k, v in pairs(c) do
    if k ~= "_internal" then copy[k] = v end
  end
  return copy
end

local function discoverBank()
  for _ = 1, 5 do
    rednet.broadcast({ type = "ping" }, BANK_PROTOCOL)
    local sender, msg = rednet.receive(BANK_PROTOCOL, 2)
    if sender and type(msg) == "table" then
      if msg.type == "treasury_online" or msg.success == true then
        bank_id = sender
        print("  Bank: " .. tostring(bank_id))
        return true
      end
    end
  end
  print("  WARN: Quid bank not found. Payouts will fail until bank is online.")
  return false
end

local function bankReq(req, timeout)
  timeout = timeout or 5
  if not bank_id then discoverBank() end
  if not bank_id then return false, "No bank server connected" end

  rednet.send(bank_id, req, BANK_PROTOCOL)
  local deadline = os.clock() + timeout

  while true do
    local remaining = deadline - os.clock()
    if remaining <= 0 then return false, "No response from bank" end
    local sender, msg = rednet.receive(BANK_PROTOCOL, remaining)
    if sender == bank_id and type(msg) == "table" and msg.success ~= nil then
      return msg.success, msg.response
    end
  end
end


local function bankAccounts()
  -- Use the bank's list_accounts endpoint. This is intentionally tolerant:
  -- older account records/scripts may not have the type field perfectly set,
  -- so company:<ticker> account IDs are treated as companies too.
  local ok, res = bankReq({ type = "list_accounts" }, 8)
  if ok and type(res) == "table" and type(res.accounts) == "table" then
    return res.accounts
  end
  return nil, res
end

local function isCompanyAccount(acc)
  if type(acc) ~= "table" then return false end
  local id = tostring(acc.account_id or acc.id or "")
  local typ = string.lower(tostring(acc.type or acc.account_type or ""))
  local status = string.lower(tostring(acc.status or "active"))

  if status ~= "active" and status ~= "" then return false end
  if typ == "company" or typ == "business" then return true end
  if id:find("^company:") then return true end
  return false
end

local function bankCompanyExists(company_id)
  company_id = trim(company_id or "")
  if company_id == "" then return false end
  local accounts, err = bankAccounts()
  if not accounts then return false, err or "Could not read bank accounts" end

  for _, acc in ipairs(accounts) do
    local id = tostring(acc.account_id or acc.id or "")
    if id == company_id and isCompanyAccount(acc) then
      return true, acc
    end
  end
  return false, "Company account not found: " .. tostring(company_id)
end

local function listClaimantCompanies(sender_id, req)
  local accounts, err = bankAccounts()
  if not accounts then
    return false, err or "Could not read bank accounts"
  end

  local companies = {}
  for _, acc in ipairs(accounts) do
    if isCompanyAccount(acc) then
      local id = tostring(acc.account_id or acc.id or "")
      local ticker = id:gsub("^company:", "")
      companies[#companies+1] = {
        company_id = id,
        account_id = id,
        ticker = string.upper(ticker),
        display_name = acc.display_name or acc.name or id,
        balance = tonumber(acc.balance) or 0,
        owner_id = acc.owner_id,
        status = acc.status or "active",
        type = acc.type or "company",
      }
    end
  end

  table.sort(companies, function(a,b)
    return tostring(a.ticker or a.company_id) < tostring(b.ticker or b.company_id)
  end)

  if #companies == 0 then
    return false, "Bank responded, but no company accounts were found. Check ServerSideAccounts list_accounts/company records."
  end

  return true, { companies = companies, count = #companies, bank_id = bank_id }
end

handlers["list_claimant_companies"] = listClaimantCompanies



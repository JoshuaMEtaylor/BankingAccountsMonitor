-- BOOT
-- =============================================================================
local function initFiles()
  contracts = readFile(FILE.contracts) or {}
  config = readFile(FILE.config) or {}

  for id, _ in pairs(contracts) do
    local n = tostring(id):match("CON%-(%d+)")
    n = tonumber(n)
    if n and n > contract_counter then contract_counter = n end
  end

  dedupeLiveContracts("Duplicate contract cleanup on boot")
  local boot_reopened, boot_repaired = bootReopenActiveContracts()
  config.boot_reopened = boot_reopened
  config.boot_repaired_cancelled = boot_repaired
  if boot_reopened > 0 or boot_repaired > 0 then
    writeFile(FILE.config, config)
  end

  if fs.exists(FILE.audit) then
    local f = fs.open(FILE.audit, "r")
    if f then
      local line = f.readLine()
      while line do
        local n = line:match("CAUD%-(%d+)")
        n = tonumber(n)
        if n and n > audit_counter then audit_counter = n end
        line = f.readLine()
      end
      f.close()
    end
  end
end

local function openModem()
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      local m = peripheral.wrap(name)
      if m and m.isWireless and m.isWireless() then
        rednet.open(name)
        print("  Modem: " .. name .. " (wireless)")
        return true
      end
    end
  end

  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      rednet.open(name)
      print("  Modem: " .. name .. " (wired fallback)")
      return true
    end
  end

  print("  ERROR: No modem found")
  return false
end


local function drawStatus()
  term.clear()
  term.setCursorPos(1, 1)
  local w = term.getSize()

  local _, s = handlers["status"](os.getComputerID(), {})

  term.setBackgroundColor(colors.black)
  term.setTextColor(colors.yellow)
  print(string.rep("=", w))
  print("  QUID CONTRACT SERVER  v" .. VERSION)
  print(string.rep("=", w))

  term.setTextColor(colors.white)
  print("  Label:    " .. (os.getComputerLabel() or "unlabelled"))
  print("  Protocol: " .. PROTOCOL)
  print("  Uptime:   " .. string.format("%.0f", os.clock()) .. "s")
  print("  Audits:   " .. tostring(audit_counter))

  term.setTextColor(colors.yellow)
  print(string.rep("-", w))
  term.setTextColor(colors.lime)
  print("  Open:      " .. tostring(s and s.open or "?"))
  term.setTextColor(colors.orange)
  print("  Claimed:   " .. tostring(s and s.claimed or "?"))
  term.setTextColor(colors.cyan)
  print("  Fulfilled: " .. tostring(s and s.fulfilled or "?"))
  term.setTextColor(colors.red)
  print("  Cancelled: " .. tostring(s and s.cancelled or "?"))
  term.setTextColor(colors.yellow)
  print("  Pending:   " .. tostring(s and s.pending or "?"))
  term.setTextColor(colors.lightGray)
  print("  Boot reset:" .. tostring(s and s.boot_reopened or 0) .. " reopened / " .. tostring(s and s.boot_repaired_cancelled or 0) .. " repaired")
  term.setTextColor(colors.white)
  print("  Total:     " .. tostring(s and s.total or countTable(contracts)))

  term.setTextColor(colors.yellow)
  print(string.rep("-", w))
  term.setTextColor(colors.lightGray)
  print("  [Running. Ctrl+T to terminate]")
  term.setTextColor(colors.white)
end

local function handleRequest(sender_id, request)
  if type(request) ~= "table" then return false, "Invalid request format" end

  local req_type = request.type
  if not req_type then return false, "Missing request type" end

  local handler = handlers[req_type]
  if not handler then
    audit("UNKNOWN", "UNKNOWN", sender_id, tostring(req_type))
    return false, "Unknown request type: " .. tostring(req_type)
  end

  local ok, success, response = pcall(handler, sender_id, request)
  if not ok then
    audit("ERROR", "SYSTEM", sender_id, tostring(success))
    return false, "Internal contract server error: " .. tostring(success)
  end

  return success, response
end

local function serverLoop()
  local request_count = 0

  while true do
    local sender_id, message, protocol = rednet.receive(PROTOCOL, 5)

    if sender_id then
      request_count = request_count + 1
      local success, response = handleRequest(sender_id, message)
      rednet.send(sender_id, {
        success = success,
        response = response,
        time = timestamp(),
      }, PROTOCOL)

      if request_count % 5 == 0 then drawStatus() end
    else
      drawStatus()
      rednet.broadcast({
        type = "contract_server_online",
        version = VERSION,
        id = os.getComputerID(),
        time = timestamp(),
      }, PROTOCOL)

      rednet.broadcast({
        type = "contract_server_online",
        version = VERSION,
        id = os.getComputerID(),
        time = timestamp(),
      }, PROTOCOL_BROADCAST)
    end
  end
end

local function main()
  term.clear()
  term.setCursorPos(1, 1)

  if os.getComputerLabel() ~= LABEL then
    os.setComputerLabel(LABEL)
  end

  print("QUID CONTRACT SERVER v" .. VERSION)
  print("Booting...")

  initFiles()
  print("  Contracts: " .. countTable(contracts))
  print("  Next ID:   CON-" .. pad(contract_counter + 1, 6))

  if not openModem() then
    print("FATAL: No modem. Halting.")
    return
  end

  discoverBank()

  audit("BOOT", "SYSTEM", os.getComputerID(), "v" .. VERSION)

  print("Boot complete.")
  sleep(1)

  drawStatus()
  rednet.broadcast({ type = "contract_server_online", version = VERSION }, PROTOCOL)
  rednet.broadcast({ type = "contract_server_online", version = VERSION }, PROTOCOL_BROADCAST)

  serverLoop()
end

main()

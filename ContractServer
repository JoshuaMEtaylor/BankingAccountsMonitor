local VERSION            = "1.0.27-COURIER-DEPOSIT-COMPLETE"
local LABEL              = "Quid-Contracts"
local PROTOCOL           = "quid_contracts"
local PROTOCOL_BROADCAST = "quid_contracts_discovery"
local BANK_PROTOCOL      = "quid_bank"
local bank_id = nil

local FILE = {
  contracts = "data/contracts.db",
  audit     = "data/contract_audit.log",
  config    = "data/config.db",
  archive_dir = "data/contract_archives",
}

-- This economy treats MineColonies contracts as live scan output, not permanent
-- state. On every ContractServer boot we archive the previous contract table and
-- start empty, so ColonyBusinessIntegrator can reacquire the current live
-- MineColonies requests and repost only what is actually valid/affordable now.
local CLEAR_CONTRACTS_ON_BOOT = true

-- Closed contracts are useful for a short audit/debug window, but they should
-- not live forever in contracts.db. This prevents fulfilled/cancelled history
-- from filling the ContractServer disk and crashing saves.
local MINECRAFT_DAY_MS = 20 * 60 * 1000
local CLOSED_CONTRACT_TTL_MS = MINECRAFT_DAY_MS
local PRUNE_CHECK_INTERVAL_MS = 60 * 1000
local AUDIT_KEEP_RECENT_LINES = 300
local MAX_CONTRACT_ARCHIVES = 3
local LOW_SPACE_THRESHOLD = 4096

local contracts = {}
local config = {}
local contract_counter = 0
local audit_counter = 0

-- =============================================================================
-- HELPERS
-- =============================================================================
local function timestamp()
  return os.epoch("utc")
end

local function pad(n, width)
  local s = tostring(n)
  while #s < width do s = "0" .. s end
  return s
end

local function ensureDir(path)
  local parts = {}
  for part in string.gmatch(path, "[^/]+") do
    parts[#parts + 1] = part
  end
  table.remove(parts)

  local current = ""
  for _, part in ipairs(parts) do
    current = current == "" and part or (current .. "/" .. part)
    if not fs.exists(current) then fs.makeDir(current) end
  end
end

local function readFile(path)
  if not fs.exists(path) then return nil end
  local f = fs.open(path, "r")
  if not f then return nil end
  local text = f.readAll()
  f.close()
  if not text or text == "" then return nil end

  local ok, data = pcall(textutils.unserialize, text)
  if ok then return data end
  return nil
end

local function trimAuditLog()
  if not fs.exists(FILE.audit) then return 0 end

  local lines = {}
  local f = fs.open(FILE.audit, "r")
  if f then
    local line = f.readLine()
    while line do
      lines[#lines + 1] = line
      line = f.readLine()
    end
    f.close()
  end

  if #lines <= AUDIT_KEEP_RECENT_LINES then return 0 end

  local keep = {}
  local start = math.max(1, #lines - AUDIT_KEEP_RECENT_LINES + 1)
  for i = start, #lines do keep[#keep + 1] = lines[i] end

  local out = fs.open(FILE.audit, "w")
  if not out then return 0 end
  local ok = pcall(function()
    for _, line in ipairs(keep) do out.writeLine(line) end
  end)
  out.close()

  if not ok then return 0 end
  return #lines - #keep
end

local function pruneContractArchives()
  if not fs.exists(FILE.archive_dir) or not fs.isDir(FILE.archive_dir) then return 0 end

  local entries = {}
  for _, name in ipairs(fs.list(FILE.archive_dir)) do
    local path = FILE.archive_dir .. "/" .. name
    if not fs.isDir(path) then
      local ts = tonumber(tostring(name):match("(%d+)")) or 0
      entries[#entries + 1] = { name = name, path = path, ts = ts }
    end
  end

  table.sort(entries, function(a, b)
    if a.ts == b.ts then return a.name < b.name end
    return a.ts > b.ts
  end)

  local removed = 0
  for i = MAX_CONTRACT_ARCHIVES + 1, #entries do
    fs.delete(entries[i].path)
    removed = removed + 1
  end
  return removed
end

local function storageCleanup()
  trimAuditLog()
  pruneContractArchives()
end

local function writeFile(path, data)
  ensureDir(path)

  local okSer, payload = pcall(textutils.serialize, data)
  if not okSer or payload == nil then return false end

  if fs.getFreeSpace then
    local dir = fs.getDir(path)
    local check_path = (dir and dir ~= "") and dir or "/"
    local free = tonumber(fs.getFreeSpace(check_path)) or 0
    if free < LOW_SPACE_THRESHOLD then storageCleanup() end
  end

  -- Atomic-ish save: write a temporary file first so a failed save does not
  -- destroy the previous database.
  local tmp = path .. ".tmp"
  if fs.exists(tmp) then fs.delete(tmp) end

  local f = fs.open(tmp, "w")
  if not f then
    storageCleanup()
    f = fs.open(tmp, "w")
    if not f then return false end
  end

  local okWrite = pcall(function() f.write(payload) end)
  f.close()

  if not okWrite then
    fs.delete(tmp)
    storageCleanup()
    return false
  end

  fs.delete(path)
  fs.move(tmp, path)
  return true
end

local function appendLine(path, line)
  ensureDir(path)

  if path == FILE.audit then trimAuditLog() end

  local f = fs.open(path, "a")
  if not f then
    storageCleanup()
    f = fs.open(path, "a")
    if not f then return false end
  end

  local ok = pcall(function() f.writeLine(line) end)
  f.close()

  if not ok then
    storageCleanup()
    return false
  end

  return true
end

local function countTable(t)
  local n = 0
  for _ in pairs(t or {}) do n = n + 1 end
  return n
end

local function trim(s)
  s = tostring(s or "")
  return s:match("^%s*(.-)%s*$")
end

local function nextContractId()
  contract_counter = contract_counter + 1
  return "CON-" .. pad(contract_counter, 6)
end

local function audit(action, actor, terminal, result)
  audit_counter = audit_counter + 1
  local id = "CAUD-" .. pad(audit_counter, 6)
  local line = string.format("%s | %d | %-20s | %-20s | %-10s | %s",
    id, timestamp(), tostring(actor), tostring(action), tostring(terminal), tostring(result))
  appendLine(FILE.audit, line)
end

local CLOSED_CONTRACT_STATUSES = {
  fulfilled = true,
  cancelled = true,
  closed = true,
  expired = true,
  paid = true,
}

local last_prune_check = 0

local function contractClosedAt(c)
  if type(c) ~= "table" then return nil end
  return tonumber(
    c.fulfilled_at
    or c.cancelled_at
    or c.closed_at
    or c.expired_at
    or c.paid_at
    or c.updated
    or c.created
  )
end

local function pruneClosedContracts(reason)
  local ts = timestamp()
  local removed = 0

  for id, c in pairs(contracts or {}) do
    if type(c) == "table" and CLOSED_CONTRACT_STATUSES[tostring(c.status or "")] then
      local closed_at = contractClosedAt(c) or ts
      if (ts - closed_at) >= CLOSED_CONTRACT_TTL_MS then
        contracts[id] = nil
        removed = removed + 1
      end
    end
  end

  if removed > 0 then
    config.last_prune_at = ts
    config.last_prune_reason = tostring(reason or "auto")
    config.last_prune_removed = removed
    config.closed_contract_ttl_ms = CLOSED_CONTRACT_TTL_MS
    writeFile(FILE.contracts, contracts)
    writeFile(FILE.config, config)
    audit("AUTO_PRUNE_CLOSED", "SYSTEM", tostring(reason or "auto"), tostring(removed) .. " removed")
  end

  return removed
end

local function pruneClosedContractsIfDue(reason, force)
  local ts = timestamp()
  if not force and (ts - last_prune_check) < PRUNE_CHECK_INTERVAL_MS then
    return 0
  end

  last_prune_check = ts
  return pruneClosedContracts(reason)
end

local function normaliseItems(items)
  if type(items) ~= "table" then return {} end
  local out = {}
  for _, item in ipairs(items) do
    if type(item) == "table" then
      local id = trim(item.item or item.id or item.name or "")
      local display = trim(item.display or item.display_name or item.label or id)
      local count = tonumber(item.count or item.needed or item.amount or item.qty) or 0
      count = math.floor(count)
      if id ~= "" and count > 0 then
        out[#out + 1] = {
          item = id,
          display = display ~= "" and display or id,
          count = count,
        }
      end
    end
  end
  return out
end

local function itemSignature(items)
  local norm = normaliseItems(items or {})
  local parts = {}
  for _, it in ipairs(norm) do
    parts[#parts + 1] = tostring(it.item) .. ":" .. tostring(it.count)
  end
  table.sort(parts)
  return table.concat(parts, ";")
end

local function sameFulfilmentItem(required, supplied)
  if not required or not supplied then return false, "Missing fulfilment item" end

  local required_item = trim(required.item or required.id or required.name or "")
  local supplied_item = trim(supplied.item or supplied.id or supplied.name or "")
  local required_count = math.floor(tonumber(required.count or 0) or 0)
  local supplied_count = math.floor(tonumber(supplied.count or supplied.amount or supplied.qty or 0) or 0)

  if required_item ~= supplied_item then
    return false, "Wrong item type"
  end
  if supplied_count < required_count then
    return false, "Insufficient quantity. Required at least " .. tostring(required_count) .. ", supplied " .. tostring(supplied_count)
  end

  -- Over-delivery is allowed because MineColonies fulfilment is a bit finicky.
  -- The contract pays the fixed contract reward only; excess items do not earn
  -- extra Quid.
  return true
end

local function fulfilmentMatchesContract(c, supplied_items)
  local required = normaliseItems(c and c.items or {})
  local supplied = normaliseItems(supplied_items or {})

  if #required <= 0 then return false, "Contract has no required items" end
  if #supplied ~= 1 then return false, "Provide exactly one accepted item type for fulfilment" end

  local last_error = "Fulfilment must use one accepted item and meet or exceed the required quantity"
  for _, req_item in ipairs(required) do
    local ok, err = sameFulfilmentItem(req_item, supplied[1])
    if ok then
      return true
    end
    last_error = err or last_error
  end

  return false, last_error
end

local function sourceKey(req)
  local key = trim(req.source_key or "")
  if key ~= "" then return key end

  local source_type = trim(req.source_type or "manual")
  local source_company = trim(req.source_company or req.poster or req.source_account or "")
  local request_id = trim(req.request_id or req.work_order_id or "")
  local building_id = trim(req.building_id or "")

  if request_id ~= "" then
    return source_type .. "|" .. source_company .. "|" .. building_id .. "|" .. request_id
  end

  return ""
end

local function findLiveContractBySourceKey(key)
  if not key or key == "" then return nil, nil end
  for id, c in pairs(contracts) do
    if c.source_key == key and (c.status == "open" or c.status == "claimed" or c.status == "pending_completion" or c.status == "pending_payout") then
      return id, c
    end
  end
  return nil, nil
end

local function duplicateKey(c)
  if not c then return nil end
  local live_status = c.status == "open" or c.status == "claimed"
  if not live_status then return nil end

  -- Prefer explicit stable source keys from v1.0.7+ integrator.
  if c.source_key and tostring(c.source_key) ~= "" then
    return "source|" .. tostring(c.source_key)
  end

  -- Fallback for old contracts created before source_key existed. This cleans
  -- old duplicate rows already present in data/contracts.db.
  local poster = tostring(c.poster or c.source_company or "")
  local title = tostring(c.title or "")
  local sig = c.item_signature or itemSignature(c.items or {})
  if poster ~= "" and title ~= "" and sig ~= "" then
    return "legacy|" .. poster .. "|" .. title .. "|" .. sig
  end
  return nil
end

local function dedupeLiveContracts(reason)
  local seen = {}
  local cancelled = 0

  local ids = {}
  for id, _ in pairs(contracts or {}) do ids[#ids+1] = id end
  table.sort(ids, function(a,b)
    local ca, cb = contracts[a], contracts[b]
    return tonumber(ca and ca.created or 0) > tonumber(cb and cb.created or 0)
  end)

  for _, id in ipairs(ids) do
    local c = contracts[id]
    local key = duplicateKey(c)
    if key then
      if not seen[key] then
        seen[key] = id
      else
        c.status = "cancelled"
        c.cancelled_at = timestamp()
        c.updated = timestamp()
        c.cancel_reason = reason or ("Duplicate live contract superseded by " .. tostring(seen[key]))
        c.claimed_by = nil
        c.claimed_type = nil
        c.claimed_at = nil
        cancelled = cancelled + 1
        audit("DEDUP_CANCEL", c.poster or "unknown", "server", id)
      end
    end
  end

  if cancelled > 0 then writeFile(FILE.contracts, contracts) end
  return cancelled
end

local function publicContract(c)
  local copy = {}
  for k, v in pairs(c) do
    if k ~= "_internal" then copy[k] = v end
  end
  return copy
end

local function discoverBank()
  for _ = 1, 5 do
    rednet.broadcast({ type = "ping" }, BANK_PROTOCOL)
    local sender, msg = rednet.receive(BANK_PROTOCOL, 2)
    if sender and type(msg) == "table" then
      if msg.type == "treasury_online" or msg.success == true then
        bank_id = sender
        print("  Bank: " .. tostring(bank_id))
        return true
      end
    end
  end
  print("  WARN: Quid bank not found. Payouts will fail until bank is online.")
  return false
end

local function bankReq(req, timeout)
  timeout = timeout or 5
  if not bank_id then discoverBank() end
  if not bank_id then return false, "No bank server connected" end

  rednet.send(bank_id, req, BANK_PROTOCOL)
  local deadline = os.clock() + timeout

  while true do
    local remaining = deadline - os.clock()
    if remaining <= 0 then return false, "No response from bank" end
    local sender, msg = rednet.receive(BANK_PROTOCOL, remaining)
    if sender == bank_id and type(msg) == "table" and msg.success ~= nil then
      return msg.success, msg.response
    end
  end
end


local function bankAccounts()
  -- Use the bank's list_accounts endpoint. This is intentionally tolerant:
  -- older account records/scripts may not have the type field perfectly set,
  -- so company:<ticker> account IDs are treated as companies too.
  local ok, res = bankReq({ type = "list_accounts" }, 8)
  if ok and type(res) == "table" and type(res.accounts) == "table" then
    return res.accounts
  end
  return nil, res
end

local function isCompanyAccount(acc)
  if type(acc) ~= "table" then return false end
  local id = tostring(acc.account_id or acc.id or "")
  local typ = string.lower(tostring(acc.type or acc.account_type or ""))
  local status = string.lower(tostring(acc.status or "active"))

  if status ~= "active" and status ~= "" then return false end
  if typ == "company" or typ == "business" then return true end
  if id:find("^company:") then return true end
  return false
end

local function resolveCompanyAccount(company_ref)
  company_ref = trim(company_ref or "")
  if company_ref == "" then return false, "Missing company reference" end

  local accounts, err = bankAccounts()
  if not accounts then return false, err or "Could not read bank accounts" end

  local wanted = string.lower(company_ref)
  local wanted_ticker = wanted:gsub("^company:", "")

  for _, acc in ipairs(accounts) do
    if isCompanyAccount(acc) then
      local id = tostring(acc.account_id or acc.id or "")
      local id_l = string.lower(id)
      local ticker = id_l:gsub("^company:", "")
      local acc_ticker = string.lower(tostring(acc.ticker or ticker or ""))

      if id_l == wanted
        or ticker == wanted_ticker
        or acc_ticker == wanted_ticker
        or ("company:" .. acc_ticker) == wanted then
        local copy = {}
        for k, v in pairs(acc) do copy[k] = v end
        copy.account_id = id
        copy.company_id = id
        copy.ticker = string.upper(ticker ~= "" and ticker or acc_ticker)
        copy.display_name = copy.display_name or copy.name or id
        return true, copy
      end
    end
  end

  return false, "Company account not found: " .. tostring(company_ref)
end

local function bankCompanyExists(company_id)
  return resolveCompanyAccount(company_id)
end

local function listClaimantCompanies(sender_id, req)
  local accounts, err = bankAccounts()
  if not accounts then
    return false, err or "Could not read bank accounts"
  end

  local companies = {}
  for _, acc in ipairs(accounts) do
    if isCompanyAccount(acc) then
      local id = tostring(acc.account_id or acc.id or "")
      local ticker = id:gsub("^company:", "")
      companies[#companies+1] = {
        company_id = id,
        account_id = id,
        ticker = string.upper(ticker),
        display_name = acc.display_name or acc.name or id,
        balance = tonumber(acc.balance) or 0,
        owner_id = acc.owner_id,
        status = acc.status or "active",
        type = acc.type or "company",
      }
    end
  end

  table.sort(companies, function(a,b)
    return tostring(a.ticker or a.company_id) < tostring(b.ticker or b.company_id)
  end)

  if #companies == 0 then
    return false, "Bank responded, but no company accounts were found. Check ServerSideAccounts list_accounts/company records."
  end

  return true, { companies = companies, count = #companies, bank_id = bank_id }
end



-- =============================================================================
-- CONTRACT OPERATIONS
-- =============================================================================
local function postContract(sender_id, req)
  local title = trim(req.title or "")
  local poster = trim(req.poster or req.source_account or "")
  local reward = tonumber(req.reward) or 0
  reward = math.floor(reward)

  if title == "" then return false, "Missing title" end
  if poster == "" then return false, "Missing poster/source account" end
  if reward <= 0 then return false, "Invalid reward" end

  local items = normaliseItems(req.items or {})
  if #items <= 0 then return false, "Contract needs at least one item" end

  local src_key = sourceKey(req)
  local sig = itemSignature(items)

  -- Live request upsert mode. MineColonies requests can change while the same
  -- contract is already open/claimed. The contract must mirror the live request
  -- rather than becoming stale and uncompleteable.
  if req.upsert and src_key ~= "" then
    local existing_id, existing = findLiveContractBySourceKey(src_key)
    if existing then
      local old_sig = existing.item_signature or itemSignature(existing.items or {})
      local new_description = trim(req.description or "")
      local old_reward = tonumber(existing.reward or 0) or 0
      local reward_changed = old_reward ~= reward
      local request_changed = (
        old_sig ~= sig or
        trim(existing.title or "") ~= title or
        trim(existing.description or "") ~= new_description or
        tonumber(existing.fixed_quantity or 0) ~= tonumber(req.fixed_quantity or existing.fixed_quantity or 0)
      )

      local changed = request_changed or reward_changed
      local preserve_claim = existing.status == "claimed" and (not req.keep_claim_on_refresh) and request_changed

      -- Claimed MineColonies jobs are an accepted bargain. Do not reopen/clear
      -- the claimant just because the live request range changed after items
      -- were delivered. The sync step below can now detect ranged-request
      -- shrinkage and mark the accepted contract fulfilled instead.
      if preserve_claim then
        existing.last_live_title = title
        existing.last_live_description = new_description
        existing.last_live_reward = reward
        existing.last_live_item_signature = sig
        existing.last_live_quantity_min = req.quantity_min
        existing.last_live_quantity_max = req.quantity_max
        existing.last_live_updated = timestamp()
        existing.updated = timestamp()
        writeFile(FILE.contracts, contracts)
        audit("CLAIM_REFRESH_HELD", poster, sender_id, existing_id)
        return true, {
          contract = publicContract(existing),
          message = "Claimed contract preserved; waiting for delivery reconciliation",
          updated = false,
          claim_preserved = true
        }
      end

      existing.title = title
      existing.description = new_description
      existing.poster = poster

      -- Open jobs float with live inflation. Claimed jobs keep the price that
      -- the player accepted unless a special bundle explicitly refreshes while claimed.
      if existing.status == "open" or (request_changed and req.keep_claim_on_refresh) then
        existing.reward = reward
      else
        existing.reward_locked = true
        existing.locked_reward = old_reward
      end

      existing.currency = "Q"
      existing.items = items
      existing.updated = timestamp()
      existing.source_type = req.source_type or existing.source_type or "manual"
      existing.source_terminal = sender_id
      existing.source_company = req.source_company or poster
      existing.work_order_id = req.work_order_id
      existing.request_id = req.request_id or existing.request_id
      existing.minecolonies_request_id = req.minecolonies_request_id or existing.minecolonies_request_id
      existing.source_family = req.source_family or existing.source_family
      existing.fixed_quantity = req.fixed_quantity or existing.fixed_quantity
      existing.quantity_min = req.quantity_min or existing.quantity_min
      existing.quantity_max = req.quantity_max or existing.quantity_max
      existing.exact_fulfillment = req.exact_fulfillment or existing.exact_fulfillment
      existing.min_fulfillment = req.min_fulfillment or existing.min_fulfillment
      existing.overdelivery_allowed = req.overdelivery_allowed or existing.overdelivery_allowed
      existing.building_id = req.building_id
      existing.location = req.location
      existing.escrow_status = req.escrow_status or existing.escrow_status or "not_locked"
      existing.source_key = src_key
      existing.item_signature = sig

      if request_changed and existing.status == "claimed" and not req.keep_claim_on_refresh then
        existing.status = "open"
        existing.claimed_by = nil
        existing.claimed_type = nil
        existing.claimed_at = nil
        existing.reopened_at = timestamp()
        existing.reopen_reason = "Live source request changed; old claim cleared"
        existing.reward_locked = nil
        existing.locked_reward = nil
      end

      writeFile(FILE.contracts, contracts)
      dedupeLiveContracts("Duplicate after live request refresh")
      audit(changed and "UPDATE" or "REFRESH", poster, sender_id, existing_id)
      return true, {
        contract = publicContract(existing),
        message = changed and "Contract reconciled from live request" or "Contract already current",
        updated = changed,
        reward_updated = (existing.status == "open" and reward_changed) or request_changed,
        reward_locked = existing.reward_locked or false
      }
    end
  end

  local contract_id = req.contract_id or nextContractId()
  if contracts[contract_id] then return false, "Contract already exists: " .. contract_id end

  local c = {
    contract_id     = contract_id,
    title           = title,
    description     = trim(req.description or ""),
    poster          = poster,
    reward          = reward,
    currency        = "Q",
    status          = "open",
    items           = items,
    item_signature  = sig,
    created         = timestamp(),
    updated         = timestamp(),
    claimed_by      = nil,
    claimed_type    = nil,
    claimed_at      = nil,

    source_type     = req.source_type or "manual",
    source_terminal = sender_id,
    source_company  = req.source_company or poster,
    source_key      = src_key ~= "" and src_key or nil,
    request_id      = req.request_id,
    minecolonies_request_id = req.minecolonies_request_id,
    source_family   = req.source_family,
    fixed_quantity  = req.fixed_quantity,
    quantity_min    = req.quantity_min,
    quantity_max    = req.quantity_max,
    exact_fulfillment = req.exact_fulfillment,
    work_order_id   = req.work_order_id,
    building_id     = req.building_id,
    location        = req.location,
    escrow_status   = req.escrow_status or "not_locked",
  }

  contracts[contract_id] = c
  writeFile(FILE.contracts, contracts)
  dedupeLiveContracts("Duplicate after live request post")
  audit("POST", poster, sender_id, contract_id)

  return true, { contract = publicContract(c), message = "Contract posted", posted = true }
end

local function listContracts(sender_id, req)
  local status = req.status or "open"
  local source_type = req.source_type
  local source_company = req.source_company
  local out = {}

  for _, c in pairs(contracts) do
    local status_ok = (status == "all" or c.status == status)
    local type_ok = (not source_type or c.source_type == source_type)
    local company_ok = (not source_company or c.source_company == source_company)
    if status_ok and type_ok and company_ok then
      out[#out + 1] = publicContract(c)
    end
  end

  table.sort(out, function(a, b)
    return (a.created or 0) > (b.created or 0)
  end)

  return true, { contracts = out, count = #out }
end

local function getContract(sender_id, req)
  local id = req.contract_id
  if not id then return false, "Missing contract_id" end
  local c = contracts[id]
  if not c then return false, "Contract not found: " .. tostring(id) end
  return true, { contract = publicContract(c) }
end

local function claimContract(sender_id, req)
  local id = req.contract_id
  local claimant = trim(req.claimant or "")
  local claimant_type = req.claimant_type or "company"

  if not id then return false, "Missing contract_id" end
  if claimant == "" then return false, "Missing claimant" end

  local c = contracts[id]
  if not c then return false, "Contract not found: " .. tostring(id) end
  if c.status ~= "open" then return false, "Contract is not open" end

  if claimant_type == "company" then
    if not claimant:find("^company:") then
      claimant = "company:" .. string.lower(claimant):gsub("%s+", "_")
    end
    local exists, acc_or_err = bankCompanyExists(claimant)
    if not exists then return false, acc_or_err end
    claimant = acc_or_err.account_id or acc_or_err.company_id or claimant
    c.claimed_company_id = claimant
    c.claimed_ticker = acc_or_err.ticker
    c.claimed_name = acc_or_err.display_name
  end

  c.status = "claimed"
  c.claimed_by = claimant
  c.claimed_type = claimant_type
  c.claimed_at = timestamp()
  c.updated = timestamp()

  writeFile(FILE.contracts, contracts)
  audit("CLAIM", claimant, sender_id, id)

  return true, { contract = publicContract(c), message = "Contract claimed" }
end

local function unclaimContract(sender_id, req)
  local id = req.contract_id
  if not id then return false, "Missing contract_id" end

  local c = contracts[id]
  if not c then return false, "Contract not found: " .. tostring(id) end
  if c.status ~= "claimed" then return false, "Contract is not claimed" end

  local old = c.claimed_by or "unknown"

  c.status = "open"
  c.claimed_by = nil
  c.claimed_type = nil
  c.claimed_at = nil
  c.claimed_company_id = nil
  c.claimed_ticker = nil
  c.claimed_name = nil
  c.updated = timestamp()

  writeFile(FILE.contracts, contracts)
  audit("UNCLAIM", old, sender_id, id)

  return true, { contract = publicContract(c), message = "Contract reopened" }
end


local function payContract(c)
  if not c then return false, "missing contract" end
  if c.payout_status == "paid" then return true, { already_paid = true, tx_id = c.payout_tx_id } end

  local from_id = trim(c.poster or c.source_company or "")
  local to_id = trim(c.claimed_company_id or c.claimed_by or "")
  local amount = tonumber(c.reward) or 0
  amount = math.floor(amount)

  if from_id == "" then return false, "Missing poster account for payout" end
  if to_id == "" then return false, "Missing claimant account for payout" end
  if amount <= 0 then return false, "Invalid payout amount" end

  -- Poster is normally company:<ticker>. Resolve it so old contracts with just
  -- a ticker or messy company refs still debit the correct company account.
  do
    local exists, acc_or_err = resolveCompanyAccount(from_id)
    if exists then
      from_id = acc_or_err.account_id or acc_or_err.company_id or from_id
      c.poster = from_id
      c.source_company = c.source_company or from_id
    end
  end

  if (c.claimed_type or "company") == "company" then
    local exists, acc_or_err = resolveCompanyAccount(to_id)
    if not exists then
      return false, "Claimant company could not be resolved for payout: " .. tostring(acc_or_err)
    end

    to_id = acc_or_err.account_id or acc_or_err.company_id or to_id
    c.claimed_company_id = to_id
    c.claimed_by = to_id
    c.claimed_ticker = acc_or_err.ticker
    c.claimed_name = acc_or_err.display_name
  end

  local ok, res = bankReq({
    type = "company_payment",
    from_id = from_id,
    to_id = to_id,
    amount = amount,
    tx_type = "CONTRACT_REWARD",
    contract_id = c.contract_id,
    memo = "Contract reward " .. tostring(c.contract_id) .. ": " .. tostring(c.title or ""),
    allow_overdraft = true,
  }, 6)

  if ok and type(res) == "table" then
    c.payout_status = "paid"
    c.payout_tx_id = res.tx_id
    c.paid_at = timestamp()
    return true, res
  end


  c.payout_status = "failed"
  c.payout_error = tostring(res)
  c.payout_failed_at = timestamp()
  return false, res
end

local function suppliedItemsFromCourierRequest(req)
  req = type(req) == "table" and req or {}

  local raw = req.deposited_items or req.delivered_items or req.fulfilled_items or req.items
  if type(raw) == "table" then
    -- Accept either a list of items or a single item table.
    if raw.item or raw.id or raw.name then raw = { raw } end
    local norm = normaliseItems(raw)
    if #norm > 0 then return norm end
  end

  local item = trim(req.item or req.item_id or req.deposited_item or req.delivered_item or req.name or "")
  local display = trim(req.display or req.display_name or req.label or item)
  local count = tonumber(req.count or req.amount or req.qty or req.quantity or req.deposited_count or req.delivered_count or 0) or 0
  count = math.floor(count)

  if item ~= "" and count > 0 then
    return {
      {
        item = item,
        display = display ~= "" and display or item,
        count = count,
      }
    }
  end

  return {}
end

local function courierDepositMatchesContract(c, supplied_items)
  local required = normaliseItems(c and c.items or {})
  local supplied = normaliseItems(supplied_items or {})

  if #required <= 0 then return false, "Contract has no required items" end
  if #supplied <= 0 then return false, "Courier delivery reported no deposited items" end

  for _, sup in ipairs(supplied) do
    local supplied_item = trim(sup.item or sup.id or sup.name or "")
    local supplied_count = math.floor(tonumber(sup.count or sup.amount or sup.qty or 0) or 0)

    if supplied_item ~= "" and supplied_count > 0 then
      for _, req_item in ipairs(required) do
        local required_item = trim(req_item.item or req_item.id or req_item.name or "")
        if supplied_item == required_item then
          return true, {
            item = supplied_item,
            display = sup.display or req_item.display or supplied_item,
            deposited = supplied_count,
            requested = tonumber(req_item.count or 0) or 0,
          }
        end
      end
    end
  end

  return false, "Courier deposited item is not one of this contract's requested items"
end

local function findCourierContract(req)
  req = type(req) == "table" and req or {}

  local direct_id = trim(req.contract_id or req.id or "")
  if direct_id ~= "" then
    return direct_id, contracts[direct_id], direct_id ~= "" and nil or "Missing contract_id"
  end

  local key = trim(req.source_key or req.key or "")
  if key == "" then key = sourceKey(req) end

  if key ~= "" then
    for id, c in pairs(contracts or {}) do
      if type(c) == "table"
        and c.source_key == key
        and (c.status == "open" or c.status == "claimed" or c.status == "pending_completion" or c.status == "pending_payout") then
        return id, c, nil
      end
    end
    return nil, nil, "No active contract found for source_key " .. tostring(key)
  end

  -- Last-resort convenience: if the courier only reports an item, find one
  -- matching active MineColonies contract. This only succeeds when exactly one
  -- candidate exists, otherwise the courier must send source_key/contract_id.
  local supplied = suppliedItemsFromCourierRequest(req)
  local matches = {}
  for id, c in pairs(contracts or {}) do
    if type(c) == "table"
      and (c.status == "open" or c.status == "claimed" or c.status == "pending_completion" or c.status == "pending_payout")
      and (c.source_type == "minecolonies_request" or tostring(c.source_key or ""):find("^mc_live:")) then
      local ok = courierDepositMatchesContract(c, supplied)
      if ok then matches[#matches + 1] = { id = id, contract = c } end
    end
  end

  if #matches == 1 then return matches[1].id, matches[1].contract, nil end
  if #matches == 0 then return nil, nil, "No matching active courier contract found" end
  return nil, nil, "Multiple matching contracts found; send source_key or contract_id"
end

local function resolveWarehouseCompanyForCourier(req, c)
  req = type(req) == "table" and req or {}
  local ref = trim(
    req.warehouse_company_id
    or req.warehouse_company
    or req.logistics_company_id
    or req.logistics_company
    or req.company_id
    or req.claimant
    or req.claimant_company
    or c.claimed_company_id
    or c.claimed_by
    or ""
  )

  if ref == "" then
    return false, "Missing warehouse/logistics company for courier payout"
  end

  local ok, acc_or_err = resolveCompanyAccount(ref)
  if not ok then return false, acc_or_err end
  return true, acc_or_err
end

local function completeContractFromCourierDeposit(sender_id, req)
  local id, c, find_err = findCourierContract(req)
  if not c then return false, find_err or "Contract not found" end

  if c.status == "fulfilled" or c.status == "paid" or c.payout_status == "paid" then
    return true, { contract = publicContract(c), already_fulfilled = true, message = "Contract already fulfilled/paid" }
  end

  if c.status ~= "open" and c.status ~= "claimed" and c.status ~= "pending_completion" and c.status ~= "pending_payout" then
    return false, "Contract is not active: " .. tostring(c.status)
  end

  local supplied = suppliedItemsFromCourierRequest(req)
  local match_ok, match_info = courierDepositMatchesContract(c, supplied)
  if not match_ok then return false, match_info end

  local wh_ok, wh_or_err = resolveWarehouseCompanyForCourier(req, c)
  if not wh_ok then return false, wh_or_err end

  local warehouse_id = wh_or_err.account_id or wh_or_err.company_id
  local warehouse_name = wh_or_err.display_name or wh_or_err.name or warehouse_id

  -- If the courier is fulfilling an unclaimed order, claim it directly for the
  -- warehouse/logistics company. If it is already claimed by another party, do
  -- not silently steal the payout unless force_warehouse_claim is explicitly set.
  local current_claimant = trim(c.claimed_company_id or c.claimed_by or "")
  if current_claimant ~= "" and current_claimant ~= warehouse_id and req.force_warehouse_claim ~= true then
    return false, "Contract already claimed by " .. tostring(current_claimant) .. "; refusing to pay warehouse " .. tostring(warehouse_id)
  end

  c.status = "claimed"
  c.claimed_by = warehouse_id
  c.claimed_type = "company"
  c.claimed_company_id = warehouse_id
  c.claimed_name = warehouse_name
  c.claimed_ticker = wh_or_err.ticker
  c.claimed_at = c.claimed_at or timestamp()

  c.courier_delivery_detected = true
  c.courier_delivery_sender = sender_id
  c.courier_delivery_at = timestamp()
  c.courier_delivery_items = supplied
  c.fulfilled_items = supplied
  c.courier_match = match_info
  c.fulfillment_rule = "courier_any_positive_deposit"

  local paid_ok, paid_res = payContract(c)

  if paid_ok then
    c.status = "fulfilled"
    c.fulfilled_at = timestamp()
    c.updated = timestamp()
    c.fulfillment_note = req.note or (
      "Courier completed contract by depositing " ..
      tostring(match_info.deposited or "?") .. "x " .. tostring(match_info.display or match_info.item or "item") ..
      ". Quantity threshold ignored for rigid NPC courier."
    )
    c.completion_confirmed_by = "courier:" .. tostring(sender_id)
    c.completion_mode = "courier_deposit"
    writeFile(FILE.contracts, contracts)
    audit("COURIER_FULFILLED", warehouse_id, sender_id, id)
    return true, {
      contract = publicContract(c),
      payout = paid_res,
      matched = match_info,
      message = "Courier delivery accepted; contract fulfilled and warehouse paid"
    }
  end

  c.status = "pending_payout"
  c.updated = timestamp()
  c.fulfillment_note = req.note or "Courier delivery accepted, but payout failed"
  c.payout_status = "failed"
  c.payout_error = tostring(paid_res)
  c.payout_failed_at = timestamp()
  c.completion_confirmed_by = "courier:" .. tostring(sender_id)
  c.completion_mode = "courier_deposit_pending_payout"
  writeFile(FILE.contracts, contracts)
  audit("COURIER_PAYOUT_FAILED", warehouse_id, sender_id, id .. " " .. tostring(paid_res))
  return false, "Courier delivery accepted, but payout failed: " .. tostring(paid_res)
end

local function markFulfilled(sender_id, req)
  local id = req.contract_id
  if not id then return false, "Missing contract_id" end

  local c = contracts[id]
  if not c then return false, "Contract not found: " .. tostring(id) end
  if c.status ~= "claimed" and c.status ~= "open" and c.status ~= "pending_completion" and c.status ~= "pending_payout" then
    return false, "Contract is not active"
  end

  -- MineColonies contracts must NOT be manually completed from the public board.
  -- The only valid completion signal is the ColonyBusinessIntegrator sync showing
  -- that the claimed source request disappeared from MineColonies after delivery.
  -- This prevents a claimant pressing Complete immediately after claiming and
  -- receiving payment without actually delivering the items.
  local source_disappeared = c.status == "pending_completion"
  local is_minecolonies_contract = (
    c.source_type == "minecolonies_request"
    or tostring(c.source_key or ""):find("^mc_live:") ~= nil
    or tostring(c.source_family or "") ~= ""
    or tostring(c.minecolonies_request_id or "") ~= ""
  )

  if is_minecolonies_contract and c.status == "claimed" then
    return false, "MineColonies contracts cannot be manually completed. Deliver the items, then run/await ColonyBusinessIntegrator sync."
  end

  if (c.exact_fulfillment or c.source_type == "minecolonies_request") and not source_disappeared then
    local ok, err = fulfilmentMatchesContract(c, req.fulfilled_items or req.items or {})
    if not ok then return false, err end
    c.fulfilled_items = normaliseItems(req.fulfilled_items or req.items or {})
  end

  local paid_ok, paid_res = payContract(c)
  if not paid_ok then
    c.status = "pending_payout"
    c.updated = timestamp()
    c.fulfillment_note = req.note or "Fulfilled but payout failed"
    writeFile(FILE.contracts, contracts)
    audit("PAYOUT_FAILED", c.claimed_by or "unknown", sender_id, id .. " " .. tostring(paid_res))
    return false, "Contract completion detected, but payout failed: " .. tostring(paid_res)
  end

  c.status = "fulfilled"
  c.fulfilled_at = timestamp()
  c.updated = timestamp()
  c.fulfillment_note = req.note or (source_disappeared and "MineColonies request disappeared after claim; completion confirmed by sync." or "")
  c.completion_confirmed_by = sender_id

  writeFile(FILE.contracts, contracts)
  audit("FULFILLED", c.claimed_by or "unknown", sender_id, id)

  return true, { contract = publicContract(c), payout = paid_res, message = "Contract marked fulfilled and paid" }
end


local function retryAllPendingPayouts(reason)
  local retried = 0
  local paid = 0
  local failed = 0
  local ts = timestamp()

  for id, c in pairs(contracts or {}) do
    if type(c) == "table" and c.status == "pending_payout" then
      retried = retried + 1
      local ok, res = payContract(c)

      if ok then
        c.status = "fulfilled"
        c.fulfilled_at = ts
        c.updated = ts
        c.fulfillment_note = "Fulfilled after pending payout retry: " .. tostring(reason or "retry")
        c.completion_confirmed_by = tostring(reason or "retry")
        paid = paid + 1
        audit("PENDING_PAYOUT_PAID", c.claimed_by or "unknown", reason or "retry", id)
      else
        c.status = "pending_payout"
        c.updated = ts
        c.payout_status = "failed"
        c.payout_error = tostring(res)
        c.payout_failed_at = ts
        failed = failed + 1
        audit("PENDING_PAYOUT_RETRY_FAILED", c.claimed_by or "unknown", reason or "retry", id .. " " .. tostring(res))
      end
    end
  end

  if retried > 0 then writeFile(FILE.contracts, contracts) end
  return retried, paid, failed
end

local function cancelContract(sender_id, req)
  local id = req.contract_id
  if not id then return false, "Missing contract_id" end

  local c = contracts[id]
  if not c then return false, "Contract not found: " .. tostring(id) end
  if c.status == "fulfilled" then return false, "Cannot cancel fulfilled contract" end

  c.status = "cancelled"
  c.cancelled_at = timestamp()
  c.updated = timestamp()
  c.cancel_reason = req.reason or ""

  writeFile(FILE.contracts, contracts)
  audit("CANCEL", c.poster or "unknown", sender_id, id)

  return true, { contract = publicContract(c), message = "Contract cancelled" }
end

local function syncSourceContracts(sender_id, req)
  local source_type = req.source_type
  local source_company = req.source_company
  local source_terminal = req.source_terminal or sender_id
  local active = {}
  local active_meta = {}

  if type(req.active_source_keys) == "table" then
    for _, key in pairs(req.active_source_keys) do
      key = trim(key)
      if key ~= "" then active[key] = true end
    end
  end

  if type(req.active_source_details) == "table" then
    for _, meta in pairs(req.active_source_details) do
      if type(meta) == "table" then
        local key = trim(meta.source_key or meta.key or "")
        if key ~= "" then
          active[key] = true
          active_meta[key] = meta
        end
      end
    end
  end

  if not source_type then return false, "Missing source_type" end

  local cancelled = 0
  local kept = 0
  local auto_completed = 0
  local payout_failed = 0

  for id, c in pairs(contracts) do
    local matches_type = c.source_type == source_type
    local matches_company = (not source_company or c.source_company == source_company)

    local matches_terminal = (not source_terminal)
      or (not c.source_terminal)
      or tostring(c.source_terminal) == tostring(source_terminal)

    local live_status = (
      c.status == "open"
      or c.status == "claimed"
      or c.status == "pending_completion"
      or c.status == "pending_payout"
    )

    local key = c.source_key

    -- MineColonies contracts are governed by their stable source_key. Do not
    -- require the same integrator terminal ID or source_company on later syncs,
    -- because reboots/remaps can change those and leave claimed jobs stuck.
    -- If the current MineColonies scan no longer reports this source_key, the
    -- claimed contract has been fulfilled in-game and should pay out.
    local is_minecolonies_contract = (
      c.source_type == "minecolonies_request"
      or tostring(key or ""):find("^mc_live:") ~= nil
      or tostring(c.source_family or "") ~= ""
      or tostring(c.minecolonies_request_id or "") ~= ""
    )

    local source_key_authoritative = (
      source_type == "minecolonies_request"
      and is_minecolonies_contract
      and key ~= nil
      and tostring(key) ~= ""
    )

    local matches_scope = false
    if source_key_authoritative then
      matches_scope = true
    else
      matches_scope = matches_type and matches_company and matches_terminal
    end

    if matches_scope and live_status then
      if not key or not active[key] then
        if c.status == "claimed" then
          -- A claimed MineColonies request disappeared from the live request list.
          -- That is the valid completion signal: the request was satisfied in-game.
          -- Pay the claimant automatically. No manual Complete button needed.
          local paid_ok, paid_res = payContract(c)

          if paid_ok then
            c.status = "fulfilled"
            c.fulfilled_at = timestamp()
            c.updated = timestamp()
            c.fulfillment_note = "Auto-completed: claimed MineColonies request disappeared after in-game fulfilment."
            c.completion_confirmed_by = "sync:" .. tostring(sender_id)
            auto_completed = auto_completed + 1
            audit("AUTO_FULFILLED", c.claimed_by or "unknown", sender_id, id)
          else
            c.status = "pending_payout"
            c.updated = timestamp()
            c.fulfillment_note = "Auto-completion detected, but payout failed"
            c.payout_status = "failed"
            c.payout_error = tostring(paid_res)
            c.payout_failed_at = timestamp()
            payout_failed = payout_failed + 1
            audit("AUTO_PAYOUT_FAILED", c.claimed_by or "unknown", sender_id, id .. " " .. tostring(paid_res))
          end

          kept = kept + 1

        elseif c.status == "pending_completion" then
          -- Old pending state from earlier versions. Complete it automatically now.
          local paid_ok, paid_res = payContract(c)

          if paid_ok then
            c.status = "fulfilled"
            c.fulfilled_at = timestamp()
            c.updated = timestamp()
            c.fulfillment_note = "Auto-completed from old pending_completion state."
            c.completion_confirmed_by = "sync:" .. tostring(sender_id)
            auto_completed = auto_completed + 1
            audit("AUTO_FULFILLED_PENDING", c.claimed_by or "unknown", sender_id, id)
          else
            c.status = "pending_payout"
            c.updated = timestamp()
            c.payout_status = "failed"
            c.payout_error = tostring(paid_res)
            c.payout_failed_at = timestamp()
            payout_failed = payout_failed + 1
            audit("AUTO_PAYOUT_FAILED", c.claimed_by or "unknown", sender_id, id .. " " .. tostring(paid_res))
          end

          kept = kept + 1

        elseif c.status == "pending_payout" then
          -- Fulfilment has already been detected. Keep retrying payout, but do
          -- not cancel or reopen the contract.
          local paid_ok, paid_res = payContract(c)

          if paid_ok then
            c.status = "fulfilled"
            c.fulfilled_at = timestamp()
            c.updated = timestamp()
            c.fulfillment_note = "Auto-completed after pending payout retry."
            c.completion_confirmed_by = "retry:" .. tostring(sender_id)
            auto_completed = auto_completed + 1
            audit("AUTO_PAYOUT_RETRY_SUCCESS", c.claimed_by or "unknown", sender_id, id)
          else
            c.status = "pending_payout"
            c.updated = timestamp()
            c.payout_status = "failed"
            c.payout_error = tostring(paid_res)
            c.payout_failed_at = timestamp()
            payout_failed = payout_failed + 1
            audit("AUTO_PAYOUT_RETRY_FAILED", c.claimed_by or "unknown", sender_id, id .. " " .. tostring(paid_res))
          end

          kept = kept + 1

        else
          -- Unclaimed/open request disappeared: it was never assigned to a claimant,
          -- so it is stale and should be cancelled.
          c.status = "cancelled"
          c.cancelled_at = timestamp()
          c.updated = timestamp()
          c.cancel_reason = req.reason or "Source request no longer exists"
          c.claimed_by = nil
          c.claimed_type = nil
          c.claimed_at = nil
          c.claimed_company_id = nil
          c.claimed_ticker = nil
          c.claimed_name = nil
          cancelled = cancelled + 1
          audit("STALE_CANCEL", c.poster or "unknown", sender_id, id)
        end
      else
        -- Some MineColonies requests, especially Dining Hall ranged food
        -- requests like "1-46 Raw Salmon", do not disappear after a partial
        -- fulfilment. They shrink instead. If a claimed contract accepted 15
        -- items and the live request maximum drops by at least 15, conclude the
        -- contract even though the request is still present.
        local meta = key and active_meta[key] or nil
        local auto_shrink_done = false

        -- Courier integration path:
        -- If the integrator/courier reports that a courier deposited any positive
        -- quantity for this source_key, complete the contract immediately and pay
        -- the warehouse/logistics company. This deliberately ignores the old
        -- random/fixed fulfilment amount because the courier NPC is deterministic.
        if type(meta) == "table" and c.status ~= "fulfilled" then
          local courier_count = tonumber(
            meta.courier_deposited_count
            or meta.courier_deposit_count
            or meta.deposited_count
            or meta.delivered_count
            or meta.amount
            or 0
          ) or 0

          local courier_done = meta.courier_completed == true
            or meta.courier_deposit == true
            or meta.courier_delivered == true
            or courier_count > 0

          if courier_done then
            local item_hint = meta.item or meta.item_id or meta.name
            if not item_hint and type(c.items) == "table" and type(c.items[1]) == "table" then
              item_hint = c.items[1].item
            end

            local okCourier, resCourier = completeContractFromCourierDeposit(sender_id, {
              contract_id = id,
              source_key = key,
              warehouse_company_id = meta.warehouse_company_id or meta.warehouse_company or meta.logistics_company_id or meta.logistics_company or meta.company_id or req.warehouse_company_id or req.warehouse_company,
              deposited_items = meta.deposited_items or meta.delivered_items or meta.items,
              item = item_hint,
              count = courier_count > 0 and courier_count or 1,
              note = "Auto-completed from courier deposit metadata in source sync.",
              force_warehouse_claim = meta.force_warehouse_claim == true or req.force_warehouse_claim == true,
            })

            if okCourier then
              auto_completed = auto_completed + 1
              auto_shrink_done = true
            else
              payout_failed = payout_failed + 1
              c.status = c.status == "pending_payout" and "pending_payout" or c.status
              c.updated = timestamp()
              c.fulfillment_note = "Courier deposit metadata detected, but completion failed: " .. tostring(resCourier)
              audit("COURIER_META_FAILED", c.claimed_by or "unknown", sender_id, id .. " " .. tostring(resCourier))
              auto_shrink_done = true
            end
          end
        end

        if not auto_shrink_done and c.status == "claimed" and type(meta) == "table" then
          local old_max = tonumber(c.quantity_max or 0) or 0
          local new_max = tonumber(meta.quantity_max or meta.max_count or old_max) or old_max
          local fixed = tonumber(c.fixed_quantity or meta.fixed_quantity or 0) or 0
          if old_max > 0 and new_max > 0 and fixed > 0 and new_max <= (old_max - fixed) then
            local paid_ok, paid_res = payContract(c)
            if paid_ok then
              c.status = "fulfilled"
              c.fulfilled_at = timestamp()
              c.updated = timestamp()
              c.fulfillment_note = "Auto-completed: live MineColonies request quantity decreased from " .. tostring(old_max) .. " to " .. tostring(new_max) .. " after claimed delivery."
              c.completion_confirmed_by = "shrink-sync:" .. tostring(sender_id)
              auto_completed = auto_completed + 1
              audit("AUTO_SHRINK_FULFILLED", c.claimed_by or "unknown", sender_id, id)
            else
              c.status = "pending_payout"
              c.updated = timestamp()
              c.fulfillment_note = "Quantity-shrink completion detected, but payout failed"
              c.payout_status = "failed"
              c.payout_error = tostring(paid_res)
              c.payout_failed_at = timestamp()
              payout_failed = payout_failed + 1
              audit("AUTO_SHRINK_PAYOUT_FAILED", c.claimed_by or "unknown", sender_id, id .. " " .. tostring(paid_res))
            end
            auto_shrink_done = true
          end
        end

        kept = kept + 1
      end
    end
  end

  writeFile(FILE.contracts, contracts)
  local deduped = dedupeLiveContracts("Duplicate live request contract")
  return true, {
    cancelled = cancelled,
    kept = kept,
    auto_completed = auto_completed,
    payout_failed = payout_failed,
    deduped = deduped
  }
end


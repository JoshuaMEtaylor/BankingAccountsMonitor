local function loadAuditCounter()
  audit_counter = 0
  if fs.exists(FILE.audit) then
    local f = fs.open(FILE.audit, "r")
    if f then
      local line = f.readLine()
      while line do
        local n = line:match("CAUD%-(%d+)")
        n = tonumber(n)
        if n and n > audit_counter then audit_counter = n end
        line = f.readLine()
      end
      f.close()
    end
  end
end

local function archiveContractsForBootRefresh(existing, ts)
  local n = countTable(existing or {})
  if n <= 0 then return nil, 0 end

  local archive_path = FILE.archive_dir .. "/contracts_boot_" .. tostring(ts or timestamp()) .. ".db"
  writeFile(archive_path, existing)
  return archive_path, n
end

local function initFiles()
  contracts = readFile(FILE.contracts) or {}
  config = readFile(FILE.config) or {}
  loadAuditCounter()
  storageCleanup()

  -- Remove old fulfilled/cancelled/closed records before any boot archive/write.
  -- This keeps the main database and the boot archive small.
  pruneClosedContractsIfDue("boot-pre-archive", true)

  if CLEAR_CONTRACTS_ON_BOOT then
    local ts = timestamp()
    local archived_path, archived_count = archiveContractsForBootRefresh(contracts, ts)

    contracts = {}
    contract_counter = 0
    writeFile(FILE.contracts, contracts)

    config.boot_reopened = 0
    config.boot_repaired_cancelled = 0
    config.boot_contract_refresh = true
    config.boot_contract_refresh_at = ts
    config.boot_contract_refresh_archived = archived_count
    config.boot_contract_refresh_archive = archived_path
    writeFile(FILE.config, config)

    audit("BOOT_REFRESH_CLEAR", "SYSTEM", os.getComputerID(), "archived=" .. tostring(archived_count))
    pruneContractArchives()
    return
  end

  for id, _ in pairs(contracts) do
    local n = tostring(id):match("CON%-(%d+)")
    n = tonumber(n)
    if n and n > contract_counter then contract_counter = n end
  end

  dedupeLiveContracts("Duplicate contract cleanup on boot")
  local boot_reopened, boot_repaired = bootReopenActiveContracts()
  config.boot_reopened = boot_reopened
  config.boot_repaired_cancelled = boot_repaired
  if boot_reopened > 0 or boot_repaired > 0 then
    writeFile(FILE.config, config)
  end
end

local function openModem()
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      local m = peripheral.wrap(name)
      if m and m.isWireless and m.isWireless() then
        rednet.open(name)
        print("  Modem: " .. name .. " (wireless)")
        return true
      end
    end
  end

  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      rednet.open(name)
      print("  Modem: " .. name .. " (wired fallback)")
      return true
    end
  end

  print("  ERROR: No modem found")
  return false
end



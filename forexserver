local function buildSyntheticTick(ms, price, changed)
  local baseline = tonumber(state.baseline_eurusd)
  if not baseline or baseline <= 0 then baseline = price end

  local usd_strength = baseline / price
  local usd_index = 100 * usd_strength
  local q_usd_if_quid_strength_1 = 3.40 / usd_strength

  last_tick = {
    ok = true,
    quality = "LIVE",
    time = ms,
    provider = "Synthetic/Oracle",
    source = ORACLE_LATEST_URL,
    upstream = "Synthetic order flow anchored to Oracle EUR/USD",
    pair = "EUR/USD",
    pair_price = price,
    synthetic_price = price,
    anchor_price = anchor_price,
    anchor_age_ms = anchor_time_ms > 0 and (ms - anchor_time_ms) or nil,
    anchor_gap_seconds = anchor_gap_seconds,
    anchor_move_pips = anchor_move_pips,
    anchor_velocity_pips_per_sec = anchor_velocity_pips_per_sec,
    recent_anchor_pps = recentAnchorPps(),
    session_activity = sessionActivityMultiplier(),
    synthetic_momentum_pips = synthetic_momentum_pips,
    synthetic_corridor_pips = synthetic_corridor_pips,
    synthetic_last_noise_pips = synthetic_last_noise_pips,
    baseline_pair_price = baseline,
    baseline_time = state.baseline_time,
    usd_index = usd_index,
    usd_strength_index = usd_strength,
    q_usd_if_quid_strength_1 = q_usd_if_quid_strength_1,
    sample_count = sample_count,
    change_count = change_count,
    synthetic_tick_count = synthetic_tick_count,
    synthetic_change_count = synthetic_change_count,
    changed = changed,
    poll_seconds = POLL_SECONDS,
    synthetic_seconds = SYNTH_SECONDS,
    response_ms = last_response_ms,
    version = VERSION,
  }
end

local function emitSyntheticPrice(ms, price, changed)
  if not price or price <= 0 then return end
  synthetic_price = price
  synthetic_time_ms = ms

  synthetic_tick_count = synthetic_tick_count + 1
  if changed then synthetic_change_count = synthetic_change_count + 1 end

  updateCandleSet("1m", price, ms)
  updateCandleSet("5m", price, ms)
  updateCandleSet("15m", price, ms)

  buildSyntheticTick(ms, price, changed)

  processStopLosses()
  checkAutoLiquidations()
  processPendingOrders()
end

local function syntheticStep()
  if not anchor_price then return end

  local ms = nowMs()

  if not synthetic_price or synthetic_price <= 0 then
    synthetic_last_anchor_seen = anchor_price
    synthetic_momentum_pips = 0
    emitSyntheticPrice(ms, anchor_price, true)
    return
  end

  local dt = math.max(0.05, (ms - (synthetic_time_ms or ms)) / 1000)
  local target = anchor_price
  local distance = target - synthetic_price
  local distancePipsSigned = distance / PIP_SIZE
  local distancePips = math.abs(distancePipsSigned)

  local pps = recentAnchorPps()
  local corridor = syntheticCorridorPips(pps)
  synthetic_corridor_pips = corridor

  -- A new real anchor gives the synthetic flow directional pressure, but we do
  -- not snap. We just bias momentum toward the new anchor.
  if synthetic_last_anchor_seen ~= anchor_price then
    synthetic_last_anchor_seen = anchor_price
    local kick = clamp(distancePips * 0.10, 0.08, 1.25)
    synthetic_momentum_pips = synthetic_momentum_pips + (sign(distancePipsSigned) * kick)
  end

  local noiseAmp = syntheticNoiseAmpPips(dt, pps)
  local shock = randSigned() * noiseAmp
  synthetic_last_noise_pips = shock

  -- Momentum makes movement look like order flow instead of pure static noise.
  -- Quiet market: small drifting pipettes.
  -- Active market: bigger continuation and wicks.
  local decay = clamp(0.82 - (dt * 0.18), 0.60, 0.90)
  synthetic_momentum_pips = (synthetic_momentum_pips * decay) + (shock * 0.55)

  local maxMomentum = clamp(0.18 + (pps * 0.90) + (anchor_move_pips * 0.015), 0.18, 2.80)
  synthetic_momentum_pips = clamp(synthetic_momentum_pips, -maxMomentum, maxMomentum)

  local movePips = synthetic_momentum_pips

  if distancePips > corridor then
    -- If we are away from the real anchor, trend back to it. The trend rate is
    -- based on real anchor velocity, so a 1 pip / 10 sec day bridges slowly,
    -- while a fast anchor jump bridges faster.
    local bridgePps = clamp((pps * 2.50) + 0.15, 0.15, 7.50)
    local trendPips = sign(distancePipsSigned) * math.min(distancePips * 0.22, bridgePps * dt)
    movePips = movePips + trendPips
  else
    -- Once near the anchor, do not glue to it. Mean-revert gently while random
    -- walk and momentum keep the candle visibly alive inside the reasonable band.
    local reversionPips = distancePipsSigned * math.min(0.18, dt / 5.0)
    movePips = movePips + reversionPips + (shock * 0.45)
  end

  local nextPrice = synthetic_price + (movePips * PIP_SIZE)

  -- If the synthetic price is far away because a new real anchor arrived, do
  -- not let random momentum move it further away. That prevents ugly fake
  -- divergence while still avoiding a snap.
  local nextDistancePips = math.abs((target - nextPrice) / PIP_SIZE)
  if distancePips > corridor and nextDistancePips > distancePips + 0.05 then
    local forcedPips = sign(distancePipsSigned) * math.min(distancePips * 0.20, clamp((pps * 2.0) + 0.12, 0.12, 6.0) * dt)
    nextPrice = synthetic_price + (forcedPips * PIP_SIZE)
    synthetic_momentum_pips = synthetic_momentum_pips * 0.35
  end

  -- Once caught up, keep the live synthetic price inside a realistic band
  -- around the anchor. Bounce momentum at the edge so it looks like a wick.
  local errorFromAnchorPips = (nextPrice - target) / PIP_SIZE
  if math.abs(errorFromAnchorPips) > corridor and distancePips <= corridor * 1.50 then
    nextPrice = target + (sign(errorFromAnchorPips) * corridor * PIP_SIZE)
    synthetic_momentum_pips = -synthetic_momentum_pips * 0.45
  end

  nextPrice = roundPrice5(nextPrice)

  -- Because EUR/USD is displayed to 5 decimals, tiny sub-pip movements can
  -- round away. Force an occasional one-pipette move if we are otherwise flat
  -- but still inside the corridor. This is what makes the candle visibly move.
  if nextPrice == synthetic_price then
    local step = (randSigned() >= 0 and 1 or -1) * 0.00001
    local nudged = roundPrice5(synthetic_price + step)
    local nudgedError = math.abs((nudged - target) / PIP_SIZE)
    if distancePips > corridor or nudgedError <= corridor then
      nextPrice = nudged
    end
  end

  local changed = (nextPrice ~= synthetic_price)
  emitSyntheticPrice(ms, nextPrice, changed)
end


local function pushPrice(price)
  local ms = nowMs()
  local baseline = tonumber(state.baseline_eurusd)

  if not baseline or baseline <= 0 then
    state.baseline_eurusd = price
    state.baseline_time = ms
    baseline = price
    saveState()
  end

  sample_count = sample_count + 1
  last_success_ms = ms
  last_error = "OK"

  local moved = (anchor_price == nil or price ~= anchor_price)
  last_price = price

  if moved then
    change_count = change_count + 1

    if anchor_price and anchor_time_ms and anchor_time_ms > 0 then
      previous_anchor_price = anchor_price
      previous_anchor_time_ms = anchor_time_ms
      recordAnchorMove(previous_anchor_price, price, previous_anchor_time_ms, ms)
    end

    anchor_price = price
    anchor_time_ms = ms
  elseif not anchor_price then
    anchor_price = price
    anchor_time_ms = ms
  end

  -- First real tick boots the synthetic market. After that, syntheticStep()
  -- generates the tradable/live price at SYNTH_SECONDS.
  if not synthetic_price then
    emitSyntheticPrice(ms, price, true)
  end
end

local function handleHttpSuccess(url, handle)
  if url ~= ORACLE_LATEST_URL then
    if handle then pcall(function() handle.close() end) end
    return
  end

  pending_http = false
  last_response_ms = nowMs() - last_request_ms

  local body = nil
  local ok, res = pcall(function() return handle.readAll() end)
  if ok then body = res end
  pcall(function() handle.close() end)

  local price = parseOraclePrice(body)
  if price then
    pushPrice(price)
  else
    failure_count = failure_count + 1
    last_error = "Bad Oracle price body: " .. clampText(body, 80)
  end
end

local function handleHttpFailure(url, reason, handle)
  if url ~= ORACLE_LATEST_URL then
    if handle then pcall(function() handle.close() end) end
    return
  end
  pending_http = false
  failure_count = failure_count + 1
  if handle then pcall(function() handle.close() end) end
  last_error = "Oracle HTTP failed: " .. tostring(reason or "unknown")
end


local function nowMs()
  if os.epoch then return os.epoch("utc") end
  return math.floor(os.time() * 1000)
end

local function ensureDir(path)
  local dir = fs.getDir(path)
  if dir and dir ~= "" and not fs.exists(dir) then fs.makeDir(dir) end
end

local function readTable(path)
  if not fs.exists(path) then return nil end
  local f = fs.open(path, "r")
  if not f then return nil end
  local text = f.readAll()
  f.close()
  if not text or text == "" then return nil end
  local ok, data = pcall(textutils.unserialize, text)
  if ok and type(data) == "table" then return data end
  return nil
end

local function writeTable(path, data)
  ensureDir(path)
  local f = fs.open(path, "w")
  if not f then return false end
  f.write(textutils.serialize(data))
  f.close()
  return true
end

local function loadState()
  local s = readTable(STATE_FILE)
  if type(s) == "table" then
    state = s
  end
  state.created_version = state.created_version or VERSION
  state.baseline_pair = state.baseline_pair or "EUR/USD"

  local c = readTable(CANDLES_FILE)
  if type(c) == "table" then
    if type(c["1m"]) == "table" then candles["1m"] = c["1m"] end
    if type(c["5m"]) == "table" then candles["5m"] = c["5m"] end
    if type(c["15m"]) == "table" then candles["15m"] = c["15m"] end
  end

  local o = readTable(ORDERS_FILE)
  if type(o) == "table" then
    if type(o.active_orders) == "table" then active_orders = o.active_orders end
    if type(o.pending_orders) == "table" then pending_orders = o.pending_orders end
    if type(o.closed_orders) == "table" then closed_orders = o.closed_orders end
    next_order_id = tonumber(o.next_order_id) or next_order_id
    next_pending_id = tonumber(o.next_pending_id) or next_pending_id
  end
end

local function saveState()
  state.saved_at = nowMs()
  writeTable(STATE_FILE, state)
  writeTable(CANDLES_FILE, candles)
  writeTable(ORDERS_FILE, {
    active_orders = active_orders,
    pending_orders = pending_orders,
    closed_orders = closed_orders,
    next_order_id = next_order_id,
    next_pending_id = next_pending_id,
    saved_at = state.saved_at,

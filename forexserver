-- Treasury FX sizing.
-- 1.00 lot = 100,000 Q notional.
-- 0.01 lot = 1,000 Q notional.
-- P/L is also in Q:
--   BUY  P/L = (live - entry) * notional_q
--   SELL P/L = (entry - live) * notional_q
-- 2 pips on 1.00 lot = 20 Q, because 100,000Q * 0.0002 = 20Q.
local LOT_NOTIONAL_Q = 100000
local LOT_UNITS = LOT_NOTIONAL_Q
local DEFAULT_LOTS = 0.01
local MIN_LOTS = 0.01
local LOT_STEP = 0.01
local DEFAULT_LEVERAGE = 10
local MAX_LEVERAGE = 100
local MAINTENANCE_MARGIN_RATE = 0.50

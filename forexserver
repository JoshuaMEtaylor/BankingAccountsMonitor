  term.setCursorBlink(false)
  term.setBackgroundColor(colors.black)
  term.clear()

  fill(1, 1, W, 1, colors.blue)
  at(2, 1, "FOREX SERVER - ORACLE/KRAKEN", colors.white, colors.blue)
  at(math.max(1, W - #VERSION), 1, VERSION, colors.lightGray, colors.blue)

  local t = safeTick()
  local q = t.quality or "OFFLINE"

  at(2, 3, "Modem:        " .. tostring(modem_name or "none"), modem_name and colors.lime or colors.red)
  at(2, 4, "Protocol:     " .. PROTOCOL, colors.lightGray)
  at(2, 5, "Oracle URL:   " .. clampText(ORACLE_LATEST_URL, math.max(10, W - 16)), colors.lightGray)

  at(2, 7, "Quality:      " .. q, colourForQuality(q))
  at(2, 8, "Live synth:   " .. fmt(t.pair_price, 5), colors.lime)
  at(2, 9, "Anchor real:  " .. fmt(t.anchor_price, 5) .. "  age " .. tostring(t.anchor_age_ms and (math.floor(t.anchor_age_ms / 100) / 10) or "n/a") .. "s", colors.yellow)
  at(2,10, "Anchor flow:  " .. fmt(t.anchor_move_pips, 2) .. " pips / " .. fmt(t.anchor_gap_seconds, 1) .. "s  " .. fmt(t.anchor_velocity_pips_per_sec, 3) .. " pips/s", colors.cyan)
  at(2,11, "Synth flow:   every " .. tostring(SYNTH_SECONDS) .. "s  ticks " .. tostring(synthetic_tick_count) .. "  changes " .. tostring(synthetic_change_count), colors.cyan)
  at(2,12, "Flow:         band " .. fmt(t.synthetic_corridor_pips, 2) .. "p  mom " .. fmt(t.synthetic_momentum_pips, 2) .. "p  vel " .. fmt(t.recent_anchor_pps, 3) .. " p/s", colors.lime)

  at(2,14, "Oracle poll:  every " .. tostring(POLL_SECONDS) .. "s", colors.yellow)
  at(2,15, "Anchor reads: " .. tostring(sample_count) .. "  Anchor changes: " .. tostring(change_count) .. "  Fails: " .. tostring(failure_count), colors.lightGray)
  at(2,16, "Stored candles 1m/5m/15m: " .. tostring(#candles["1m"]) .. " / " .. tostring(#candles["5m"]) .. " / " .. tostring(#candles["15m"]), colors.lightGray)
  local pendingInfo = pending_http and ("pending " .. ageText(last_request_ms)) or "idle"
  at(2,17, "Last anchor: " .. ageText(last_success_ms) .. " ago  Response: " .. tostring(last_response_ms or 0) .. "ms  HTTP: " .. pendingInfo, colors.lightGray)
  at(2,18, "Orders:       open " .. tostring(#active_orders) .. " pending " .. tostring(#pending_orders) .. "  P/L " .. fmt(ordersSnapshot(nil).unrealized_pnl_q, 2) .. " Q  Bank " .. tostring(bank_id or "search"), colors.yellow)

  at(2,20, "Recent 5m closes", colors.white)
  drawSparkline(candles["5m"], 2, 21, math.max(10, W - 4), "close", colors.lime)

  at(2, H - 2, "Status: " .. clampText(last_error, math.max(10, W - 10)), last_error == "OK" and colors.lime or colors.orange)
  at(2, H - 1, "Server stores persistent 1m/5m/15m candle history for tabbed clients.", colors.gray)
end

local function main()
  loadState()
  openModem()

  requestOracleLatest()

  math.randomseed(nowMs() + os.getComputerID())
  poll_timer = os.startTimer(POLL_SECONDS)
  synth_timer = os.startTimer(SYNTH_SECONDS)
  draw_timer = os.startTimer(DRAW_SECONDS)
  save_timer = os.startTimer(SAVE_SECONDS)

  draw()

  while true do
    local ev = { os.pullEvent() }

    if ev[1] == "timer" then
      local id = ev[2]
      if id == poll_timer then
        requestOracleLatest()
        poll_timer = os.startTimer(POLL_SECONDS)
      elseif id == synth_timer then
        syntheticStep()
        synth_timer = os.startTimer(SYNTH_SECONDS)
      elseif id == draw_timer then
        draw()
        draw_timer = os.startTimer(DRAW_SECONDS)
      elseif id == save_timer then
        saveState()
        save_timer = os.startTimer(SAVE_SECONDS)
      end

    elseif ev[1] == "http_success" then
      handleHttpSuccess(ev[2], ev[3])

    elseif ev[1] == "http_failure" then
      handleHttpFailure(ev[2], ev[3], ev[4])

    elseif ev[1] == "rednet_message" then
      local sender, msg, protocol = ev[2], ev[3], ev[4]
      if protocol == PROTOCOL or protocol == nil then
        handleRequest(sender, msg)
      end

    elseif ev[1] == "term_resize" or ev[1] == "monitor_resize" then
      draw()
    end
  end
end

main()

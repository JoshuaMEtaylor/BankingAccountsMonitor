-- DISPLAY
-- =============================================================================
local function draw()
  W, H = term.getSize()
  term.setCursorBlink(false)
  term.setBackgroundColor(colors.black)
  term.clear()

  fill(1, 1, W, 1, colors.blue)
  at(2, 1, "FOREX SERVER - USD FEED PROBE", colors.white, colors.blue)
  at(math.max(1, W - #VERSION), 1, VERSION, colors.lightGray, colors.blue)

  local t = safeTick()
  at(2, 3, "Modem:       " .. tostring(modem_name or "none"), modem_name and colors.lime or colors.red)
  at(2, 4, "Protocol:    " .. PROTOCOL, colors.lightGray)
  at(2, 5, "Provider:    FMP /stable/quote", colors.lightGray)

  at(2, 7, "Quality:     " .. tostring(t.quality or "OFFLINE"), colourForQuality(t.quality))
  at(2, 8, "Pair:        " .. tostring(t.pair or PRIMARY_PAIR), colors.yellow)
  at(2, 9, "EUR/USD:     " .. fmt(t.pair_price, 6), colors.lime)
  at(2,10, "Baseline:    " .. fmt(t.baseline_pair_price, 6), colors.white)
  at(2,11, "USD index:   " .. fmt(t.usd_index, 4), colors.cyan)
  at(2,12, "USD strength:" .. fmt(t.usd_strength_index, 6) .. "x", colors.cyan)
  at(2,13, "Q/USD @ Q=1: $" .. fmt(t.q_usd_if_quid_strength_1, 4), colors.lime)

  at(2,15, "Peg formula:", colors.white)
  at(4,16, "QUSD = 3.40 * quid_strength / " .. fmt(t.usd_strength_index, 6), colors.lightGray)

  at(2,18, "USD strength history", colors.white)
  drawSparkline(history, 2, 19, math.max(10, W - 4), "usd_strength_index", colors.cyan)

  local untilFetch = math.max(0, math.floor((next_fetch_ms - nowMs()) / 1000))
  at(2, H - 3, "Next API refresh: " .. tostring(untilFetch) .. "s", colors.gray)
  at(2, H - 2, "Status: " .. clampText(last_error, W - 10), last_error == "OK" and colors.lime or colors.orange)
  at(2, H - 1, "This build proves live USD data first. No bank/Quid scan in this version.", colors.gray)
end

-- =============================================================================
-- MAIN
-- =============================================================================
local function main()
  loadState()
  openModem()
  refreshMarket(true)
  draw()

  while true do
    local timer = os.startTimer(1)
    local ev = { os.pullEvent() }

    if ev[1] == "timer" and ev[2] == timer then
      refreshMarket(false)
      draw()
    elseif ev[1] == "rednet_message" then
      local sender, msg, protocol = ev[2], ev[3], ev[4]
      if protocol == PROTOCOL or protocol == nil then
        handleRequest(sender, msg)
      end
      draw()
    elseif ev[1] == "term_resize" or ev[1] == "monitor_resize" then
      draw()
    end
  end
end

main()

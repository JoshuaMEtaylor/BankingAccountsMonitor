end

local function fmt(n, dp)
  n = tonumber(n)
  if n == nil then return "n/a" end
  return string.format("%." .. tostring(dp or 5) .. "f", n)
end

local function clampText(s, n)
  s = tostring(s or "")
  n = tonumber(n) or 80
  s = s:gsub("\n", " "):gsub("\r", " ")
  if #s > n then return s:sub(1, n - 3) .. "..." end
  return s
end

local function ageText(ms)
  if not ms or ms <= 0 then return "n/a" end
  local age = nowMs() - ms
  if age < 1000 then return tostring(age) .. "ms" end
  if age < 60000 then return string.format("%.1fs", age / 1000) end
  return string.format("%.1fm", age / 60000)
end

local function quality()
  -- Do not mark the market stale just because ComputerCraft missed/dropped an
  -- HTTP event while the server was busy settling a trade with the bank.
  -- Once we have a valid last tick, that tick remains the current market price
  -- until a newer tick arrives.
  if last_tick and tonumber(last_tick.pair_price) then return "LIVE" end
  if last_success_ms > 0 then return "LIVE" end
  return "OFFLINE"
end

local function colourForQuality(q)
  if q == "LIVE" then return colors.lime end
  if q == "STALE" then return colors.orange end
  if q == "OFFLINE" then return colors.red end
  return colors.yellow
end

local function openModem()
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      local m = peripheral.wrap(name)
      if m and m.isWireless and m.isWireless() then
        rednet.open(name)
        modem_name = name
        return true
      end
    end
  end
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      rednet.open(name)
      modem_name = name
      return true
    end
  end
  return false
end

local function clearPendingHttpBeforeBlocking(reason)
  if pending_http then
    pending_http = false
    skipped_polls = skipped_polls + 1
    last_error = "HTTP poll resumed after blocking bank call" .. (reason and (": " .. tostring(reason)) or "")
  end
end

local function discoverBank()
  if bank_id then return true end
  if not modem_name then return false end
  clearPendingHttpBeforeBlocking("bank discovery")

  for attempt = 1, 4 do
    rednet.broadcast({ type = "ping", client = "forexserver", version = VERSION }, BANK_PROTOCOL)
    local sender, msg = rednet.receive(BANK_PROTOCOL, 2)
    if sender and type(msg) == "table" then
      if msg.success ~= nil or msg.type == "treasury_online" then
        bank_id = sender
        return true
      end
    end
  end

  return false
end

local function bankRequest(req)
  if not bank_id and not discoverBank() then
    return false, "Bank server unavailable"
  end

  clearPendingHttpBeforeBlocking("bank request")
  rednet.send(bank_id, req, BANK_PROTOCOL)
  local sender, msg = rednet.receive(BANK_PROTOCOL, BANK_TIMEOUT)
  if sender ~= bank_id or type(msg) ~= "table" then
    bank_id = nil
    return false, "No response from bank"
  end

  return msg.success == true, msg.response or msg.error
end


local function at(x, y, text, fg, bg)
  W, H = term.getSize()
  if y < 1 or y > H or x > W then return end
  if x < 1 then x = 1 end
  term.setCursorPos(x, y)
  term.setTextColor(fg or colors.white)
  term.setBackgroundColor(bg or colors.black)
  local maxw = W - x + 1
  if maxw > 0 then term.write(tostring(text or ""):sub(1, maxw)) end
end

local function fill(x, y, w, h, bg)
  W, H = term.getSize()
  term.setBackgroundColor(bg or colors.black)
  local row = string.rep(" ", math.max(0, w))
  for yy = y, y + h - 1 do
    if yy >= 1 and yy <= H then
      term.setCursorPos(math.max(1, x), yy)
      term.write(row:sub(1, math.max(0, W - x + 1)))
    end
  end
end

local function drawSparkline(list, x, y, w, key, fg)
  if type(list) ~= "table" or #list < 2 then
    at(x, y, "awaiting history", colors.gray)
    return
  end

  local start = math.max(1, #list - w + 1)
  local vals = {}
  local lo, hi = nil, nil
  for i = start, #list do
    local v = tonumber(list[i] and list[i][key])
    if v then
      vals[#vals + 1] = v
      lo = lo and math.min(lo, v) or v
      hi = hi and math.max(hi, v) or v
    end
  end

  if #vals < 2 then
    at(x, y, "awaiting history", colors.gray)
    return
  end

  if hi == lo then hi = lo + 0.000001 end
  local chars = {"_", ".", ":", "-", "=", "+", "*", "#"}
  local out = ""
  for _, v in ipairs(vals) do
    local t = (v - lo) / (hi - lo)
    local idx = math.floor(t * (#chars - 1)) + 1
    if idx < 1 then idx = 1 end
    if idx > #chars then idx = #chars end
    out = out .. chars[idx]
  end
  at(x, y, out:sub(-w), fg or colors.cyan)
end

local function copyCandles(list)
  local out = {}
  if type(list) ~= "table" then return out end
  for i = 1, #list do
    local c = list[i]
    out[i] = {
      bucket = c.bucket,
      open = c.open,
      high = c.high,
      low = c.low,
      close = c.close,
      samples = c.samples,
      updated = c.updated,
    }
  end
  return out
end

local function trimCandles(tf)
  local cfg = TIMEFRAMES[tf]
  local list = candles[tf]
  if not cfg or type(list) ~= "table" then return end
  while #list > cfg.max do table.remove(list, 1) end
end

local function updateCandleSet(tf, price, ms)
  local cfg = TIMEFRAMES[tf]
  if not cfg then return end
  local list = candles[tf]
  if type(list) ~= "table" then
    list = {}
    candles[tf] = list
  end

  local bucket = math.floor(ms / (cfg.seconds * 1000)) * (cfg.seconds * 1000)
  local c = list[#list]

  if not c or c.bucket ~= bucket then
    -- Trading-terminal behaviour: a new candle opens at the previous candle's
    -- close, not halfway through the next movement. This keeps candles joined.
    local openPrice = price
    if c and tonumber(c.close) then openPrice = tonumber(c.close) end
    c = {
      bucket = bucket,
      open = openPrice,
      high = math.max(openPrice, price),
      low = math.min(openPrice, price),
      close = price,
      samples = 1,
      updated = ms,
    }
    list[#list + 1] = c
  else
    if price > c.high then c.high = price end
    if price < c.low then c.low = price end
    c.close = price
    c.samples = (c.samples or 0) + 1
    c.updated = ms
  end

  trimCandles(tf)
end

local function parseOraclePrice(body)
  body = tostring(body or ""):gsub("%s+", "")
  local p = tonumber(body)
  if p and p > 0 then return p end
  return nil
end

local function requestOracleLatest()
  if pending_http then
    local age = nowMs() - (last_request_ms or 0)
    if age > HTTP_WATCHDOG_MS then
      -- ComputerCraft can occasionally never deliver http_success/http_failure.
      -- If we leave pending_http stuck true forever, polling stops and quality
      -- becomes stale even though the oracle is still fine.
      pending_http = false
      failure_count = failure_count + 1
      last_error = "HTTP watchdog reset after " .. tostring(age) .. "ms"
    else
      skipped_polls = skipped_polls + 1
      return
    end
  end

  if not http or type(http.request) ~= "function" then
    last_error = "ComputerCraft HTTP API unavailable/disabled"
    return
  end

  pending_http = true
  last_request_ms = nowMs()

  local ok, err = pcall(function()
    http.request(ORACLE_LATEST_URL)
  end)

  if not ok then
    pending_http = false
    failure_count = failure_count + 1
    last_error = "http.request failed: " .. tostring(err)
  end
end


local function clamp(n, lo, hi)
  n = tonumber(n) or 0
  if n < lo then return lo end
  if n > hi then return hi end
  return n
end

local function randSigned()
  return (math.random() * 2) - 1
end

local function recordAnchorMove(oldPrice, newPrice, oldMs, newMs)
  oldPrice = tonumber(oldPrice)
  newPrice = tonumber(newPrice)
  oldMs = tonumber(oldMs) or 0
  newMs = tonumber(newMs) or nowMs()

  if not oldPrice or not newPrice or oldPrice <= 0 or newPrice <= 0 or oldMs <= 0 or newMs <= oldMs then
    return
  end

  local gapS = math.max(0.1, (newMs - oldMs) / 1000)
  local movePips = math.abs(newPrice - oldPrice) / PIP_SIZE
  local pps = movePips / gapS

  anchor_gap_seconds = gapS
  anchor_move_pips = movePips
  anchor_velocity_pips_per_sec = pps

  anchor_history[#anchor_history + 1] = {
    time = newMs,
    gap_s = gapS,
    move_pips = movePips,
    pps = pps,
    dir = newPrice >= oldPrice and 1 or -1,
  }

  while #anchor_history > SYNTH_HISTORY_MAX do table.remove(anchor_history, 1) end
end

local function recentAnchorPps()
  if #anchor_history == 0 then return 0.05 end

  local totalWeight = 0
  local total = 0
  local now = nowMs()

  for i = #anchor_history, 1, -1 do
    local h = anchor_history[i]
    local ageS = math.max(0, (now - (tonumber(h.time) or now)) / 1000)
    local w = 1 / (1 + ageS / 20)
    total = total + ((tonumber(h.pps) or 0) * w)
    totalWeight = totalWeight + w
  end

  if totalWeight <= 0 then return 0.05 end

  local pps = total / totalWeight

  -- If the anchor itself has not changed for a while, calm the synthetic flow down.
  local quietS = anchor_time_ms > 0 and ((now - anchor_time_ms) / 1000) or 60
  local quietDecay = 1 / (1 + quietS / 25)

  return math.max(0.02, pps * quietDecay)
end

local function sessionActivityMultiplier()
  -- Small realism layer only. Real anchor movement remains the main driver.
  -- os.date("!*t") is UTC, which maps well to FX session discussion.
  local t = os.date("!*t")
  local wday = tonumber(t.wday) or 1 -- Sunday=1
  local hour = tonumber(t.hour) or 0

  if wday == 1 or wday == 7 then return 0.15 end -- weekend

  if hour >= 13 and hour < 16 then return 1.30 end -- London/NY overlap
  if hour >= 7 and hour < 12 then return 1.10 end -- London
  if hour >= 16 and hour < 21 then return 0.95 end -- NY
  if hour >= 0 and hour < 6 then return 0.45 end -- Asia/quiet for EUR/USD
  return 0.65
end

local function sign(n)
  n = tonumber(n) or 0
  if n > 0 then return 1 end
  if n < 0 then return -1 end
  return 0
end

local function syntheticCorridorPips(pps)
  pps = tonumber(pps) or 0
  local activity = sessionActivityMultiplier()

  -- The corridor is the allowed "live order flow" band around the real anchor
  -- once synthetic price has caught up. Quiet anchors get a tight band. Moving
  -- anchors get a wider band.
  local move = tonumber(anchor_move_pips) or 0
  local c = (0.65 + (pps * 4.50) + (move * 0.035)) * math.max(0.35, activity)

  return clamp(c, 0.45, 8.00)
end

local function syntheticNoiseAmpPips(dt, pps)
  dt = math.max(0.05, tonumber(dt) or SYNTH_SECONDS)
  pps = tonumber(pps) or 0

  local activity = sessionActivityMultiplier()
  local anchorPps = tonumber(anchor_velocity_pips_per_sec) or 0

  -- This is the important change:
  -- even if the latest anchor is currently unchanged, the candle still gets a
  -- small visible pipette-level random walk. The size is still scaled by recent
  -- anchor movement, so a slow day stays slow.
  local flowPps = (pps * 0.65) + (anchorPps * 0.35)
  flowPps = clamp(flowPps, 0.06, 5.00)

  local amp = (0.045 + (flowPps * 0.32)) * math.sqrt(dt / 0.25) * math.max(0.45, activity)

  -- 0.035 pip = enough to sometimes round into a 0.1 pip visible move.
  -- Higher real movement expands the random walk naturally.
  return clamp(amp, 0.035, 1.20)
end

local function roundPrice5(price)

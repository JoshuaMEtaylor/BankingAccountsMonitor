local function nowMs()
  if os.epoch then return os.epoch("utc") end
  return math.floor(os.time() * 1000)
end

local function ensureDir(path)
  local dir = fs.getDir(path)
  if dir and dir ~= "" and not fs.exists(dir) then fs.makeDir(dir) end
end

local function readTable(path)
  if not fs.exists(path) then return nil end
  local f = fs.open(path, "r")
  if not f then return nil end
  local text = f.readAll()
  f.close()
  if not text or text == "" then return nil end
  local ok, data = pcall(textutils.unserialize, text)
  if ok and type(data) == "table" then return data end
  return nil
end

local function writeTable(path, data)
  ensureDir(path)
  local f = fs.open(path, "w")
  if not f then return false end
  f.write(textutils.serialize(data))
  f.close()
  return true
end

local function loadState()
  local s = readTable(STATE_FILE)
  if type(s) == "table" then
    state = s
  end
  state.created_version = state.created_version or VERSION
  state.baseline_pair = state.baseline_pair or "EUR/USD"

  local c = readTable(CANDLES_FILE)
  if type(c) == "table" then
    if type(c["1m"]) == "table" then candles["1m"] = c["1m"] end
    if type(c["5m"]) == "table" then candles["5m"] = c["5m"] end
    if type(c["15m"]) == "table" then candles["15m"] = c["15m"] end
  end

  local o = readTable(ORDERS_FILE)
  if type(o) == "table" then
    if type(o.active_orders) == "table" then active_orders = o.active_orders end
    if type(o.closed_orders) == "table" then closed_orders = o.closed_orders end
    next_order_id = tonumber(o.next_order_id) or next_order_id
  end
end

local function saveState()
  state.saved_at = nowMs()
  writeTable(STATE_FILE, state)
  writeTable(CANDLES_FILE, candles)
  writeTable(ORDERS_FILE, {
    active_orders = active_orders,
    closed_orders = closed_orders,
    next_order_id = next_order_id,
    saved_at = state.saved_at,
    version = VERSION,
  })
end

local function fmt(n, dp)
  n = tonumber(n)
  if n == nil then return "n/a" end
  return string.format("%." .. tostring(dp or 5) .. "f", n)
end

local function clampText(s, n)
  s = tostring(s or "")
  n = tonumber(n) or 80
  s = s:gsub("\n", " "):gsub("\r", " ")
  if #s > n then return s:sub(1, n - 3) .. "..." end
  return s
end

local function ageText(ms)
  if not ms or ms <= 0 then return "n/a" end
  local age = nowMs() - ms
  if age < 1000 then return tostring(age) .. "ms" end
  if age < 60000 then return string.format("%.1fs", age / 1000) end
  return string.format("%.1fm", age / 60000)
end

local function quality()
  if last_success_ms <= 0 then return "OFFLINE" end
  if nowMs() - last_success_ms > STALE_AFTER_MS then return "STALE" end
  return "LIVE"
end

local function colourForQuality(q)
  if q == "LIVE" then return colors.lime end
  if q == "STALE" then return colors.orange end
  if q == "OFFLINE" then return colors.red end
  return colors.yellow
end

local function openModem()
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      local m = peripheral.wrap(name)
      if m and m.isWireless and m.isWireless() then
        rednet.open(name)
        modem_name = name
        return true
      end
    end
  end
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      rednet.open(name)
      modem_name = name
      return true
    end
  end
  return false
end

local function discoverBank()
  if bank_id then return true end
  if not modem_name then return false end

  for attempt = 1, 4 do
    rednet.broadcast({ type = "ping", client = "forexserver", version = VERSION }, BANK_PROTOCOL)
    local sender, msg = rednet.receive(BANK_PROTOCOL, 2)
    if sender and type(msg) == "table" then
      if msg.success ~= nil or msg.type == "treasury_online" then
        bank_id = sender
        return true
      end
    end
  end

  return false
end

local function bankRequest(req)
  if not bank_id and not discoverBank() then
    return false, "Bank server unavailable"
  end

  rednet.send(bank_id, req, BANK_PROTOCOL)
  local sender, msg = rednet.receive(BANK_PROTOCOL, BANK_TIMEOUT)
  if sender ~= bank_id or type(msg) ~= "table" then
    bank_id = nil
    return false, "No response from bank"
  end

  return msg.success == true, msg.response or msg.error
end


local function at(x, y, text, fg, bg)
  W, H = term.getSize()
  if y < 1 or y > H or x > W then return end
  if x < 1 then x = 1 end
  term.setCursorPos(x, y)
  term.setTextColor(fg or colors.white)
  term.setBackgroundColor(bg or colors.black)
  local maxw = W - x + 1
  if maxw > 0 then term.write(tostring(text or ""):sub(1, maxw)) end
end

local function fill(x, y, w, h, bg)
  W, H = term.getSize()
  term.setBackgroundColor(bg or colors.black)
  local row = string.rep(" ", math.max(0, w))
  for yy = y, y + h - 1 do
    if yy >= 1 and yy <= H then
      term.setCursorPos(math.max(1, x), yy)
      term.write(row:sub(1, math.max(0, W - x + 1)))
    end
  end
end

local function drawSparkline(list, x, y, w, key, fg)
  if type(list) ~= "table" or #list < 2 then
    at(x, y, "awaiting history", colors.gray)
    return
  end

  local start = math.max(1, #list - w + 1)
  local vals = {}
  local lo, hi = nil, nil
  for i = start, #list do
    local v = tonumber(list[i] and list[i][key])
    if v then
      vals[#vals + 1] = v
      lo = lo and math.min(lo, v) or v
      hi = hi and math.max(hi, v) or v
    end
  end

  if #vals < 2 then
    at(x, y, "awaiting history", colors.gray)
    return
  end

  if hi == lo then hi = lo + 0.000001 end
  local chars = {"_", ".", ":", "-", "=", "+", "*", "#"}
  local out = ""
  for _, v in ipairs(vals) do
    local t = (v - lo) / (hi - lo)
    local idx = math.floor(t * (#chars - 1)) + 1
    if idx < 1 then idx = 1 end
    if idx > #chars then idx = #chars end
    out = out .. chars[idx]
  end
  at(x, y, out:sub(-w), fg or colors.cyan)
end

local function copyCandles(list)
  local out = {}
  if type(list) ~= "table" then return out end
  for i = 1, #list do
    local c = list[i]
    out[i] = {
      bucket = c.bucket,
      open = c.open,
      high = c.high,
      low = c.low,
      close = c.close,
      samples = c.samples,
      updated = c.updated,
    }
  end
  return out
end

local function trimCandles(tf)
  local cfg = TIMEFRAMES[tf]
  local list = candles[tf]
  if not cfg or type(list) ~= "table" then return end
  while #list > cfg.max do table.remove(list, 1) end
end

local function updateCandleSet(tf, price, ms)
  local cfg = TIMEFRAMES[tf]
  if not cfg then return end
  local list = candles[tf]
  if type(list) ~= "table" then
    list = {}
    candles[tf] = list
  end

  local bucket = math.floor(ms / (cfg.seconds * 1000)) * (cfg.seconds * 1000)
  local c = list[#list]

  if not c or c.bucket ~= bucket then
    -- Trading-terminal behaviour: a new candle opens at the previous candle's
    -- close, not halfway through the next movement. This keeps candles joined.
    local openPrice = price
    if c and tonumber(c.close) then openPrice = tonumber(c.close) end
    c = {
      bucket = bucket,
      open = openPrice,
      high = math.max(openPrice, price),
      low = math.min(openPrice, price),
      close = price,
      samples = 1,
      updated = ms,
    }
    list[#list + 1] = c
  else
    if price > c.high then c.high = price end
    if price < c.low then c.low = price end
    c.close = price
    c.samples = (c.samples or 0) + 1
    c.updated = ms
  end

  trimCandles(tf)
end

local function parseOraclePrice(body)
  body = tostring(body or ""):gsub("%s+", "")
  local p = tonumber(body)
  if p and p > 0 then return p end
  return nil
end

local function requestOracleLatest()
  if pending_http then
    skipped_polls = skipped_polls + 1
    return
  end

  if not http or type(http.request) ~= "function" then
    last_error = "ComputerCraft HTTP API unavailable/disabled"
    return
  end

  pending_http = true
  last_request_ms = nowMs()

  local ok, err = pcall(function()
    http.request(ORACLE_LATEST_URL)
  end)

  if not ok then
    pending_http = false
    failure_count = failure_count + 1
    last_error = "http.request failed: " .. tostring(err)
  end
end

local function pushPrice(price)
  local ms = nowMs()
  local baseline = tonumber(state.baseline_eurusd)

  if not baseline or baseline <= 0 then
    state.baseline_eurusd = price
    state.baseline_time = ms
    baseline = price
    saveState()
  end

  local usd_strength = baseline / price
  local usd_index = 100 * usd_strength
  local q_usd_if_quid_strength_1 = 3.40 / usd_strength
  local moved = (last_price == nil or price ~= last_price)

  sample_count = sample_count + 1
  if moved then change_count = change_count + 1 end
  last_price = price
  last_success_ms = ms
  last_error = "OK"

  updateCandleSet("1m", price, ms)
  updateCandleSet("5m", price, ms)
  updateCandleSet("15m", price, ms)
  checkAutoLiquidations()

  last_tick = {
    ok = true,
    quality = "LIVE",
    time = ms,
    provider = "Oracle",
    source = ORACLE_LATEST_URL,
    upstream = "Kraken EUR/USD ticker via Oracle node",
    pair = "EUR/USD",
    pair_price = price,
    baseline_pair_price = baseline,
    baseline_time = state.baseline_time,
    usd_index = usd_index,
    usd_strength_index = usd_strength,
    q_usd_if_quid_strength_1 = q_usd_if_quid_strength_1,
    sample_count = sample_count,
    change_count = change_count,
    changed = moved,
    poll_seconds = POLL_SECONDS,
    response_ms = last_response_ms,
    version = VERSION,
  }
end

local function handleHttpSuccess(url, handle)
  if url ~= ORACLE_LATEST_URL then
    if handle then pcall(function() handle.close() end) end
    return
  end

  pending_http = false
  last_response_ms = nowMs() - last_request_ms

  local body = nil
  local ok, res = pcall(function() return handle.readAll() end)
  if ok then body = res end
  pcall(function() handle.close() end)

  local price = parseOraclePrice(body)
  if price then
    pushPrice(price)
  else
    failure_count = failure_count + 1
    last_error = "Bad Oracle price body: " .. clampText(body, 80)
  end
end

local function handleHttpFailure(url, reason, handle)
  if url ~= ORACLE_LATEST_URL then
    if handle then pcall(function() handle.close() end) end
    return
  end
  pending_http = false
  failure_count = failure_count + 1
  if handle then pcall(function() handle.close() end) end
  last_error = "Oracle HTTP failed: " .. tostring(reason or "unknown")
end


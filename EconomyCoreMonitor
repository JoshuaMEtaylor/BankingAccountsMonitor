local C = {
  bg = colors.black,
  header = colors.blue,
  title = colors.white,
  text = colors.lightGray,
  dim = colors.gray,
  good = colors.lime,
  warn = colors.orange,
  bad = colors.red,
  gdp = colors.blue,
  capita = colors.cyan,
  inflation = colors.purple,
  inequality = colors.red,
  money = colors.green,
  scale = colors.brown,
}

local function card(x, y, w, h, title, colour)
  fill(x, y, w, h, C.bg)
  fill(x, y, w, 1, colour or colors.gray)
  writeAt(x + 1, y, string.upper(title or ""), colors.white, colour or colors.gray)
end

local function metric(x, y, label, value, valueColour, labelW)
  labelW = labelW or 20
  writeAt(x, y, tostring(label):sub(1, labelW), C.text, C.bg)
  writeAt(x + labelW + 1, y, tostring(value or "Awaiting data"), valueColour or colors.white, C.bg)
end

local function graphCard(x, y, w, h, title, currentLabel, currentValue, currentColour, series, colour, missingReason)
  card(x, y, w, h, title, colour)

  writeAt(x + 2, y + 2, string.upper(currentLabel or "CURRENT"), C.text, C.bg)
  writeAt(x + 2, y + 3, tostring(currentValue or "Awaiting data"), currentColour or C.warn, C.bg)

  local gx = x + 2
  local gy = y + 6
  local gw = w - 4
  local gh = h - 9
  if gh < 4 then gh = 4 end

  if not series or #series < 2 then
    fill(gx, gy, gw, gh, C.bg)
    centerIn(x, gy + math.floor(gh / 2), w, "Awaiting live history", C.warn, C.bg)
    writeAt(x + 2, y + h - 2, "Waiting: " .. shortText(missingReason or "source data", w - 13), C.dim, C.bg)
    return
  end

  local start = math.max(1, #series - gw + 1)
  local values = {}
  for i = start, #series do
    local v = tonumber(series[i])
    if v then values[#values + 1] = v end
  end
  if #values < 2 then
    centerIn(x, gy + math.floor(gh / 2), w, "Awaiting live history", C.warn, C.bg)
    return
  end

  local minV = values[1]
  local maxV = values[1]
  for _, v in ipairs(values) do
    if v < minV then minV = v end
    if v > maxV then maxV = v end
  end
  local range = maxV - minV
  if range == 0 then range = 1 end

  -- Render a connected low-resolution line chart.
  -- Older builds plotted each sample as a marker, which looked like scattered points.
  -- This builds a tiny character canvas first, then draws line segments between samples.
  local canvas = {}
  for row = 1, gh do
    canvas[row] = {}
    for col = 1, gw do
      canvas[row][col] = " "
    end
  end

  -- Light horizontal guide lines, kept subtle so the actual line is the focus.
  for row = 1, gh do
    if row == 1 or row == gh or row == math.ceil(gh / 2) then
      for col = 1, gw do
        canvas[row][col] = "."
      end
    end
  end

  local points = {}
  for i, v in ipairs(values) do
    if i <= gw then
      local norm = (v - minV) / range
      local py = gy + gh - 1 - math.floor(norm * (gh - 1) + 0.5)
      py = clamp(py, gy, gy + gh - 1)
      points[#points + 1] = { x = i, y = py - gy + 1 }
    end
  end

  local function put(col, row, ch)
    if row >= 1 and row <= gh and col >= 1 and col <= gw then
      canvas[row][col] = ch
    end
  end

  for i = 2, #points do
    local a = points[i - 1]
    local b = points[i]
    local dy = b.y - a.y

    if dy == 0 then
      put(a.x, a.y, "-")
      put(b.x, b.y, "-")
    else
      local ch = dy < 0 and "/" or "\\"
      put(a.x, a.y, ch)
      put(b.x, b.y, ch)

      -- When a move is too steep for a one-character diagonal, fill the gap
      -- vertically in the new column so it reads as one connected move.
      if math.abs(dy) > 1 then
        local step = dy > 0 and 1 or -1
        local row = a.y + step
        while row ~= b.y do
          put(b.x, row, "|")
          row = row + step
        end
      end
    end
  end

  -- Mark the latest point without turning the whole graph back into markers.
  local latest = points[#points]
  if latest then put(latest.x, latest.y, "o") end

  for row = 1, gh do
    writeAt(gx, gy + row - 1, table.concat(canvas[row]), colour, C.bg)
  end

  writeAt(x + 2, y + h - 1, "min " .. fmtNum(minV, 1), C.dim, C.bg)
  local maxText = "max " .. fmtNum(maxV, 1)
  writeAt(x + w - #maxText - 1, y + h - 1, maxText, C.dim, C.bg)
end

local function drawInequalityCard(x, y, w, h, snap)
  local q = snap and snap.inequality or {}
  card(x, y, w, h, "INEQUALITY", C.inequality)

  metric(x + 2, y + 2, "Top 1% share", q.top1_share and fmtPct(q.top1_share, 1) or "Awaiting data", q.top1_share and colors.white or C.warn)
  metric(x + 2, y + 3, "Average balance", fmtMoney(q.average_balance), q.average_balance and colors.white or C.warn)
  metric(x + 2, y + 4, "Citizen wealth", fmtMoney(q.total_balance), q.total_balance and colors.white or C.warn)
  metric(x + 2, y + 5, "Accounts", tostring(q.observations or "Awaiting data"), q.observations and colors.white or C.warn)

  local barW = math.max(10, w - 6)
  local filled = 0
  if q.top1_share then filled = math.floor(clamp(q.top1_share / 100, 0, 1) * barW) end
  local barY = math.min(y + 7, y + h - 3)
  fill(x + 2, barY, barW, 1, colors.gray)
  if filled > 0 then fill(x + 2, barY, filled, 1, C.inequality) end
  if barY + 1 <= y + h - 2 then
    writeAt(x + 2, barY + 1, "Top 1% share of citizen balances", C.dim, C.bg)
  end

  writeAt(x + 2, y + h - 1, shortText(q.status or "Awaiting account aggregation", w - 4), q.status and q.status:find("Live") and C.good or C.warn, C.bg)
end

local function drawMonetaryCard(x, y, w, h, snap)
  local po = snap and snap.price_oracle or {}
  local wp = type(po.wage_price) == "table" and po.wage_price or {}
  local m = snap and snap.monetary or {}
  card(x, y, w, h, "MONETARY CONDITIONS", C.money)

  local issued = tonumber(m.issued_supply)
  local private = tonumber(m.private_supply)
  local treasury = tonumber(m.treasury_reserve)
  local reserve = tonumber(m.reserve_share)

  metric(x + 2, y + 2, "Issued supply", fmtMoney(issued), issued and C.good or C.warn, 18)
  metric(x + 2, y + 3, "Private supply", fmtMoney(private), private and colors.white or C.warn, 18)
  metric(x + 2, y + 4, "Treasury", fmtMoney(treasury), treasury and colors.white or C.warn, 18)
  metric(x + 2, y + 5, "Treasury share", reserve and fmtPct(reserve, 1) or "Awaiting data", reserve and colors.white or C.warn, 18)

  if not po.connected then
    metric(x + 2, y + 7, "Fallback inflation", fmtPct(snap and snap.inflation, 2), snap and snap.inflation and colors.white or C.warn, 18)
    writeAt(x + 2, y + h - 1, shortText(po.status or "Awaiting wage/price oracle", w - 4), C.warn, C.bg)
    return
  end

  local priceIdx = tonumber(wp.national_price_index or po.national_price_index)
  local wageIdx = tonumber(wp.wage_index or po.wage_index)
  local moneyPressure = tonumber(wp.money_pressure)
  local businessPressure = tonumber(wp.business_margin_pressure)
  local workerPressure = tonumber(wp.wage_demand_pressure)
  local wageCostPressure = tonumber(wp.wage_cost_pressure)
  local totalPressure = tonumber(wp.total_inflation_pressure)
  local realWage = tonumber(wp.real_wage_ratio)
  local bankRate = tonumber(po.inflation_percent)

  metric(x + 2, y + 7, "Inflation rate", bankRate and fmtPct(bankRate, 2) or "Awaiting data", bankRate and colors.white or C.warn, 18)
  metric(x + 2, y + 8, "Price index", fmtIndex(priceIdx, 3), priceIdx and colors.white or C.warn, 18)
  metric(x + 2, y + 9, "Wage index", fmtIndex(wageIdx, 3), wageIdx and colors.white or C.warn, 18)
  metric(x + 2, y + 10, "Real wage", realWage and fmtPct(realWage * 100, 1) or "Awaiting data", realWage and (realWage < 1 and C.warn or C.good) or C.warn, 18)
  metric(x + 2, y + 11, "Money pressure", moneyPressure and fmtPct(moneyPressure * 100, 2) or "Awaiting data", moneyPressure and colors.white or C.warn, 18)
  metric(x + 2, y + 12, "Business drift", businessPressure and fmtPct(businessPressure * 100, 3) or "Awaiting data", businessPressure and colors.white or C.warn, 18)
  metric(x + 2, y + 13, "Worker pressure", workerPressure and fmtPct(workerPressure * 100, 2) or "Awaiting data", workerPressure and workerPressure > 0 and C.warn or C.dim, 18)
  metric(x + 2, y + 14, "Wage-cost", wageCostPressure and fmtPct(wageCostPressure * 100, 2) or "Awaiting data", wageCostPressure and wageCostPressure > 0 and C.warn or C.dim, 18)
  metric(x + 2, y + 15, "Total pressure", totalPressure and fmtPct(totalPressure * 100, 2) or "Awaiting data", totalPressure and colors.white or C.warn, 18)

  writeAt(x + 2, y + h - 1, shortText(po.status or "Live monetary + wage pressure", w - 4), C.good, C.bg)
end

local function drawPriceOracleCard(x, y, w, h, snap)
  local po = snap and snap.price_oracle or {}
  card(x, y, w, h, "PRICE / INFLATION ENGINE", C.money)

  if not po.connected then
    metric(x + 2, y + 2, "Status", shortText(po.status or "Awaiting price oracle", w - 15), C.warn)
    local m = snap and snap.monetary or {}
    metric(x + 2, y + 4, "Issued supply", fmtMoney(m.issued_supply), m.issued_supply and C.good or C.warn)
    metric(x + 2, y + 5, "Fallback inflation", fmtPct(snap and snap.inflation, 2), snap and snap.inflation and colors.white or C.warn)
    writeAt(x + 2, y + h - 1, "Bank oracle endpoint failed; reboot/patched ServerSideAccounts required", C.warn, C.bg)
    return
  end

  local food = sectorFromOracle(po, "food") or {}
  local construction = sectorFromOracle(po, "construction") or {}
  local fuel = sectorFromOracle(po, "fuel") or {}
  local logistics = sectorFromOracle(po, "logistics") or {}
  local tools = sectorFromOracle(po, "tools") or {}
  local hospitality = sectorFromOracle(po, "hospitality") or {}
  local general = sectorFromOracle(po, "general") or {}

  local floor = tonumber(food.price_pressure_floor or general.price_pressure_floor)
  local pressure = tonumber(food.monetary_pressure or general.monetary_pressure)
  local shock = tonumber(food.shock_pressure or general.shock_pressure)
  local defCap = tonumber(food.max_daily_deflation or general.max_daily_deflation)

  metric(x + 2, y + 2, "Bank rate", fmtPct(po.inflation_percent, 2), po.inflation_percent and colors.white or C.warn, 16)
  metric(x + 2, y + 3, "Price pressure", fmtPct(pressure and (pressure * 100) or nil, 1), pressure and colors.white or C.warn, 16)
  metric(x + 2, y + 4, "Admin floor", fmtPct(floor and (floor * 100) or nil, 1), floor and floor > 0 and C.warn or C.dim, 16)
  metric(x + 2, y + 5, "Print shock", fmtPct(shock and (shock * 100) or nil, 1), shock and shock > 0 and C.warn or C.dim, 16)
  metric(x + 2, y + 6, "Deflation cap", fmtPct(defCap and (defCap * 100) or nil, 1), defCap and colors.white or C.warn, 16)
  metric(x + 2, y + 8, "General/Food", fmtIndex(general.index, 2) .. " / " .. fmtIndex(food.index, 2), food.index and colors.white or C.warn, 16)
  metric(x + 2, y + 9, "Construct/Fuel", fmtIndex(construction.index, 2) .. " / " .. fmtIndex(fuel.index, 2), construction.index and colors.white or C.warn, 16)

  local q = po.quotes or {}
  local lineY = y + 11
  if lineY <= y + h - 3 then
    writeAt(x + 2, lineY, "Live quotes", colors.white, C.bg)
  end
  if lineY + 1 <= y + h - 2 then
    local meal = quoteLabel(q.dining_meal) or "n/a"
    local large = quoteLabel(q.large_meal) or "n/a"
    writeAt(x + 2, lineY + 1, shortText("Meal normal/large: " .. meal .. " / " .. large, w - 4), C.text, C.bg)
  end
  if lineY + 2 <= y + h - 2 then
    local build = quoteLabel(q.oak_planks_64) or "n/a"
    local iron = quoteLabel(q.iron_ingot_8) or "n/a"
    writeAt(x + 2, lineY + 2, shortText("64 planks: " .. build .. "   8 iron: " .. iron, w - 4), C.text, C.bg)
  end
  if lineY + 3 <= y + h - 2 then
    local coal = quoteLabel(q.coal_16) or "n/a"
    writeAt(x + 2, lineY + 3, shortText("16 coal: " .. coal, w - 4), C.text, C.bg)
  end

  writeAt(x + 2, y + h - 1, shortText(po.status or "Live sector CPI", w - 4), C.good, C.bg)
end

local function drawScaleCard(x, y, w, h, snap)
  local s = snap and snap.scale or {}
  card(x, y, w, h, "POPULATION / COMPANIES / TRANSACTIONS", C.scale)
  metric(x + 2, y + 2, "Population", tostring(s.population or "Awaiting data"), s.population and colors.white or C.warn)
  metric(x + 2, y + 3, "Companies", tostring(s.companies or "Awaiting data"), s.companies and colors.white or C.warn)
  metric(x + 2, y + 4, "TX today", s.transactions_today ~= nil and tostring(s.transactions_today) or "Awaiting data", s.transactions_today ~= nil and colors.white or C.warn)
  local txBreak = "E/A/P/S: " .. tostring(s.economic_transactions_today or 0) .. "/" .. tostring(s.admin_transactions_today or 0) .. "/" .. tostring(s.payroll_transactions_today or 0) .. "/" .. tostring(s.service_transactions_today or 0)
  writeAt(x + 2, y + 5, shortText(txBreak, w - 4), C.text, C.bg)

  local c = snap and snap.contracts or {}
  local contractLine = "Contracts O/C/F: " .. tostring(c.open or 0) .. "/" .. tostring(c.claimed or 0) .. "/" .. tostring(c.fulfilled or 0)
  writeAt(x + 2, y + 6, shortText(contractLine, w - 4), c.connected and C.good or C.warn, C.bg)

  local svc = snap and snap.service_gdp or nil
  local hosp = snap and snap.hospitality_gdp or nil
  local conGdp = snap and snap.contract_gdp or nil
  local serviceLine = "GDP split C/S: " .. fmtMoney(conGdp or 0) .. " / " .. fmtMoney(svc or 0)
  writeAt(x + 2, y + 7, shortText(serviceLine, w - 4), (svc and svc > 0) and C.good or C.dim, C.bg)
  if hosp and hosp > 0 then
    writeAt(x + 2, y + 8, shortText("Restaurant/meals GDP: " .. fmtMoney(hosp), w - 4), colors.yellow, C.bg)
  end

  writeAt(x + 2, y + 10, "Top companies", colors.white, C.bg)
  local top = s.top_companies or {}
  if type(top) ~= "table" or #top == 0 then
    writeAt(x + 2, y + 11, "No company account data", C.warn, C.bg)
  else
    local maxRows = math.min(10, #top, math.max(1, h - 13))
    for i = 1, maxRows do
      local company = top[i] or {}
      local name = shortText(company.name or company.id or ("Company " .. i), math.max(8, w - 18))
      local bal = fmtMoney(company.balance)
      local line = tostring(i) .. ". " .. name
      writeAt(x + 2, y + 10 + i, shortText(line, w - 18), C.text, C.bg)
      writeAt(x + w - #bal - 2, y + 10 + i, bal, colors.white, C.bg)
    end
  end

  writeAt(x + 2, y + h - 1, shortText(s.tx_today_status or "Awaiting real transaction stats", w - 4), C.dim, C.bg)
end

local function drawHeader(snap)
  local w = getSize()
  fill(1, 1, w, 1, C.header)
  writeAt(2, 1, "ECONOMY CORE MONITOR", C.title, C.header)
  local v = "v" .. VERSION
  writeAt(w - #v, 1, v, C.title, C.header)

  fill(1, 2, w, 2, C.bg)
  local clock = (snap and snap.mc_clock) or minecraftClock()
  writeAt(2, 2, "Mode: " .. tostring(snap and snap.mode or "CONNECTING"), C.dim, C.bg)
  writeAt(34, 2, "Data: " .. tostring(snap and snap.quality or "NO DATA"), (snap and snap.quality == "OFFICIAL") and C.good or C.warn, C.bg)
  writeAt(54, 2, "Date: " .. tostring(clock.date_text), C.good, C.bg)
  writeAt(76, 2, "Time: " .. tostring(clock.time_text), C.good, C.bg)

  writeAt(2, 3, "Tick: " .. tostring(clock.tick_text), C.good, C.bg)
  writeAt(18, 3, "GDP window: " .. tostring(GDP_PERIOD_MC_DAYS) .. " MC days", C.warn, C.bg)
  writeAt(52, 3, "Last update: " .. tostring(last_update_text or "never"), C.dim, C.bg)
  if db_id then writeAt(86, 3, "Bank: " .. tostring(db_id), C.dim, C.bg) end
  if contract_id then writeAt(102, 3, "Contracts: " .. tostring(contract_id), C.dim, C.bg) end
end

local function drawFooter()
  local w, h = getSize()
  fill(1, h - 1, w, 2, C.bg)
  writeAt(1, h - 1, string.rep("-", w), C.dim, C.bg)
  local text = "Refresh: " .. REFRESH_SECONDS .. "s   CORE FINANCE / CONTRACT + SERVICE GDP   Monitor: " .. (monitor and "attached" or "terminal") .. "   [Q] Quit"
  writeAt(2, h, text, C.dim, C.bg)
  if last_error ~= "" then writeAt(math.max(2, w - #last_error - 2), h, last_error, C.bad, C.bg) end
end

local function drawScreen()
  clear(C.bg)
  local w, h = getSize()
  local snap = last_snapshot

  if w < 80 or h < 24 then
    centerIn(1, 2, w, "ECONOMY CORE MONITOR", colors.yellow, C.bg)
    centerIn(1, 4, w, "Monitor too small. Use a bigger monitor or lower text scale.", C.bad, C.bg)
    drawFooter()
    return
  end

  drawHeader(snap)

  local margin = 2
  local gap = 2
  local colW = math.floor((w - (margin * 2) - (gap * 2)) / 3)
  local col1 = margin
  local col2 = col1 + colW + gap
  local col3 = col2 + colW + gap

  local topY = 4
  local topH = math.max(14, math.floor((h - 7) * 0.55))
  local bottomY = topY + topH + 1
  local bottomH = h - bottomY - 2
  if bottomH < 11 then bottomH = 11 end

  graphCard(col1, topY, colW, topH, "GDP", "Rolling GDP (365 MC days)", fmtMoney(snap and snap.gdp), snap and snap.gdp and colors.white or C.warn, history.gdp, C.gdp, snap and snap.output_status or "GDP output data")
  graphCard(col2, topY, colW, topH, "GDP / PER CAPITA", "Rolling GDP / capita", fmtMoney(snap and snap.gdp_per_capita), snap and snap.gdp_per_capita and colors.white or C.warn, history.gdp_per_capita, C.capita, snap and snap.output_status or "GDP output data")
  graphCard(col3, topY, colW, topH, "INFLATION", "Bank inflation rate", fmtPct(snap and snap.inflation, 2), snap and snap.inflation and colors.white or C.warn, history.inflation, C.inflation, snap and snap.inflation_status or "inflation data")

  drawInequalityCard(col1, bottomY, colW, bottomH, snap)
  drawMonetaryCard(col2, bottomY, colW, bottomH, snap)
  drawScaleCard(col3, bottomY, colW, bottomH, snap)

  drawFooter()
end

-- =============================================================================
-- MAIN LOOP
-- =============================================================================
local function main()
  setupDisplay()
  loadHistory()

  if not openModem() then
    last_error = "No modem found"
    drawScreen()
    sleep(5)
    restoreDisplay()
    print("ERROR: No modem found. Attach a modem and reboot.")
    return
  end

  while not connectServer() do
    drawScreen()
    sleep(3)
  end
  connectContractServer(true)

  local ok, err = refreshSnapshot()
  if not ok then last_error = tostring(err) end
  drawScreen()

  local timer = os.startTimer(REFRESH_SECONDS)
  while true do
    local ev, p1 = os.pullEvent()
    if ev == "timer" and p1 == timer then
      if not db_id then connectServer() end
      local refreshOk, refreshErr = refreshSnapshot()
      if not refreshOk then last_error = tostring(refreshErr) end
      drawScreen()
      timer = os.startTimer(REFRESH_SECONDS)
    elseif ev == "key" then
      if p1 == keys.q then break end
      if p1 == keys.r then
        local refreshOk, refreshErr = refreshSnapshot()
        if not refreshOk then last_error = tostring(refreshErr) end
        drawScreen()
      end
    elseif ev == "terminate" then
      break
    end
  end

  saveHistory()
  restoreDisplay()
  print("Economy Core Monitor closed.")
end

main()

-- DATA CALCULATION
-- =============================================================================
local function inequalityFromAccounts(accounts)
  if type(accounts) ~= "table" then
    return { status = "Awaiting account aggregation" }
  end

  local balances = {}
  for _, acc in ipairs(accounts) do
    if type(acc) == "table" and acc.type == "citizen" and acc.status ~= "suspended" then
      balances[#balances + 1] = tonumber(acc.balance) or 0
    end
  end

  if #balances < 2 then
    return { status = "Need 2+ citizen accounts", observations = #balances }
  end

  local total = 0
  for _, v in ipairs(balances) do
    total = total + v
  end

  local average = total / #balances
  -- This is account-balance inequality, not income inequality.
  -- With small Minecraft populations, top 1% effectively means the richest citizen account.
  local top1 = calculateTopShare(copyList(balances), 0.01)

  return {
    top1_share = top1,
    average_balance = average,
    total_balance = total,
    observations = #balances,
    status = "Live citizen balance distribution",
  }
end

local function topCompaniesFromAccounts(accounts)
  local companies = {}
  if type(accounts) ~= "table" then return companies end

  for _, acc in ipairs(accounts) do
    if type(acc) == "table" and acc.type == "company" and acc.status ~= "suspended" then
      companies[#companies + 1] = {
        id = tostring(acc.account_id or acc.display_name or "company"),
        name = tostring(acc.display_name or acc.account_id or "company"),
        balance = tonumber(acc.balance) or 0,
      }
    end
  end

  table.sort(companies, function(a, b)
    return (tonumber(a.balance) or 0) > (tonumber(b.balance) or 0)
  end)

  local out = {}
  for i = 1, math.min(10, #companies) do
    out[#out + 1] = companies[i]
  end
  return out
end

local function trimTxSamples()
  history.tx_samples = history.tx_samples or {}
  while #history.tx_samples > 288 do
    table.remove(history.tx_samples, 1)
  end
end

local function estimateTxPerDay(currentTx)
  currentTx = tonumber(currentTx)
  if currentTx == nil then return nil, "Awaiting transaction counter" end
  history.tx_samples = history.tx_samples or {}
  local now = nowMs()
  history.tx_samples[#history.tx_samples + 1] = { t = now, tx = currentTx }
  trimTxSamples()
  if #history.tx_samples < 2 then return nil, "Collecting baseline" end
  local oldest = history.tx_samples[1]
  local elapsedMs = now - (tonumber(oldest.t) or now)
  local delta = currentTx - (tonumber(oldest.tx) or currentTx)
  if elapsedMs <= 0 then return nil, "Collecting baseline" end
  if delta < 0 then delta = 0 end
  local perDay = delta / (elapsedMs / 86400000)
  return perDay, "Estimated from local monitor history"
end

local function analyseContracts(contracts, status)
  local now = nowMs()
  local gdp = 0
  local gdpEvents = 0
  local fulfilledValue = 0
  local openValue = 0
  local claimedValue = 0
  local totalValue = 0
  local newestFulfilled = nil

  contracts = type(contracts) == "table" and contracts or {}
  for _, c in ipairs(contracts) do
    if type(c) == "table" then
      local reward = tonumber(c.reward or c.value or c.amount) or 0
      local st = tostring(c.status or "")
      totalValue = totalValue + reward
      if st == "open" then openValue = openValue + reward end
      if st == "claimed" then claimedValue = claimedValue + reward end
      if st == "fulfilled" or st == "paid" or st == "closed" then
        fulfilledValue = fulfilledValue + reward
        local t = tonumber(c.fulfilled_at or c.paid_at or c.closed_at or c.updated or c.created)
        if t then
          if not newestFulfilled or t > newestFulfilled then newestFulfilled = t end
          if now - t <= GDP_PERIOD_MS then
            gdp = gdp + reward
            gdpEvents = gdpEvents + 1
          end
        else
          -- If old contracts have no timestamp, count them as visible fulfilled output.
          gdp = gdp + reward
          gdpEvents = gdpEvents + 1
        end
      end
    end
  end

  status = type(status) == "table" and status or {}
  return {
    connected = contract_id ~= nil,
    total = tonumber(status.total) or #contracts,
    open = tonumber(status.open) or 0,
    claimed = tonumber(status.claimed) or 0,
    fulfilled = tonumber(status.fulfilled) or 0,
    cancelled = tonumber(status.cancelled) or 0,
    gdp_24h = gdp,
    gdp_events = gdpEvents,
    fulfilled_value = fulfilledValue,
    open_value = openValue,
    claimed_value = claimedValue,
    total_value = totalValue,
    newest_fulfilled = newestFulfilled,
    status = "GDP from fulfilled contracts, rolling 24h",
  }
end

local function fetchContractEconomy()
  if not contract_id then
    connectContractServer(true)
  end
  if not contract_id then
    return {
      connected = false,
      status = "Waiting for ContractServer",
      open = 0,
      claimed = 0,
      fulfilled = 0,
      cancelled = 0,
      total = 0,
    }
  end

  local okStatus, status = contractRequest({ type = "status" }, 2)
  if not okStatus or type(status) ~= "table" then
    local err = tostring(status or "status unavailable")
    contract_id = nil
    last_contract_error = err
    return { connected = false, status = err, open = 0, claimed = 0, fulfilled = 0, cancelled = 0, total = 0 }
  end

  local okList, listRes = contractRequest({ type = "list_contracts", status = "all" }, 3)
  local contracts = {}
  if okList and type(listRes) == "table" then
    contracts = listRes.contracts or {}
  end

  local out = analyseContracts(contracts, status)
  out.server_id = contract_id
  return out
end

local function normaliseNationalStats(raw)
  local monetaryRaw = raw.monetary or raw.supply or {}
  local outputRaw = raw.output or raw.gdp or {}
  local pricesRaw = raw.prices or {}
  local scaleRaw = raw.population or raw.scale or {}
  local inequalityRaw = raw.inequality or raw.wealth_inequality or {}
  local activityRaw = raw.activity or {}

  local issued = num(monetaryRaw.issued_supply or monetaryRaw.in_circulation or monetaryRaw.total_supply)
  local treasury = num(monetaryRaw.treasury_reserve or monetaryRaw.treasury_balance)
  local private = num(monetaryRaw.private_supply)
  if not private and issued and treasury then private = issued - treasury end
  local reserveShare = nil
  if issued and issued > 0 and treasury then reserveShare = (treasury / issued) * 100 end

  local monetaryInflation, monetaryInflationStatus = calculateMonetaryInflation(issued)

  local population = num(scaleRaw.active_citizens or scaleRaw.citizens or raw.citizen_count)
  local companies = num(scaleRaw.companies or raw.company_count)
  local totalTx = num(scaleRaw.transactions or raw.tx_count or activityRaw.transactions)
  local gdp = num(outputRaw.nominal_gdp or outputRaw.gdp)
  local gdpCap = num(outputRaw.gdp_per_capita)
  if not gdpCap and gdp and population and population > 0 then gdpCap = gdp / population end

  local txDay = num(activityRaw.transactions_per_day or scaleRaw.transactions_per_day)
  local txStatus = activityRaw.status or "Live / estimated"
  if not txDay then txDay, txStatus = estimateTxPerDay(totalTx) end

  return {
    mode = "official national_statistics",
    quality = raw.quality or raw.status or "OFFICIAL",
    time = raw.time or nowMs(),
    gdp = gdp,
    gdp_per_capita = gdpCap,
    inflation = monetaryInflation,
    output_status = outputRaw.status or (gdp and "Live" or "Awaiting GDP output data"),
    inflation_status = monetaryInflationStatus or "Awaiting monetary supply baseline",
    inequality = {
      top1_share = num(inequalityRaw.top1_share or inequalityRaw.top_1_share),
      average_balance = num(inequalityRaw.average_balance or inequalityRaw.mean),
      total_balance = num(inequalityRaw.total_balance),
      observations = num(inequalityRaw.observations),
      status = inequalityRaw.status or "Awaiting citizen balance distribution",
    },
    monetary = {
      issued_supply = issued,
      private_supply = private,
      treasury_reserve = treasury,
      reserve_share = reserveShare,
      status = monetaryRaw.status or "Live",
    },
    scale = {
      population = population,
      companies = companies,
      transactions_total = totalTx,
      transactions_per_day = txDay,
      tx_day_status = txStatus,
      top_companies = scaleRaw.top_companies or scaleRaw.company_top10 or raw.top_companies or {},
      source = raw.source or "national_statistics",
    },
    contracts = raw.contracts or raw.contract_activity or {},
  }
end

local function fallbackSnapshot()
  local okStatus, status = dbRequest({ type = "status" }, 3)
  if not okStatus or type(status) ~= "table" then
    return nil, "Status unavailable: " .. tostring(status)
  end

  local okAccounts, accRes = dbRequest({ type = "list_accounts" }, 3)
  local accounts = nil
  if okAccounts and type(accRes) == "table" then accounts = accRes.accounts or {} end

  local supply = status.supply or {}
  local issued = num(supply.in_circulation or ((num(supply.total_minted) or 0) - (num(supply.total_burned) or 0)))
  local treasury = num(supply.treasury_balance)
  local private = nil
  if issued and treasury then private = issued - treasury end
  local reserveShare = nil
  if issued and issued > 0 and treasury then reserveShare = (treasury / issued) * 100 end

  local txDay, txStatus = estimateTxPerDay(status.tx_count)
  local inflation, inflationStatus = calculateMonetaryInflation(issued)
  local contractEco = fetchContractEconomy()

  local gdp = nil
  local outputStatus = "Waiting for ContractServer / fulfilled contracts"
  if contractEco and contractEco.connected then
    gdp = tonumber(contractEco.gdp_24h) or 0
    outputStatus = contractEco.status or "GDP from fulfilled contracts"
  end

  local population = num(status.citizen_count)
  local gdpCap = nil
  if gdp and population and population > 0 then gdpCap = gdp / population end

  return {
    mode = "FALLBACK + CONTRACTS",
    quality = contractEco and contractEco.connected and "LIVE" or "PARTIAL",
    time = status.time or nowMs(),
    gdp = gdp,
    gdp_per_capita = gdpCap,
    inflation = inflation,
    output_status = outputStatus,
    inflation_status = inflationStatus,
    inequality = inequalityFromAccounts(accounts),
    monetary = {
      issued_supply = issued,
      private_supply = private,
      treasury_reserve = treasury,
      reserve_share = reserveShare,
      status = "Live from ledger supply",
    },
    scale = {
      population = population,
      companies = num(status.company_count),
      transactions_total = num(status.tx_count),
      transactions_per_day = txDay,
      tx_day_status = txStatus,
      top_companies = topCompaniesFromAccounts(accounts),
      source = "bank status + accounts + contract server",
    },
    contracts = contractEco,
  }
end

local function refreshSnapshot()
  if not db_id then return false, "No server connected" end

  local okNational, national = dbRequest({ type = "national_statistics" }, 3)
  local snap = nil
  if okNational and type(national) == "table" then
    snap = normaliseNationalStats(national)

    local contractEco = fetchContractEconomy()
    snap.contracts = contractEco
    if (not snap.gdp) and contractEco and contractEco.connected then
      snap.gdp = tonumber(contractEco.gdp_24h) or 0
      snap.output_status = contractEco.status or "GDP from fulfilled contracts"
      local pop = snap.scale and tonumber(snap.scale.population)
      if pop and pop > 0 then snap.gdp_per_capita = snap.gdp / pop end
    end

    if snap.inflation == nil then
      local inf, infStatus = calculateMonetaryInflation(snap.monetary and snap.monetary.issued_supply)
      snap.inflation = inf
      snap.inflation_status = infStatus
    end
  else
    local fallback, err = fallbackSnapshot()
    if not fallback then return false, err end
    snap = fallback
  end

  last_snapshot = snap
  last_error = ""

  local okTime, timeText = pcall(function()
    return os.date("!%H:%M:%S", math.floor(nowMs() / 1000))
  end)
  if okTime and timeText then last_update_text = timeText .. " UTC" else last_update_text = textutils.formatTime(os.time(), true) end

  pushHistory("gdp", snap.gdp)
  pushHistory("gdp_per_capita", snap.gdp_per_capita)
  pushHistory("inflation", snap.inflation)
  pushHistory("issued_supply", snap.monetary and snap.monetary.issued_supply)
  saveHistory()

  return true, snap
end

-- =============================================================================
-- DRAWING
-- =============================================================================
local C = {
  bg = colors.black,
  header = colors.blue,
  title = colors.white,
  text = colors.lightGray,
  dim = colors.gray,
  good = colors.lime,
  warn = colors.orange,
  bad = colors.red,
  gdp = colors.blue,
  capita = colors.cyan,
  inflation = colors.purple,
  inequality = colors.red,
  money = colors.green,
  scale = colors.brown,
}

local function card(x, y, w, h, title, colour)
  fill(x, y, w, h, C.bg)
  fill(x, y, w, 1, colour or colors.gray)
  writeAt(x + 1, y, string.upper(title or ""), colors.white, colour or colors.gray)
end

local function metric(x, y, label, value, valueColour, labelW)
  labelW = labelW or 20
  writeAt(x, y, tostring(label):sub(1, labelW), C.text, C.bg)
  writeAt(x + labelW + 1, y, tostring(value or "Awaiting data"), valueColour or colors.white, C.bg)
end

local function graphCard(x, y, w, h, title, currentLabel, currentValue, currentColour, series, colour, missingReason)
  card(x, y, w, h, title, colour)

  writeAt(x + 2, y + 2, string.upper(currentLabel or "CURRENT"), C.text, C.bg)
  writeAt(x + 2, y + 3, tostring(currentValue or "Awaiting data"), currentColour or C.warn, C.bg)

  local gx = x + 2
  local gy = y + 6
  local gw = w - 4
  local gh = h - 9
  if gh < 4 then gh = 4 end

  if not series or #series < 2 then
    fill(gx, gy, gw, gh, C.bg)
    centerIn(x, gy + math.floor(gh / 2), w, "Awaiting live history", C.warn, C.bg)
    writeAt(x + 2, y + h - 2, "Waiting: " .. shortText(missingReason or "source data", w - 13), C.dim, C.bg)
    return
  end

  local start = math.max(1, #series - gw + 1)
  local values = {}
  for i = start, #series do
    local v = tonumber(series[i])
    if v then values[#values + 1] = v end
  end
  if #values < 2 then
    centerIn(x, gy + math.floor(gh / 2), w, "Awaiting live history", C.warn, C.bg)
    return
  end

  local minV = values[1]
  local maxV = values[1]
  for _, v in ipairs(values) do
    if v < minV then minV = v end
    if v > maxV then maxV = v end
  end
  local range = maxV - minV
  if range == 0 then range = 1 end

  for row = 0, gh - 1 do
    writeAt(gx, gy + row, string.rep(".", gw), colors.gray, C.bg)
  end

  local lastY = nil
  for i, v in ipairs(values) do
    local px = gx + i - 1
    if px <= gx + gw - 1 then
      local norm = (v - minV) / range
      local py = gy + gh - 1 - math.floor(norm * (gh - 1) + 0.5)
      py = clamp(py, gy, gy + gh - 1)
      if lastY and py == lastY then
        writeAt(px, py, "-", colour, C.bg)
      else
        writeAt(px, py, "*", colour, C.bg)
      end
      lastY = py
    end
  end

  writeAt(x + 2, y + h - 1, "min " .. fmtNum(minV, 1), C.dim, C.bg)
  local maxText = "max " .. fmtNum(maxV, 1)
  writeAt(x + w - #maxText - 1, y + h - 1, maxText, C.dim, C.bg)
end

local function drawInequalityCard(x, y, w, h, snap)
  local q = snap and snap.inequality or {}
  card(x, y, w, h, "INEQUALITY", C.inequality)

  metric(x + 2, y + 2, "Top 1% share", q.top1_share and fmtPct(q.top1_share, 1) or "Awaiting data", q.top1_share and colors.white or C.warn)
  metric(x + 2, y + 3, "Average balance", fmtMoney(q.average_balance), q.average_balance and colors.white or C.warn)
  metric(x + 2, y + 4, "Citizen wealth", fmtMoney(q.total_balance), q.total_balance and colors.white or C.warn)
  metric(x + 2, y + 5, "Accounts", tostring(q.observations or "Awaiting data"), q.observations and colors.white or C.warn)

  local barW = math.max(10, w - 6)
  local filled = 0
  if q.top1_share then filled = math.floor(clamp(q.top1_share / 100, 0, 1) * barW) end
  local barY = math.min(y + 7, y + h - 3)
  fill(x + 2, barY, barW, 1, colors.gray)
  if filled > 0 then fill(x + 2, barY, filled, 1, C.inequality) end
  if barY + 1 <= y + h - 2 then
    writeAt(x + 2, barY + 1, "Top 1% share of citizen balances", C.dim, C.bg)
  end

  writeAt(x + 2, y + h - 1, shortText(q.status or "Awaiting account aggregation", w - 4), q.status and q.status:find("Live") and C.good or C.warn, C.bg)
end

local function drawMonetaryCard(x, y, w, h, snap)
  local m = snap and snap.monetary or {}
  card(x, y, w, h, "MONETARY CONDITIONS", C.money)
  metric(x + 2, y + 2, "Issued supply", fmtMoney(m.issued_supply), m.issued_supply and C.good or C.warn)
  metric(x + 2, y + 3, "Private supply", fmtMoney(m.private_supply), m.private_supply and colors.white or C.warn)
  metric(x + 2, y + 4, "Treasury reserve", fmtMoney(m.treasury_reserve), m.treasury_reserve and colors.white or C.warn)
  metric(x + 2, y + 5, "Treasury Control", fmtPct(m.reserve_share, 2), m.reserve_share and colors.white or C.warn)
  writeAt(x + 2, y + h - 1, shortText(m.status or "Awaiting supply data", w - 4), m.status and C.good or C.warn, C.bg)
end

local function drawScaleCard(x, y, w, h, snap)
  local s = snap and snap.scale or {}
  card(x, y, w, h, "POPULATION / COMPANIES / TRANSACTIONS", C.scale)
  metric(x + 2, y + 2, "Population", tostring(s.population or "Awaiting data"), s.population and colors.white or C.warn)
  metric(x + 2, y + 3, "Companies", tostring(s.companies or "Awaiting data"), s.companies and colors.white or C.warn)
  metric(x + 2, y + 4, "Transactions / day", s.transactions_per_day and (fmtNum(s.transactions_per_day, 1) .. " / day") or "Collecting baseline", s.transactions_per_day and colors.white or C.warn)

  local c = snap and snap.contracts or {}
  local contractLine = "Contracts O/C/F: " .. tostring(c.open or 0) .. "/" .. tostring(c.claimed or 0) .. "/" .. tostring(c.fulfilled or 0)
  writeAt(x + 2, y + 5, shortText(contractLine, w - 4), c.connected and C.good or C.warn, C.bg)

  writeAt(x + 2, y + 7, "Top companies", colors.white, C.bg)
  local top = s.top_companies or {}
  if type(top) ~= "table" or #top == 0 then
    writeAt(x + 2, y + 8, "No company account data", C.warn, C.bg)
  else
    local maxRows = math.min(10, #top, math.max(1, h - 10))
    for i = 1, maxRows do
      local company = top[i] or {}
      local name = shortText(company.name or company.id or ("Company " .. i), math.max(8, w - 18))
      local bal = fmtMoney(company.balance)
      local line = tostring(i) .. ". " .. name
      writeAt(x + 2, y + 7 + i, shortText(line, w - 18), C.text, C.bg)
      writeAt(x + w - #bal - 2, y + 7 + i, bal, colors.white, C.bg)
    end
  end

  writeAt(x + 2, y + h - 1, shortText(s.tx_day_status or "Awaiting tx counter", w - 4), C.dim, C.bg)
end

local function drawHeader(snap)
  local w = getSize()
  fill(1, 1, w, 1, C.header)
  writeAt(2, 1, "ECONOMY CORE MONITOR", C.title, C.header)
  local v = "v" .. VERSION
  writeAt(w - #v, 1, v, C.title, C.header)
  fill(1, 2, w, 1, C.bg)
  writeAt(2, 2, "Mode: " .. tostring(snap and snap.mode or "CONNECTING"), C.dim, C.bg)
  writeAt(34, 2, "Data: " .. tostring(snap and snap.quality or "NO DATA"), (snap and snap.quality == "OFFICIAL") and C.good or C.warn, C.bg)
  writeAt(54, 2, "Updated: " .. tostring(last_update_text), C.dim, C.bg)
  if db_id then writeAt(82, 2, "Bank: " .. tostring(db_id), C.dim, C.bg) end
  if contract_id then writeAt(96, 2, "Contracts: " .. tostring(contract_id), C.dim, C.bg) end
end

local function drawFooter()
  local w, h = getSize()
  fill(1, h - 1, w, 2, C.bg)
  writeAt(1, h - 1, string.rep("-", w), C.dim, C.bg)
  local text = "Refresh: " .. REFRESH_SECONDS .. "s   CONTRACT GDP BUILD   Monitor: " .. (monitor and "attached" or "terminal") .. "   [Q] Quit"
  writeAt(2, h, text, C.dim, C.bg)
  if last_error ~= "" then writeAt(math.max(2, w - #last_error - 2), h, last_error, C.bad, C.bg) end
end

local function drawScreen()
  clear(C.bg)
  local w, h = getSize()
  local snap = last_snapshot

  if w < 80 or h < 24 then
    centerIn(1, 2, w, "ECONOMY CORE MONITOR", colors.yellow, C.bg)
    centerIn(1, 4, w, "Monitor too small. Use a bigger monitor or lower text scale.", C.bad, C.bg)
    drawFooter()
    return
  end

  drawHeader(snap)

  local margin = 2
  local gap = 2
  local colW = math.floor((w - (margin * 2) - (gap * 2)) / 3)
  local col1 = margin
  local col2 = col1 + colW + gap
  local col3 = col2 + colW + gap

  local topY = 4
  local topH = math.max(14, math.floor((h - 7) * 0.55))
  local bottomY = topY + topH + 1
  local bottomH = h - bottomY - 2
  if bottomH < 11 then bottomH = 11 end

  graphCard(col1, topY, colW, topH, "GDP", "Current GDP", fmtMoney(snap and snap.gdp), snap and snap.gdp and colors.white or C.warn, history.gdp, C.gdp, snap and snap.output_status or "GDP output data")
  graphCard(col2, topY, colW, topH, "GDP / PER CAPITA", "Current GDP / capita", fmtMoney(snap and snap.gdp_per_capita), snap and snap.gdp_per_capita and colors.white or C.warn, history.gdp_per_capita, C.capita, snap and snap.output_status or "GDP output data")
  graphCard(col3, topY, colW, topH, "INFLATION", "Current inflation", fmtPct(snap and snap.inflation, 2), snap and snap.inflation and colors.white or C.warn, history.inflation, C.inflation, snap and snap.inflation_status or "inflation data")

  drawInequalityCard(col1, bottomY, colW, bottomH, snap)
  drawMonetaryCard(col2, bottomY, colW, bottomH, snap)
  drawScaleCard(col3, bottomY, colW, bottomH, snap)

  drawFooter()
end

-- =============================================================================
-- MAIN LOOP
-- =============================================================================
local function main()
  setupDisplay()
  loadHistory()

  if not openModem() then
    last_error = "No modem found"
    drawScreen()
    sleep(5)
    restoreDisplay()
    print("ERROR: No modem found. Attach a modem and reboot.")
    return
  end

  while not connectServer() do
    drawScreen()
    sleep(3)
  end
  connectContractServer(true)

  local ok, err = refreshSnapshot()
  if not ok then last_error = tostring(err) end
  drawScreen()

  local timer = os.startTimer(REFRESH_SECONDS)
  while true do
    local ev, p1 = os.pullEvent()
    if ev == "timer" and p1 == timer then
      if not db_id then connectServer() end
      local refreshOk, refreshErr = refreshSnapshot()
      if not refreshOk then last_error = tostring(refreshErr) end
      drawScreen()
      timer = os.startTimer(REFRESH_SECONDS)
    elseif ev == "key" then
      if p1 == keys.q then break end
      if p1 == keys.r then
        local refreshOk, refreshErr = refreshSnapshot()
        if not refreshOk then last_error = tostring(refreshErr) end
        drawScreen()
      end
    elseif ev == "terminate" then
      break
    end
  end

  saveHistory()
  restoreDisplay()
  print("Economy Core Monitor closed.")
end

main()

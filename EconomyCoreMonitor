local function drawScale(x, y, w, h)
  card(x, y, w, h, "POPULATION / COMPANIES", C.brown)
  local st = cache.status or {}
  local a = accountStats()

  local pop = num(st.citizen_count) or (a.citizens > 0 and a.citizens or nil)
  local companies = num(st.company_count) or (a.companies > 0 and a.companies or nil)
  local tx = num(st.tx_count)

  metric(x + 2, y + 2, "Citizens", tostring(pop or "n/a"), pop and C.white or C.warn)
  metric(x + 2, y + 3, "Companies", tostring(companies or "n/a"), companies and C.white or C.warn)
  metric(x + 2, y + 4, "Transactions", tostring(tx or "n/a"), tx and C.white or C.warn)
  metric(x + 2, y + 5, "Citizen wealth", fmtMoney(a.citizen_total), a.citizens > 0 and C.white or C.dim)
  metric(x + 2, y + 6, "Company wealth", fmtMoney(a.company_total), a.companies > 0 and C.white or C.dim)

  writeAt(x + 2, y + 8, "Top companies", C.white, C.bg)
  if #a.top == 0 then
    writeAt(x + 2, y + 9, "No cached account data yet", C.warn, C.bg)
  else
    local rows = math.min(#a.top, math.max(1, h - 11))
    for i = 1, rows do
      local c = a.top[i]
      local name = shortText(tostring(i) .. ". " .. c.name, math.max(8, w - 18))
      local bal = fmtMoney(c.balance)
      writeAt(x + 2, y + 8 + i, name, C.text, C.bg)
      writeAt(x + w - #bal - 2, y + 8 + i, bal, C.white, C.bg)
    end
  end
end

local function drawOutput(x, y, w, h)
  card(x, y, w, h, "GDP / CONTRACTS", C.header)
  local g = cache.gdp or {}
  local c = cache.contracts or {}
  local st = cache.status or {}
  local a = accountStats()
  local pop = num(st.citizen_count) or (a.citizens > 0 and a.citizens or nil)

  local gdp = num(g.private_gdp or g.gdp or g.total)
  local gdpCap = nil
  if gdp and pop and pop > 0 then gdpCap = gdp / pop end

  metric(x + 2, y + 2, "Private GDP", fmtMoney(gdp), gdp and C.white or C.warn)
  metric(x + 2, y + 3, "GDP / capita", fmtMoney(gdpCap), gdpCap and C.white or C.warn)
  metric(x + 2, y + 5, "Contracts open", tostring(c.open or "n/a"), c.open and C.white or C.warn)
  metric(x + 2, y + 6, "Claimed", tostring(c.claimed or "n/a"), c.claimed and C.white or C.warn)
  metric(x + 2, y + 7, "Fulfilled", tostring(c.fulfilled or "n/a"), c.fulfilled and C.white or C.warn)
  metric(x + 2, y + 8, "Cancelled", tostring(c.cancelled or "n/a"), c.cancelled and C.white or C.warn)

  writeAt(x + 2, y + h - 1, "ContractServer status only; no list_contracts scan", C.dim, C.bg)
end

local function drawFooter()
  local w, h = getSize()
  fill(1, h - 1, w, 2, C.bg)
  writeAt(1, h - 1, string.rep("-", w), C.dim, C.bg)
  local text = "Low impact mode: no tick/quotes/full contract scans   [R] Refresh  [Q] Quit"
  writeAt(2, h, text, C.dim, C.bg)
  if last_error and last_error ~= "" then
    writeAt(math.max(2, w - #last_error - 2), h, shortText(last_error, math.max(10, w - 4)), C.bad, C.bg)
  end
end

local function drawScreen()
  clear(C.bg)
  local w, h = getSize()

  if w < 80 or h < 24 then
    centerIn(1, 2, w, "ECONOMY CORE MONITOR", C.warn, C.bg)
    centerIn(1, 4, w, "Monitor too small. Use a bigger monitor or lower text scale.", C.bad, C.bg)
    drawFooter()
    return
  end

  drawHeader()

  local margin = 2
  local gap = 2
  local colW = math.floor((w - margin * 2 - gap * 2) / 3)
  local col1 = margin
  local col2 = col1 + colW + gap
  local col3 = col2 + colW + gap

  local topY = 5
  local topH = math.max(14, math.floor((h - 8) * 0.55))
  local bottomY = topY + topH + 1
  local bottomH = h - bottomY - 2
  if bottomH < 10 then bottomH = 10 end

  drawMonetary(col1, topY, colW, topH)
  drawInflation(col2, topY, colW, topH)
  drawLocalQuotes(col3, topY, colW, topH)

  drawScale(col1, bottomY, colW, bottomH)
  drawOutput(col2, bottomY, colW, bottomH)

  card(col3, bottomY, colW, bottomH, "STATUS", C.dim)
  metric(col3 + 2, bottomY + 2, "Bank ID", tostring(db_id or "n/a"), db_id and C.good or C.warn)
  metric(col3 + 2, bottomY + 3, "Modem", tostring(modem_name or "n/a"), modem_name and C.white or C.warn)
  metric(col3 + 2, bottomY + 4, "Monitor", monitor and "attached" or "terminal", monitor and C.white or C.warn)
  metric(col3 + 2, bottomY + 5, "Accounts age", last_accounts_refresh > 0 and (math.floor((nowMs() - last_accounts_refresh) / 1000) .. "s") or "not cached", C.dim)
  metric(col3 + 2, bottomY + 6, "Contracts age", last_contract_refresh > 0 and (math.floor((nowMs() - last_contract_refresh) / 1000) .. "s") or "not cached", C.dim)
  writeAt(col3 + 2, bottomY + bottomH - 1, "If server struggles, raise REFRESH_SECONDS.", C.dim, C.bg)

  drawFooter()
end

-- =============================================================================
-- MAIN
-- =============================================================================
local function safeRefresh(all)
  if not db_id then discoverBank() end
  if not db_id then
    last_error = "No bank server discovered"
    return
  end

  refreshFast()

  local now = nowMs()
  if all or (now - last_accounts_refresh >= SLOW_REFRESH_SECONDS * 1000) then
    refreshSlowAccounts()
  end
  if all or (now - last_contract_refresh >= CONTRACT_REFRESH_SECONDS * 1000) then
    refreshContracts()
  end
end

local function main()
  setupDisplay()

  if not openModem() then
    last_error = "No modem found"
    drawScreen()
    sleep(5)
    restoreDisplay()
    print("ERROR: No modem found. Attach a modem and reboot.")
    return
  end

  discoverBank()
  discoverContracts()
  safeRefresh(true)
  drawScreen()

  local timer = os.startTimer(REFRESH_SECONDS)
  while true do
    local ev, p1 = os.pullEvent()
    if ev == "timer" and p1 == timer then
      safeRefresh(false)
      drawScreen()
      timer = os.startTimer(REFRESH_SECONDS)
    elseif ev == "key" then
      if p1 == keys.q then break end
      if p1 == keys.r then
        safeRefresh(true)
        drawScreen()
      end
    elseif ev == "terminate" then
      break
    end
  end

  restoreDisplay()
  print("Economy Core Monitor closed.")
end

main()

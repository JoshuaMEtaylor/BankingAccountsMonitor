local function inequalityFromAccounts(accounts)
  if type(accounts) ~= "table" then
    return { status = "Awaiting account aggregation" }
  end

  local balances = {}
  for _, acc in ipairs(accounts) do
    if type(acc) == "table" and acc.type == "citizen" and acc.status ~= "suspended" then
      balances[#balances + 1] = tonumber(acc.balance) or 0
    end
  end

  if #balances < 2 then
    return { status = "Need 2+ citizen accounts", observations = #balances }
  end

  local total = 0
  for _, v in ipairs(balances) do
    total = total + v
  end

  local average = total / #balances
  -- This is account-balance inequality, not income inequality.
  -- With small Minecraft populations, top 1% effectively means the richest citizen account.
  local top1 = calculateTopShare(copyList(balances), 0.01)

  return {
    top1_share = top1,
    average_balance = average,
    total_balance = total,
    observations = #balances,
    status = "Live citizen balance distribution",
  }
end

local function topCompaniesFromAccounts(accounts)
  local companies = {}
  if type(accounts) ~= "table" then return companies end

  for _, acc in ipairs(accounts) do
    if type(acc) == "table" and acc.type == "company" and acc.status ~= "suspended" then
      companies[#companies + 1] = {
        id = tostring(acc.account_id or acc.display_name or "company"),
        name = tostring(acc.display_name or acc.account_id or "company"),
        balance = tonumber(acc.balance) or 0,
      }
    end
  end

  table.sort(companies, function(a, b)
    return (tonumber(a.balance) or 0) > (tonumber(b.balance) or 0)
  end)

  local out = {}
  for i = 1, math.min(10, #companies) do
    out[#out + 1] = companies[i]
  end
  return out
end

local function trimTxSamples()
  history.tx_samples = history.tx_samples or {}
  while #history.tx_samples > 288 do
    table.remove(history.tx_samples, 1)
  end
end

local function estimateTxPerDay(currentTx)
  currentTx = tonumber(currentTx)
  if currentTx == nil then return nil, "Awaiting transaction counter" end
  history.tx_samples = history.tx_samples or {}
  local now = nowMs()
  history.tx_samples[#history.tx_samples + 1] = { t = now, tx = currentTx }
  trimTxSamples()
  if #history.tx_samples < 2 then return nil, "Collecting baseline" end
  local oldest = history.tx_samples[1]
  local elapsedMs = now - (tonumber(oldest.t) or now)
  local delta = currentTx - (tonumber(oldest.tx) or currentTx)
  if elapsedMs <= 0 then return nil, "Collecting baseline" end
  if delta < 0 then delta = 0 end
  local perDay = delta / (elapsedMs / 86400000)
  return perDay, "Estimated from local monitor history"
end

local function analyseContracts(contracts, status)
  local now = nowMs()
  local currentDay = currentMinecraftDay()
  local gdp = 0
  local gdpEvents = 0
  local fulfilledValue = 0
  local openValue = 0
  local claimedValue = 0
  local totalValue = 0
  local newestFulfilled = nil

  contracts = type(contracts) == "table" and contracts or {}
  for _, c in ipairs(contracts) do
    if type(c) == "table" then
      local reward = tonumber(c.reward or c.value or c.amount) or 0
      local st = tostring(c.status or "")
      totalValue = totalValue + reward
      if st == "open" then openValue = openValue + reward end
      if st == "claimed" then claimedValue = claimedValue + reward end
      if st == "fulfilled" or st == "paid" or st == "closed" then
        fulfilledValue = fulfilledValue + reward
        local mcDay = contractMinecraftDay(c)
        local t = tonumber(c.fulfilled_at or c.paid_at or c.closed_at or c.updated or c.created)
        if t and (not newestFulfilled or t > newestFulfilled) then newestFulfilled = t end

        local withinWindow = false
        if mcDay ~= nil then
          local ageDays = currentDay - math.floor(mcDay)
          withinWindow = ageDays >= 0 and ageDays < GDP_PERIOD_MC_DAYS
        elseif t then
          -- Fallback for older ContractServer builds that only store os.epoch timestamps.
          -- 365 Minecraft days is treated as 365 standard 20-minute days.
          withinWindow = (now - t) <= GDP_PERIOD_MS
        else
          -- If old contracts have no timestamp/day, count them as visible fulfilled output.
          withinWindow = true
        end

        if withinWindow then
          gdp = gdp + reward
          gdpEvents = gdpEvents + 1
        end
      end
    end
  end

  status = type(status) == "table" and status or {}
  return {
    connected = contract_id ~= nil,
    total = tonumber(status.total) or #contracts,
    open = tonumber(status.open) or 0,
    claimed = tonumber(status.claimed) or 0,
    fulfilled = tonumber(status.fulfilled) or 0,
    cancelled = tonumber(status.cancelled) or 0,
    gdp_365d = gdp,
    gdp_24h = gdp,
    gdp_period_mc_days = GDP_PERIOD_MC_DAYS,
    gdp_events = gdpEvents,
    fulfilled_value = fulfilledValue,
    open_value = openValue,
    claimed_value = claimedValue,
    total_value = totalValue,
    newest_fulfilled = newestFulfilled,
    status = "GDP from fulfilled contracts, rolling " .. tostring(GDP_PERIOD_MC_DAYS) .. " MC days",
  }
end

local function fetchContractEconomy()
  if not contract_id then
    connectContractServer(true)
  end
  if not contract_id then
    return {
      connected = false,
      status = "Waiting for ContractServer",
      open = 0,
      claimed = 0,
      fulfilled = 0,
      cancelled = 0,
      total = 0,
    }
  end

  local okStatus, status = cachedContractRequest({ type = "status" }, 2, CONTRACT_STATUS_POLL_SECONDS)
  if not okStatus or type(status) ~= "table" then
    local err = tostring(status or "status unavailable")
    contract_id = nil
    last_contract_error = err
    return { connected = false, status = err, open = 0, claimed = 0, fulfilled = 0, cancelled = 0, total = 0 }
  end

  local okList, listRes = cachedContractRequest({ type = "list_contracts", status = "all" }, 5, CONTRACT_LIST_POLL_SECONDS)
  local contracts = {}
  if okList and type(listRes) == "table" then
    contracts = listRes.contracts or {}
  end

  local out = analyseContracts(contracts, status)
  out.server_id = contract_id
  return out
end

local function normaliseNationalStats(raw)
  local monetaryRaw = raw.monetary or raw.supply or {}
  local outputRaw = raw.output or raw.gdp or {}
  local pricesRaw = raw.prices or {}
  local scaleRaw = raw.population or raw.scale or {}
  local inequalityRaw = raw.inequality or raw.wealth_inequality or {}
  local activityRaw = raw.activity or {}

  local issued = num(monetaryRaw.issued_supply or monetaryRaw.in_circulation or monetaryRaw.total_supply)
  local treasury = num(monetaryRaw.treasury_reserve or monetaryRaw.treasury_balance)
  local private = num(monetaryRaw.private_supply)
  if not private and issued and treasury then private = issued - treasury end
  local reserveShare = nil
  if issued and issued > 0 and treasury then reserveShare = (treasury / issued) * 100 end

  local monetaryInflation, monetaryInflationStatus = calculateMonetaryInflation(issued)

  local population = num(scaleRaw.active_citizens or scaleRaw.citizens or raw.citizen_count)
  local companies = num(scaleRaw.companies or raw.company_count)
  local totalTx = num(scaleRaw.transactions or raw.tx_count or activityRaw.transactions)
  local gdp = num(outputRaw.gdp_365d or outputRaw.rolling_gdp_365d or outputRaw.nominal_gdp or outputRaw.gdp)
  local gdpCap = num(outputRaw.gdp_per_capita)
  if not gdpCap and gdp and population and population > 0 then gdpCap = gdp / population end

  local txStats = raw.transaction_stats or activityRaw.transaction_stats or {}
  local txToday = type(txStats.today) == "table" and txStats.today or {}
  local txStatus = txStats.note or activityRaw.status or "Awaiting real bank transaction stats"

  return {
    mode = "official national_statistics",
    quality = raw.quality or raw.status or "OFFICIAL",
    time = raw.time or nowMs(),
    mc_clock = minecraftClock(),
    gdp_period_mc_days = GDP_PERIOD_MC_DAYS,
    gdp = gdp,
    gdp_per_capita = gdpCap,
    inflation = monetaryInflation,
    output_status = outputRaw.status or (gdp and "Live" or "Awaiting GDP output data"),
    inflation_status = monetaryInflationStatus or "Awaiting monetary supply baseline",
    inequality = {
      top1_share = num(inequalityRaw.top1_share or inequalityRaw.top_1_share),
      average_balance = num(inequalityRaw.average_balance or inequalityRaw.mean),
      total_balance = num(inequalityRaw.total_balance),
      observations = num(inequalityRaw.observations),
      status = inequalityRaw.status or "Awaiting citizen balance distribution",
    },
    monetary = {
      issued_supply = issued,
      private_supply = private,
      treasury_reserve = treasury,
      reserve_share = reserveShare,
      status = monetaryRaw.status or "Live",
    },
    scale = {
      population = population,
      companies = companies,
      transactions_total = totalTx,
      transactions_today = num(txToday.total),
      economic_transactions_today = num(txToday.economic),
      admin_transactions_today = num(txToday.admin),
      payroll_transactions_today = num(txToday.payroll),
      service_transactions_today = num(txToday.service),
      transaction_value_today = num(txToday.value),
      tx_today_status = txStatus,
      top_companies = scaleRaw.top_companies or scaleRaw.company_top10 or raw.top_companies or {},
      source = raw.source or "national_statistics",
    },
    tx_stats = txStats,
    contracts = raw.contracts or raw.contract_activity or {},
  }
end

local function fallbackSnapshot()
  -- v0.5.8: do not let one broken/old endpoint blank the entire monitor.
  -- The v1.4.3 bank does not expose national_statistics, and in some worlds the
  -- status handler may fail while supply/list_accounts/price-oracle still work.
  -- So this snapshot is assembled from separate narrow endpoints.
  local endpointErrors = {}

  local okStatus, status = cachedDbRequest({ type = "status" }, 3, LIGHT_POLL_SECONDS)
  if not okStatus or type(status) ~= "table" then
    endpointErrors[#endpointErrors + 1] = "status=" .. shortText(tostring(status), 36)
    status = {}
  end

  local okSupply, supplyRes = cachedDbRequest({ type = "supply" }, 3, LIGHT_POLL_SECONDS)
  local supply = {}
  if okSupply and type(supplyRes) == "table" then
    supply = supplyRes
  else
    endpointErrors[#endpointErrors + 1] = "supply=" .. shortText(tostring(supplyRes), 36)
    if type(status.supply) == "table" then supply = status.supply end
  end

  local okAccounts, accRes = cachedDbRequest({ type = "list_accounts" }, 5, ACCOUNT_LIST_POLL_SECONDS)
  local accounts = nil
  local accountsFromPrevious = false
  if okAccounts and type(accRes) == "table" then
    accounts = accRes.accounts or {}
  else
    endpointErrors[#endpointErrors + 1] = "accounts=" .. shortText(tostring(accRes), 36)
    -- Preserve important display values instead of replacing them with zero or
    -- Awaiting Data when the account endpoint is slow for one refresh.
    if last_snapshot and last_snapshot._raw_accounts then
      accounts = last_snapshot._raw_accounts
      accountsFromPrevious = true
    end
  end

  local issued = num(supply.in_circulation or supply.total_supply)
  if not issued then
    local minted = num(supply.total_minted) or 0
    local burned = num(supply.total_burned) or 0
    if minted > 0 or burned > 0 then issued = minted - burned end
  end

  local treasury = num(supply.treasury_balance or supply.treasury_reserve)
  local private = num(supply.private_supply)

  local derivedPopulation = 0
  local derivedCompanies = 0
  local derivedCitizenWealth = 0
  local derivedTreasury = nil
  if type(accounts) == "table" then
    for _, acc in ipairs(accounts) do
      if type(acc) == "table" and acc.status ~= "suspended" then
        if acc.account_id == "treasury:quid_bank" then derivedTreasury = num(acc.balance) end
        if acc.type == "citizen" then
          derivedPopulation = derivedPopulation + 1
          derivedCitizenWealth = derivedCitizenWealth + (num(acc.balance) or 0)
        elseif acc.type == "company" then
          derivedCompanies = derivedCompanies + 1
        end
      end
    end
  end

  if not treasury then treasury = derivedTreasury end
  if not private and issued and treasury then private = issued - treasury end
  local reserveShare = nil
  if issued and issued > 0 and treasury then reserveShare = (treasury / issued) * 100 end

  local population = num(status.citizen_count)
  if not population and derivedPopulation > 0 then population = derivedPopulation end

  local companyCount = num(status.company_count)
  if not companyCount and derivedCompanies > 0 then companyCount = derivedCompanies end

  local txTotal = num(status.tx_count)
  local txStats = nil
  local txToday = {}
  local txStatus = "Awaiting real bank transaction stats"
  local okTx, txRes = cachedDbRequest({ type = "transaction_stats" }, 3, TX_STATS_POLL_SECONDS)
  if okTx and type(txRes) == "table" then
    txStats = txRes
    txToday = type(txRes.today) == "table" and txRes.today or {}
    txStatus = txRes.note or "Real bank-side MC-day transaction count"
  else
    endpointErrors[#endpointErrors + 1] = "tx_stats=" .. shortText(tostring(txRes), 36)
  end

  -- Prefer the bank's actual inflation state. The older adaptive monetary
  -- calculation remains only as a fallback if that endpoint is unavailable.
  local inflation, inflationStatus = nil, nil
  local okInf, infRes = cachedDbRequest({ type = "get_inflation_state" }, 3, LIGHT_POLL_SECONDS)
  if okInf and type(infRes) == "table" then
    local st = infRes.state or infRes
    local rate = num(st.inflation_rate)
    inflation = num(st.inflation_percent)
    if not inflation and rate then inflation = rate * 100 end
    inflationStatus = "Bank inflation state"
  else
    endpointErrors[#endpointErrors + 1] = "inflation=" .. shortText(tostring(infRes), 36)
    inflation, inflationStatus = calculateMonetaryInflation(issued)
  end

  local contractEco = fetchContractEconomy()

  -- GDP is now assembled from two output streams:
  --   1. ContractServer fulfilled contracts.
  --   2. Bank ledger service output, especially Dining Hall / restaurant meals.
  -- The bank request explicitly excludes contract payouts so we do not double
  -- count contracts already read from ContractServer.
  local bankServiceGdp = 0
  local bankHospitalityGdp = 0
  local bankServiceEvents = 0
  local bankGdpRes = nil
  local okGdp, gdpRes = cachedDbRequest({
    type = "economic_gdp",
    days = GDP_PERIOD_MC_DAYS,
    exclude_contracts = true,
  }, 4, ECONOMIC_GDP_POLL_SECONDS)

  if okGdp and type(gdpRes) == "table" then
    bankGdpRes = gdpRes
    bankServiceGdp = num(gdpRes.service_gdp or gdpRes.services_gdp or gdpRes.non_contract_gdp or gdpRes.gdp or gdpRes.private_gdp) or 0
    bankHospitalityGdp = num(gdpRes.hospitality_gdp or gdpRes.meal_gdp) or 0
    bankServiceEvents = num(gdpRes.service_events or gdpRes.hospitality_events or gdpRes.transaction_count) or 0
  else
    endpointErrors[#endpointErrors + 1] = "service_gdp=" .. shortText(tostring(gdpRes), 36)
  end

  local contractGdp = 0
  local outputStatus = "Waiting for ContractServer / bank service GDP"
  if contractEco and contractEco.connected then
    contractGdp = tonumber(contractEco.gdp_365d or contractEco.gdp_24h) or 0
    outputStatus = "GDP = fulfilled contracts + bank service output"
  elseif bankServiceGdp > 0 then
    outputStatus = "GDP = bank service output; ContractServer unavailable"
  else
    outputStatus = "Waiting for fulfilled contracts / restaurant service sales"
  end

  local gdp = contractGdp + bankServiceGdp

  local gdpCap = nil
  if gdp and population and population > 0 then gdpCap = gdp / population end

  local quality = "LIVE"
  if #endpointErrors > 0 then quality = "PARTIAL" end

  local sourceText = "direct endpoints"
  if #endpointErrors > 0 then
    sourceText = "direct endpoints; degraded: " .. table.concat(endpointErrors, "; ")
  end

  return {
    mode = "DIRECT ENDPOINTS",
    quality = quality,
    time = num(status.time) or nowMs(),
    mc_clock = minecraftClock(),
    gdp_period_mc_days = GDP_PERIOD_MC_DAYS,
    gdp = gdp,
    gdp_per_capita = gdpCap,
    inflation = inflation,
    status_price_indices = type(status.price_indices) == "table" and status.price_indices or nil,
    status_inflation = type(status.inflation) == "table" and status.inflation or nil,
    output_status = outputStatus,
    inflation_status = inflationStatus or "Awaiting inflation state",
    inequality = inequalityFromAccounts(accounts),
    monetary = {
      issued_supply = issued,
      private_supply = private,
      treasury_reserve = treasury,
      reserve_share = reserveShare,
      status = (okSupply and "Live from supply endpoint") or "Supply degraded",
    },
    scale = {
      population = population,
      companies = companyCount,
      transactions_total = txTotal,
      transactions_today = num(txToday.total),
      economic_transactions_today = num(txToday.economic),
      admin_transactions_today = num(txToday.admin),
      payroll_transactions_today = num(txToday.payroll),
      service_transactions_today = num(txToday.service),
      transaction_value_today = num(txToday.value),
      tx_today_status = txStatus,
      top_companies = topCompaniesFromAccounts(accounts),
      source = sourceText,
    },
    tx_stats = txStats,
    contracts = contractEco,
    service_gdp = bankServiceGdp,
    hospitality_gdp = bankHospitalityGdp,
    contract_gdp = contractGdp,
    bank_gdp = bankGdpRes,
    service_events = bankServiceEvents,
    _raw_accounts = accounts,
    accounts_from_previous = accountsFromPrevious,
  }
end

local function refreshSnapshot()
  if not db_id then return false, "No server connected" end

  -- Read-only monitor: do not call tick_inflation from the dashboard.
  -- ServerSideAccounts should update inflation on its own write/price paths.
  -- Keeping the monitor passive prevents it from stalling other bank scripts.

  local snap, err = fallbackSnapshot()
  if not snap then return false, err or "Could not build snapshot" end

  -- Read the national wage/price pressure oracle for display. This is one
  -- honest national CPI/wage-index model, not fake separate sector CPIs.
  snap.price_oracle = fetchPriceOracle()

  snap.mc_clock = minecraftClock()
  snap.gdp_period_mc_days = GDP_PERIOD_MC_DAYS

  last_snapshot = snap
  last_error = ""

  local okTime, timeText = pcall(function()
    return os.date("!%H:%M:%S", math.floor(nowMs() / 1000))
  end)
  if okTime and timeText then last_update_text = timeText .. " UTC" else last_update_text = textutils.formatTime(os.time(), true) end

  pushHistory("gdp", snap.gdp)
  pushHistory("gdp_per_capita", snap.gdp_per_capita)
  pushHistory("inflation", snap.inflation)
  pushHistory("issued_supply", snap.monetary and snap.monetary.issued_supply)
  saveHistory()

  return true, snap
end


local function drawHeader()
  local w = getSize()
  fill(1, 1, w, 1, C.header)
  writeAt(2, 1, "ECONOMY CORE MONITOR", C.white, C.header)
  local v = "v" .. VERSION
  writeAt(w - #v, 1, v, C.white, C.header)

  fill(1, 2, w, 2, C.bg)
  writeAt(2, 2, "Bank: " .. tostring(db_id or "not connected"), db_id and C.good or C.bad, C.bg)
  writeAt(24, 2, "Contracts: " .. tostring(contract_id or "not connected"), contract_id and C.good or C.warn, C.bg)
  writeAt(58, 2, currentMinecraftClock(), C.good, C.bg)
  writeAt(2, 3, "Last update: " .. tostring(last_update), C.dim, C.bg)
  writeAt(34, 3, "Refresh: " .. tostring(REFRESH_SECONDS) .. "s low-impact", C.dim, C.bg)
end

local function drawMonetary(x, y, w, h)
  card(x, y, w, h, "MONETARY CONDITIONS", C.green)
  local supply = extractSupply(cache.status, cache.supply)
  metric(x + 2, y + 2, "Issued supply", fmtMoney(supply.issued), supply.issued and C.good or C.warn)
  metric(x + 2, y + 3, "Private supply", fmtMoney(supply.private), supply.private and C.white or C.warn)
  metric(x + 2, y + 4, "Treasury", fmtMoney(supply.treasury), supply.treasury and C.white or C.warn)
  metric(x + 2, y + 5, "Treasury control", fmtPct(supply.reserve_share, 2), supply.reserve_share and C.white or C.warn)
  metric(x + 2, y + 7, "Minted", fmtMoney(supply.total_minted), supply.total_minted and C.white or C.dim)
  metric(x + 2, y + 8, "Burned", fmtMoney(supply.total_burned), supply.total_burned and C.white or C.dim)
end

local function drawInflation(x, y, w, h)
  card(x, y, w, h, "PRICE / INFLATION ENGINE", C.purple)
  local po = cache.price or {}
  local inf = type(po.inflation) == "table" and po.inflation or cache.inflation or {}

  local rate = num(inf.inflation_percent)
  if not rate and num(inf.inflation_rate) then rate = num(inf.inflation_rate) * 100 end

  local general = getSector("general")
  local food = getSector("food")
  local build = getSector("construction")
  local fuel = getSector("fuel")
  local logi = getSector("logistics")
  local tools = getSector("tools")
  local hosp = getSector("hospitality")

  local pressure = num(food.monetary_pressure or general.monetary_pressure)
  local shock = num(food.shock_pressure or general.shock_pressure)
  local floor = num(food.price_pressure_floor or general.price_pressure_floor)
  local sticky = num(food.sticky_floor_from_ath or general.sticky_floor_from_ath)
  local defcap = num(food.max_daily_deflation or general.max_daily_deflation)

  metric(x + 2, y + 2, "Bank rate", fmtPct(rate, 2), rate and C.white or C.warn, 17)
  metric(x + 2, y + 3, "Pressure", fmtPct(pressure and pressure * 100 or nil, 1), pressure and C.white or C.warn, 17)
  metric(x + 2, y + 4, "Print shock", fmtPct(shock and shock * 100 or nil, 1), shock and shock > 0 and C.warn or C.dim, 17)
  metric(x + 2, y + 5, "Admin floor", fmtPct(floor and floor * 100 or nil, 1), floor and floor > 0 and C.warn or C.dim, 17)
  metric(x + 2, y + 6, "Deflation cap", fmtPct(defcap and defcap * 100 or nil, 1), defcap and C.white or C.warn, 17)
  metric(x + 2, y + 7, "Sticky floor", sticky and (fmtPct(sticky * 100, 0) .. " ATH") or "n/a", sticky and C.white or C.warn, 17)

  metric(x + 2, y + 9, "General / Food", fmtIndex(general.index) .. " / " .. fmtIndex(food.index), food.index and C.white or C.warn, 17)
  metric(x + 2, y + 10, "Build / Fuel", fmtIndex(build.index) .. " / " .. fmtIndex(fuel.index), build.index and C.white or C.warn, 17)
  metric(x + 2, y + 11, "Logi / Tools", fmtIndex(logi.index) .. " / " .. fmtIndex(tools.index), logi.index and C.white or C.warn, 17)
  metric(x + 2, y + 12, "Hospitality", fmtIndex(hosp.index), hosp.index and C.white or C.warn, 17)

  local status = po.model and "Live CPI endpoint only; no quote calls" or "Price oracle unavailable"
  writeAt(x + 2, y + h - 1, shortText(status, w - 4), po.model and C.good or C.warn, C.bg)
end

local function drawLocalQuotes(x, y, w, h)
  card(x, y, w, h, "LOCAL PRICE ESTIMATES", C.cyan)
  local food = sectorIndex("food") or 1
  local build = sectorIndex("construction") or 1
  local fuel = sectorIndex("fuel") or 1
  local tools = sectorIndex("tools") or 1
  local logi = sectorIndex("logistics") or 1

  metric(x + 2, y + 2, "Meal normal", fmtMoney(localQuote(2, food, 1, 1.0)), C.white)

local VERSION          = "1.0.9"
local PROTOCOL         = "quid_bank"
local TREASURY_ACCOUNT = "treasury:quid_bank"
local DB_TIMEOUT       = 5

local db_id = nil
local modem_name = nil
local last_status = nil
local last_accounts = nil
local last_message = ""
local last_message_colour = colors.lightGray

-- =============================================================================
-- BASIC HELPERS
-- =============================================================================
local function getSize()
  return term.getSize()
end

local function clear(bg)
  term.setCursorBlink(false)
  term.setBackgroundColor(bg or colors.black)
  term.setTextColor(colors.white)
  term.clear()
  term.setCursorPos(1, 1)
end

local function writeAt(x, y, text, fg, bg)
  local w, h = getSize()
  if y < 1 or y > h or x > w then return end
  if x < 1 then x = 1 end
  term.setCursorPos(x, y)
  if bg then term.setBackgroundColor(bg) end
  if fg then term.setTextColor(fg) end
  local max_len = w - x + 1
  if max_len > 0 then
    term.write(tostring(text or ""):sub(1, max_len))
  end
end

local function fill(x, y, w, h, bg)
  local sw, sh = getSize()
  if w <= 0 or h <= 0 then return end
  if x < 1 then x = 1 end
  term.setBackgroundColor(bg or colors.black)
  local row = string.rep(" ", math.max(0, w))
  for yy = y, y + h - 1 do
    if yy >= 1 and yy <= sh then
      term.setCursorPos(x, yy)
      term.write(row:sub(1, sw - x + 1))
    end
  end
end

local function center(y, text, fg, bg)
  local w = getSize()
  text = tostring(text or "")
  local x = math.floor((w - #text) / 2) + 1
  writeAt(x, y, text, fg, bg)
end

local function money(n)
  n = tonumber(n) or 0
  local sign = ""
  if n < 0 then
    sign = "-"
    n = math.abs(n)
  end
  local s = tostring(math.floor(n))
  local out = ""
  while #s > 3 do
    out = "," .. s:sub(-3) .. out
    s = s:sub(1, -4)
  end
  return sign .. s .. out .. " Q"
end

local function trim(s)
  s = tostring(s or "")
  return s:match("^%s*(.-)%s*$")
end

local function normaliseAccountId(s)
  s = trim(s)
  if s == "" then return "" end
  if s:find(":") then return s end
  return "citizen:" .. string.lower(s):gsub("%s+", "_")
end

local function accountNameFromList(account_id)
  if type(last_accounts) ~= "table" then return account_id end
  for _, acc in ipairs(last_accounts) do
    if tostring(acc.account_id or "") == tostring(account_id) then
      local name = trim(acc.display_name or "")
      if name ~= "" then return name end
      return account_id
    end
  end
  return account_id
end

local function findAccountById(account_id)
  if type(last_accounts) ~= "table" then return nil end
  for _, acc in ipairs(last_accounts) do
    if tostring(acc.account_id or "") == tostring(account_id) then
      return acc
    end
  end
  return nil
end

local function resolveGrantRecipient(input)
  local raw = trim(input)
  if raw == "" then return "", "Missing recipient", "unknown" end

  -- Keep full explicit account IDs untouched:
  --   citizen:mc_5
  --   company:hrth
  --   treasury:quid_bank
  if raw:find(":") then
    return raw, accountNameFromList(raw), "explicit"
  end

  -- Pull a fresh account list if we do not have one yet, so ticker lookup works.
  if type(last_accounts) ~= "table" then
    requestAccounts()
  end

  local key = string.lower(raw):gsub("%s+", "_")
  local company_id = "company:" .. key
  local citizen_id = "citizen:" .. key

  -- Ticker/company shorthand comes first.
  -- Example: HRTH -> company:hrth
  local company = findAccountById(company_id)
  if company then
    return company_id, accountNameFromList(company_id), "company_ticker"
  end

  -- Then citizen username shorthand.
  -- Example: akox -> citizen:akox
  local citizen = findAccountById(citizen_id)
  if citizen then
    return citizen_id, accountNameFromList(citizen_id), "citizen_username"
  end

  -- If it looks like a 4-letter ticker and we cannot prove otherwise,
  -- assume the user means a company ticker. The bank server will reject it
  -- if the company account does not exist.
  if raw:match("^%a%a%a%a$") then
    return company_id, company_id, "company_ticker_guess"
  end

  -- Fallback preserves old behaviour for normal citizen usernames.
  return citizen_id, citizen_id, "citizen_username_guess"
end

local function positiveInt(v)
  local n = tonumber(v)
  if not n then return nil end
  n = math.floor(n)
  if n <= 0 then return nil end
  return n
end

local function setMessage(msg, col)
  last_message = tostring(msg or "")
  last_message_colour = col or colors.lightGray
end

local function button(x, y, w, label, bg, fg)
  fill(x, y, w, 1, bg or colors.gray)
  local tx = x + math.floor((w - #label) / 2)
  writeAt(tx, y, label, fg or colors.white, bg or colors.gray)
  return { x1 = x, x2 = x + w - 1, y1 = y, y2 = y }
end

local function hit(b, mx, my)
  return b and mx >= b.x1 and mx <= b.x2 and my >= b.y1 and my <= b.y2
end

local function drawTop(title)
  local w = getSize()
  fill(1, 1, w, 1, colors.gray)
  writeAt(2, 1, title or "FISCAL CONTROLS", colors.yellow, colors.gray)
  local v = "v" .. VERSION
  writeAt(w - #v, 1, v, colors.white, colors.gray)
end

local function drawBottom()
  local w, h = getSize()
  fill(1, h, w, 1, colors.black)
  if last_message ~= "" then
    writeAt(2, h, last_message, last_message_colour, colors.black)
  end
  local q = "[Q] Quit"
  writeAt(w - #q, h, q, colors.lightGray, colors.black)
end

-- =============================================================================
-- MODEM / NETWORK
-- =============================================================================
local function openModem()
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      local modem = peripheral.wrap(name)
      if modem and modem.isWireless and modem.isWireless() then
        rednet.open(name)
        modem_name = name
        return true
      end
    end
  end

  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      rednet.open(name)
      modem_name = name
      return true
    end
  end

  return false
end

local function connectServer()
  clear(colors.black)
  drawTop("FISCAL CONTROLS")
  center(4, "Connecting to Quid Bank server...", colors.white, colors.black)
  center(6, "Modem: " .. tostring(modem_name or "none"), colors.lightGray, colors.black)

  for attempt = 1, 8 do
    center(8, "Attempt " .. attempt .. " of 8", colors.lightGray, colors.black)

    rednet.broadcast({ type = "ping" }, PROTOCOL)
    local sender, msg = rednet.receive(PROTOCOL, 4)

    if sender and type(msg) == "table" then
      if msg.type == "treasury_online" then
        db_id = sender
        center(10, "Connected to server " .. tostring(db_id), colors.lime, colors.black)
        sleep(0.4)
        return true
      end

      if msg.success == true and type(msg.response) == "table" then
        db_id = sender
        center(10, "Connected to server " .. tostring(db_id), colors.lime, colors.black)
        sleep(0.4)
        return true
      end
    end
  end

  center(10, "Connection failed.", colors.red, colors.black)
  center(12, "Check server is running and modem is open.", colors.lightGray, colors.black)
  sleep(3)
  return false
end

local function dbRequest(request, timeout)
  timeout = timeout or DB_TIMEOUT
  if not db_id then return false, "No server connected" end

  rednet.send(db_id, request, PROTOCOL)

  local deadline = os.clock() + timeout
  while true do
    local remaining = deadline - os.clock()
    if remaining <= 0 then
      return false, "No response from server"
    end

    local sender, msg = rednet.receive(PROTOCOL, remaining)
    if sender == db_id and type(msg) == "table" and msg.success ~= nil then
      return msg.success, msg.response
    end
  end
end

-- =============================================================================
-- SERVER ACTIONS
-- =============================================================================
local function refreshStatus()
  local ok, res = dbRequest({ type = "status" })
  if ok and type(res) == "table" then
    last_status = res
    setMessage("Status refreshed.", colors.lime)
    return true, res
  end
  setMessage("Status unavailable: " .. tostring(res), colors.red)
  return false, res
end

local function requestAccounts()
  local ok, res = dbRequest({ type = "list_accounts" })
  if ok and type(res) == "table" then
    last_accounts = res.accounts or {}
    return true, last_accounts
  end
  setMessage("Accounts unavailable: " .. tostring(res), colors.red)
  return false, res
end


local function requestFiscalHistory()
  local ok, res = dbRequest({
    type = "fiscal_history",
    account_id = TREASURY_ACCOUNT,
    limit = 80,
  })

  if ok and type(res) == "table" then
    return true, res
  end

  setMessage("Fiscal history unavailable: " .. tostring(res), colors.red)
  return false, res
end

-- =============================================================================
-- EVENT FORMS WITH BACK BUTTONS
-- =============================================================================
local function inputBox(x, y, w, value, focused)
  value = tostring(value or "")
  fill(x, y, w, 1, colors.gray)
  writeAt(x, y, (value .. string.rep(" ", w)):sub(1, w), colors.white, colors.gray)

  return {
    x1 = x,
    x2 = x + w - 1,
    y1 = y,
    y2 = y,
    cursor_x = x + math.min(#value, w - 1),
    cursor_y = y
  }
end

local function formScreen(title, help, fields, submitLabel)
  local focused = 1
  local err = ""
  for _, f in ipairs(fields) do
    f.value = f.value or ""
  end

  local function draw()
    local w, h = getSize()
    clear(colors.black)
    drawTop(title)

    if help and help ~= "" then
      writeAt(2, 3, help, colors.lightGray, colors.black)
    end

    local y = help and 5 or 3
    local fieldHits = {}
    for i, f in ipairs(fields) do
      writeAt(2, y, f.label, colors.white, colors.black)
      fieldHits[i] = inputBox(2, y + 1, w - 3, f.value, focused == i)
      y = y + 3
    end

    if err ~= "" then
      writeAt(2, h - 3, err, colors.red, colors.black)
    else
      writeAt(2, h - 3, "TAB changes field. ESC/B/back button cancels.", colors.lightGray, colors.black)
    end

    local bw = math.floor((w - 6) / 2)
    local bSubmit = button(2, h - 1, bw, submitLabel or "Submit", colors.blue, colors.white)
    local bBack = button(4 + bw, h - 1, bw, "Back", colors.gray, colors.white)

    -- Cursor belongs only inside the selected input field.
    -- It is positioned after buttons are drawn, so it cannot blink on Back/Review.
    local active = fieldHits[focused]
    if active then
      term.setCursorPos(active.cursor_x, active.cursor_y)
      term.setCursorBlink(true)
    else
      term.setCursorBlink(false)
    end

    return fieldHits, bSubmit, bBack
  end

  local fieldHits, bSubmit, bBack = draw()

  local function submit()
    local out = {}
    for _, f in ipairs(fields) do
      local v = trim(f.value)
      if f.required and v == "" then
        err = "Missing: " .. f.label
        return nil
      end
      out[f.key] = v
    end
    return out
  end

  while true do
    local ev, p1, p2, p3 = os.pullEvent()

    if ev == "char" then
      local f = fields[focused]
      local maxLen = f.max or 40
      if #f.value < maxLen then
        f.value = f.value .. p1
      end
      err = ""
      fieldHits, bSubmit, bBack = draw()

    elseif ev == "key" then
      if p1 == keys.backspace then
        local f = fields[focused]
        f.value = tostring(f.value):sub(1, -2)
        err = ""
        fieldHits, bSubmit, bBack = draw()

      elseif p1 == keys.tab then
        focused = focused % #fields + 1
        fieldHits, bSubmit, bBack = draw()

      elseif p1 == keys.enter then
        if focused < #fields then
          focused = focused + 1
          fieldHits, bSubmit, bBack = draw()
        else
          local out = submit()
          if out then return out end
          fieldHits, bSubmit, bBack = draw()
        end

      elseif p1 == keys.escape or p1 == keys.b then
        return nil
      end

    elseif ev == "mouse_click" then
      local mx, my = p2, p3
      if hit(bBack, mx, my) then
        return nil
      elseif hit(bSubmit, mx, my) then
        local out = submit()
        if out then return out end
        fieldHits, bSubmit, bBack = draw()
      else
        for i, box in ipairs(fieldHits) do
          if hit(box, mx, my) then
            focused = i
            fieldHits, bSubmit, bBack = draw()
            break
          end
        end
      end
    end
  end
end

local function confirmScreen(title, lines, confirmLabel, dangerous)
  local function draw()
    local w, h = getSize()
    clear(colors.black)
    drawTop(title)
    local y = 3
    for _, line in ipairs(lines) do
      writeAt(2, y, tostring(line), colors.white, colors.black)
      y = y + 1
      if y > h - 4 then break end
    end
    writeAt(2, h - 3, "Confirm this state finance action?", dangerous and colors.red or colors.orange, colors.black)
    local bw = math.floor((w - 6) / 2)
    local bConfirm = button(2, h - 1, bw, confirmLabel or "Confirm", dangerous and colors.red or colors.blue, colors.white)
    local bBack = button(4 + bw, h - 1, bw, "Back", colors.gray, colors.white)
    return bConfirm, bBack
  end

  local bConfirm, bBack = draw()
  while true do
    local ev, p1, p2, p3 = os.pullEvent()
    if ev == "mouse_click" then
      if hit(bBack, p2, p3) then return false end
      if hit(bConfirm, p2, p3) then return true end
    elseif ev == "key" then
      if p1 == keys.enter then return true end
      if p1 == keys.escape or p1 == keys.b or p1 == keys.backspace then return false end
    end
  end
end


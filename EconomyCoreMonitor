-- =============================================================================
-- ECONOMY CORE MONITOR
-- Quid national statistics display - contract-aware Minecraft core build
--
-- Shows only:
--   GDP
--   GDP / PER CAPITA
--   INFLATION
--   INEQUALITY (account balance distribution, not income)
--   MONETARY CONDITIONS
--   POPULATION
--   COMPANIES
--   TRANSACTIONS PER DAY
--
-- Read-only. No banking controls. No trade panel. Contract GDP + tapered money-supply inflation.
-- =============================================================================

local VERSION         = "0.5.2-TAPERED-INFLATION"
local PROTOCOL        = "quid_bank"
local CONTRACT_PROTOCOL = "quid_contracts"
local DB_TIMEOUT      = 5
local CONTRACT_TIMEOUT = 3
local GDP_PERIOD_MS   = 24 * 60 * 60 * 1000
local REFRESH_SECONDS = 5
local TEXT_SCALE      = 0.5
local HISTORY_FILE    = "data/economy_core_monitor_history.db"
local INFLATION_BASE_FILE = "data/economy_monetary_inflation_base.db"
local INFLATION_HALF_LIFE_MS = 24 * 60 * 60 * 1000 -- no new printing: inflation pressure halves every 24h
local MAX_HISTORY     = 120

local native_term = term.current()
local monitor = nil
local modem_name = nil
local db_id = nil
local contract_id = nil
local last_contract_error = ""
local last_error = ""
local last_snapshot = nil
local last_update_text = "never"

local history = {
  gdp = {},
  gdp_per_capita = {},
  inflation = {},
  issued_supply = {},
  tx_samples = {},
}

-- =============================================================================
-- SMALL HELPERS
-- =============================================================================
local function nowMs()
  if os.epoch then return os.epoch("utc") end
  return math.floor(os.time() * 1000)
end

local function ensureDir(path)
  local dir = fs.getDir(path)
  if dir and dir ~= "" and not fs.exists(dir) then
    fs.makeDir(dir)
  end
end

local function readTable(path)
  if not fs.exists(path) then return nil end
  local f = fs.open(path, "r")
  if not f then return nil end
  local text = f.readAll()
  f.close()
  if not text or text == "" then return nil end
  local ok, data = pcall(textutils.unserialize, text)
  if ok then return data end
  return nil
end

local function writeTable(path, data)
  ensureDir(path)
  local f = fs.open(path, "w")
  if not f then return false end
  f.write(textutils.serialize(data))
  f.close()
  return true
end

local function loadHistory()
  local data = readTable(HISTORY_FILE)
  if type(data) == "table" then
    for k, v in pairs(data) do
      if type(v) == "table" then history[k] = v end
    end
  end
end

local function saveHistory()
  writeTable(HISTORY_FILE, history)
end

local function getSize()
  return term.getSize()
end

local function clear(bg)
  term.setCursorBlink(false)
  term.setBackgroundColor(bg or colors.black)
  term.setTextColor(colors.white)
  term.clear()
  term.setCursorPos(1, 1)
end

local function writeAt(x, y, text, fg, bg)
  local w, h = getSize()
  if y < 1 or y > h or x > w then return end
  if x < 1 then x = 1 end
  term.setCursorPos(x, y)
  if bg then term.setBackgroundColor(bg) end
  if fg then term.setTextColor(fg) end
  local maxLen = w - x + 1
  if maxLen > 0 then
    term.write(tostring(text or ""):sub(1, maxLen))
  end
end

local function fill(x, y, w, h, bg)
  local sw, sh = getSize()
  if w <= 0 or h <= 0 then return end
  if x < 1 then x = 1 end
  if x > sw then return end
  term.setBackgroundColor(bg or colors.black)
  local row = string.rep(" ", math.max(0, w))
  for yy = y, y + h - 1 do
    if yy >= 1 and yy <= sh then
      term.setCursorPos(x, yy)
      term.write(row:sub(1, sw - x + 1))
    end
  end
end

local function centerIn(x, y, w, text, fg, bg)
  text = tostring(text or "")
  local tx = x + math.floor((w - #text) / 2)
  writeAt(tx, y, text, fg, bg)
end

local function num(v)
  local n = tonumber(v)
  if n == nil then return nil end
  return n
end

local function safeDiv(a, b)
  a = tonumber(a)
  b = tonumber(b)
  if not a or not b or b == 0 then return nil end
  return a / b
end

local function clamp(v, lo, hi)
  if v < lo then return lo end
  if v > hi then return hi end
  return v
end

local function countTable(t)
  local n = 0
  if type(t) ~= "table" then return 0 end
  for _ in pairs(t) do n = n + 1 end
  return n
end

local function trimHistory(list)
  while #list > MAX_HISTORY do
    table.remove(list, 1)
  end
end

local function pushHistory(key, value)
  value = tonumber(value)
  if value == nil then return end
  history[key] = history[key] or {}
  history[key][#history[key] + 1] = value
  trimHistory(history[key])
end

local function fmtMoney(v)
  local n = tonumber(v)
  if n == nil then return "Awaiting data" end
  local sign = ""
  if n < 0 then
    sign = "-"
    n = math.abs(n)
  end
  local whole = tostring(math.floor(n + 0.5))
  local out = ""
  while #whole > 3 do
    out = "," .. whole:sub(-3) .. out
    whole = whole:sub(1, -4)
  end
  return sign .. whole .. out .. " Q"
end

local function fmtNum(v, decimals)
  local n = tonumber(v)
  if n == nil then return "Awaiting data" end
  decimals = decimals or 0
  return string.format("%." .. tostring(decimals) .. "f", n)
end

local function fmtPct(v, decimals)
  local n = tonumber(v)
  if n == nil then return "Awaiting data" end
  decimals = decimals or 2
  return string.format("%." .. tostring(decimals) .. "f%%", n)
end

local function shortText(text, maxLen)
  text = tostring(text or "")
  maxLen = maxLen or 30
  if #text <= maxLen then return text end
  return text:sub(1, maxLen - 3) .. "..."
end

local function copyList(values)
  local out = {}
  if type(values) ~= "table" then return out end
  for i = 1, #values do out[i] = values[i] end
  return out
end

local function calculateMedian(values)
  if type(values) ~= "table" or #values == 0 then return nil end
  table.sort(values)
  local n = #values
  if n % 2 == 1 then return values[math.ceil(n / 2)] end
  return ((values[n / 2] or 0) + (values[(n / 2) + 1] or 0)) / 2
end

local function calculateTopShare(values, fraction)
  if type(values) ~= "table" or #values == 0 then return nil end
  fraction = fraction or 0.1
  table.sort(values, function(a, b) return a > b end)
  local total = 0
  for _, v in ipairs(values) do total = total + (tonumber(v) or 0) end
  if total <= 0 then return 0 end
  local take = math.max(1, math.ceil(#values * fraction))
  local top = 0
  for i = 1, take do top = top + (tonumber(values[i]) or 0) end
  return (top / total) * 100
end

local function growthPct(current, previous)
  current = tonumber(current)
  previous = tonumber(previous)
  if not current or not previous or previous == 0 then return nil end
  return ((current / previous) - 1) * 100
end

local function getAdaptiveInflationBase(issued)
  issued = tonumber(issued)
  if not issued or issued <= 0 then
    return nil, "Awaiting issued money supply"
  end

  local now = nowMs()
  local state = readTable(INFLATION_BASE_FILE)

  -- Backwards-compatible with v0.5.1, which stored issued_supply as a fixed baseline.
  local baseIssued = nil
  if type(state) == "table" then
    baseIssued = tonumber(state.base_issued_supply or state.issued_supply)
  end

  if type(state) ~= "table" or not baseIssued or baseIssued <= 0 then
    state = {
      base_issued_supply = issued,
      last_issued_supply = issued,
      created = now,
      updated = now,
      half_life_ms = INFLATION_HALF_LIFE_MS,
      note = "Adaptive inflation baseline. Without new printing, the current supply slowly becomes the baseline.",
    }
    writeTable(INFLATION_BASE_FILE, state)
    return issued, "Adaptive monetary inflation baseline created"
  end

  local lastUpdate = tonumber(state.updated or state.created or now) or now
  local elapsed = math.max(0, now - lastUpdate)

  -- Exponential taper: after each half-life, half of the remaining inflation pressure fades.
  local alpha = 0
  if elapsed > 0 then
    alpha = 1 - math.pow(0.5, elapsed / INFLATION_HALF_LIFE_MS)
    alpha = clamp(alpha, 0, 1)
  end

  local newBase = baseIssued + ((issued - baseIssued) * alpha)
  if newBase <= 0 then newBase = issued end

  state.base_issued_supply = newBase
  state.last_issued_supply = issued
  state.updated = now
  state.half_life_ms = INFLATION_HALF_LIFE_MS
  state.note = "Adaptive inflation baseline. Without new printing, current supply slowly becomes the baseline."
  writeTable(INFLATION_BASE_FILE, state)

  return newBase, nil
end

local function calculateMonetaryInflation(issued)
  issued = tonumber(issued)
  local base, err = getAdaptiveInflationBase(issued)
  if not base then return nil, err or "Awaiting adaptive monetary baseline" end

  local inflation = ((issued / base) - 1) * 100
  return inflation, "Adaptive money-supply inflation, 24h half-life"
end


local function openModem()
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      local m = peripheral.wrap(name)
      if m and m.isWireless and m.isWireless() then
        rednet.open(name)
        modem_name = name
        return true
      end
    end
  end
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      rednet.open(name)
      modem_name = name
      return true
    end
  end
  return false
end

local function dbRequest(req, timeout)
  timeout = timeout or DB_TIMEOUT
  if not db_id then return false, "No server connected" end
  rednet.send(db_id, req, PROTOCOL)
  local deadline = os.clock() + timeout
  while true do
    local remaining = deadline - os.clock()
    if remaining <= 0 then return false, "No response from server" end
    local sender, msg = rednet.receive(PROTOCOL, remaining)
    if sender == db_id and type(msg) == "table" and msg.success ~= nil then
      return msg.success, msg.response
    end
  end
end

local function cacheKey(prefix, req)
  local ok, serialized = pcall(textutils.serialize, req or {})
  if not ok then serialized = tostring(req) end
  return tostring(prefix or "cache") .. ":" .. tostring(serialized)
end

local function cachedDbRequest(req, timeout, ttlSeconds)
  ttlSeconds = tonumber(ttlSeconds) or 0
  if ttlSeconds <= 0 then return dbRequest(req, timeout) end

  local key = cacheKey("db", req)
  local now = os.clock()
  local entry = request_cache[key]
  if entry and (now - (tonumber(entry.time) or 0)) < ttlSeconds then
    return entry.ok, entry.response, true, false
  end

  local ok, response = dbRequest(req, timeout)

  -- Important: do not cache failures. A single timeout should not blank GDP/c,
  -- inequality, companies, CPI, or quotes for the full cache window. If we have
  -- an older successful value, return it as stale instead of replacing it with
  -- an error/zero state.
  if ok then
    request_cache[key] = { time = now, ok = ok, response = response }
    return ok, response, false, false
  end

  if entry and entry.ok then
    return entry.ok, entry.response, true, true
  end

  return ok, response, false, false
end

local function clearRequestCache()
  request_cache = {}
end

local function connectServer()
  db_id = nil
  clear(colors.black)
  local w, h = getSize()
  centerIn(1, math.floor(h / 2) - 2, w, "ECONOMY CORE MONITOR", colors.yellow, colors.black)
  centerIn(1, math.floor(h / 2), w, "Connecting to Quid Bank server...", colors.lightGray, colors.black)
  centerIn(1, math.floor(h / 2) + 1, w, "Modem: " .. tostring(modem_name or "none"), colors.gray, colors.black)

  if FORCED_BANK_ID then
    db_id = FORCED_BANK_ID
    clearRequestCache()
    centerIn(1, math.floor(h / 2) + 3, w, "Using forced bank ID " .. tostring(db_id), colors.lime, colors.black)
    sleep(0.4)
    return true
  end

  -- Do not accept the first random treasury_online broadcast blindly. Collect
  -- responses briefly and prefer a direct ping reply from ServerSideAccounts.
  for attempt = 1, 8 do
    centerIn(1, math.floor(h / 2) + 3, w, "Bank attempt " .. attempt .. " of 8", colors.gray, colors.black)
    rednet.broadcast({ type = "ping" }, PROTOCOL)

    local bestDirect = nil
    local bestBroadcast = nil
    local deadline = os.clock() + 4
    while true do
      local remaining = deadline - os.clock()
      if remaining <= 0 then break end
      local sender, msg = rednet.receive(PROTOCOL, remaining)
      if sender and type(msg) == "table" then
        if msg.success == true and type(msg.response) == "table" then
          local r = msg.response
          local message = tostring(r.message or "")
          if message:find("Quid Bank", 1, true) or r.version or r.label then
            bestDirect = sender
            break
          end
        elseif msg.type == "treasury_online" and (msg.version or msg.id) then
          bestBroadcast = sender
        end
      end
    end

    if bestDirect or bestBroadcast then
      db_id = bestDirect or bestBroadcast
      clearRequestCache()
      centerIn(1, math.floor(h / 2) + 5, w, "Connected to bank " .. tostring(db_id), colors.lime, colors.black)
      sleep(0.4)
      return true
    end
  end
  last_error = "Unable to discover bank server"
  return false
end

local function connectContractServer(silent)
  contract_id = nil
  last_contract_error = ""

  if not silent then
    local w, h = getSize()
    centerIn(1, math.floor(h / 2) + 7, w, "Looking for ContractServer...", colors.lightGray, colors.black)
  end

  rednet.broadcast({ type = "ping" }, CONTRACT_PROTOCOL)
  local deadline = os.clock() + CONTRACT_TIMEOUT
  while true do
    local remaining = deadline - os.clock()
    if remaining <= 0 then break end
    local sender, msg = rednet.receive(CONTRACT_PROTOCOL, remaining)
    if sender and type(msg) == "table" then
      if msg.success == true or msg.type == "contract_server_online" then
        contract_id = sender
        return true
      end
    end
  end

  last_contract_error = "No ContractServer"
  return false
end

local function contractRequest(req, timeout)
  timeout = timeout or CONTRACT_TIMEOUT
  if not contract_id then return false, "No ContractServer connected" end
  rednet.send(contract_id, req, CONTRACT_PROTOCOL)
  local deadline = os.clock() + timeout
  while true do
    local remaining = deadline - os.clock()
    if remaining <= 0 then return false, "No response from ContractServer" end
    local sender, msg = rednet.receive(CONTRACT_PROTOCOL, remaining)
    if sender == contract_id and type(msg) == "table" and msg.success ~= nil then
      return msg.success, msg.response
    end
  end
end

local function cachedContractRequest(req, timeout, ttlSeconds)
  ttlSeconds = tonumber(ttlSeconds) or 0
  if ttlSeconds <= 0 then return contractRequest(req, timeout) end

  local key = cacheKey("contract", req)
  local now = os.clock()
  local entry = request_cache[key]
  if entry and (now - (tonumber(entry.time) or 0)) < ttlSeconds then
    return entry.ok, entry.response, true, false
  end

  local ok, response = contractRequest(req, timeout)
  if ok then
    request_cache[key] = { time = now, ok = ok, response = response }
    return ok, response, false, false
  end

  if entry and entry.ok then
    return entry.ok, entry.response, true, true
  end

  return ok, response, false, false
end


-- =============================================================================
-- PRICE / INFLATION ORACLE
-- ServerSideAccounts v1.4.6+ exposes a zero-baseline wide sector price oracle.
-- Prices rise easily under money-print/inflation pressure, but deflate slowly
-- and deflate slowly after inflation shocks.
-- =============================================================================
local function sectorFromOracle(priceOracle, name)
  if type(priceOracle) ~= "table" or type(priceOracle.sectors) ~= "table" then return nil end
  return priceOracle.sectors[name]
end

local function sectorIndexFromOracle(priceOracle, name)
  local rec = sectorFromOracle(priceOracle, name)
  if type(rec) ~= "table" then return nil end
  return tonumber(rec.index)
end

local function quoteLabel(q)
  if type(q) ~= "table" then return nil end
  local total = tonumber(q.total)
  if total == nil then return nil end
  return fmtMoney(total)
end

local function fetchPriceOracle()
  local ok, res, fromCache, stale = cachedDbRequest({ type = "get_price_indices" }, 5, PRICE_ORACLE_POLL_SECONDS)
  if not ok or type(res) ~= "table" then
    -- Do not let one slow oracle response blank the whole panel if we previously
    -- had live CPI. Keep the last good oracle visible and mark it stale.
    local previous = last_snapshot and last_snapshot.price_oracle
    if type(previous) == "table" and previous.connected then
      local out = shallowCopyTable(previous)
      out.status = "Price oracle stale; last good CPI retained"
      out.stale = true
      return out
    end

    return {
      connected = false,
      status = "Price oracle unavailable: " .. tostring(res),
      sectors = {},
      quotes = {},
    }
  end

  local inflation = type(res.inflation) == "table" and res.inflation or {}
  local sectors = type(res.sectors) == "table" and res.sectors or {}
  local rate = tonumber(inflation.inflation_rate)
  local percent = tonumber(inflation.inflation_percent)
  if not percent and rate then percent = rate * 100 end

  local out = {
    connected = true,
    model = tostring(res.model or "national_wage_price_pressure"),
    status = stale and "Cached national wage/price pressure" or "Live national wage/price pressure",
    note = res.note,
    time = tonumber(res.time),
    stale = stale == true,
    inflation = inflation,
    inflation_rate = rate,
    inflation_percent = percent,
    old_price_index = tonumber(inflation.price_index),
    price_index_percent = tonumber(inflation.price_index_percent),
    wage_price = type(res.wage_price) == "table" and res.wage_price or {},
    national_price_index = tonumber(res.national_price_index),
    wage_index = tonumber(res.wage_index),
    sectors = sectors,
    quotes = {},
  }

  local previousQuotes = {}
  if last_snapshot and type(last_snapshot.price_oracle) == "table" and type(last_snapshot.price_oracle.quotes) == "table" then
    previousQuotes = last_snapshot.price_oracle.quotes
  end

  local function cachedQuote(key, req)
    local qOk, qRes = cachedDbRequest(req, 4, QUOTE_POLL_SECONDS)
    if qOk and type(qRes) == "table" then
      out.quotes[key] = qRes
    elseif type(previousQuotes[key]) == "table" then
      out.quotes[key] = previousQuotes[key]
      out.quotes[key].stale = true
    end
  end

  -- A few visible quote examples give the monitor immediate practical meaning.
  -- These are intentionally broad, not deep behavioural modelling. Failures keep
  -- the previous quote rather than deleting the panel values.
  cachedQuote("dining_meal", { type = "quote_service_price", service = "dining_meal", tier = "normal" })
  cachedQuote("large_meal", { type = "quote_service_price", service = "dining_meal", tier = "large" })
  cachedQuote("oak_planks_64", { type = "quote_item_price", item = "oak_planks", count = 64, sector = "construction" })
  cachedQuote("iron_ingot_8", { type = "quote_item_price", item = "iron_ingot", count = 8, sector = "tools" })
  cachedQuote("coal_16", { type = "quote_item_price", item = "coal", count = 16, sector = "fuel" })

  return out
end


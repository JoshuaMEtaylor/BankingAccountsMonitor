  metric(x + 2, y + 4, "64 planks", fmtMoney(localQuote(1, build, 64, 1.0)), C.white)
  metric(x + 2, y + 5, "8 iron", fmtMoney(localQuote(5, tools, 8, 1.0)), C.white)
  metric(x + 2, y + 6, "16 coal", fmtMoney(localQuote(2, fuel, 16, 1.0)), C.white)
  metric(x + 2, y + 7, "Courier job", fmtMoney(localQuote(4, logi, 1, 1.0)), C.white)

  writeAt(x + 2, y + h - 1, "Estimated locally from CPI, not bank quote endpoints", C.dim, C.bg)

local function cCls()
  size()
  term.setCursorBlink(false)
  term.setBackgroundColor(QC.bg)
  term.setTextColor(QC.body)
  term.clear()
  term.setCursorPos(1, 1)
end

local function cAt(x, y, text, fg, bg)
  size()
  if y < 1 or y > H or x > W then return end
  if x < 1 then x = 1 end
  term.setCursorPos(x, y)
  if bg then term.setBackgroundColor(bg) end
  if fg then term.setTextColor(fg) end
  term.write(tostring(text or ""):sub(1, math.max(0, W - x + 1)))
end

local function cFill(x, y, w, h, bg)
  size()
  if w <= 0 or h <= 0 then return end
  if x < 1 then x = 1 end
  term.setBackgroundColor(bg or QC.card)
  local row = string.rep(" ", math.max(0, w))
  for yy = y, y + h - 1 do
    if yy >= 1 and yy <= H then
      term.setCursorPos(x, yy)
      term.write(row:sub(1, math.max(0, W - x + 1)))
    end
  end
end

local function cCentre(y, text, fg, bg)
  text = tostring(text or "")
  cAt(math.max(1, math.floor((W - #text) / 2) + 1), y, text, fg, bg)
end

local function cTop()
  cFill(1, 1, W, 1, QC.header)
  cAt(2, 1, "QUID COMPANY TERMINAL", QC.hdr_fg, QC.header)
  cAt(W - #VERSION, 1, VERSION, QC.dim, QC.header)
end

local function cCard(x, y, w, h) cFill(x, y, w, h, QC.card) end

local function cBtn(x, y, w, label, bg, fg)
  bg = bg or QC.btn_pri
  fg = fg or QC.btn_fg
  cFill(x, y, w, 1, bg)
  cAt(x + math.max(0, math.floor((w - #label) / 2)), y, label, fg, bg)
  return { x1 = x, x2 = x + w - 1, y1 = y, y2 = y }
end

local function cInput(x, y, w, value, masked, focused)
  value = tostring(value or "")
  local shown = masked and string.rep("*", #value) or value
  cFill(x, y, w, 1, QC.input_bg)
  cAt(x, y, (shown .. string.rep(" ", w)):sub(1, w), QC.input_fg, QC.input_bg)
  if focused then
    term.setCursorPos(x + math.min(#value, w - 1), y)
    term.setCursorBlink(true)
  end
  return { x1 = x, x2 = x + w - 1, y1 = y, y2 = y }
end

local function cStatus()
  cFill(1, H, W, 1, QC.bg)
  if company.msg ~= "" then
    cAt(2, H, company.msg:sub(1, W - 2), company.msg_col, QC.bg)
  end
end

local function cSet(msg, col)
  company.msg = tostring(msg or "")
  company.msg_col = col or QC.dim
end

local function cTrim(s)
  s = tostring(s or "")
  return s:match("^%s*(.-)%s*$")
end

local function cTicker(s)
  s = cTrim(s):upper()
  s = s:gsub("%s+", "")
  s = s:gsub("[^A-Z0-9_%-]", "")
  return s
end

local function cCompanyId(ticker)
  ticker = cTicker(ticker)
  if ticker == "" then return "" end
  return "company:" .. string.lower(ticker)
end

local function cNormalCompany(s)
  s = cTrim(s)
  if s == "" then return "" end
  if s:find(":") then return s end
  return cCompanyId(s)
end

local function cMoney(n)
  return money(n)
end

local function cShort(s, maxLen)
  s = tostring(s or "")
  maxLen = maxLen or 30
  if #s <= maxLen then return s end
  return s:sub(1, maxLen - 3) .. "..."
end

local function cPositiveInt(s)
  local n = tonumber(s)
  if not n then return nil end
  n = math.floor(n)
  if n <= 0 then return nil end
  return n
end

local function cDisplayTicker(co)
  if type(co) == "table" and co.ticker and tostring(co.ticker) ~= "" then
    return tostring(co.ticker)
  end
  if company.active_id then
    return tostring(company.active_id):gsub("^company:", ""):upper()
  end
  return ""
end

local function cIsOwner()
  return company.active and (company.active.owner_id == company.citizen_id or company.active.account_owner_id == company.citizen_id)
end

local function cBankReq(payload, timeout)
  return request(company.bank_server, BANK_PROTOCOL, payload, timeout or TIMEOUT)
end

local function cContractReq(payload, timeout)
  return request(company.contract_server, CONTRACT_PROTOCOL, payload, timeout or TIMEOUT)
end

local function cConnectBank()
  if company.bank_server then return true end

  local id, err = findServer(BANK_PROTOCOL, "QUID COMPANY TERMINAL", function(msg)
    return msg.type == "treasury_online" or (msg.success == true and type(msg.response) == "table")
  end)

  if id then company.bank_server = id; return true end
  cSet(err or "Bank connection failed.", QC.err)
  return false
end

local function cConnectContracts(silent)
  if company.contract_server then return true end
  if not openModem() then
    if not silent then cSet("No modem found.", QC.err) end
    return false
  end

  rednet.broadcast({ type = "ping" }, CONTRACT_PROTOCOL)
  local sender, msg = rednet.receive(CONTRACT_PROTOCOL, 2)

  if sender and type(msg) == "table" then
    if msg.type == "contract_server_online" or (msg.success == true and type(msg.response) == "table") then
      company.contract_server = sender
      if not silent then cSet("Contract server connected.", QC.ok) end
      return true
    end
  end

  if not silent then cSet("No contract server found.", QC.warn) end
  return false
end

local function cResult(title, lines, colour)
  cCls(); cTop(); cCard(2, 4, W - 2, H - 5)
  cAt(4, 5, title, colour or QC.card_fg, QC.card)
  local y = 7
  for _, line in ipairs(lines or {}) do
    if y > H - 3 then break end
    cAt(4, y, tostring(line), colour or QC.card_fg, QC.card)
    y = y + 1
  end
  local b = cBtn(4, H - 2, W - 6, "Continue", QC.btn_pri, QC.btn_fg)
  cStatus()
  while true do
    local ev, a, x, y2 = os.pullEvent()
    if ev == "mouse_click" and hit(b, x, y2) then return end
    if ev == "key" and (a == keys.enter or a == keys.escape or a == keys.backspace) then return end
  end
end

local function cConfirm(title, lines, yesLabel)
  cCls(); cTop(); cCard(2, 4, W - 2, H - 5)
  cAt(4, 5, title, QC.card_fg, QC.card)
  local y = 7
  for _, line in ipairs(lines or {}) do
    if y > H - 4 then break end
    cAt(4, y, tostring(line), QC.card_fg, QC.card)
    y = y + 1
  end
  local bw = math.floor((W - 8) / 2)
  local yes = cBtn(4, H - 2, bw, yesLabel or "Confirm", QC.btn_pri, QC.btn_fg)
  local no = cBtn(5 + bw, H - 2, bw, "Back", QC.btn_sec, QC.card_fg)
  cStatus()
  while true do
    local ev, a, x, y2 = os.pullEvent()
    if ev == "mouse_click" then
      if hit(yes, x, y2) then return true end
      if hit(no, x, y2) then return false end
    elseif ev == "key" then
      if a == keys.enter then return true end
      if a == keys.escape or a == keys.backspace then return false end
    end
  end
end

local function cLoadCompany(company_id)
  company_id = cNormalCompany(company_id)
  if company_id == "" then cSet("Enter ticker or company ID.", QC.err); return false end


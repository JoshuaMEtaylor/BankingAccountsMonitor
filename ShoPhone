local function cTabs()
  -- Pocket computers are too narrow for five full tabs on one line.
  -- Use short labels across two rows:
  --   Reg/Co/Cap
  --   Cont/Ops
  local labels = { company.active_id and "Diss" or "Reg", "Co", "Cap", "Cont", "Ops" }
  local modes  = { "register", "company", "capital", "contracts", "ops" }
  local buttons = {}

  cFill(1, 5, W, 2, QC.bg)

  local row1 = {1, 2, 3}
  local row2 = {4, 5}

  local function drawRow(row, y)
    local gap = 1
    local count = #row
    local available = W - 2 - ((count - 1) * gap)
    local tw = math.floor(available / count)
    local x = 2

    for _, i in ipairs(row) do
      local label = labels[i]
      local active = company.mode == modes[i]
      local bg = active and QC.tab_act or QC.tab_inact
      local fg = active and QC.tab_fg_a or QC.tab_fg_i
      local ww = math.min(tw, W - x + 1)

      cFill(x, y, ww, 1, bg)
      cAt(x + math.max(0, math.floor((ww - #label) / 2)), y, label, fg, bg)

      buttons[i] = { x1 = x, x2 = x + ww - 1, y1 = y, y2 = y, mode = modes[i] }
      x = x + ww + gap
    end
  end

  drawRow(row1, 5)
  drawRow(row2, 6)

  return buttons
end

local function cButtonRow(y, specs)
  local out = {}
  local n = #specs
  if n <= 0 then return out end

  local gap = 1
  local x0 = 4
  local total = W - 7
  local bw = math.floor((total - ((n - 1) * gap)) / n)
  if bw < 7 then bw = 7 end

  for i, spec in ipairs(specs) do
    local x = x0 + ((i - 1) * (bw + gap))
    local ww = bw
    if i == n then ww = math.max(7, W - x - 2) end
    out[spec.key] = cBtn(x, y, ww, spec.label, spec.bg, spec.fg)
  end
  return out
end

local function cRegister()
  if company.active_id then
    if not cIsOwner() then cSet("Only owner can dissolve this company.", QC.err); return end
    local payout = company.active and tonumber(company.active.cash_balance) or 0
    if not cConfirm("Dissolve company", {
      "Company: " .. tostring(company.active_id),
      "Owner:   " .. tostring(company.citizen_id),
      "Payout:  " .. cMoney(payout),
      "",
      "This deletes the company account after payout.",
    }, "Dissolve") then
      cSet("Dissolve cancelled.", QC.dim)
      return
    end

    local ok, res = cBankReq({
      type = "dissolve_company",
      username = company.username,
      password = company.password,
      company_id = company.active_id,
      memo = "Company dissolved by owner",
    })

    if ok and type(res) == "table" then
      local paid = tonumber(res.paid_out) or 0
      cResult("COMPANY DISSOLVED", {
        "Company: " .. tostring(res.company_id or company.active_id),
        "Owner:   " .. tostring(company.citizen_id),
        "Paid:    " .. cMoney(paid),
      }, QC.ok)
      company.active_id = nil
      company.active = nil
      company.edit_name = ""
      company.edit_ticker = ""
      company.mode = "register"
      cSet("Company dissolved.", QC.ok)
    else
      cSet("Dissolve failed: " .. tostring(res), QC.err)
    end
    return
  end

  local name = cTrim(company.reg_name)
  local ticker = cTicker(company.reg_ticker)
  local company_id = cCompanyId(ticker)

  if name == "" then cSet("Missing company name.", QC.err); return end
  if ticker == "" then cSet("Invalid ticker.", QC.err); return end

  if not cConfirm("Confirm company registration", {
    "Name:    " .. name,
    "Ticker:  " .. ticker,
    "Account: " .. company_id,
    "Owner:   " .. tostring(company.citizen_id),
  }, "Register") then
    cSet("Registration cancelled.", QC.dim)
    return
  end

  local ok, res = cBankReq({
    type = "register_company",
    name = name,
    ticker = ticker,
    biz_type = "general",
    owner_id = company.citizen_id,
    shares_total = 1000,
    shares_public = 0,
  })

  if ok and type(res) == "table" then
    company.active_id = tostring(res.company_id or company_id)
    cLoadCompany(company.active_id)
    company.reg_name = ""
    company.reg_ticker = ""
    company.mode = "company"
    cResult("COMPANY REGISTERED", {
      "Name:    " .. tostring(res.name or name),
      "Ticker:  " .. tostring(res.ticker or ticker),
      "Account: " .. tostring(company.active_id),
      "Owner:   " .. tostring(company.citizen_id),
    }, QC.ok)
  else
    cSet("Registration failed: " .. tostring(res), QC.err)
  end
end

local function cUpdateCompany()

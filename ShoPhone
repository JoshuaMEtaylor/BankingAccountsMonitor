    if focus == 1 then company.post_title = company.post_title:sub(1, -2) end
    if focus == 2 then company.post_reward = company.post_reward:sub(1, -2) end
  elseif company.mode == "ops" then
    if focus == 1 then company.ops_id = company.ops_id:sub(1, -2) end
    if focus == 2 then company.ops_note = company.ops_note:sub(1, -2) end
  end
end

local function cClearForm()
  if company.mode == "register" then
    company.reg_name, company.reg_ticker = "", ""
  elseif company.mode == "company" then
    company.edit_name = company.active and tostring(company.active.name or "") or ""
    company.edit_ticker = cDisplayTicker(company.active)
  elseif company.mode == "capital" then
    company.capital_amount = ""
    company.capital_memo = "Owner capital injection"
  elseif company.mode == "contracts" then
    company.post_title, company.post_reward = "", ""
  elseif company.mode == "ops" then
    company.ops_id, company.ops_note = "", ""
  end
end

local function companiesApp()
  if not company.logged then
    if not cLoginScreen() then return end
  end

  local focus = 1
  local tabs, fields, buttons = cDrawMain(focus)

  while true do
    local ev, a, x, y = os.pullEvent()

    if ev == "mouse_click" then
      for _, tab in ipairs(tabs) do
        if hit(tab, x, y) then
          company.mode = tab.mode
          focus = 1
          if tab.mode == "contracts" or tab.mode == "ops" then cConnectContracts(true) end
        end
      end

      for i, field in ipairs(fields or {}) do
        if hit(field, x, y) then focus = i end
      end

      if buttons.home and hit(buttons.home, x, y) then return end
      if buttons.clear and hit(buttons.clear, x, y) then cClearForm(); cSet("Form cleared.", QC.dim) end
      if buttons.company and hit(buttons.company, x, y) then company.mode = "company"; focus = 1 end
      if buttons.dissolve and hit(buttons.dissolve, x, y) then cRegister() end
      if buttons.primary and hit(buttons.primary, x, y) then cRegister() end
      if buttons.save and hit(buttons.save, x, y) then cUpdateCompany() end
      if buttons.payin and hit(buttons.payin, x, y) then cCapitalise(false) end
      if buttons.payout and hit(buttons.payout, x, y) then cCapitalise(true) end
      if buttons.post and hit(buttons.post, x, y) then cPostContract() end
      if buttons.list and hit(buttons.list, x, y) then cShowContracts() end
      if buttons.fulfil and hit(buttons.fulfil, x, y) then cFulfilOrCancel(false) end
      if buttons.cancel and hit(buttons.cancel, x, y) then cFulfilOrCancel(true) end

      tabs, fields, buttons = cDrawMain(focus)

    elseif ev == "char" then
      cAppend(focus, a)
      tabs, fields, buttons = cDrawMain(focus)

    elseif ev == "key" then
      if a == keys.backspace then
        cBackspace(focus)
      elseif a == keys.tab then
        focus = focus == 1 and 2 or 1
      elseif a == keys.escape then
        return
      end
      tabs, fields, buttons = cDrawMain(focus)
    end
  end
end


-- =============================================================================
-- PLACEHOLDER APPS
-- =============================================================================
local function placeholder(app)
  while true do
    appFrame(app.name)
    fill(3, 4, W - 4, H - 7, C.card)
    center(5, app.icon, C.card_fg, C.card)
    center(7, app.name, C.card_fg, C.card)
    center(10, "Coming soon", colors.gray, C.card)

    local bBack = button(4, H - 2, W - 6, "Back", C.btn)
    bottomBar()

    local ev, a, b, c = os.pullEvent()
    if ev == "mouse_click" and hit(bBack, b, c) then return end
    if ev == "key" and (a == keys.backspace or a == keys.escape or a == keys.q) then return end
  end
end

local function openApp(app)
  if app.id == "bank" then bankApp()
  elseif app.id == "contracts" then contractsApp()
  elseif app.id == "companies" then companiesApp()
  else placeholder(app) end
end

-- =============================================================================
-- MAIN
-- =============================================================================
boot()

while true do
  local boxes = drawHome()
  local ev, a, b, c = os.pullEvent()

  if ev == "mouse_click" then
    for _, box in ipairs(boxes) do
      if hit(box, b, c) then
        selected = box.index
        message = box.app.name
        drawHome()
        sleep(0.08)
        openApp(box.app)
        selected = nil
        message = "Ready"
        break
      end
    end

  elseif ev == "key" then
    if a == keys.q then
      clear(colors.black)
      center(math.floor(H / 2), "Power off", C.warn, colors.black)
      sleep(0.35)
      clear(colors.black)
      return

    elseif a == keys.left or a == keys.up then
      selected = (selected or 1) - 1
      if selected < 1 then selected = #apps end

    elseif a == keys.right or a == keys.down then
      selected = (selected or 0) + 1
      if selected > #apps then selected = 1 end

    elseif a == keys.enter and selected then
      openApp(apps[selected])
      selected = nil
      message = "Ready"
    end
  end
end

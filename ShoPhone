local function cCapitalise(isPayout)
  if not company.active_id then cSet("Load/select a company first.", QC.err); return end
  if not cIsOwner() then cSet("Only the owner can move company funds.", QC.err); return end

  local amount = cPositiveInt(company.capital_amount)
  if not amount then cSet("Enter a valid amount.", QC.err); return end

  local memo = cTrim(company.capital_memo)
  if memo == "" then memo = isPayout and "Owner company payout" or "Owner capital injection" end

  if isPayout then
    if not cConfirm("Confirm company payout", {
      "From: " .. tostring(company.active_id),
      "To:   " .. tostring(company.citizen_id),
      "Amt:  " .. cMoney(amount),
      "Memo: " .. memo,
    }, "Pay Out") then return end

    local ok, res = cBankReq({
      type = "company_withdraw",
      username = company.username,
      password = company.password,
      company_id = company.active_id,
      amount = amount,
      memo = memo,
    })

    if ok then
      company.capital_amount = ""
      company.capital_memo = "Owner capital injection"
      cLoadCompany(company.active_id)
      cSet("Paid out " .. cMoney(amount), QC.ok)
    else
      cSet("Payout failed: " .. tostring(res), QC.err)
    end
  else
    if not cConfirm("Confirm capital injection", {
      "From: " .. tostring(company.citizen_id),
      "To:   " .. tostring(company.active_id),
      "Amt:  " .. cMoney(amount),
      "Memo: " .. memo,
    }, "Transfer") then return end

    local ok, res = cBankReq({
      type = "transfer",
      username = company.username,
      password = company.password,
      to_id = company.active_id,
      amount = amount,
      memo = memo,
    })

    if ok then
      company.capital_amount = ""
      cLoadCompany(company.active_id)
      cSet("Transferred " .. cMoney(amount), QC.ok)
    else
      cSet("Transfer failed: " .. tostring(res), QC.err)
    end
  end
end

local function cPostContract()
  if not company.active_id then cSet("Load/select a company first.", QC.err); return end
  if not cIsOwner() then cSet("Only the owner can post contracts.", QC.err); return end
  if not cConnectContracts(false) then return end

  local title = cTrim(company.post_title)
  local reward = cPositiveInt(company.post_reward)
  if title == "" then cSet("Missing contract title.", QC.err); return end
  if not reward then cSet("Invalid reward.", QC.err); return end

  if not cConfirm("Post company contract", {
    "Company: " .. company.active_id,
    "Title:   " .. title,
    "Reward:  " .. cMoney(reward),
    "",
    "No escrow is locked yet.",
  }, "Post") then return end

  local ok, res = cContractReq({
    type = "post_contract",
    title = title,
    description = "",
    poster = company.active_id,
    source_account = company.active_id,
    source_company = company.active_id,
    source_type = "company_terminal",
    reward = reward,
    items = {{ item = "company:work_order", display = "Company work order", count = 1 }},
    escrow_status = "not_locked",
  }, 8)

  if ok and type(res) == "table" then
    local c = res.contract or {}
    company.post_title = ""
    company.post_reward = ""
    cResult("CONTRACT POSTED", {
      "ID:      " .. tostring(c.contract_id or "?"),
      "Company: " .. company.active_id,
      "Reward:  " .. cMoney(reward),
      "Status:  " .. tostring(c.status or "open"),
    }, QC.ok)
    cSet("Posted contract.", QC.ok)
  else
    cSet("Post failed: " .. tostring(res), QC.err)
  end
end

local function cShowContracts()
  if not company.active_id then cSet("Load/select a company first.", QC.err); return end
  if not cConnectContracts(false) then return end

  local ok, res = cContractReq({ type = "list_contracts", status = "all" }, 8)
  if not ok or type(res) ~= "table" then cSet("Contract list failed: " .. tostring(res), QC.err); return end

  local rows = {}
  for _, ct in ipairs(res.contracts or {}) do
    if ct.poster == company.active_id or ct.claimed_by == company.active_id or ct.source_company == company.active_id then
      rows[#rows + 1] = tostring(ct.contract_id or "?") .. " | " .. tostring(ct.status or "?") .. " | " .. cMoney(ct.reward or 0) .. " | " .. cShort(ct.title or "", 20)
      if #rows >= 14 then break end
    end
  end

  if #rows == 0 then rows = {"No contracts found for " .. company.active_id} end
  cResult("COMPANY CONTRACTS", rows, QC.card_fg)
end

local function cFulfilOrCancel(cancel)
  if not company.active_id then cSet("Load/select a company first.", QC.err); return end
  if not cConnectContracts(false) then return end

  local id = cTrim(company.ops_id)
  if id == "" then cSet("Enter contract ID.", QC.err); return end

  if cancel then
    if not cIsOwner() then cSet("Only owner can cancel contracts.", QC.err); return end
    if not cConfirm("Cancel contract", {"Contract: " .. id}, "Cancel") then return end
    local ok, res = cContractReq({ type = "cancel_contract", contract_id = id, reason = "Cancelled from ShoPhone by " .. tostring(company.citizen_id) }, 8)
    if ok then cSet("Cancelled: " .. id, QC.ok) else cSet("Cancel failed: " .. tostring(res), QC.err) end
  else
    if not cConfirm("Mark fulfilled", {"Contract: " .. id, "Note: " .. cTrim(company.ops_note)}, "Fulfil") then return end
    local ok, res = cContractReq({ type = "mark_fulfilled", contract_id = id, note = cTrim(company.ops_note) }, 8)
    if ok then cSet("Marked fulfilled: " .. id, QC.ok) else cSet("Fulfil failed: " .. tostring(res), QC.err) end
  end
end


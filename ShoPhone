      bank.balance = res.balance or bank.balance

      qAt(2, 5, "Reference", QB.dim, QB.bg)
      qAt(13, 5, "Type", QB.dim, QB.bg)
      qAt(22, 5, "Amount", QB.dim, QB.bg)
      qAt(33, 5, "Note", QB.dim, QB.bg)
      qAt(1, 6, string.rep("-", W), QB.sep, QB.bg)


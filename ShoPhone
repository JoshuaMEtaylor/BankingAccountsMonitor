local function qTabs(y, mode)
  qFill(1, y, W, 1, QB.bg)
  local tw = math.floor(W / 2)
  local b1 = qBtn(1, y, tw, "  Log In  ", mode == "login" and QB.tab_act or QB.tab_bg, mode == "login" and QB.tab_fg_a or QB.tab_fg_i)
  local b2 = qBtn(tw + 1, y, W - tw, "  Register  ", mode == "register" and QB.tab_act or QB.tab_bg, mode == "register" and QB.tab_fg_a or QB.tab_fg_i)
  return b1, b2
end

local function bankConnect()
  if bank.server then return true end

  local id, err = findServer(BANK_PROTOCOL, "QUID BANK OF PLENTY", function(msg)
    return (msg.success and type(msg.response) == "table") or msg.type == "treasury_online"
  end)

  if id then bank.server = id; return true end
  message = err or "Bank offline"
  return false
end

local function bankReq(payload)
  return request(bank.server, BANK_PROTOCOL, payload, TIMEOUT)
end

local function bankConnecting()
  if bank.server then return true end
  if not openModem() then
    qCls()
    qTopBar()
    qCentre(math.floor(H / 2), "No modem found.", QB.err, QB.bg)
    sleep(1.5)
    return false
  end

  qCls()
  qTopBar()
  qCentre(math.floor(H / 2) - 1, "Connecting to Quid Bank...", QB.dim, QB.bg)

  for attempt = 1, 8 do
    qFill(1, math.floor(H / 2) + 1, W, 1, QB.bg)
    qCentre(math.floor(H / 2) + 1, "Attempt " .. attempt .. " of 8", QB.dim, QB.bg)

    rednet.broadcast({ type = "ping" }, BANK_PROTOCOL)
    local sender, msg = rednet.receive(BANK_PROTOCOL, 4)

    if sender and type(msg) == "table" then
      if (msg.success and type(msg.response) == "table") or msg.type == "treasury_online" then
        bank.server = sender
        qCentre(math.floor(H / 2) + 1, "Connected.", QB.ok, QB.bg)
        sleep(0.4)
        return true
      end
    end
  end

  qCentre(math.floor(H / 2) + 1, "Connection failed.", QB.err, QB.bg)
  sleep(1.5)
  return false
end

local function bankLogin()
  if not bankConnecting() then return false end

  local mode = "login"
  local fields = { "", "" }
  local focus = 1
  local msg = ""
  local msgCol = QB.err

  local function draw()
    qCls()
    qTopBar()
    term.setCursorBlink(false)

    local tabLogin, tabReg = qTabs(3, mode)

    local cardY = 5
    local cardH = H - cardY - 1
    qCard(2, cardY, W - 2, cardH)

    qAt(4, cardY + 1, "Username", QB.label, QB.card)
    qInput(4, cardY + 2, W - 6, fields[1], false, focus == 1)

    qAt(4, cardY + 4, "Password", QB.label, QB.card)
    qInput(4, cardY + 5, W - 6, fields[2], true, focus == 2)

    local submitLabel = mode == "login" and "Log In" or "Create Account"
    local bSubmit = qBtn(4, cardY + 7, W - 6, submitLabel, QB.btn_pri)
    local bBack = qBtn(4, H - 1, W - 6, "Back to ShoPhone", QB.btn_sec, QB.card_fg)

    if msg ~= "" then
      qAt(4, cardY + 9, msg:sub(1, W - 6), msgCol, QB.card)
    end

    qStatus()

    local cy = focus == 1 and (cardY + 2) or (cardY + 5)
    local v = fields[focus] or ""
    term.setCursorPos(4 + math.min(#v, W - 7), cy)
    term.setCursorBlink(true)

    return tabLogin, tabReg, bSubmit, bBack, cardY
  end

  local tabLogin, tabReg, bSubmit, bBack, cardY = draw()

  local function submit()
    if fields[1] == "" or fields[2] == "" then
      msg, msgCol = "Please fill in all fields", QB.err
      return false
    end

    msg, msgCol = mode == "login" and "Authenticating..." or "Creating account...", QB.dim
    draw()

    local reqType = mode == "login" and "login" or "create_account"
    local ok, res = bankReq({
      type = reqType,
      username = fields[1],
      password = fields[2],
      display_name = fields[1],
    })

    if ok and type(res) == "table" then
      bank.logged = true
      bank.username = fields[1]
      bank.password = fields[2]
      bank.citizen_id = res.citizen_id or ""
      bank.display = res.display_name or fields[1]
      bank.title = res.title or "Account Holder"
      bank.balance = res.balance or 0
      return true
    end

    msg, msgCol = tostring(res or "Login failed"), QB.err
    return false
  end

  while true do
    local ev, a, b, c = os.pullEvent()

    if ev == "char" then
      if #fields[focus] < W - 7 then fields[focus] = fields[focus] .. a end
      tabLogin, tabReg, bSubmit, bBack, cardY = draw()

    elseif ev == "key" then
      if a == keys.backspace then
        fields[focus] = fields[focus]:sub(1, -2)
      elseif a == keys.tab then
        focus = focus == 1 and 2 or 1
      elseif a == keys.enter then
        if focus == 1 then focus = 2 else if submit() then return true end end
      elseif a == keys.escape then
        return false
      end
      tabLogin, tabReg, bSubmit, bBack, cardY = draw()

    elseif ev == "mouse_click" then
      if hit(bBack, b, c) then return false end
      if hit(tabLogin, b, c) then mode = "login"; msg = "" end
      if hit(tabReg, b, c) then mode = "register"; msg = "" end
      if c == cardY + 2 then focus = 1 end
      if c == cardY + 5 then focus = 2 end
      if hit(bSubmit, b, c) then if submit() then return true end end
      tabLogin, tabReg, bSubmit, bBack, cardY = draw()
    end
  end
end

local function bankRefresh()
  local ok, res = bankReq({ type = "balance", username = bank.username, password = bank.password })
  if ok and type(res) == "table" then
    bank.balance = res.balance or bank.balance
    return true
  end
  return false, res
end

local function bankTransfer()
  local fields = { "", "", "" }
  local focus = 1
  local msg = ""
  local msgCol = QB.err

  local function draw()
    qCls()
    qTopBar()
    term.setCursorBlink(false)

    qFill(1, 2, W, 2, QB.card)
    qAt(3, 2, "From", QB.label, QB.card)
    qAt(3, 3, bank.citizen_id or "", QB.card_fg, QB.card)
    local bal = money(bank.balance)
    qAt(W - #bal - 1, 2, "Balance", QB.label, QB.card)
    qAt(W - #bal - 1, 3, bal, QB.money, QB.card)

    qSep(4)
    qCard(2, 5, W - 2, H - 6)

    qAt(4, 6, "Recipient", QB.label, QB.card)
    qInput(4, 7, W - 6, fields[1], false, focus == 1)

    qAt(4, 9, "Amount (Quid)", QB.label, QB.card)
    qInput(4, 10, W - 6, fields[2], false, focus == 2)

    qAt(4, 12, "Memo (optional)", QB.label, QB.card)
    qInput(4, 13, W - 6, fields[3], false, focus == 3)

    local bw = math.floor((W - 6) / 2)
    local bSend = qBtn(4, 15, bw, "Send Transfer", QB.btn_pri)
    local bBack = qBtn(bw + 5, 15, bw, "Cancel", QB.btn_sec, QB.card_fg)

    if msg ~= "" then qAt(4, 17, msg:sub(1, W - 6), msgCol, QB.card) end

    qStatus()

    local cy = focus == 1 and 7 or (focus == 2 and 10 or 13)
    local v = fields[focus] or ""
    term.setCursorPos(4 + math.min(#v, W - 7), cy)
    term.setCursorBlink(true)

    return bSend, bBack
  end

  local bSend, bBack = draw()

  local function submit()
    local amount = tonumber(fields[2])
    if fields[1] == "" then msg, msgCol = "Enter a recipient", QB.err; return false end
    if not amount or amount <= 0 then msg, msgCol = "Enter a valid amount", QB.err; return false end

    msg, msgCol = "Processing...", QB.dim
    draw()

    local ok, res = bankReq({
      type = "transfer",
      username = bank.username,
      password = bank.password,
      to_id = fields[1],
      amount = amount,
      memo = fields[3],
    })

    if ok and type(res) == "table" then
      bankRefresh()
      qCls()
      qTopBar()
      qCard(3, 4, W - 4, 9)
      qCentre(5, "Transfer Complete", QB.ok, QB.card)
      qAt(5, 7, "To:     ", QB.label, QB.card)
      qAt(14, 7, fields[1], QB.card_fg, QB.card)
      qAt(5, 8, "Amount: ", QB.label, QB.card)
      qAt(14, 8, money(amount), QB.money, QB.card)
      qAt(5, 9, "Ref:    ", QB.label, QB.card)
      qAt(14, 9, tostring(res.tx_id or ""), QB.label, QB.card)
      qAt(5, 11, "Balance:", QB.label, QB.card)
      qAt(14, 11, money(bank.balance), QB.money, QB.card)
      qBtn(math.floor(W / 2) - 5, 14, 12, "Back to Home", QB.btn_pri)
      qStatus()
      os.pullEvent("mouse_click")
      return true
    end

    msg, msgCol = tostring(res or "Transfer failed"), QB.err
    return false
  end

  while true do
    local ev, a, b, c = os.pullEvent()

    if ev == "char" then
      if #fields[focus] < W - 7 then fields[focus] = fields[focus] .. a end
    elseif ev == "key" then
      if a == keys.backspace then
        fields[focus] = fields[focus]:sub(1, -2)
      elseif a == keys.tab then
        focus = focus % 3 + 1
      elseif a == keys.enter then
        if focus < 3 then focus = focus + 1 else submit() end
      elseif a == keys.escape then
        return
      end
    elseif ev == "mouse_click" then
      if hit(bBack, b, c) then return end
      if hit(bSend, b, c) then submit() end
      if c == 7 then focus = 1 elseif c == 10 then focus = 2 elseif c == 13 then focus = 3 end
    end

    bSend, bBack = draw()
  end
end

local function bankHistory()
  qCls()
  qTopBar()
  qCentre(math.floor(H / 2), "Loading transactions...", QB.dim, QB.bg)


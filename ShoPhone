    qAt(W - #bal - 1, 2, bal, QB.money, QB.card)
    qAt(3, 3, bank.citizen_id or "", QB.label, QB.card)

    qSep(4)

    if not ok or type(res) ~= "table" then
      qCentre(8, "Could not load transactions.", QB.err, QB.bg)
    else

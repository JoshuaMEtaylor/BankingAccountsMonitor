          qAt(2, row, tostring(tx.tx_id or ""):sub(1, 10), QB.dim, bg)
          qAt(13, row, tostring(tx.type or ""):sub(1, 8), QB.dim, bg)
          qAt(22, row, dir .. tostring(tx.amount or 0) .. "q", col, bg)
          qAt(33, row, tostring(tx.memo or ""):sub(1, W - 33), QB.dim, bg)

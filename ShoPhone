local function cRefreshOwned(silent)
  if not company.logged then return false end

  local ok, res = cBankReq({
    type = "list_my_companies",
    username = company.username,
    password = company.password,
  })

  if ok and type(res) == "table" and type(res.companies) == "table" then
    if not company.active_id and #res.companies > 0 then
      local co = res.companies[1]
      company.active_id = tostring(co.company_id or "")
      company.active = co
      company.edit_name = tostring(co.name or "")
      company.edit_ticker = cDisplayTicker(co)
    end
    if not silent then cSet("Owned companies: " .. tostring(res.count or #res.companies), QC.ok) end
    return true
  end

  if not silent then cSet("Owned company scan failed: " .. tostring(res), QC.warn) end
  return false
end

local function cLoginScreen()
  if not cConnectBank() then return false end

  local focus = 1
  local boxes = {}
  local bLogin, bBack

  local function draw()
    cCls(); cTop(); cCard(2, 4, W - 2, H - 5)
    cAt(4, 5, "Log in with your normal bank account.", QC.label, QC.card)
    cAt(4, 6, "This unlocks company controls.", QC.label, QC.card)

    cAt(4, 8, "Username", QC.card_fg, QC.card)
    boxes[1] = cInput(4, 9, W - 6, company.login_user, false, focus == 1)

    cAt(4, 11, "Password", QC.card_fg, QC.card)
    boxes[2] = cInput(4, 12, W - 6, company.login_pass, true, focus == 2)

    bLogin = cBtn(4, 15, W - 6, "Log In", QC.btn_pri, QC.btn_fg)
    bBack = cBtn(4, H - 2, W - 6, "Back to ShoPhone", QC.btn_sec, QC.card_fg)
    cStatus()
  end

  local function doLogin()
    if cTrim(company.login_user) == "" or cTrim(company.login_pass) == "" then
      cSet("Enter username and password.", QC.err)
      return false
    end

    cSet("Authenticating...", QC.dim)
    draw()

    local ok, res = cBankReq({ type = "login", username = company.login_user, password = company.login_pass })
    if ok and type(res) == "table" then
      company.logged = true
      company.username = company.login_user
      company.password = company.login_pass
      company.citizen_id = res.citizen_id or ""
      company.title = res.title or "Account Holder"
      company.login_pass = ""

      cSet("Logged in as " .. tostring(company.citizen_id), QC.ok)
      cRefreshOwned(true)
      cConnectContracts(true)
      return true
    end

    cSet(tostring(res or "Login failed"), QC.err)
    return false
  end

  draw()

  while true do
    local ev, a, x, y = os.pullEvent()
    if ev == "char" then
      if focus == 1 and #company.login_user < 32 then company.login_user = company.login_user .. a end
      if focus == 2 and #company.login_pass < 32 then company.login_pass = company.login_pass .. a end
      draw()
    elseif ev == "key" then
      if a == keys.backspace then
        if focus == 1 then company.login_user = company.login_user:sub(1, -2) end
        if focus == 2 then company.login_pass = company.login_pass:sub(1, -2) end
      elseif a == keys.tab then
        focus = focus == 1 and 2 or 1
      elseif a == keys.enter then
        if focus == 1 then focus = 2 else if doLogin() then return true end end
      elseif a == keys.escape then
        return false
      end
      draw()
    elseif ev == "mouse_click" then
      if hit(bBack, x, y) then return false end
      if hit(bLogin, x, y) then if doLogin() then return true end end
      for i, box in ipairs(boxes) do if hit(box, x, y) then focus = i end end
      draw()
    end
  end
end


-- =============================================================================
-- FOREX CLIENT
-- forexclient
-- v0.6.3-EURUSD-5M-PROPER-CANDLES-UPDATER
--
-- Purpose:
--   Trading-terminal style client for the Oracle/Kraken EUR/USD forexserver.
--
-- This build:
--   - safe self updater using startup.new/startup.old
--   - requests server-side candle history at boot so the chart does not start
--     from a single fresh candle
--   - renders proper joined candlesticks
--   - neutral/no-change candles draw flat instead of fake red/green bodies
--   - keeps updating the active candle from live server ticks
-- =============================================================================

local args = {...}

-- =============================================================================
-- SAFE SELF UPDATE
-- =============================================================================
-- Normal run:
--   startup
--   startup <server_id>
--
-- Manual test / bypass updater:
--   startup --updated
--   startup --updated <server_id>
--
-- Downloads to startup.new first. Only replaces startup.lua after the new file
-- exists and is non-empty, so a failed download cannot delete the running script.
if args[1] ~= "--updated" then
  print("[ Forex Client ]")
  print("Checking GitHub update...")

  local tmp = "startup.new"
  local old = "startup.old"
  fs.delete(tmp)

  local cb = tostring(os.epoch and os.epoch("utc") or math.floor(os.clock() * 100000))
  local url = "https://raw.githubusercontent.com/JoshuaMEtaylor/BankingAccountsMonitor/refs/heads/main/forexclient?cb=" .. cb
  shell.run("wget " .. url .. " " .. tmp)

  local okDownload = false
  if fs.exists(tmp) then
    local f = fs.open(tmp, "r")
    local body = f and f.readAll() or ""
    if f then f.close() end
    okDownload = body and #body > 50
  end

  if not okDownload then
    fs.delete(tmp)
    print("Update failed or empty. Keeping existing startup.lua.")
    print("Run startup --updated to bypass updater for manual testing.")
    return
  end

  fs.delete(old)
  if fs.exists("startup.lua") then fs.move("startup.lua", old) end
  fs.move(tmp, "startup.lua")

  print("Updated. Relaunching...")
  sleep(0.5)

  local relaunch = { "startup.lua", "--updated" }
  for i = 1, #args do relaunch[#relaunch + 1] = tostring(args[i]) end
  local unpackFn = table.unpack or unpack
  shell.run(unpackFn(relaunch))
  return
end

local VERSION = "0.6.3-EURUSD-5M-PROPER-CANDLES-UPDATER"
local FX_PROTOCOL = "quid_fx"
local server_id = tonumber(args[2])

local SAMPLE_SECONDS = 0.10
local DRAW_SECONDS = 0.25
local SAVE_SECONDS = 30
local RESPONSE_TIMEOUT_MS = 2000

local TIMEFRAME = "5m"
local CANDLE_SECONDS = 300
local MAX_CANDLES = 576
local TEXT_SCALE = 0.5

-- Chart scaling.
-- A full 0.90000-1.90000 axis is too wide for a ComputerCraft candle chart;
-- normal EUR/USD movement becomes invisible. Instead we use a proper trading
-- terminal style window: centre around visible price action, enforce a minimum
-- range so every tiny move does not become an ATH/ATL, and keep 0.9/1.9 as hard
-- safety rails.
local HARD_MIN_PRICE = 0.90000
local HARD_MAX_PRICE = 1.90000
local MIN_VISIBLE_RANGE = 0.01000 -- 100 pips total; enough to avoid fake ATH scaling.
local PRICE_EPS = 0.000005       -- half a pip at 5dp; treated as neutral/doji.

local CANDLES_FILE = "data/forex_client_eurusd_5m_candles.db"
local STATE_FILE = "data/forex_client_state.db"

local native = term.current()
local monitor = nil
local modem_name = nil
local W, H = term.getSize()

local candles = {}
local state = {
  created_version = VERSION,
  timeframe = TIMEFRAME,
}

local last_tick = nil
local previous_price = nil
local last_error = "Booting..."
local last_server_seen_ms = 0
local last_tick_ms = 0
local last_request_ms = 0
local last_response_ms = 0
local last_history_ms = 0
local last_history_count = 0
local pending_request = false
local pending_since_ms = 0
local request_count = 0
local response_count = 0
local sample_count = 0
local change_count = 0
local timeout_count = 0
local discover_count = 0

local sample_timer = nil
local draw_timer = nil
local save_timer = nil
local discover_timer = nil

local function nowMs()
  if os.epoch then return os.epoch("utc") end
  return math.floor(os.time() * 1000)
end

local function ensureDir(path)
  local dir = fs.getDir(path)
  if dir and dir ~= "" and not fs.exists(dir) then fs.makeDir(dir) end
end

local function readTable(path)
  if not fs.exists(path) then return nil end
  local f = fs.open(path, "r")
  if not f then return nil end
  local text = f.readAll()
  f.close()
  if not text or text == "" then return nil end
  local ok, data = pcall(textutils.unserialize, text)
  if ok and type(data) == "table" then return data end
  return nil
end

local function writeTable(path, data)
  ensureDir(path)
  local f = fs.open(path, "w")
  if not f then return false end
  f.write(textutils.serialize(data))
  f.close()
  return true
end

local function loadState()
  local s = readTable(STATE_FILE)
  if type(s) == "table" then state = s end
  state.created_version = state.created_version or VERSION
  state.timeframe = TIMEFRAME

  local c = readTable(CANDLES_FILE)
  if type(c) == "table" then candles = c end
  while #candles > MAX_CANDLES do table.remove(candles, 1) end
end

local function saveState()
  state.saved_at = nowMs()
  state.server_id = server_id
  writeTable(STATE_FILE, state)
  writeTable(CANDLES_FILE, candles)
end

local function fmt(n, dp)
  n = tonumber(n)
  if n == nil then return "n/a" end
  return string.format("%." .. tostring(dp or 5) .. "f", n)
end

local function clampText(s, n)
  s = tostring(s or "")
  n = tonumber(n) or 80
  s = s:gsub("\n", " "):gsub("\r", " ")
  if #s > n then return s:sub(1, n - 3) .. "..." end
  return s
end

local function ageText(ms)
  if not ms or ms <= 0 then return "n/a" end
  local age = nowMs() - ms
  if age < 1000 then return tostring(age) .. "ms" end
  if age < 60000 then return string.format("%.1fs", age / 1000) end
  return string.format("%.1fm", age / 60000)
end

local function colourForQuality(q)
  if q == "LIVE" then return colors.lime end
  if q == "STALE" then return colors.orange end
  if q == "OFFLINE" then return colors.red end
  return colors.yellow
end

local function cls()
  term.setCursorBlink(false)
  term.setBackgroundColor(colors.black)
  term.setTextColor(colors.white)
  term.clear()
  term.setCursorPos(1, 1)
end

local function at(x, y, text, fg, bg)
  W, H = term.getSize()
  if y < 1 or y > H or x > W then return end
  if x < 1 then x = 1 end
  term.setCursorPos(x, y)
  term.setTextColor(fg or colors.white)
  term.setBackgroundColor(bg or colors.black)
  local maxw = W - x + 1
  if maxw > 0 then term.write(tostring(text or ""):sub(1, maxw)) end
end

local function fill(x, y, w, h, bg)
  W, H = term.getSize()
  if w <= 0 or h <= 0 then return end
  term.setBackgroundColor(bg or colors.black)
  local row = string.rep(" ", w)
  for yy = y, y + h - 1 do
    if yy >= 1 and yy <= H then
      term.setCursorPos(math.max(1, x), yy)
      term.write(row:sub(1, math.max(0, W - x + 1)))
    end
  end
end

local function putChar(x, y, ch, fg, bg)
  W, H = term.getSize()
  if x < 1 or x > W or y < 1 or y > H then return end
  term.setCursorPos(x, y)
  term.setTextColor(fg or colors.white)
  term.setBackgroundColor(bg or colors.black)
  term.write(ch or " ")
end

local function putBlock(x, y, bg)
  putChar(x, y, " ", colors.white, bg or colors.black)
end

local function setupDisplay()
  monitor = peripheral.find and peripheral.find("monitor") or nil
  if monitor then
    pcall(function() monitor.setTextScale(TEXT_SCALE) end)
    term.redirect(monitor)
  end
  cls()
end

local function openModem()
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      local m = peripheral.wrap(name)
      if m and m.isWireless and m.isWireless() then
        rednet.open(name)
        modem_name = name
        return true
      end
    end
  end
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      rednet.open(name)
      modem_name = name
      return true
    end
  end
  return false
end

local function trimCandles()
  while #candles > MAX_CANDLES do table.remove(candles, 1) end
end

local function broadcastPing()
  discover_count = discover_count + 1
  rednet.broadcast({ type = "ping", client = "forexclient", version = VERSION }, FX_PROTOCOL)
end

local function sendTickRequest()
  if not server_id then
    last_error = "Searching for forexserver..."
    return
  end

  if pending_request then
    if nowMs() - pending_since_ms > RESPONSE_TIMEOUT_MS then
      pending_request = false
      timeout_count = timeout_count + 1
      last_error = "Server response timeout"
    else
      return
    end
  end

  request_count = request_count + 1
  pending_request = true
  pending_since_ms = nowMs()
  last_request_ms = pending_since_ms

  rednet.send(server_id, {
    type = "get_usd_tick",
    client = "forexclient",
    version = VERSION,
    request_id = request_count,
  }, FX_PROTOCOL)
end

local function requestHistory()
  if not server_id then return end
  rednet.send(server_id, {
    type = "get_usd_history",
    timeframe = TIMEFRAME,
    client = "forexclient",
    version = VERSION,
  }, FX_PROTOCOL)
end

local function updateCandle(price, tickTime)
  price = tonumber(price)
  if not price or price <= 0 then return end

  local ms = tonumber(tickTime) or nowMs()
  local bucket = math.floor(ms / (CANDLE_SECONDS * 1000)) * (CANDLE_SECONDS * 1000)
  local c = candles[#candles]

  if not c or c.bucket ~= bucket then
    -- Trading-terminal behaviour: new candle opens at previous candle close.
    local openPrice = price
    if c and tonumber(c.close) then openPrice = tonumber(c.close) end
    c = {
      bucket = bucket,
      open = openPrice,
      high = math.max(openPrice, price),
      low = math.min(openPrice, price),
      close = price,
      samples = 1,
      updated = ms,
    }
    candles[#candles + 1] = c
  else
    if price > c.high then c.high = price end
    if price < c.low then c.low = price end
    c.close = price
    c.samples = (c.samples or 0) + 1
    c.updated = ms
  end

  trimCandles()
end

local function absorbTick(tick)
  if type(tick) ~= "table" then return end
  local price = tonumber(tick.pair_price or tick.price or tick.eurusd or tick.latest)
  if not price or price <= 0 then return end

  sample_count = sample_count + 1
  local moved = false
  if previous_price and price ~= previous_price then
    change_count = change_count + 1
    moved = true
  end
  previous_price = price

  last_tick = tick
  last_tick._client_price = price
  last_tick._client_moved = moved
  last_tick_ms = nowMs()
  last_server_seen_ms = nowMs()

  updateCandle(price, tick.time or nowMs())
  last_error = "OK"
end

local function replaceCandlesFromServer(list)
  if type(list) ~= "table" then return end
  candles = {}
  local prevClose = nil
  for i = 1, #list do
    local c = list[i]
    if type(c) == "table" then
      local open = tonumber(c.open)
      local high = tonumber(c.high)
      local low = tonumber(c.low)
      local close = tonumber(c.close)
      if close then
        if prevClose then open = prevClose end
        open = open or close
        high = math.max(high or open, open, close)
        low = math.min(low or open, open, close)
        candles[#candles + 1] = {
          bucket = tonumber(c.bucket),
          open = open,
          high = high,
          low = low,
          close = close,
          samples = tonumber(c.samples) or 0,
          updated = tonumber(c.updated) or tonumber(c.bucket) or 0,
        }
        prevClose = close
      end
    end
  end
  trimCandles()
  last_history_ms = nowMs()
  last_history_count = #candles
end

local function handleServerMessage(sender, msg)
  if type(msg) ~= "table" then return end

  if msg.type == "forex_server_online" then
    server_id = sender
    state.server_id = sender
    last_server_seen_ms = nowMs()
    last_error = "Found forexserver " .. tostring(sender)
    requestHistory()
    return
  end

  if msg.success ~= nil then
    if not server_id then server_id = sender end
    if sender ~= server_id then return end

    pending_request = false
    last_response_ms = nowMs() - last_request_ms
    response_count = response_count + 1
    last_server_seen_ms = nowMs()

    if msg.success == true and type(msg.response) == "table" then
      if type(msg.response.candles) == "table" then
        replaceCandlesFromServer(msg.response.candles)
        if type(msg.response.latest) == "table" then absorbTick(msg.response.latest) end
        last_error = "Loaded " .. tostring(#candles) .. " candles from server"
      else
        absorbTick(msg.response)
      end
    else
      last_error = tostring(msg.error or msg.response or "Server returned failure")
    end
  end
end

local function visibleCandles(maxCandles)
  local out = {}
  local start = math.max(1, #candles - maxCandles + 1)
  for i = start, #candles do out[#out + 1] = candles[i] end
  return out
end

local function drawTradingCandles(x, y, w, h)
  fill(x, y, w, h, colors.black)

  local axisW = 10
  local chartW = w - axisW - 1
  if chartW < 12 or h < 8 then
    at(x, y, "Window too small for chart", colors.orange)
    return
  end

  local candleWidth = chartW >= 70 and 3 or 2
  local gap = 1
  local span = candleWidth + gap
  local maxCandles = math.max(1, math.floor(chartW / span))
  local list = visibleCandles(maxCandles)

  if #list == 0 then
    at(x + 2, y + math.floor(h / 2), "Awaiting server candle history...", colors.gray)
    return
  end

  -- Build a visual copy where each candle opens from the previous candle close.
  -- This also fixes older server history if it had disconnected candle opens.
  local visual = {}
  local lo, hi = nil, nil
  for i, c in ipairs(list) do
    local rawOpen = tonumber(c.open)
    local close = tonumber(c.close)
    local high = tonumber(c.high)
    local low = tonumber(c.low)

    if rawOpen and close and high and low then
      local open = rawOpen
      if i > 1 and visual[i - 1] and visual[i - 1].close then
        open = visual[i - 1].close
      end

      high = math.max(high, open, close)
      low = math.min(low, open, close)

      visual[#visual + 1] = {
        bucket = c.bucket,
        open = open,
        high = high,
        low = low,
        close = close,
        samples = c.samples,
      }

      lo = lo and math.min(lo, low) or low
      hi = hi and math.max(hi, high) or high
    end
  end

  if #visual == 0 or not lo or not hi then return end

  -- Proper terminal scaling: centre around visible action but keep a minimum
  -- range. This avoids the old "every candle is the ATH" autoscale problem
  -- without flattening the whole market into the bottom of a 0.9-1.9 chart.
  local range = hi - lo
  local mid = (hi + lo) / 2
  local targetRange = math.max(range * 1.35, MIN_VISIBLE_RANGE)
  local chartLo = mid - (targetRange / 2)
  local chartHi = mid + (targetRange / 2)

  if chartLo < HARD_MIN_PRICE then
    chartHi = chartHi + (HARD_MIN_PRICE - chartLo)
    chartLo = HARD_MIN_PRICE
  end
  if chartHi > HARD_MAX_PRICE then
    chartLo = chartLo - (chartHi - HARD_MAX_PRICE)
    chartHi = HARD_MAX_PRICE
  end
  if chartLo < HARD_MIN_PRICE then chartLo = HARD_MIN_PRICE end
  if chartHi <= chartLo then chartHi = chartLo + MIN_VISIBLE_RANGE end

  local function py(price)
    local p = tonumber(price) or chartLo
    local t = (p - chartLo) / (chartHi - chartLo)
    if t < 0 then t = 0 end
    if t > 1 then t = 1 end
    return y + h - 1 - math.floor(t * (h - 1) + 0.5)
  end

  local topY = y
  local midY = y + math.floor((h - 1) / 2)
  local botY = y + h - 1

  for xx = x, x + chartW - 1 do
    putChar(xx, topY, ".", colors.gray, colors.black)
    putChar(xx, midY, ".", colors.gray, colors.black)
    putChar(xx, botY, ".", colors.gray, colors.black)
  end

  at(x + chartW + 1, topY, fmt(chartHi, 5), colors.lightGray)
  at(x + chartW + 1, midY, fmt((chartHi + chartLo) / 2, 5), colors.lightGray)
  at(x + chartW + 1, botY, fmt(chartLo, 5), colors.lightGray)

  local startX = x + chartW - (#visual * span) + 1
  for i, c in ipairs(visual) do
    local baseX = startX + (i - 1) * span
    local wickX = baseX + math.floor(candleWidth / 2)

    local open = tonumber(c.open)
    local high = tonumber(c.high)
    local low = tonumber(c.low)
    local close = tonumber(c.close)

    if open and high and low and close then
      local delta = close - open
      local neutral = math.abs(delta) <= PRICE_EPS
      local up = delta > PRICE_EPS
      local bodyCol = neutral and colors.lightGray or (up and colors.green or colors.red)
      local wickCol = neutral and colors.gray or colors.lightGray

      local yh = py(high)
      local yl = py(low)
      local yo = py(open)
      local yc = py(close)
      local bodyTop = math.min(yo, yc)
      local bodyBot = math.max(yo, yc)

      -- Wick. If high/low map to one row, this becomes a tiny tick.
      for yy = yh, yl do
        putChar(wickX, yy, "|", wickCol, colors.black)
      end

      if neutral then
        -- Flat/doji candle: no fake red/green body.
        local yy = py(close)
        for xx = baseX, baseX + candleWidth - 1 do
          putChar(xx, yy, "-", bodyCol, colors.black)
        end
      elseif bodyTop == bodyBot then
        -- Movement exists but is smaller than one terminal row at this zoom.
        -- Draw a one-row body, not a fake oversized block.
        for xx = baseX, baseX + candleWidth - 1 do
          putBlock(xx, bodyTop, bodyCol)
        end
      else
        for xx = baseX, baseX + candleWidth - 1 do
          for yy = bodyTop, bodyBot do
            putBlock(xx, yy, bodyCol)
          end
        end
      end
    end
  end
end

local function draw()
  W, H = term.getSize()
  cls()

  fill(1, 1, W, 1, colors.blue)
  at(2, 1, "EUR/USD TERMINAL  |  " .. TIMEFRAME .. " candles", colors.white, colors.blue)
  at(math.max(1, W - #VERSION), 1, VERSION, colors.lightGray, colors.blue)

  local price = last_tick and tonumber(last_tick._client_price or last_tick.pair_price)
  local q = last_tick and tostring(last_tick.quality or "unknown") or "OFFLINE"
  local priceCol = colors.white
  if last_tick and last_tick._client_moved then priceCol = colors.lime end

  at(2, 3, "Live EUR/USD", colors.yellow)
  at(2, 4, fmt(price, 5), priceCol)
  at(18, 3, "Quality", colors.lightGray)
  at(18, 4, q, colourForQuality(q))
  at(30, 3, "Server", colors.lightGray)
  at(30, 4, tostring(server_id or "searching"), server_id and colors.lime or colors.orange)
  at(42, 3, "Last tick", colors.lightGray)
  at(42, 4, ageText(last_tick_ms) .. " ago", colors.white)

  at(2, 6, "Source: Oracle relay -> Kraken EUR/USD -> CC forexserver", colors.gray)
  at(2, 7, "Scale: centred min-range " .. fmt(MIN_VISIBLE_RANGE, 5) .. " within hard rails " .. fmt(HARD_MIN_PRICE, 1) .. "-" .. fmt(HARD_MAX_PRICE, 1) .. " | poll " .. tostring(SAMPLE_SECONDS) .. "s | response " .. tostring(last_response_ms or 0) .. "ms | candles " .. tostring(last_history_count), colors.gray)

  local chartTop = 9
  local chartH = math.max(10, H - chartTop - 5)
  drawTradingCandles(2, chartTop, W - 3, chartH)

  local c = candles[#candles]
  if c then
    local up = (tonumber(c.close) or 0) >= (tonumber(c.open) or 0)
    local col = up and colors.green or colors.red
    at(2, H - 4, "Current " .. TIMEFRAME .. " candle", colors.yellow)
    at(2, H - 3, "O:" .. fmt(c.open, 5) .. "  H:" .. fmt(c.high, 5) .. "  L:" .. fmt(c.low, 5) .. "  C:" .. fmt(c.close, 5), col)
  end

  at(2, H - 2, "Samples " .. tostring(sample_count) .. " | Changes " .. tostring(change_count) .. " | Timeouts " .. tostring(timeout_count) .. " | History age " .. ageText(last_history_ms), colors.lightGray)
  at(2, H - 1, "Status: " .. clampText(last_error, math.max(10, W - 10)), last_error == "OK" and colors.lime or colors.orange)
end

local function main()
  if os.getComputerLabel() ~= "ForexClient" then pcall(os.setComputerLabel, "ForexClient") end

  setupDisplay()
  loadState()

  if not openModem() then
    last_error = "No modem found"
    draw()
    return
  end

  if state.server_id and not server_id then server_id = tonumber(state.server_id) end
  if server_id then requestHistory() else broadcastPing() end

  sample_timer = os.startTimer(SAMPLE_SECONDS)
  draw_timer = os.startTimer(DRAW_SECONDS)
  save_timer = os.startTimer(SAVE_SECONDS)
  discover_timer = os.startTimer(3)

  draw()

  while true do
    local ev = { os.pullEvent() }

    if ev[1] == "timer" then
      local id = ev[2]
      if id == sample_timer then
        sendTickRequest()
        sample_timer = os.startTimer(SAMPLE_SECONDS)
      elseif id == draw_timer then
        draw()
        draw_timer = os.startTimer(DRAW_SECONDS)
      elseif id == save_timer then
        saveState()
        save_timer = os.startTimer(SAVE_SECONDS)
      elseif id == discover_timer then
        if not server_id then
          broadcastPing()
        end
        discover_timer = os.startTimer(3)
      end

    elseif ev[1] == "rednet_message" then
      local sender, msg, protocol = ev[2], ev[3], ev[4]
      if protocol == FX_PROTOCOL or protocol == nil then
        handleServerMessage(sender, msg)
      end

    elseif ev[1] == "term_resize" or ev[1] == "monitor_resize" then
      draw()
    end
  end
end

local ok, err = pcall(main)
if not ok then
  term.redirect(native)
  term.setTextColor(colors.red)
  print("Forex client error: " .. tostring(err))
end

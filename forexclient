local function openModem()
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      local m = peripheral.wrap(name)
      if m and m.isWireless and m.isWireless() then
        rednet.open(name)
        modem_name = name
        return true
      end
    end
  end

  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      rednet.open(name)
      modem_name = name
      return true
    end
  end

  return false
end

local function discoverBank()
  if bank_id then return true end

  for attempt = 1, 6 do
    rednet.broadcast({ type = "ping", client = "forexclient", version = VERSION }, BANK_PROTOCOL)
    local sender, msg = rednet.receive(BANK_PROTOCOL, 3)
    if sender and type(msg) == "table" then
      -- The bank server replies success/response to ping.
      if msg.success ~= nil or msg.type == "treasury_online" then
        bank_id = sender
        state.bank_id = sender
        return true
      end
    end
  end

  return false
end

local function bankRequest(req)
  if not bank_id then return false, "Bank server not connected" end
  rednet.send(bank_id, req, BANK_PROTOCOL)
  local sender, msg = rednet.receive(BANK_PROTOCOL, BANK_TIMEOUT)
  if sender ~= bank_id or type(msg) ~= "table" then
    return false, "No response from bank"
  end
  return msg.success == true, msg.response or msg.error
end

local function refreshBankBalance()
  if not bank_session.logged_in then return false, "Not logged in" end
  local ok, res = bankRequest({
    type = "balance",
    username = bank_session.username,
    password = bank_session._password,
  })

  if ok and type(res) == "table" then
    bank_session.balance = tonumber(res.balance) or bank_session.balance or 0
    return true, res
  end

  return false, res
end

local function drawLoginFrame(msg, col)
  W, H = term.getSize()
  cls()
  fill(1, 1, W, 1, colors.blue)
  at(2, 1, "EUR/USD METATRADER LITE - BANK LOGIN", colors.white, colors.blue)
  at(math.max(1, W - #VERSION), 1, VERSION, colors.lightGray, colors.blue)

  at(3, 3, "This terminal must be linked to a Quid Bank account before trading.", colors.lightGray)
  at(3, 5, "Bank server: " .. tostring(bank_id or "searching"), bank_id and colors.lime or colors.orange)
  if msg and msg ~= "" then at(3, 7, msg, col or colors.orange) end
end

local function loginToBank()
  while true do
    drawLoginFrame("Connecting to Quid Bank...", colors.orange)

    if not discoverBank() then
      drawLoginFrame("Could not find Quid Bank. Check bank server/modems.", colors.red)
      sleep(3)
    else
      drawLoginFrame("Enter bank username and password.", colors.lime)

      at(3, 9, "Username:", colors.yellow)
      at(3, 10, "> ", colors.white)
      term.setCursorBlink(true)
      local username = read()

      at(3, 12, "Password:", colors.yellow)
      at(3, 13, "> ", colors.white)
      local password = read("*")
      term.setCursorBlink(false)

      if tostring(username or "") ~= "" and tostring(password or "") ~= "" then
        drawLoginFrame("Authenticating...", colors.orange)

        local ok, res = bankRequest({
          type = "login",
          username = username,
          password = password,
        })

        if ok and type(res) == "table" then
          bank_session.logged_in = true
          bank_session.citizen_id = res.citizen_id
          bank_session.display_name = res.display_name
          bank_session.username = username
          bank_session._password = password
          bank_session.balance = tonumber(res.balance) or 0
          bank_session.title = res.title or "Account Holder"

          state.bank_username = username
          saveState()

          drawLoginFrame("Linked account: " .. tostring(bank_session.citizen_id), colors.lime)
          sleep(0.5)
          return true
        else
          drawLoginFrame("Login failed: " .. tostring(res or "unknown"), colors.red)
          sleep(2)
        end
      end
    end
  end
end


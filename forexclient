local args = {...}

-- =============================================================================
-- SAFE SELF UPDATE
-- =============================================================================
-- Normal run:
--   startup
--   startup <server_id>
--
-- Manual test / bypass updater:
--   startup --updated
--   startup --updated <server_id>
if args[1] ~= "--updated" then
  print("[ Forex Client ]")
  print("Checking GitHub update...")

  local tmp = "startup.new"
  local old = "startup.old"
  fs.delete(tmp)

  local cb = tostring(os.epoch and os.epoch("utc") or math.floor(os.clock() * 100000))
  local url = "https://raw.githubusercontent.com/JoshuaMEtaylor/BankingAccountsMonitor/refs/heads/main/forexclient?cb=" .. cb
  shell.run("wget " .. url .. " " .. tmp)

  local okDownload = false
  if fs.exists(tmp) then
    local f = fs.open(tmp, "r")
    local body = f and f.readAll() or ""
    if f then f.close() end
    okDownload = body and #body > 50
  end

  if not okDownload then
    fs.delete(tmp)
    print("Update failed or empty. Keeping existing startup.lua.")
    print("Run startup --updated to bypass updater for manual testing.")
    return
  end

  fs.delete(old)
  if fs.exists("startup.lua") then fs.move("startup.lua", old) end
  fs.move(tmp, "startup.lua")

  print("Updated. Relaunching...")
  sleep(0.5)

  local relaunch = { "startup.lua", "--updated" }
  for i = 1, #args do relaunch[#relaunch + 1] = tostring(args[i]) end
  local unpackFn = table.unpack or unpack
  shell.run(unpackFn(relaunch))
  return
end


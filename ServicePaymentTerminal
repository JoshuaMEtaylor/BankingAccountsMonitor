local colony = nil
local auto_charge = true
local last_message = "Booting..."
local last_colour = colors.lightGray
local W, H = term.getSize()

local prices = {}
local inflation_state = {}
local pricing = {
  general_index = 1.00,
  food_index = 1.00,
  effective_index = 1.00,
  normal_meal = BASE_NORMAL_MEAL_PRICE,
  live_food_prices = 0,

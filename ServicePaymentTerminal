local function textHasHospitality(text)
  text = lower(text or "")
  return text:find("hospitality", 1, true)
    or text:find("dining", 1, true)
    or text:find("restaurant", 1, true)
    or text:find("catering", 1, true)
    or text:find("cook", 1, true)
    or text:find("kitchen", 1, true)
    or text:find("waiter", 1, true)
end

local function collectText(v, out, depth, seen)
  out = out or {}
  depth = depth or 0
  if depth > 4 then return out end
  seen = seen or {}

  local tv = type(v)
  if tv == "string" or tv == "number" or tv == "boolean" then
    out[#out + 1] = tostring(v)
    return out
  end
  if tv ~= "table" then return out end
  if seen[v] then return out end
  seen[v] = true

  local keys = {
    "work", "workBuilding", "work_building", "job", "jobName", "job_name",
    "profession", "occupation", "role", "title", "name", "type", "buildingType"
  }
  for _, k in ipairs(keys) do
    if v[k] ~= nil then collectText(v[k], out, depth + 1, seen) end
  end
  return out
end

local function isDiningStaffCitizen(z)
  local chunks = {}
  collectText(z, chunks, 0, {})
  local text = lower(table.concat(chunks, " "))
  if text == "" then return false end
  return text:find("waiter", 1, true) ~= nil
    or text:find("cook", 1, true) ~= nil
    or text:find("restaurant", 1, true) ~= nil
    or text:find("dining", 1, true) ~= nil
    or text:find("kitchen", 1, true) ~= nil
end

local function isTavernStaffCitizen(z)
  local chunks = {}
  collectText(z, chunks, 0, {})
  local text = lower(table.concat(chunks, " "))
  if text == "" then return false end
  return text:find("tavern", 1, true) ~= nil
    or text:find("innkeeper", 1, true) ~= nil
    or text:find("host", 1, true) ~= nil
    or text:find("bartender", 1, true) ~= nil
end

local function diningCompanyIdForBuilding(b)
  if type(b) ~= "table" then return nil end
  local explicit = b.company_id or b.companyId or b.account_id or b.accountId or b.business_id or b.businessId
  if explicit and tostring(explicit) ~= "" then
    explicit = tostring(explicit)
    if explicit:find("^company:") and isSafeCompanyId(explicit) then return explicit end
  end
  return nil
end

local function isDiningBuilding(b)
  if type(b) ~= "table" then return false end
  local t = normalType(b.type or b.name or b.buildingType)
  local n = lower((b.name or "") .. " " .. (b.type or "") .. " " .. (b.buildingType or ""))

  local wanted = t:find("dining", 1, true)
    or t:find("restaurant", 1, true)
    or t == "cook"
    or n:find("dining", 1, true)
    or n:find("restaurant", 1, true)
    or n:find("cook", 1, true)
    or n:find("kitchen", 1, true)

  local wrong = n:find("tavern", 1, true) or n:find("inn", 1, true) or n:find("bar", 1, true)
  return wanted and not wrong
end

local function isTavernBuilding(b)
  if type(b) ~= "table" then return false end
  local text = normalType(
    tostring(b.name or "") .. " " ..
    tostring(b.type or "") .. " " ..
    tostring(b.buildingType or "") .. " " ..
    tostring(b.job or "")
  )

  return text:find("tavern", 1, true) ~= nil
    or text:find("inn", 1, true) ~= nil
    or text:find("lodging", 1, true) ~= nil
end

local function diningBuildings(buildings)
  local out = {}
  for _, b in pairs(buildings or {}) do
    if isDiningBuilding(b) then
      local p = getPos(b)
      if p then
        out[#out + 1] = {
          name = tostring(b.name or b.type or "Dining Hall"),
          company_id = diningCompanyIdForBuilding(b),
          pos = p,
          raw = b,
        }
      end
    end
  end
  return out
end

local function tavernBuildings(buildings)
  local out = {}
  for _, b in pairs(buildings or {}) do
    if isTavernBuilding(b) then
      local p = getPos(b)
      if p then
        out[#out + 1] = {
          name = tostring(b.name or b.type or b.buildingType or "Tavern"),
          pos = p,
          raw = b,
        }
      end
    end
  end
  return out
end

local function nearestBuilding(pos, list)
  if not pos then return nil, nil end
  local best, bestDist = nil, 999999
  for _, b in ipairs(list or {}) do
    local d = dist(pos, b.pos)
    if d < bestDist then best = b; bestDist = d end
  end
  return best, bestDist
end

local function isNearBuilding(pos, list, radius)
  local best, bestDist = nearestBuilding(pos, list)
  if best and bestDist and bestDist <= radius then return true, best, bestDist end
  return false, best, bestDist
end


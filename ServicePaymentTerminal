end

local VERSION = "1.1.1-BANK-SERVICE-OBSERVATIONS"
local BANK_PROTOCOL = "quid_bank"
local SERVICE_KEY = "dining_hall"
local SCAN_SECONDS = 2
local EAT_DELAY_SECONDS = 2
local MATCH_WINDOW_SECONDS = 6
local SAT_DELTA_MIN = 0.50

local db_id, modem_name = nil, nil
local last_message, last_colour = "Booting...", colors.lightGray
local auto_charge = true
local obs, prev_stock, prev_citizens = nil, nil, nil
local pending_food, sat_events = {}, {}
local stats = { citizens_seen=0, citizen_inventory_sources=0, chargeable_units=0, stock_kinds=0, stock_units=0, last_loss=0, pending=0, sat_events=0, matched=0, charged=0, unpaid=0, unattributed=0 }

local function now() return os.epoch("utc") end
local function lower(s) return string.lower(tostring(s or "")) end
local function setMsg(m,c) last_message=tostring(m or ""); last_colour=c or colors.lightGray end
local function money(n) return tostring(math.floor((tonumber(n) or 0)+0.5)).." Q" end

local function openModem()
  for _, n in ipairs(peripheral.getNames()) do if peripheral.getType(n)=="modem" then rednet.open(n); modem_name=n; return true end end
  return false
end
local function discoverBank()
  for _=1,5 do
    rednet.broadcast({type="ping"}, BANK_PROTOCOL)
    local sender,msg=rednet.receive(BANK_PROTOCOL,2)
    if sender and type(msg)=="table" and (msg.type=="treasury_online" or msg.success==true) then db_id=sender; return true end
  end
  return false
end
local function bankReq(req, timeout)
  timeout=timeout or 6
  if not db_id then discoverBank() end
  if not db_id then return false,"No bank server connected" end
  rednet.send(db_id, req, BANK_PROTOCOL)
  local deadline=os.clock()+timeout
  while true do
    local rem=deadline-os.clock()
    if rem<=0 then return false,"No response from bank" end
    local sender,msg=rednet.receive(BANK_PROTOCOL, rem)
    if sender==db_id and type(msg)=="table" and msg.success~=nil then return msg.success,msg.response end
  end
end

local function stockCopy(t) local out={}; for k,v in pairs(t or {}) do out[tostring(k)]=tonumber(v) or 0 end; return out end
local function stockStats(t) local k,u=0,0; for _,v in pairs(t or {}) do k=k+1; u=u+(tonumber(v) or 0) end; return k,u end
local function stockLoss(old,new)
  local losses,qtyTotal,valueTotal={},0,0
  for item, oldQty in pairs(old or {}) do
    local newQty=tonumber((new or {})[item]) or 0
    oldQty=tonumber(oldQty) or 0
    if newQty<oldQty then
      local qty=oldQty-newQty
      local unit=1
      local id=lower(item)
      if id:find("golden_carrot",1,true) or id:find("cake",1,true) or id:find("rabbit_stew",1,true) then unit=4
      elseif id:find("steak",1,true) or id:find("cooked_beef",1,true) or id:find("cooked_porkchop",1,true) or id:find("cooked_salmon",1,true) then unit=3
      elseif id:find("cooked_",1,true) or id:find("bread",1,true) or id:find("pie",1,true) or id:find("stew",1,true) or id:find("soup",1,true) then unit=2 end
      losses[#losses+1]={item=item,qty=qty,unit=unit,value=qty*unit}
      qtyTotal=qtyTotal+qty; valueTotal=valueTotal+(qty*unit)
    end
  end
  return losses,qtyTotal,valueTotal
end
local function summary(losses) local p={}; for _,l in ipairs(losses or {}) do p[#p+1]=tostring(l.qty).."x "..tostring(l.item) end; return #p>0 and table.concat(p,", ") or "meal" end
local function citizenMap(rows) local out={}; for _,z in ipairs(rows or {}) do if z.citizen_id then out[z.citizen_id]={name=z.display_name or z.citizen_id,saturation=tonumber(z.saturation) or 0} end end; return out end
local function updateSaturationEvents(old,new)
  local t=now()
  for id,z in pairs(new or {}) do
    local p=(old or {})[id]
    if p then local d=(tonumber(z.saturation) or 0)-(tonumber(p.saturation) or 0); if d>=SAT_DELTA_MIN then sat_events[#sat_events+1]={time=t,citizen_id=id,name=z.name,delta=d} end end
  end
  local keep={}; for _,e in ipairs(sat_events) do if t-e.time <= (MATCH_WINDOW_SECONDS+EAT_DELAY_SECONDS+4)*1000 then keep[#keep+1]=e end end
  sat_events=keep; stats.sat_events=#sat_events
end
local function findLastSat(start_ms,end_ms) local best=nil; for _,e in ipairs(sat_events) do if e.time>=start_ms and e.time<=end_ms and (not best or e.time>best.time) then best=e end end; return best end
local function processPending()
  local t=now(); local keep={}
  for _,p in ipairs(pending_food) do
    if t>=p.due then
      local ev=findLastSat(p.detected_at,p.due+(MATCH_WINDOW_SECONDS*1000))
      if ev and obs and obs.company_id then
        local amount=math.max(1,math.floor(p.value or 1))
        local ok,res=bankReq({type="hospitality_meal_payment", citizen_id=ev.citizen_id, company_id=obs.company_id, amount=amount, item=p.summary, memo="Dining Hall meal: "..p.summary},6)
        if ok and type(res)=="table" then
          stats.matched=stats.matched+1; stats.charged=stats.charged+(tonumber(res.paid) or 0); stats.unpaid=stats.unpaid+(tonumber(res.shortfall) or 0)
          setMsg("Charged "..tostring(ev.name).." "..money(res.paid or 0).." for "..p.summary, colors.lime)
        else setMsg("Meal payment failed: "..tostring(res), colors.red); keep[#keep+1]=p end
      else stats.unattributed=stats.unattributed+(tonumber(p.qty) or 0); setMsg("Food decrease had no saturation match: "..p.summary, colors.orange) end
    else keep[#keep+1]=p end
  end
  pending_food=keep; stats.pending=#pending_food
end
local function poll()
  local ok,res=bankReq({type="get_service_observations", service_key=SERVICE_KEY},6)
  if not ok then setMsg("No service observation: "..tostring(res),colors.red); return end
  obs=res.observation or res
  stats.citizens_seen=tonumber(obs.citizens_seen) or #(obs.citizens or {})
  stats.citizen_inventory_sources=tonumber(obs.citizen_inventory_sources) or 0
  stats.chargeable_units=tonumber(obs.chargeable_units) or 0
  local st=stockCopy(obs.dining_stock or {})
  local cits=citizenMap(obs.citizens or {})
  updateSaturationEvents(prev_citizens,cits)
  if prev_stock then local losses,qty,value=stockLoss(prev_stock,st); stats.last_loss=qty; if qty>0 then pending_food[#pending_food+1]={detected_at=now(),due=now()+EAT_DELAY_SECONDS*1000,losses=losses,qty=qty,value=math.max(1,value),summary=summary(losses)}; setMsg("Food decrease detected: "..summary(losses),colors.yellow) end end
  prev_stock=st; prev_citizens=cits; stats.stock_kinds,stats.stock_units=stockStats(st); processPending()
end

local function cls() term.setCursorBlink(false); term.setBackgroundColor(colors.black); term.setTextColor(colors.white); term.clear(); term.setCursorPos(1,1) end
local function at(x,y,text,fg,bg) local W,H=term.getSize(); if y<1 or y>H then return end; term.setCursorPos(x,y); term.setTextColor(fg or colors.white); term.setBackgroundColor(bg or colors.black); term.write(tostring(text or ""):sub(1,W-x+1)) end
local function fill(x,y,w,h,bg) term.setBackgroundColor(bg or colors.black); local row=string.rep(" ",w); for yy=y,y+h-1 do term.setCursorPos(x,yy); term.write(row) end end
local function button(x,y,w,label,bg,fg) fill(x,y,w,1,bg or colors.gray); at(x+math.floor((w-#label)/2),y,label,fg or colors.white,bg or colors.gray); return {x1=x,x2=x+w-1,y1=y,y2=y} end
local function hit(b,x,y) return b and x>=b.x1 and x<=b.x2 and y>=b.y1 and y<=b.y2 end
local function draw()
  local W,H=term.getSize(); cls(); fill(1,1,W,1,colors.purple)
  at(2,1,"SERVICE PAYMENT TERMINAL",colors.white,colors.purple); at(math.max(2,W-#VERSION),1,VERSION,colors.lightGray,colors.purple)
  at(2,3,"Source:       Bank service observations",colors.white)
  at(2,4,"Bank:         "..tostring(db_id or "not connected"),db_id and colors.lime or colors.red)
  at(2,5,"Company:      "..tostring(obs and (obs.company_name or obs.company_id) or "unknown"),(obs and obs.company_id) and colors.lime or colors.red)
  at(2,6,"Company src:  "..tostring(obs and obs.company_source or "none"),colors.lightGray)
  at(2,8,"Citizens seen:       "..tostring(stats.citizens_seen),stats.citizens_seen>0 and colors.lime or colors.orange)
  at(2,9,"Citizen inv sources: "..tostring(stats.citizen_inventory_sources),stats.citizen_inventory_sources>0 and colors.lime or colors.orange)
  at(2,10,"Stock kinds/units:   "..tostring(stats.stock_kinds).." / "..tostring(stats.stock_units),colors.white)
  at(2,11,"Last food decrease:  "..tostring(stats.last_loss),stats.last_loss>0 and colors.yellow or colors.gray)
  at(2,12,"Pending meals:       "..tostring(stats.pending),stats.pending>0 and colors.yellow or colors.gray)
  at(2,13,"Saturation events:   "..tostring(stats.sat_events),colors.cyan)
  at(2,15,"Matched: "..tostring(stats.matched).."  Charged: "..money(stats.charged).."  Unpaid: "..money(stats.unpaid),colors.lime)
  at(2,16,"Unattributed food:   "..tostring(stats.unattributed).." units",stats.unattributed>0 and colors.orange or colors.gray)
  local third=math.floor((W-8)/3)
  local bScan=button(2,H-3,third,"Poll Now",colors.purple); local bAuto=button(4+third,H-3,third,auto_charge and "Auto Off" or "Auto On",colors.gray); local bRecon=button(6+third*2,H-3,third,"Reconnect",colors.gray)
  at(2,H-1,last_message,last_colour)
  return bScan,bAuto,bRecon
end
local function main()
  if not openModem() then print("No modem found."); return end
  discoverBank(); poll()
  local bScan,bAuto,bRecon=draw(); local timer=os.startTimer(SCAN_SECONDS)
  while true do
    local ev,p1,p2,p3=os.pullEvent()
    if ev=="timer" and p1==timer then if auto_charge then poll() end; bScan,bAuto,bRecon=draw(); timer=os.startTimer(SCAN_SECONDS)
    elseif ev=="mouse_click" then if hit(bScan,p2,p3) then poll() elseif hit(bAuto,p2,p3) then auto_charge=not auto_charge; setMsg("Auto "..(auto_charge and "on" or "off"),colors.yellow) elseif hit(bRecon,p2,p3) then discoverBank(); setMsg("Reconnected.",colors.lime) end; bScan,bAuto,bRecon=draw()
    elseif ev=="terminate" then break end
  end
end
local ok,err=pcall(main); if not ok then term.setTextColor(colors.red); print("Runtime error: "..tostring(err)) end

local function resolveHospitalityCompanyFromMappings()
  local ok, res = bankReq({ type = "list_employee_mappings", include_inactive = false }, 4)
  if not ok or type(res) ~= "table" or type(res.employees) ~= "table" then return nil, nil end

  local score = {}
  for _, e in ipairs(res.employees or {}) do
    if type(e) == "table" then
      local cid = tostring(e.company_id or "")
      local industry = lower(e.industry or "")
      local text = table.concat({
        tostring(e.company_name or ""),
        tostring(e.job_text or ""),
        tostring(e.work_type or ""),
        tostring(e.work_name or ""),
        tostring(e.building_key or ""),
      }, " ")

      if isSafeCompanyId(cid) and (industry == "hospitality" or textHasHospitality(text)) then
        score[cid] = (score[cid] or 0) + (industry == "hospitality" and 5 or 1)
      end
    end
  end

  local best, bestScore = nil, 0
  for cid, sc in pairs(score) do
    if sc > bestScore then best, bestScore = cid, sc end
  end

  if best then return best, "employee_mappings" end
  return nil, nil
end

local function resolveHospitalityCompanyFromAccounts()
  local ok, res = bankReq({ type = "list_accounts" }, 4)
  if not ok or type(res) ~= "table" or type(res.accounts) ~= "table" then return nil, nil end

  local best, bestScore = nil, 0
  for _, acc in ipairs(res.accounts or {}) do
    if type(acc) == "table" and acc.type == "company" and acc.status ~= "suspended" then
      local cid = tostring(acc.account_id or "")
      local name = lower((acc.display_name or "") .. " " .. cid)
      local sc = 0
      if name:find("hospitality", 1, true) then sc = sc + 100 end
      if name:find("dining", 1, true) then sc = sc + 80 end
      if name:find("catering", 1, true) then sc = sc + 75 end
      if name:find("restaurant", 1, true) then sc = sc + 70 end
      if name:find("cook", 1, true) then sc = sc + 60 end
      if name:find("halloway", 1, true) then sc = sc + 50 end
      if isSafeCompanyId(cid) and sc > bestScore then best, bestScore = cid, sc end
    end
  end

  if best then return best, "account_search" end
  return nil, nil
end

local function resolveHospitalityCompany(dining)
  for _, d in ipairs(dining or {}) do
    if d and isSafeCompanyId(d.company_id) then return d.company_id, "building_company_id" end
  end

  local cid, source = resolveHospitalityCompanyFromMappings()
  if cid then return cid, source end

  cid, source = resolveHospitalityCompanyFromAccounts()
  if cid then return cid, source end

  if isSafeCompanyId(TARGET_COMPANY) then return TARGET_COMPANY, "fallback" end
  return nil, "unresolved"
end


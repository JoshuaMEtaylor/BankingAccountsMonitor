-- =============================================================================
-- BASICS
-- =============================================================================
local function now()
  return os.epoch("utc")
end

local function mcDay()
  if os.day then return math.floor(tonumber(os.day()) or 0) end
  return math.floor(now() / 1200000)
end

local function tickSeconds(ticks)
  return (tonumber(ticks) or 0) / 20
end

local function msFromTicks(ticks)
  return math.floor(tickSeconds(ticks) * 1000)
end

local function lower(s)
  return string.lower(tostring(s or ""))
end

local function trim(s)
  return tostring(s or ""):match("^%s*(.-)%s*$")
end

local function setMsg(msg, col)
  last_message = tostring(msg or "")
  last_colour = col or colors.lightGray
end

local function ensureDir(path)
  local dir = fs.getDir(path)
  if dir and dir ~= "" and not fs.exists(dir) then fs.makeDir(dir) end
end

local function readFile(path)
  if not fs.exists(path) then return nil end
  local f = fs.open(path, "r")
  if not f then return nil end
  local text = f.readAll()
  f.close()
  if not text or text == "" then return nil end
  local ok, data = pcall(textutils.unserialize, text)
  if ok then return data end
  return nil
end

local function writeFile(path, data)
  ensureDir(path)
  local f = fs.open(path, "w")
  if not f then return false end
  f.write(textutils.serialize(data))
  f.close()
  return true
end

local function money(n)
  n = tonumber(n) or 0
  local sign = ""
  if n < 0 then sign = "-"; n = math.abs(n) end
  local s = tostring(math.floor(n + 0.5))
  local out = ""
  while #s > 3 do
    out = "," .. s:sub(-3) .. out
    s = s:sub(1, -4)
  end
  return sign .. s .. out .. " Q"
end

local function locString(loc)
  if type(loc) ~= "table" then return "0,0,0" end
  local x = loc.x or loc[1] or 0
  local y = loc.y or loc[2] or 0
  local z = loc.z or loc[3] or 0
  return tostring(x) .. "," .. tostring(y) .. "," .. tostring(z)
end

local function normalType(s)
  s = tostring(s or "")
  s = s:gsub("com%.minecolonies%.building%.", "")
  s = s:gsub("com%.minecolonies%.job%.", "")
  return lower(s)
end

local function simpleItemName(name)
  name = tostring(name or "")
  name = name:gsub("^minecraft:", "")
  name = name:gsub("^minecolonies:", "")
  name = name:gsub("^%w+:", "")
  return lower(name)
end

-- =============================================================================
-- STOCK ITEM RULES
-- =============================================================================
local function isExcludedFuel(item)
  local id = simpleItemName(item)

  return id == "coal"
    or id == "charcoal"
    or id == "coal_block"
    or id == "block_of_coal"
    or id:find("coal_block", 1, true)
    or id:find("charcoal", 1, true)
end

local function isTrackedDiningItem(item)
  item = trim(item or "")
  if item == "" then return false end
  if isExcludedFuel(item) then return false end
  return true
end

local function foodTier(item)
  local id = simpleItemName(item)

  -- Still tiered for pricing, but detection is NOT whitelist based.
  -- Anything in dining stock except coal/charcoal is tracked. Unknown/simple
  -- items fall back to Tier 1 = 1 Q each.
  if id:find("golden_carrot", 1, true)
    or id:find("cake", 1, true)
    or id:find("rabbit_stew", 1, true) then
    return 4
  end

  if id:find("steak", 1, true)
    or id:find("cooked_beef", 1, true)
    or id:find("cooked_porkchop", 1, true)
    or id:find("cooked_salmon", 1, true) then
    return 3
  end

  if id:find("cooked_", 1, true)
    or id:find("bread", 1, true)
    or id:find("pumpkin_pie", 1, true)
    or id:find("mushroom_stew", 1, true)
    or id:find("beetroot_soup", 1, true) then
    return 2
  end

  return 1
end

local function foodUnitPrice(item)
  local t = foodTier(item)
  if t < 1 then t = 1 end
  return t
end


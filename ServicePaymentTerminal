-- CONFIG
-- =============================================================================
local VERSION = "1.2.3-PRICE-SHOCK-FALLBACK"
local BANK_PROTOCOL = "quid_bank"
local TARGET_COMPANY = "company:grki"

local SCAN_SECONDS = 2
local DINING_RADIUS = 28
local NEAR_GRACE_SECONDS = 25
local MEAL_COOLDOWN_SECONDS = 150

local MIN_SAT_GAIN = 2.00
local SMALL_GAIN = 2.00
local NORMAL_GAIN = 5.00
local LARGE_GAIN = 9.00
local FULL_GAIN = 13.00

local BASE_NORMAL_MEAL_PRICE = 2.00
local MIN_CHARGE = 1

-- Immediate visible inflation fallback. The bank-side v1.4.4 oracle also uses
-- this as its default price-pressure floor. This terminal only uses it when the
-- bank oracle cannot be reached, so meals do not silently fall back to x1.000.
local LOCAL_PRICE_PRESSURE_FLOOR = 0.26
local LOCAL_GENERAL_SENSITIVITY = 1.00
local LOCAL_FOOD_SENSITIVITY = 1.40
local LOCAL_FOOD_BIAS = 0.05

local STATE_FILE = "data/service_payment_state.db"
local CONFIG_FILE = "data/service_payment_config.db"

-- Meal pricing is now quoted by the bank's wide sector price oracle.
-- This terminal keeps only the POS detection logic; the bank owns the price system.


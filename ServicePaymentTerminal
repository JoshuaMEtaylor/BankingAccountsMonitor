local function buildingText(b)
  if type(b) ~= "table" then return "" end

  local parts = {}
  for _, k in ipairs({ "building_type", "building_name", "type", "name", "industry", "company_name", "ticker" }) do
    if b[k] then parts[#parts + 1] = tostring(b[k]) end
  end

  return lower(table.concat(parts, " "))
end

local function isDiningHallBusinessRecord(b)
  local txt = buildingText(b)

  -- Dining Hall specifically. Avoid choosing Tavern just because it is also in
  -- the hospitality industry.
  local is_dining = txt:find("dining", 1, true)
    or txt:find("dininghall", 1, true)
    or txt:find("dining_hall", 1, true)
    or txt:find("restaurant", 1, true)

  local is_wrong_service = txt:find("tavern", 1, true)
    or txt:find("bar", 1, true)
    or txt:find("inn", 1, true)

  return is_dining and not is_wrong_service
end

local function resolveDiningCompanyFromBuildings()
  local building_companies = readFile(FILE_BUILDING_COMPANIES) or {}

  local best = nil
  for _, b in pairs(building_companies) do
    if type(b) == "table" and b.company_id and isDiningHallBusinessRecord(b) then
      best = b
      break
    end
  end

  if best then
    return best.company_id, best.name or best.company_name or best.company_id
  end

  return nil
end

local function resolveDiningCompanyFromIndustryFallback()
  -- Only a final fallback. This may be the wrong hospitality business if Tavern
  -- and Dining Hall are separate companies, so building-specific lookup above
  -- is preferred.
  local industries = readFile(FILE_INDUSTRY_COMPANIES) or {}
  local h = industries.hospitality

  if type(h) == "table" and h.company_id then
    return h.company_id, h.name or h.company_id
  end

  return nil
end

local function hospitalityCompany()
  -- This terminal is for the Dining Hall service specifically, not the whole
  -- hospitality industry. Resolve from the building->company mapping first so
  -- it chooses the Dining Hall company, not the first/generic hospitality one.

  if config.dining_company_id and config.dining_company_id ~= "" then
    return config.dining_company_id, config.dining_company_name or config.dining_company_id
  end

  if config.company_id and config.company_id ~= "" then
    return config.company_id, config.company_name or config.company_id
  end

  local company_id, company_name = resolveDiningCompanyFromBuildings()
  if company_id then return company_id, company_name end

  company_id, company_name = resolveDiningCompanyFromIndustryFallback()
  if company_id then return company_id, company_name end

  return "unresolved", "Dining Hall company not found"
end

local function citizenJobText(z)
  local parts = {}

  if type(z) ~= "table" then return "" end
  if z.job then parts[#parts+1] = tostring(z.job) end
  if z.title then parts[#parts+1] = tostring(z.title) end
  if z.profession then parts[#parts+1] = tostring(z.profession) end

  if type(z.work) == "table" then
    if z.work.job then parts[#parts+1] = tostring(z.work.job) end
    if z.work.type then parts[#parts+1] = tostring(z.work.type) end
    if z.work.name then parts[#parts+1] = tostring(z.work.name) end
  end

  return lower(table.concat(parts, " "))
end

local function isDiningWorker(z)
  local txt = citizenJobText(z) .. " " .. lower(z and z.name or "")
  return txt:find("waiter",1,true)
    or txt:find("cook",1,true)
    or txt:find("chef",1,true)
    or txt:find("restaurant",1,true)
    or txt:find("dining",1,true)
end

-- =============================================================================
-- STOCK READING
-- =============================================================================
local function addFood(counts, item, qty)
  qty = tonumber(qty) or 0
  if qty <= 0 then return end
  if not isTrackedDiningItem(item) then return end

  local id = simpleItemName(item)
  counts[id] = (counts[id] or 0) + qty
end

local function countFromInventory(inv, counts)
  if not inv or type(inv.list) ~= "function" then return false end

  local ok, items = pcall(inv.list)
  if not ok or type(items) ~= "table" then return false end

  local before = 0
  for _ in pairs(counts) do before = before + 1 end

  for _, st in pairs(items) do
    if type(st) == "table" then
      addFood(counts, st.name or st.displayName or st.item, st.count or st.qty or st.amount or 0)
    end
  end

  local after = 0
  for _ in pairs(counts) do after = after + 1 end
  return after > before
end

local function countFromStorageTable(tbl, counts)
  if type(tbl) ~= "table" then return false end

  local before_units = 0
  for _, q in pairs(counts) do before_units = before_units + q end

  local lists = { "items", "contents", "inventory", "stacks" }
  for _, k in ipairs(lists) do
    if type(tbl[k]) == "table" then
      for _, st in pairs(tbl[k]) do
        if type(st) == "table" then
          addFood(counts, st.name or st.displayName or st.item or st.id, st.count or st.qty or st.amount or 0)
        end
      end
    end
  end

  if tbl.name and (tbl.count or tbl.qty or tbl.amount) then
    addFood(counts, tbl.name, tbl.count or tbl.qty or tbl.amount)
  end

  local possible = { tbl.peripheral, tbl.peripheral_name, tbl.name }
  for _, pname in ipairs(possible) do
    if type(pname) == "string" and peripheral.isPresent(pname) then
      countFromInventory(peripheral.wrap(pname), counts)
    end
  end

  local after_units = 0
  for _, q in pairs(counts) do after_units = after_units + q end
  return after_units > before_units
end

local function countFromCitizenInventoryValue(v, counts, depth)
  if type(v) ~= "table" then return false end
  depth = depth or 0
  if depth > 5 then return false end

  local before_units = 0
  for _, q in pairs(counts) do before_units = before_units + q end

  -- Direct stack-like table.
  local item_name = v.name or v.item or v.id or v.item_id or v.itemName or v.displayName
  local qty = v.count or v.qty or v.amount or v.size or v.quantity

  if item_name and qty then
    addFood(counts, item_name, qty)
  end

  -- Common inventory containers exposed by AP/mod integrations.
  local keys = {
    "inventory", "items", "stacks", "contents", "mainInventory",
    "main_inventory", "heldItems", "held_items", "food", "foods",
    "slots", "backpack", "equipment"
  }

  for _, k in ipairs(keys) do
    if type(v[k]) == "table" then
      countFromCitizenInventoryValue(v[k], counts, depth + 1)
    end
  end

  -- Array-style inventory list.
  local is_arrayish = false
  for k, _ in pairs(v) do
    if type(k) == "number" then is_arrayish = true break end
  end

  if is_arrayish then
    for _, child in pairs(v) do
      if type(child) == "table" then
        countFromCitizenInventoryValue(child, counts, depth + 1)
      end
    end
  end

  local after_units = 0
  for _, q in pairs(counts) do after_units = after_units + q end
  return after_units > before_units
end

local function countCitizenInventories(counts)
  local total_sources = 0
  local dining_sources = 0
  local citizens_seen = 0

  if not colony or not colony.getCitizens then
    stats.citizens_seen = 0
    return 0, 0, 0
  end

  local ok, citizens = pcall(colony.getCitizens)
  if not ok or type(citizens) ~= "table" then
    stats.citizens_seen = 0
    return 0, 0, 0
  end

  citizens_seen = #citizens

  -- Do NOT depend on job detection for stock detection.
  -- Advanced Peripherals/MineColonies can expose job fields inconsistently.
  -- So we inspect every citizen for inventory-like tables, and still record how
  -- many of those were recognised as Waiter/Cook/Chef.
  for _, z in ipairs(citizens) do
    local before_units = 0
    for _, q in pairs(counts) do before_units = before_units + q end

    local changed = countFromCitizenInventoryValue(z, counts, 0)

    local after_units = 0
    for _, q in pairs(counts) do after_units = after_units + q end

    if changed or after_units > before_units then
      total_sources = total_sources + 1
      if isDiningWorker(z) then dining_sources = dining_sources + 1 end
    end
  end

  stats.citizens_seen = citizens_seen
  return total_sources, dining_sources, citizens_seen
end

local function readFoodStock()
  local counts = {}
  local sources = 0
  local seen_peripherals = {}

  local citizen_inventory_sources, worker_sources, citizens_seen = countCitizenInventories(counts)
  if citizen_inventory_sources > 0 then sources = sources + citizen_inventory_sources end

  local function tryPeripheral(pname)
    if type(pname) ~= "string" or pname == "" then return end
    if seen_peripherals[pname] then return end
    seen_peripherals[pname] = true

    if peripheral.isPresent(pname) then
      local obj = peripheral.wrap(pname)
      if obj and type(obj.list) == "function" then
        if countFromInventory(obj, counts) then sources = sources + 1 end
      end
    end
  end

  -- Configured inventory peripheral names.
  local invs = config.inventories or config.inventory_names or {}
  if type(invs) == "table" then
    for _, pname in ipairs(invs) do
      tryPeripheral(pname)
    end
  end

  -- Named fallback: attached inventories with useful names.
  for _, pname in ipairs(peripheral.getNames()) do
    local n = lower(pname)
    if n:find("dining",1,true)
      or n:find("restaurant",1,true)
      or n:find("cook",1,true)
      or n:find("kitchen",1,true)
      or n:find("hospitality",1,true) then
      tryPeripheral(pname)
    end
  end

  -- Practical fallback:
  -- ComputerCraft inventory peripheral names are usually generic, e.g.
  -- minecraft:barrel_0 or sophisticatedstorage:chest_2, not "dining".
  -- On this terminal, scanning all directly attached inventory peripherals is
  -- the sensible default. Coal/charcoal are already filtered out, so this still only counts
  -- chargeable dining stock.
  if config.scan_all_attached_inventories ~= false and sources == 0 then
    for _, pname in ipairs(peripheral.getNames()) do
      local obj = peripheral.wrap(pname)
      if obj and type(obj.list) == "function" then
        tryPeripheral(pname)
      end
    end
  end

  local kinds = 0
  local units = 0
  for _, q in pairs(counts) do
    kinds = kinds + 1
    units = units + (tonumber(q) or 0)
  end

  stats.stock_sources = sources
  stats.worker_stock_sources = worker_sources or 0
  stats.citizen_inventory_sources = citizen_inventory_sources or 0
  stats.citizens_seen = citizens_seen or stats.citizens_seen or 0
  stats.food_kinds = kinds
  stats.food_units = units

  return counts
end

local function stockLosses(old, new)
  old = old or {}
  new = new or {}

  local losses = {}
  local total_qty = 0
  local total_value = 0

  for item, oldQty in pairs(old) do
    local newQty = tonumber(new[item]) or 0
    oldQty = tonumber(oldQty) or 0
    if newQty < oldQty then
      local qty = oldQty - newQty
      local unit = foodUnitPrice(item)
      local value = unit * qty

      losses[#losses+1] = {
        item = item,
        qty = qty,
        unit = unit,
        value = value,
        tier = foodTier(item),
      }

      total_qty = total_qty + qty
      total_value = total_value + value
    end
  end

  table.sort(losses, function(a,b)
    if a.value ~= b.value then return a.value > b.value end
    return tostring(a.item) < tostring(b.item)
  end)

  return losses, total_qty, total_value
end

-- =============================================================================
-- CITIZEN SATURATION
-- =============================================================================
local function getCitizens()
  if not colony or not colony.getCitizens then return {} end
  local ok, z = pcall(colony.getCitizens)
  if ok and type(z) == "table" then return z end
  return {}
end

local function citizenStableId(z)
  if type(z) ~= "table" then return nil end
  return z.id or z.citizen_id or z.citizenId or z.citizenID or z.uuid
end

local function citizenAccountId(z)
  local id = citizenStableId(z)
  if not id then return nil end
  local sid = tostring(id)
  if sid:find("^citizen:") then return sid end
  if sid:find("^mc_") then return "citizen:" .. sid end
  return "citizen:mc_" .. sid
end

local function citizenName(z)
  return tostring(z and (z.name or z.display_name or citizenAccountId(z)) or "Citizen")
end

local function snapshotCitizens()
  local snap = {}
  for _, z in ipairs(getCitizens()) do
    local id = citizenAccountId(z)
    if id then
      snap[id] = {
        id = id,
        name = citizenName(z),
        saturation = tonumber(z.saturation or z.food or 0) or 0,
        betterFood = z.betterFood,
        state = tostring(z.state or ""),
        location = z.location,
      }
    end
  end
  return snap
end

local function updateSaturationEvents(prev, cur)
  local t = now()
  prev = prev or {}

  for id, c in pairs(cur or {}) do
    local p = prev[id]
    if p then
      local delta = (tonumber(c.saturation) or 0) - (tonumber(p.saturation) or 0)
      if delta >= SATURATION_DELTA_MIN then
        saturation_events[#saturation_events+1] = {
          time = t,
          citizen_id = id,
          name = c.name,
          delta = delta,
          state = c.state,
        }
      end
    end
  end

  local keep = {}
  local max_age = msFromTicks((config.eat_delay_ticks or DEFAULT_EAT_DELAY_TICKS) + (config.match_window_extra_ticks or MATCH_WINDOW_EXTRA_TICKS) + 200)
  for _, ev in ipairs(saturation_events) do
    if t - ev.time <= max_age then keep[#keep+1] = ev end
  end
  saturation_events = keep
  stats.saturation_events = #saturation_events
end

local function lastSaturationIncreaseBetween(start_time, end_time)
  local best = nil
  for _, ev in ipairs(saturation_events) do
    if ev.time >= start_time and ev.time <= end_time then
      if not best or ev.time > best.time then best = ev end
    end
  end
  return best
end


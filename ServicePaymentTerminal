  pricing.tavern.sector_label = "fallback"
  pricing.tavern.tier = "standard room"
  pricing.tavern.source = "fallback: " .. tostring(res)
  return false
end

local function refreshPricing()
  local okDining = true
  local okTavern = true
  if ENABLE_DINING then okDining = refreshDiningPricing() end
  if ENABLE_TAVERN then okTavern = refreshTavernPricing() end
  return okDining and okTavern
end

local function priceMeal(gain)
  gain = tonumber(gain) or 0
  if gain <= MIN_SAT_GAIN then return 0, "none", 0 end

  local ok, res = bankReq({
    type = "quote_service_price",
    service = "dining_meal",
    saturation_gain = gain,
    sector = "food",
  }, 4)

  if ok and type(res) == "table" then
    local amount = roundMoney(res.total or pricing.dining.normal_meal or SALMON_BASE_PRICE)
    pricing.dining.normal_meal = amount > 0 and amount or pricing.dining.normal_meal
    pricing.dining.food_index = tonumber(res.sector_index or res.effective_index) or pricing.dining.food_index
    pricing.dining.effective_index = tonumber(res.effective_index or res.sector_index) or pricing.dining.effective_index
    pricing.dining.source = tostring(res.source or "bank quote")
    pricing.dining.tier = tostring(res.tier or "meal")
    return amount, tostring(res.tier or "meal"), tonumber(res.tier_multiplier) or 1.00
  end

  return roundMoney(SALMON_BASE_PRICE), "salmon", 1.00
end

-- =============================================================================
-- PAYMENT / EVENT HELPERS
-- =============================================================================
local function addEvent(ev)
  state.events = state.events or {}
  ev.time = ev.time or now()
  state.events[#state.events + 1] = ev
  while #state.events > 40 do table.remove(state.events, 1) end
end

local function totalReceivables()
  local total = 0
  for _, n in pairs(state.receivables or {}) do total = total + (tonumber(n) or 0) end
  return total
end

local function decodeMealPayment(res, requested)
  requested = tonumber(requested) or 0

  local company_received = tonumber(res.company_received or res.paid or res.amount_paid or res.amount or 0) or 0
  local citizen_paid = tonumber(res.citizen_paid or res.from_citizen or res.citizen_amount or 0)
  local treasury_paid = tonumber(res.treasury_paid or res.treasury_covered or res.subsidy_paid or res.state_paid or res.subsidy or 0)
  local shortfall = tonumber(res.shortfall or res.unpaid or res.remaining_shortfall or 0) or 0

  if company_received >= requested and shortfall <= 0 then shortfall = 0 end
  if not citizen_paid then citizen_paid = 0 end
  if not treasury_paid then treasury_paid = 0 end

  local split_total = citizen_paid + treasury_paid
  if company_received > 0 and split_total == 0 then
    citizen_paid = company_received
  elseif company_received > 0 and split_total < company_received and treasury_paid > 0 then
    treasury_paid = treasury_paid + (company_received - split_total)
  end

  local covered = citizen_paid + treasury_paid
  if covered < company_received then covered = company_received end
  local uncovered = math.max(0, requested - covered)
  if shortfall > uncovered then uncovered = shortfall end

  return {
    company_received = company_received,
    citizen_paid = citizen_paid,
    treasury_paid = treasury_paid,
    uncovered = uncovered,
    tx_id = res.tx_id or res.payment_tx_id or res.citizen_tx_id,
    treasury_tx_id = res.treasury_tx_id or res.subsidy_tx_id,
    raw = res,
  }
end

local function chargeCitizenMeal(citizen_id, name, amount, label, gain, company_id)
  company_id = company_id or active_company_id or TARGET_COMPANY
  local ok, res = bankReq({
    type = "hospitality_meal_payment",
    citizen_id = citizen_id,
    company_id = company_id,
    amount = amount,
    item = label,
    memo = "Dining Hall " .. label .. " (sat +" .. string.format("%.1f", gain) .. ", treasury fallback if needed)",
  }, 6)

  if ok and type(res) == "table" then
    local pay = decodeMealPayment(res, amount)

    stats.meals_charged = stats.meals_charged + 1
    stats.dining_revenue = stats.dining_revenue + pay.company_received
    stats.citizen_paid = stats.citizen_paid + pay.citizen_paid
    stats.treasury_covered = stats.treasury_covered + pay.treasury_paid
    stats.unpaid = stats.unpaid + pay.uncovered
    stats.last_meal_charge = pay.company_received
    stats.last_citizen_paid = pay.citizen_paid
    stats.last_treasury_covered = pay.treasury_paid
    stats.last_uncovered = pay.uncovered

    if pay.uncovered > 0 then
      state.receivables = state.receivables or {}
      state.receivables[citizen_id] = (tonumber(state.receivables[citizen_id]) or 0) + pay.uncovered
    end

    addEvent({
      type = "meal_charge",
      citizen_id = citizen_id,
      company_id = company_id,
      name = name,
      label = label,
      gain = gain,
      amount = amount,
      company_received = pay.company_received,
      citizen_paid = pay.citizen_paid,
      treasury_paid = pay.treasury_paid,
      uncovered = pay.uncovered,
      tx_id = pay.tx_id,
      treasury_tx_id = pay.treasury_tx_id,
      food_index = pricing.dining.food_index,
      effective_index = pricing.dining.effective_index,
    })

    if pay.uncovered > 0 then
      setMsg(tostring(name) .. " meal partly unpaid: " .. money(pay.uncovered), colors.orange)
    elseif pay.treasury_paid > 0 then
      setMsg("Meal paid " .. money(pay.company_received) .. " for " .. tostring(name) .. " (Treasury covered " .. money(pay.treasury_paid) .. ")", colors.lime)
    else
      setMsg("Meal paid " .. money(pay.company_received) .. " for " .. tostring(name), colors.lime)
    end
    return true
  end

  setMsg("Meal charge failed: " .. tostring(res), colors.red)
  return false
end

local function chargeTavernNight(person, tavern)
  local amount = roundMoney(pricing.tavern.nightly_fee)
  if amount <= 0 then return false, "Invalid nightly fee" end

  local memo = "Tavern nightly stay"
  if tavern and tavern.name then memo = memo .. " at " .. tostring(tavern.name) end
  memo = memo .. " for " .. tostring(person.name or person.key)

  local ok, res = bankReq({
    type = "tavern_night_payment",
    payer_id = person.account_id,
    guest_id = person.guest_id or person.key,
    guest_name = person.name,
    treasury_id = TREASURY_ID,
    amount = amount,
    tier = "standard",
    memo = memo,
  }, 6)

  if ok and type(res) == "table" then
    local paid = tonumber(res.paid or res.amount or amount) or amount
    stats.stays_charged = stats.stays_charged + 1
    stats.tavern_revenue = stats.tavern_revenue + paid
    stats.last_tavern_charge = paid
    stats.last_tavern_guest = tostring(person.name or person.key)
    stats.last_tavern_source = tostring(res.source or person.source)

    if res.external_guest or person.source ~= "citizen" then
      stats.tavern_guest_revenue = stats.tavern_guest_revenue + paid
    else
      stats.tavern_citizen_revenue = stats.tavern_citizen_revenue + paid
    end

    addEvent({
      type = "tavern_night",
      day = mcDay(),
      person_key = person.key,
      name = person.name,
      source = res.source or person.source,
      tavern = tavern and tavern.name or nil,
      amount = paid,
      tx_id = res.tx_id,
      price_index = pricing.tavern.hospitality_index,
      price_source = pricing.tavern.source,
    })

    setMsg("Tavern stay paid: " .. tostring(person.name) .. " -> Treasury " .. money(paid), colors.lime)
    return true
  end

  stats.tavern_failed_charges = stats.tavern_failed_charges + 1
  setMsg("Tavern charge failed for " .. tostring(person.name) .. ": " .. tostring(res), colors.red)
  return false, res
end

-- =============================================================================
-- DINING PROCESSING
-- =============================================================================
local function processDiningCitizen(z, dining)
  local cid = citizenAccountId(z)
  if not cid then return end

  local name = personName(z, cid)
  local sat = tonumber(z.saturation or z.food or z.foodLevel or z.food_level or 0) or 0
  local pos = getPos(z)
  local near = false
  local nearBuilding = nil
  local nearDistance = nil

  if #dining > 0 then
    near, nearBuilding, nearDistance = isNearBuilding(pos, dining, DINING_RADIUS)
  else
    near = true
  end

  local t = now()
  state.citizens = state.citizens or {}
  local rec = state.citizens[cid] or {}
  rec.name = name
  rec.dining_staff = isDiningStaffCitizen(z) and true or false

  if near then
    rec.near_at = t
    rec.near_building = nearBuilding and nearBuilding.name or "proximity disabled"
    rec.near_company_id = nearBuilding and nearBuilding.company_id or active_company_id or TARGET_COMPANY
    rec.near_distance = nearDistance
    stats.near_dining = stats.near_dining + 1
  end

  local oldSat = tonumber(rec.sat)
  if oldSat ~= nil then
    local gain = sat - oldSat
    if gain > MIN_SAT_GAIN then
      stats.saturation_rises = stats.saturation_rises + 1
      stats.last_gain = gain

      local amount, label = priceMeal(gain)
      if amount > 0 and auto_charge then
        local company_id = rec.near_company_id or active_company_id or TARGET_COMPANY
        if chargeCitizenMeal(cid, name, amount, label, gain, company_id) then
          rec.last_charge_at = t
          rec.last_charge_amount = amount
          rec.last_charge_label = label
          rec.last_gain = gain
        end
      end
    end
  end

  rec.sat = sat
  rec.last_seen = t
  state.citizens[cid] = rec
end

local function pruneMissingCitizens(seen)
  local cutoff = now() - (60 * 60 * 1000)
  for cid, rec in pairs(state.citizens or {}) do
    if not seen[cid] and tonumber(rec.last_seen or 0) < cutoff then
      state.citizens[cid] = nil
    end
  end
end

-- =============================================================================
-- TAVERN PROCESSING
-- =============================================================================
local function makeTavernPerson(z, source)
  local name = personName(z, source == "citizen" and "citizen" or "guest")
  if source == "citizen" then
    local cid = citizenAccountId(z)
    if not cid then return nil end
    return {
      key = cid,
      source = "citizen",
      name = name,
      account_id = cid,
      guest_id = nil,
      pos = getPos(z),
      raw = z,
    }
  end

  local gid = visitorGuestId(z)
  return {
    key = gid,
    source = "visitor",
    name = name,
    account_id = nil,
    guest_id = gid,
    pos = getPos(z),
    raw = z,
  }
end

local function processTavernPerson(person, taverns)
  if not person then return end
  local day = mcDay()
  state.tavern_stays = state.tavern_stays or {}
  local rec = state.tavern_stays[person.key] or {}

  local near = false
  local tavern = nil
  local distance = nil

  if person.pos and #taverns > 0 then
    tavern, distance = nearestBuilding(person.pos, taverns)
    if tavern and distance and distance <= TAVERN_RADIUS then near = true end
  elseif person.source == "visitor" and CHARGE_VISITORS_WITHOUT_POSITION then
    near = true
    tavern = taverns[1]
  end

  rec.name = person.name
  rec.source = person.source
  rec.last_seen = now()

  if not near then
    stats.tavern_skipped_not_near = stats.tavern_skipped_not_near + 1
    state.tavern_stays[person.key] = rec
    return
  end

  stats.near_tavern = stats.near_tavern + 1
  rec.near_at = now()
  rec.tavern = tavern and tavern.name or "visitor list"
  rec.distance = distance

  if person.source == "citizen" and isTavernStaffCitizen(person.raw) then
    stats.tavern_skipped_staff = stats.tavern_skipped_staff + 1
    state.tavern_stays[person.key] = rec
    return
  end

  if person.source == "citizen" and CHARGE_CITIZENS_ONLY_AT_NIGHT and not isNight() then
    stats.tavern_skipped_not_night = stats.tavern_skipped_not_night + 1
    state.tavern_stays[person.key] = rec
    return
  end

  if tonumber(rec.last_charged_day) == day then
    stats.tavern_already_charged_today = stats.tavern_already_charged_today + 1
    state.tavern_stays[person.key] = rec
    return
  end

  if auto_charge then
    local ok = chargeTavernNight(person, tavern)
    if ok then
      rec.last_charged_day = day
      rec.last_charged_at = now()
      rec.last_amount = pricing.tavern.nightly_fee
    end
  end

  state.tavern_stays[person.key] = rec
end

local function pruneOldTavernStays(seen)
  local cutoff = now() - (2 * 60 * 60 * 1000)
  for key, rec in pairs(state.tavern_stays or {}) do
    if not seen[key] and tonumber(rec.last_seen or 0) < cutoff then
      state.tavern_stays[key] = nil
    end
  end
end

-- =============================================================================
-- POLL LOOP
-- =============================================================================
local function resetScanStats()
  stats.citizens_seen = 0
  stats.visitors_seen = 0
  stats.buildings_seen = 0
  stats.dining_buildings = 0
  stats.near_dining = 0
  stats.saturation_rises = 0
  stats.taverns_found = 0
  stats.tavern_people_seen = 0
  stats.near_tavern = 0
  stats.tavern_already_charged_today = 0
  stats.tavern_skipped_staff = 0
  stats.tavern_skipped_not_near = 0
  stats.tavern_skipped_not_night = 0
end

local function poll()
  if not connectColony() then
    setMsg("No local colonyIntegrator on this terminal.", colors.red)
    return false
  end
  if not db_id then discoverBank() end
  refreshPricing()
  resetScanStats()

  local buildings = getLiveBuildings()
  local citizens = getLiveCitizens()
  local visitors = getLiveVisitors()

  stats.buildings_seen = countRows(buildings)
  stats.citizens_seen = countRows(citizens)
  stats.visitors_seen = countRows(visitors)

  local dining = {}
  if ENABLE_DINING then
    dining = diningBuildings(buildings)
    stats.dining_buildings = #dining

    local resolved_company, resolved_source = resolveHospitalityCompany(dining)
    active_company_id = resolved_company or TARGET_COMPANY
    active_company_source = resolved_source or "fallback"

    if #dining > 0 then active_dining_name = dining[1].name or "Dining Hall" else active_dining_name = "fallback target" end
    for _, d in ipairs(dining or {}) do d.company_id = active_company_id end

    local seenDining = {}
    for _, z in pairs(citizens or {}) do
      local cid = citizenAccountId(z)
      if cid then seenDining[cid] = true end
      processDiningCitizen(z, dining)
    end
    pruneMissingCitizens(seenDining)
  end

  if ENABLE_TAVERN then
    local taverns = tavernBuildings(buildings)
    stats.taverns_found = #taverns
    stats.tavern_people_seen = stats.citizens_seen + stats.visitors_seen

    local seenTavern = {}
    for _, z in pairs(citizens or {}) do
      local p = makeTavernPerson(z, "citizen")
      if p then
        seenTavern[p.key] = true
        processTavernPerson(p, taverns)
      end
    end

    for _, z in pairs(visitors or {}) do
      local p = makeTavernPerson(z, "visitor")
      if p then
        seenTavern[p.key] = true
        processTavernPerson(p, taverns)
      end
    end

    pruneOldTavernStays(seenTavern)
  end

  writeFile(STATE_FILE, state)

  if ENABLE_TAVERN and stats.taverns_found <= 0 and stats.visitors_seen <= 0 then
    setMsg("Scanned. Dining active; no Tavern found and no visitor list available.", colors.orange)
  elseif auto_charge then
    setMsg("Scanned NPC business transactions.", colors.lime)
  else
    setMsg("Scanned NPC business transactions. Auto charge is off.", colors.orange)
  end

  return true
end

-- =============================================================================
-- DISPLAY
-- =============================================================================
local function cls()
  W, H = term.getSize()
  term.setCursorBlink(false)
  term.setBackgroundColor(colors.black)
  term.setTextColor(colors.white)
  term.clear()
  term.setCursorPos(1, 1)
end

local function at(x, y, text, fg, bg)
  W, H = term.getSize()
  if y < 1 or y > H or x > W then return end
  if x < 1 then x = 1 end
  term.setCursorPos(x, y)
  term.setTextColor(fg or colors.white)
  term.setBackgroundColor(bg or colors.black)
  local maxw = W - x + 1
  if maxw > 0 then term.write(tostring(text or ""):sub(1, maxw)) end
end

local function fill(x, y, w, h, bg)
  W, H = term.getSize()
  if w <= 0 or h <= 0 then return end
  term.setBackgroundColor(bg or colors.black)
  local row = string.rep(" ", w)
  for yy = y, y + h - 1 do
    if yy >= 1 and yy <= H then
      term.setCursorPos(math.max(1, x), yy)
      term.write(row:sub(1, math.max(0, W - x + 1)))
    end
  end
end

local function button(x, y, w, label, bg, fg)
  fill(x, y, w, 1, bg or colors.gray)
  local tx = x + math.floor((w - #label) / 2)
  at(tx, y, label, fg or colors.white, bg or colors.gray)
  return { x1 = x, x2 = x + w - 1, y1 = y, y2 = y }
end

local function hit(b, x, y)
  return b and x >= b.x1 and x <= b.x2 and y >= b.y1 and y <= b.y2
end

local function draw()
  cls()
  fill(1, 1, W, 1, colors.purple)
  at(2, 1, "NPC BUSINESS PAYMENT TERMINAL", colors.white, colors.purple)
  at(math.max(2, W - #VERSION), 1, VERSION, colors.lightGray, colors.purple)

  at(2, 3, "Time:         " .. mctText() .. (isNight() and "  NIGHT" or "  DAY"), isNight() and colors.lime or colors.lightGray)
  at(2, 4, "Bank:         " .. tostring(db_id or "not connected"), db_id and colors.lime or colors.red)
  at(2, 5, "Colony:       " .. tostring(colony and "connected" or "missing"), colony and colors.lime or colors.red)
  at(2, 6, "Auto:         " .. (auto_charge and "ON" or "OFF") .. "   Citizens " .. tostring(stats.citizens_seen) .. " / Visitors " .. tostring(stats.visitors_seen), auto_charge and colors.lime or colors.orange)

  at(2, 8, "DINING HALL / RESTAURANT", colors.cyan)
  at(2, 9, "Company:      " .. tostring(active_company_id or TARGET_COMPANY) .. " via " .. tostring(active_company_source or "fallback"), colors.lightGray)
  at(2, 10, "Dining halls: " .. tostring(stats.dining_buildings) .. "   Near: " .. tostring(stats.near_dining) .. "   Radius: " .. tostring(DINING_RADIUS), stats.dining_buildings > 0 and colors.lime or colors.orange)
  at(2, 11, "Meal price:   " .. money(pricing.dining.normal_meal) .. "   " .. tostring(pricing.dining.tier) .. "   Food x" .. string.format("%.3f", tonumber(pricing.dining.food_index) or 1), colors.cyan)
  at(2, 12, "Meals:        " .. tostring(stats.meals_charged) .. "   Revenue: " .. money(stats.dining_revenue) .. "   Sat rises: " .. tostring(stats.saturation_rises), colors.lime)
  at(2, 13, "Paid by:      Citizens " .. money(stats.citizen_paid) .. " / Treasury " .. money(stats.treasury_covered) .. " / Unpaid " .. money(stats.unpaid), stats.unpaid > 0 and colors.orange or colors.lightGray)

  at(2, 15, "STATE TAVERN / INN", colors.orange)
  at(2, 16, "Treasury:     " .. TREASURY_ID .. "   Taverns: " .. tostring(stats.taverns_found) .. "   Radius: " .. tostring(TAVERN_RADIUS), stats.taverns_found > 0 and colors.lime or colors.orange)
  at(2, 17, "Nightly fee:  " .. money(pricing.tavern.nightly_fee) .. "   " .. tostring(pricing.tavern.tier) .. "   Hosp x" .. string.format("%.3f", tonumber(pricing.tavern.hospitality_index) or 1), colors.cyan)
  at(2, 18, "Eligible:     Near " .. tostring(stats.near_tavern) .. "   Already today " .. tostring(stats.tavern_already_charged_today) .. "   Skipped day " .. tostring(stats.tavern_skipped_not_night), colors.lightGray)
  at(2, 19, "Stays:        " .. tostring(stats.stays_charged) .. "   Treasury revenue: " .. money(stats.tavern_revenue), colors.lime)
  at(2, 20, "Revenue src:  Citizens " .. money(stats.tavern_citizen_revenue) .. " / External guests " .. money(stats.tavern_guest_revenue), colors.lightGray)
  at(2, 21, "Last stay:    " .. tostring(stats.last_tavern_guest or "") .. " " .. money(stats.last_tavern_charge) .. " (" .. tostring(stats.last_tavern_source or "") .. ")", colors.gray)

  local third = math.floor((W - 8) / 3)
  local bScan = button(2, H - 3, third, "Poll Now", colors.purple)
  local bAuto = button(4 + third, H - 3, third, auto_charge and "Auto Off" or "Auto On", colors.gray)
  local bRecon = button(6 + third * 2, H - 3, third, "Reconnect", colors.gray)

  at(2, H - 1, tostring(last_message):sub(1, W - 2), last_colour)
  return bScan, bAuto, bRecon
end

-- =============================================================================
-- MAIN
-- =============================================================================
local function loadConfig()
  local cfg = readFile(CONFIG_FILE)
  if type(cfg) ~= "table" then return end

  if tonumber(cfg.scan_seconds) then SCAN_SECONDS = math.max(1, tonumber(cfg.scan_seconds)) end
  if tonumber(cfg.dining_radius) then DINING_RADIUS = math.max(4, tonumber(cfg.dining_radius)) end
  if tonumber(cfg.tavern_radius) then TAVERN_RADIUS = math.max(4, tonumber(cfg.tavern_radius)) end
  if cfg.auto_charge ~= nil then auto_charge = cfg.auto_charge and true or false end
  if cfg.enable_dining ~= nil then ENABLE_DINING = cfg.enable_dining and true or false end
  if cfg.enable_tavern ~= nil then ENABLE_TAVERN = cfg.enable_tavern and true or false end
  if cfg.charge_visitors_without_position ~= nil then CHARGE_VISITORS_WITHOUT_POSITION = cfg.charge_visitors_without_position and true or false end
  if cfg.charge_citizens_only_at_night ~= nil then CHARGE_CITIZENS_ONLY_AT_NIGHT = cfg.charge_citizens_only_at_night and true or false end

  if cfg.target_company or cfg.company_id then
    local t = tostring(cfg.target_company or cfg.company_id)
    if t ~= "" then
      if not t:find("^company:") then t = companyIdFromName(t) or t end
      TARGET_COMPANY = t
      active_company_id = TARGET_COMPANY
      active_dining_name = "config override"
    end
  end
end

local function saveConfig()
  writeFile(CONFIG_FILE, {
    scan_seconds = SCAN_SECONDS,
    dining_radius = DINING_RADIUS,
    tavern_radius = TAVERN_RADIUS,
    auto_charge = auto_charge,
    enable_dining = ENABLE_DINING,
    enable_tavern = ENABLE_TAVERN,
    charge_visitors_without_position = CHARGE_VISITORS_WITHOUT_POSITION,
    charge_citizens_only_at_night = CHARGE_CITIZENS_ONLY_AT_NIGHT,
    target_company = TARGET_COMPANY,
  })
end

local function main()
  local loaded = readFile(STATE_FILE)
  if type(loaded) == "table" then state = loaded end
  state.citizens = type(state.citizens) == "table" and state.citizens or {}
  state.receivables = type(state.receivables) == "table" and state.receivables or {}
  state.tavern_stays = type(state.tavern_stays) == "table" and state.tavern_stays or {}
  state.events = type(state.events) == "table" and state.events or {}

  loadConfig()

  if not openModem() then
    print("No modem found.")
    return
  end

  discoverBank()
  connectColony()
  poll()

  local bScan, bAuto, bRecon = draw()
  local timer = os.startTimer(SCAN_SECONDS)

  while true do
    local ev, p1, p2, p3 = os.pullEvent()

    if ev == "timer" and p1 == timer then
      if auto_charge then poll() end
      bScan, bAuto, bRecon = draw()
      timer = os.startTimer(SCAN_SECONDS)

    elseif ev == "mouse_click" then
      if hit(bScan, p2, p3) then
        poll()
      elseif hit(bAuto, p2, p3) then
        auto_charge = not auto_charge
        saveConfig()
        setMsg("Auto " .. (auto_charge and "on" or "off"), colors.yellow)
      elseif hit(bRecon, p2, p3) then
        discoverBank()
        connectColony()
        refreshPricing()
        setMsg("Reconnected.", colors.lime)
      end
      bScan, bAuto, bRecon = draw()

    elseif ev == "terminate" then
      writeFile(STATE_FILE, state)
      saveConfig()
      break
    end
  end
end

local ok, err = pcall(main)
if not ok then
  term.setTextColor(colors.red)
  print("Runtime error: " .. tostring(err))
end

local function saveHistory()
  while #history.events > 500 do table.remove(history.events, 1) end
  while #history.unpaid > 500 do table.remove(history.unpaid, 1) end
  writeFile(FILE_HISTORY, history)
end

local function dayRec()
  local key = tostring(mcDay())
  history.days[key] = history.days[key] or {
    day = mcDay(),
    events = 0,
    matched = 0,
    charged = 0,
    unpaid = 0,
    unattributed = 0,
    created = now(),
  }
  return history.days[key]
end

local function chargeCitizenMeal(ev, pending)
  local company_id, company_name = hospitalityCompany()
  if not company_id or company_id == "" or company_id == "unresolved" then
    setMsg("Dining Hall company unresolved. Need building_companies.db mapping.", colors.red)
    return false
  end

  local amount = math.floor(tonumber(pending.total_value) or 0)
  if amount < 1 then amount = 1 end

  local ok, res = bankReq({
    type = "hospitality_meal_payment",
    citizen_id = ev.citizen_id,
    company_id = company_id,
    amount = amount,
    item = pending.summary,
    memo = "Dining Hall meal: " .. pending.summary,
  }, 6)

  local rec = dayRec()
  rec.events = (rec.events or 0) + 1
  rec.matched = (rec.matched or 0) + 1

  local paid = 0
  local shortfall = amount

  if ok and type(res) == "table" then
    paid = tonumber(res.paid) or 0
    shortfall = tonumber(res.shortfall) or 0

    rec.charged = (rec.charged or 0) + paid
    rec.unpaid = (rec.unpaid or 0) + shortfall

    history.events[#history.events+1] = {
      time = now(),
      day = mcDay(),
      type = "dining_hall_service",
      citizen_id = ev.citizen_id,
      citizen_name = ev.name,
      company_id = company_id,
      company_name = company_name,
      amount = amount,
      paid = paid,
      shortfall = shortfall,
      losses = pending.losses,
      summary = pending.summary,
      saturation_delta = ev.delta,
      tx_id = res.tx_id,
    }

    if shortfall > 0 then
      history.unpaid[#history.unpaid+1] = {
        time = now(),
        day = mcDay(),
        citizen_id = ev.citizen_id,
        citizen_name = ev.name,
        company_id = company_id,
        amount = shortfall,
        summary = pending.summary,
      }
    end

    stats.matched_today = rec.matched
    stats.charged_today = rec.charged
    stats.unpaid_today = rec.unpaid

    setMsg(ev.name .. " charged " .. money(paid) .. " for " .. pending.summary .. (shortfall > 0 and (" / unpaid " .. money(shortfall)) or ""), shortfall > 0 and colors.orange or colors.lime)
    return true
  end

  history.events[#history.events+1] = {
    time = now(),
    day = mcDay(),
    type = "dining_hall_payment_failed",
    citizen_id = ev.citizen_id,
    citizen_name = ev.name,
    company_id = company_id,
    amount = amount,
    error = tostring(res),
    losses = pending.losses,
    summary = pending.summary,
  }

  setMsg("Payment failed: " .. tostring(res), colors.red)
  return false
end

local function recordUnattributed(pending)
  local rec = dayRec()
  rec.events = (rec.events or 0) + 1
  rec.unattributed = (rec.unattributed or 0) + (tonumber(pending.total_qty) or 0)

  history.events[#history.events+1] = {
    time = now(),
    day = mcDay(),
    type = "unattributed_dining_hall_consumption",
    total_qty = pending.total_qty,
    total_value = pending.total_value,
    losses = pending.losses,
    summary = pending.summary,
  }

  stats.unattributed_today = rec.unattributed
  setMsg("Food consumed but no saturation match: " .. pending.summary, colors.orange)
end

local function summarizeLosses(losses)
  if #losses == 0 then return "food" end
  local parts = {}
  for _, l in ipairs(losses) do
    parts[#parts+1] = tostring(l.qty) .. "x " .. tostring(l.item)
  end
  return table.concat(parts, ", ")
end

-- =============================================================================
-- SCANNING
-- =============================================================================
local function processDueFoodEvents()
  local t = now()
  local keep = {}

  local eat_delay = msFromTicks(config.eat_delay_ticks or DEFAULT_EAT_DELAY_TICKS)
  local extra = msFromTicks(config.match_window_extra_ticks or MATCH_WINDOW_EXTRA_TICKS)

  for _, pending in ipairs(pending_food_events) do
    if t >= pending.due_time then
      local match = lastSaturationIncreaseBetween(pending.detected_at, pending.due_time + extra)

      if match then
        chargeCitizenMeal(match, pending)
      else
        recordUnattributed(pending)
      end
    else
      keep[#keep+1] = pending
    end
  end

  pending_food_events = keep
  stats.pending_events = #pending_food_events
end

local function scanOnce()
  if not colony then findColony() end
  if not db_id then discoverBank() end

  local current_stock = readFoodStock()
  local current_citizens = snapshotCitizens()

  updateSaturationEvents(prev_citizens, current_citizens)

  if prev_stock then
    local losses, total_qty, total_value = stockLosses(prev_stock, current_stock)
    stats.last_food_loss = total_qty

    if total_qty > 0 then
      local t = now()
      local delay_ms = msFromTicks(config.eat_delay_ticks or DEFAULT_EAT_DELAY_TICKS)

      pending_food_events[#pending_food_events+1] = {
        detected_at = t,
        due_time = t + delay_ms,
        losses = losses,
        total_qty = total_qty,
        total_value = math.max(1, math.floor(total_value)),
        summary = summarizeLosses(losses),
      }

      stats.pending_events = #pending_food_events
      setMsg("Food decrease detected: " .. summarizeLosses(losses) .. ". Waiting for saturation increase.", colors.yellow)
    end
  end

  prev_stock = current_stock
  prev_citizens = current_citizens

  processDueFoodEvents()
  saveHistory()
end

-- =============================================================================
-- DISPLAY
-- =============================================================================
local function cls()
  term.setCursorBlink(false)
  term.setBackgroundColor(colors.black)
  term.setTextColor(colors.white)
  term.clear()
  term.setCursorPos(1, 1)
end

local function at(x, y, text, fg, bg)
  local W, H = term.getSize()
  if y < 1 or y > H or x > W then return end
  term.setCursorPos(x, y)
  term.setTextColor(fg or colors.white)
  term.setBackgroundColor(bg or colors.black)
  local maxw = W - x + 1
  if maxw > 0 then term.write(tostring(text or ""):sub(1, maxw)) end
end

local function fill(x, y, w, h, bg)
  term.setBackgroundColor(bg or colors.black)
  local W, H = term.getSize()
  local row = string.rep(" ", math.max(0, w))
  for yy = y, y + h - 1 do
    if yy >= 1 and yy <= H then
      term.setCursorPos(x, yy)
      term.write(row:sub(1, math.max(0, W - x + 1)))
    end
  end
end

local function button(x, y, w, label, bg, fg)
  fill(x, y, w, 1, bg or colors.gray)
  local tx = x + math.floor((w - #label) / 2)
  at(tx, y, label, fg or colors.white, bg or colors.gray)
  return { x1 = x, x2 = x + w - 1, y1 = y, y2 = y }
end

local function hit(b, mx, my)
  return b and mx >= b.x1 and mx <= b.x2 and my >= b.y1 and my <= b.y2
end

local function draw()
  local W, H = term.getSize()
  cls()

  fill(1, 1, W, 1, colors.purple)
  at(2, 1, "SERVICE PAYMENT TERMINAL", colors.white, colors.purple)
  at(math.max(2, W - #VERSION), 1, VERSION, colors.lightGray, colors.purple)

  local company_id, company_name = hospitalityCompany()
  local rec = dayRec()

  at(2, 3, "Service:      Dining Hall", colors.white)
  at(2, 4, "Colony:       " .. tostring(colony_name), colors.lightGray)
  at(2, 5, "Bank:         " .. tostring(db_id or "not connected"), db_id and colors.lime or colors.red)
  at(2, 6, "Company:      " .. tostring(company_name) .. " (" .. tostring(company_id) .. ")", colors.lime)
  at(2, 7, "Auto charge:  " .. (auto_charge and "ON" or "OFF"), auto_charge and colors.lime or colors.orange)

  at(2, 9,  "Stock sources:        " .. tostring(stats.stock_sources), stats.stock_sources > 0 and colors.lime or colors.orange)
  at(2, 10, "Citizens seen:        " .. tostring(stats.citizens_seen or 0), (stats.citizens_seen or 0) > 0 and colors.lime or colors.orange)
  at(2, 11, "Citizen inv sources:  " .. tostring(stats.citizen_inventory_sources or 0), (stats.citizen_inventory_sources or 0) > 0 and colors.lime or colors.orange)
  at(2, 12, "Waiter/Cook sources:  " .. tostring(stats.worker_stock_sources or 0), (stats.worker_stock_sources or 0) > 0 and colors.lime or colors.orange)
  at(2, 13, "Tracked kinds/units:  " .. tostring(stats.food_kinds) .. " / " .. tostring(stats.food_units), colors.white)
  at(2, 14, "Last food decrease:   " .. tostring(stats.last_food_loss), stats.last_food_loss > 0 and colors.yellow or colors.gray)
  at(2, 15, "Pending food events:  " .. tostring(#pending_food_events), #pending_food_events > 0 and colors.yellow or colors.gray)
  at(2, 16, "Saturation events:    " .. tostring(#saturation_events), colors.cyan)

  at(2, 18, "Matched meals today:  " .. tostring(rec.matched or 0), colors.white)
  at(2, 19, "Charged today:        " .. money(rec.charged or 0), colors.lime)
  at(2, 20, "Unpaid receivable:    " .. money(rec.unpaid or 0), (rec.unpaid or 0) > 0 and colors.orange or colors.gray)
  at(2, 21, "Unattributed food:    " .. tostring(rec.unattributed or 0) .. " units", (rec.unattributed or 0) > 0 and colors.orange or colors.gray)

  -- Inventory discovery note removed to keep the screen compact.

  local third = math.floor((W - 8) / 3)
  local bScan = button(2, H - 3, third, "Scan Now", colors.purple)
  local bAuto = button(4 + third, H - 3, third, auto_charge and "Auto Off" or "Auto On", colors.gray)
  local bRecon = button(6 + (third * 2), H - 3, third, "Reconnect", colors.gray)

  at(2, H - 1, tostring(last_message), last_colour)
  return bScan, bAuto, bRecon
end

-- =============================================================================
-- MAIN
-- =============================================================================
local function main()
  loadConfig()
  loadHistory()

  if not openModem() then
    cls()
    print("No modem found.")
    print("Attach a modem and reboot.")
    return
  end

  findColony()
  discoverBank()

  -- Initial baseline scan. Do not charge on first read.
  prev_stock = readFoodStock()
  prev_citizens = snapshotCitizens()

  local bScan, bAuto, bRecon = draw()
  local timer = os.startTimer(tickSeconds(config.scan_interval_ticks or DEFAULT_SCAN_INTERVAL_TICKS))

  while true do
    local ev, p1, p2, p3 = os.pullEvent()

    if ev == "timer" and p1 == timer then
      if auto_charge then scanOnce() end
      bScan, bAuto, bRecon = draw()
      timer = os.startTimer(tickSeconds(config.scan_interval_ticks or DEFAULT_SCAN_INTERVAL_TICKS))

    elseif ev == "mouse_click" then
      local mx, my = p2, p3
      if hit(bScan, mx, my) then
        scanOnce()
      elseif hit(bAuto, mx, my) then
        auto_charge = not auto_charge
        saveConfig()
        setMsg("Auto charge " .. (auto_charge and "enabled" or "disabled"), auto_charge and colors.lime or colors.orange)
      elseif hit(bRecon, mx, my) then
        findColony()
        discoverBank()
        setMsg("Reconnected.", colors.lime)
      end
      bScan, bAuto, bRecon = draw()

    elseif ev == "terminate" then
      saveHistory()
      saveConfig()
      break
    end
  end
end

local ok, err = pcall(main)
if not ok then
  term.setCursorBlink(false)
  term.setTextColor(colors.red)
  print("Runtime error: " .. tostring(err))
end

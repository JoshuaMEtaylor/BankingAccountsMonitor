-- =============================================================================
-- SERVICE PAYMENT TERMINAL
-- ServicePaymentTerminal
--
-- v1.2.5-HALLOWAY-DINING-TARGET
--
-- Dining Hall / Restaurant point-of-sale for MineColonies citizens.
--
-- This does NOT try to read waiter/cook inventories. MineColonies keeps food on
-- the worker, and the Colony Integrator does not expose that inventory in a
-- useful way. Instead this terminal watches citizen saturation changes:
--
--   hungry citizen near Dining Hall + saturation gain = inferred meal served
--
-- Price is calculated by the bank's wide sector price oracle:
--   1. saturation gain tier, as the quantity/meal-size proxy
--   2. Food CPI / Hospitality sector pressure
--   3. current positive inflation_rate as an immediate price-pressure floor
--
-- Payment route:
--   citizen account -> detected Dining Hall company account via bank hospitality_meal_payment endpoint
-- =============================================================================

local args = {...}

if args[1] ~= "--updated" then
  print("[ Service Payment Terminal ]")
  print("Deleting old version...")
  fs.delete("startup.lua")
  print("Downloading latest from GitHub...")
  local cb = tostring(os.epoch and os.epoch("utc") or math.floor(os.clock() * 100000))
  local url = "https://raw.githubusercontent.com/JoshuaMEtaylor/BankingAccountsMonitor/refs/heads/main/ServicePaymentTerminal?cb=" .. cb
  shell.run("wget " .. url .. " startup.lua")
  if not fs.exists("startup.lua") then
    print("Download failed. Expected GitHub file: ServicePaymentTerminal")
    return
  end
  print("Relaunching...")
  sleep(0.5)
  shell.run("startup.lua", "--updated")
  return
end


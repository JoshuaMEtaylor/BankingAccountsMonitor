-- =============================================================================
-- SERVICE PAYMENT TERMINAL
-- ServicePaymentTerminal
--
-- v1.1.4-DIRECT-COLONY-EMPLOYEE-INVENTORY
--
-- This version is for a terminal that has its OWN colonyIntegrator attached.
--
-- It uses:
--   1. local colonyIntegrator.getCitizens()
--   2. bank list_company_payroll_payees for company:grki
--   3. direct recursive scan of those employees' live citizen tables
--
-- It does not use local company mapping files or industry fallback state.
-- =============================================================================

local args = {...}

if args[1] ~= "--updated" then
  print("[ Service Payment Terminal ]")
  print("Deleting old version...")
  fs.delete("startup.lua")
  print("Downloading latest from GitHub...")
  local cb = tostring(os.epoch and os.epoch("utc") or math.floor(os.clock() * 100000))
  local url = "https://raw.githubusercontent.com/JoshuaMEtaylor/BankingAccountsMonitor/refs/heads/main/ServicePaymentTerminal?cb=" .. cb
  shell.run("wget " .. url .. " startup.lua")
  if not fs.exists("startup.lua") then
    print("Download failed. Expected GitHub file: ServicePaymentTerminal")
    return
  end
  print("Relaunching...")
  sleep(0.5)
  shell.run("startup.lua", "--updated")
  return
end

local VERSION = "1.1.4-DIRECT-COLONY-EMPLOYEE-INVENTORY"
local BANK_PROTOCOL = "quid_bank"
local TARGET_COMPANY = "company:grki"

local SCAN_SECONDS = 2
local EAT_DELAY_SECONDS = 2
local MATCH_WINDOW_SECONDS = 6
local SAT_DELTA_MIN = 0.50

local db_id = nil
local colony = nil
local auto_charge = true
local last_message = "Booting..."
local last_colour = colors.lightGray

local prev_stock = nil
local prev_citizens = nil
local pending_food = {}
local sat_events = {}

local stats = {
  citizens_seen = 0,
  payroll_employees = 0,
  employees_live_seen = 0,
  employee_inv_sources = 0,
  stock_kinds = 0,
  stock_units = 0,
  last_loss = 0,
  pending = 0,
  sat_events = 0,
  matched = 0,
  charged = 0,
  unpaid = 0,
  unattributed = 0,
}

local function now()
  return os.epoch("utc")
end

local function lower(s)
  return string.lower(tostring(s or ""))
end

local function setMsg(msg, col)
  last_message = tostring(msg or "")
  last_colour = col or colors.lightGray
end

local function money(n)
  n = tonumber(n) or 0
  local sign = ""
  if n < 0 then sign = "-"; n = math.abs(n) end
  return sign .. tostring(math.floor(n + 0.5)) .. " Q"
end

local function simpleItemName(name)
  name = tostring(name or "")
  name = name:gsub("^minecraft:", "")
  name = name:gsub("^minecolonies:", "")
  name = name:gsub("^%w+:", "")
  return lower(name)
end

local function isCoalOrCharcoal(item)
  local id = simpleItemName(item)
  return id == "coal"
    or id == "charcoal"
    or id == "coal_block"
    or id == "block_of_coal"
    or id:find("coal_block", 1, true)
    or id:find("charcoal", 1, true)
end

local function openModem()
  for _, n in ipairs(peripheral.getNames()) do
    if peripheral.getType(n) == "modem" then
      rednet.open(n)
      return true
    end
  end
  return false
end

local function connectColony()
  colony = peripheral.find("colonyIntegrator") or peripheral.find("colony_integrator")
  return colony ~= nil
end

local function discoverBank()
  for _ = 1, 5 do
    rednet.broadcast({ type = "ping" }, BANK_PROTOCOL)
    local sender, msg = rednet.receive(BANK_PROTOCOL, 2)
    if sender and type(msg) == "table" and (msg.type == "treasury_online" or msg.success == true) then
      db_id = sender
      return true
    end
  end
  return false
end

local function bankReq(req, timeout)
  timeout = timeout or 6
  if not db_id then discoverBank() end
  if not db_id then return false, "No bank server connected" end

  rednet.send(db_id, req, BANK_PROTOCOL)
  local deadline = os.clock() + timeout

  while true do
    local rem = deadline - os.clock()
    if rem <= 0 then return false, "No response from bank" end
    local sender, msg = rednet.receive(BANK_PROTOCOL, rem)
    if sender == db_id and type(msg) == "table" and msg.success ~= nil then
      return msg.success, msg.response
    end
  end
end

local function citizenStableId(z)
  if type(z) ~= "table" then return nil end
  local id = z.id or z.citizen_id or z.citizenId or z.uuid or z.name
  if id == nil then return nil end
  return tostring(id)
end

local function citizenUsername(z)
  local id = citizenStableId(z)
  if not id then return nil end
  id = id:gsub("[^%w_%-]", "_")
  if id:find("^mc_") then return id end
  return "mc_" .. id
end

local function citizenAccountId(z)
  local u = citizenUsername(z)
  if not u then return nil end
  return "citizen:" .. u
end

local function serviceSaturation(z)
  return tonumber(z and (z.saturation or z.food or z.foodLevel or z.food_level) or 0) or 0
end

local function scanValueForInventory(v, counts, depth, seen)
  if type(v) ~= "table" then return end
  depth = depth or 0
  if depth > 7 then return end
  seen = seen or {}
  if seen[v] then return end
  seen[v] = true

  local item_name = v.name or v.item or v.id or v.item_id or v.itemName or v.displayName or v.display
  local qty = v.count or v.qty or v.amount or v.size or v.quantity

  if item_name ~= nil and qty ~= nil then
    qty = tonumber(qty) or 0
    if qty > 0 and not isCoalOrCharcoal(item_name) then
      local id = simpleItemName(item_name)
      counts[id] = (counts[id] or 0) + qty
    end
  end

  local keys = {
    "inventory", "items", "stacks", "contents", "mainInventory",
    "main_inventory", "heldItems", "held_items", "food", "foods",
    "slots", "backpack", "equipment", "armor", "offhand",
    "hand", "mainHand", "mainhand", "heldItem", "held_item"
  }

  for _, k in ipairs(keys) do
    if type(v[k]) == "table" then
      scanValueForInventory(v[k], counts, depth + 1, seen)
    end
  end

  for k, child in pairs(v) do
    if type(k) == "number" and type(child) == "table" then
      scanValueForInventory(child, counts, depth + 1, seen)
    end
  end
end

local function getLiveCitizens()
  if not colony or type(colony.getCitizens) ~= "function" then return {} end
  local ok, citizens = pcall(colony.getCitizens)
  if ok and type(citizens) == "table" then return citizens end
  return {}
end

local function getPayrollEmployees()
  local set = {}
  local rows = {}

  local ok, res = bankReq({
    type = "list_company_payroll_payees",
    company_id = TARGET_COMPANY,
    limit = 3000,
  }, 6)

  if ok and type(res) == "table" and type(res.payees) == "table" then
    for _, e in ipairs(res.payees) do
      local cid = tostring(e.citizen_id or "")
      if cid ~= "" then
        set[cid] = e
        rows[#rows + 1] = e
      end
    end
    return set, rows, "ledger_company_payroll"
  end

  ok, res = bankReq({ type = "list_employee_mappings", include_inactive = false }, 6)
  if ok and type(res) == "table" and type(res.employees) == "table" then
    for _, e in ipairs(res.employees) do
      if type(e) == "table" and e.active ~= false and tostring(e.company_id or "") == TARGET_COMPANY then
        local cid = tostring(e.citizen_id or "")
        if cid ~= "" then
          set[cid] = e
          rows[#rows + 1] = e
        end
      end
    end
    return set, rows, "fallback_employee_mappings"
  end

  return set, rows, "none"
end

local function stockStats(t)
  local kinds, units = 0, 0
  for _, q in pairs(t or {}) do
    if (tonumber(q) or 0) > 0 then
      kinds = kinds + 1
      units = units + (tonumber(q) or 0)
    end
  end
  return kinds, units
end

local function unitPrice(item)
  local id = lower(item)
  if id:find("golden_carrot", 1, true) or id:find("cake", 1, true) or id:find("rabbit_stew", 1, true) then return 4 end
  if id:find("steak", 1, true) or id:find("cooked_beef", 1, true) or id:find("cooked_porkchop", 1, true) or id:find("cooked_salmon", 1, true) then return 3 end
  if id:find("cooked_", 1, true) or id:find("bread", 1, true) or id:find("pie", 1, true) or id:find("stew", 1, true) or id:find("soup", 1, true) then return 2 end
  return 1
end

local function stockLoss(old, new)
  local losses, total_qty, total_value = {}, 0, 0

  for item, oldQty in pairs(old or {}) do
    local newQty = tonumber((new or {})[item]) or 0
    oldQty = tonumber(oldQty) or 0

    if newQty < oldQty then
      local qty = oldQty - newQty
      local unit = unitPrice(item)
      losses[#losses + 1] = { item = item, qty = qty, unit = unit, value = qty * unit }
      total_qty = total_qty + qty
      total_value = total_value + (qty * unit)
    end
  end

  return losses, total_qty, total_value
end

local function summary(losses)
  local out = {}
  for _, l in ipairs(losses or {}) do
    out[#out + 1] = tostring(l.qty) .. "x " .. tostring(l.item)
  end
  if #out == 0 then return "meal" end
  return table.concat(out, ", ")
end

local function citizenMap(citizens)
  local out = {}
  for _, z in ipairs(citizens or {}) do
    local cid = citizenAccountId(z)
    if cid then
      out[cid] = {
        name = tostring(z.name or z.display_name or cid),
        saturation = serviceSaturation(z),
      }
    end
  end
  return out
end

local function updateSaturationEvents(old, new)
  local t = now()

  for id, z in pairs(new or {}) do
    local p = (old or {})[id]
    if p then
      local delta = (tonumber(z.saturation) or 0) - (tonumber(p.saturation) or 0)
      if delta >= SAT_DELTA_MIN then
        sat_events[#sat_events + 1] = {
          time = t,
          citizen_id = id,
          name = z.name,
          delta = delta,
        }
      end
    end
  end

  local keep = {}
  local max_age = (MATCH_WINDOW_SECONDS + EAT_DELAY_SECONDS + 4) * 1000
  for _, ev in ipairs(sat_events) do
    if t - ev.time <= max_age then keep[#keep + 1] = ev end
  end
  sat_events = keep
  stats.sat_events = #sat_events
end

local function findLastSat(start_ms, end_ms)
  local best = nil
  for _, ev in ipairs(sat_events) do
    if ev.time >= start_ms and ev.time <= end_ms then
      if not best or ev.time > best.time then best = ev end
    end
  end
  return best
end

local function processPending()
  local t = now()
  local keep = {}

  for _, p in ipairs(pending_food) do
    if t >= p.due then
      local ev = findLastSat(p.detected_at, p.due + (MATCH_WINDOW_SECONDS * 1000))

      if ev then
        local amount = math.max(1, math.floor(p.value or 1))
        local ok, res = bankReq({
          type = "hospitality_meal_payment",
          citizen_id = ev.citizen_id,
          company_id = TARGET_COMPANY,
          amount = amount,
          item = p.summary,
          memo = "Dining Hall meal: " .. p.summary,
        }, 6)

        if ok and type(res) == "table" then
          stats.matched = stats.matched + 1
          stats.charged = stats.charged + (tonumber(res.paid) or 0)
          stats.unpaid = stats.unpaid + (tonumber(res.shortfall) or 0)
          setMsg("Charged " .. tostring(ev.name) .. " " .. money(res.paid or 0) .. " for " .. p.summary, colors.lime)
        else
          setMsg("Meal payment failed: " .. tostring(res), colors.red)
          keep[#keep + 1] = p
        end
      else
        stats.unattributed = stats.unattributed + (tonumber(p.qty) or 0)
        setMsg("Stock decrease had no saturation match: " .. p.summary, colors.orange)
      end
    else
      keep[#keep + 1] = p
    end
  end

  pending_food = keep
  stats.pending = #pending_food
end

local function poll()
  if not connectColony() then
    setMsg("No local colonyIntegrator on this terminal.", colors.red)
    return
  end

  local citizens = getLiveCitizens()
  local employee_set, employees, source = getPayrollEmployees()

  stats.citizens_seen = #citizens
  stats.payroll_employees = #employees
  stats.employees_live_seen = 0
  stats.employee_inv_sources = 0

  local stock = {}

  for _, z in ipairs(citizens) do
    local cid = citizenAccountId(z)
    if cid and employee_set[cid] then
      stats.employees_live_seen = stats.employees_live_seen + 1

      local before_units = 0
      for _, q in pairs(stock) do before_units = before_units + (tonumber(q) or 0) end

      scanValueForInventory(z, stock, 0, {})

      local after_units = 0
      for _, q in pairs(stock) do after_units = after_units + (tonumber(q) or 0) end

      if after_units > before_units then
        stats.employee_inv_sources = stats.employee_inv_sources + 1
      end
    end
  end

  local cits = citizenMap(citizens)
  updateSaturationEvents(prev_citizens, cits)

  if prev_stock then
    local losses, qty, value = stockLoss(prev_stock, stock)
    stats.last_loss = qty

    if qty > 0 then
      pending_food[#pending_food + 1] = {
        detected_at = now(),
        due = now() + (EAT_DELAY_SECONDS * 1000),
        losses = losses,
        qty = qty,
        value = math.max(1, value),
        summary = summary(losses),
      }
      setMsg("Employee inventory decrease: " .. summary(losses), colors.yellow)
    end
  else
    setMsg("Baseline taken from direct colony employee scan.", colors.lime)
  end

  prev_stock = stock
  prev_citizens = cits
  stats.stock_kinds, stats.stock_units = stockStats(stock)

  processPending()
end

local function cls()
  term.setCursorBlink(false)
  term.setBackgroundColor(colors.black)
  term.setTextColor(colors.white)
  term.clear()
  term.setCursorPos(1, 1)
end

local function at(x, y, text, fg, bg)
  local W, H = term.getSize()
  if y < 1 or y > H then return end
  term.setCursorPos(x, y)
  term.setTextColor(fg or colors.white)
  term.setBackgroundColor(bg or colors.black)
  term.write(tostring(text or ""):sub(1, W - x + 1))
end

local function fill(x, y, w, h, bg)
  term.setBackgroundColor(bg or colors.black)
  local row = string.rep(" ", math.max(0, w))
  for yy = y, y + h - 1 do
    term.setCursorPos(x, yy)
    term.write(row)
  end
end

local function button(x, y, w, label, bg, fg)
  fill(x, y, w, 1, bg or colors.gray)
  at(x + math.floor((w - #label) / 2), y, label, fg or colors.white, bg or colors.gray)
  return { x1 = x, x2 = x + w - 1, y1 = y, y2 = y }
end

local function hit(b, x, y)
  return b and x >= b.x1 and x <= b.x2 and y >= b.y1 and y <= b.y2
end

local function draw()
  local W, H = term.getSize()
  cls()
  fill(1, 1, W, 1, colors.purple)
  at(2, 1, "SERVICE PAYMENT TERMINAL", colors.white, colors.purple)
  at(math.max(2, W - #VERSION), 1, VERSION, colors.lightGray, colors.purple)

  at(2, 3, "Source:       local colonyIntegrator", colors.white)
  at(2, 4, "Bank:         " .. tostring(db_id or "not connected"), db_id and colors.lime or colors.red)
  at(2, 5, "Colony:       " .. tostring(colony and "connected" or "missing"), colony and colors.lime or colors.red)
  at(2, 6, "Company:      " .. TARGET_COMPANY, colors.lime)

  at(2, 8,  "Citizens seen:       " .. tostring(stats.citizens_seen), stats.citizens_seen > 0 and colors.lime or colors.orange)
  at(2, 9,  "Payroll employees:   " .. tostring(stats.payroll_employees), stats.payroll_employees > 0 and colors.lime or colors.orange)
  at(2, 10, "Employees live seen: " .. tostring(stats.employees_live_seen), stats.employees_live_seen > 0 and colors.lime or colors.orange)
  at(2, 11, "Employee inv sources:" .. tostring(stats.employee_inv_sources), stats.employee_inv_sources > 0 and colors.lime or colors.orange)
  at(2, 12, "Stock kinds/units:   " .. tostring(stats.stock_kinds) .. " / " .. tostring(stats.stock_units), stats.stock_units > 0 and colors.lime or colors.orange)
  at(2, 13, "Last stock decrease: " .. tostring(stats.last_loss), stats.last_loss > 0 and colors.yellow or colors.gray)
  at(2, 14, "Pending meals:       " .. tostring(stats.pending), stats.pending > 0 and colors.yellow or colors.gray)
  at(2, 15, "Saturation events:   " .. tostring(stats.sat_events), colors.cyan)

  at(2, 17, "Matched: " .. tostring(stats.matched) .. "  Charged: " .. money(stats.charged) .. "  Unpaid: " .. money(stats.unpaid), colors.lime)
  at(2, 18, "Unattributed:        " .. tostring(stats.unattributed), stats.unattributed > 0 and colors.orange or colors.gray)

  local third = math.floor((W - 8) / 3)
  local bScan = button(2, H - 3, third, "Poll Now", colors.purple)
  local bAuto = button(4 + third, H - 3, third, auto_charge and "Auto Off" or "Auto On", colors.gray)
  local bRecon = button(6 + third * 2, H - 3, third, "Reconnect", colors.gray)

  at(2, H - 1, last_message, last_colour)
  return bScan, bAuto, bRecon
end

local function main()
  if not openModem() then
    print("No modem found.")
    return
  end

  discoverBank()
  connectColony()
  poll()

  local bScan, bAuto, bRecon = draw()
  local timer = os.startTimer(SCAN_SECONDS)

  while true do
    local ev, p1, p2, p3 = os.pullEvent()

    if ev == "timer" and p1 == timer then
      if auto_charge then poll() end
      bScan, bAuto, bRecon = draw()
      timer = os.startTimer(SCAN_SECONDS)

    elseif ev == "mouse_click" then
      if hit(bScan, p2, p3) then
        poll()
      elseif hit(bAuto, p2, p3) then
        auto_charge = not auto_charge
        setMsg("Auto " .. (auto_charge and "on" or "off"), colors.yellow)
      elseif hit(bRecon, p2, p3) then
        discoverBank()
        connectColony()
        setMsg("Reconnected.", colors.lime)
      end
      bScan, bAuto, bRecon = draw()

    elseif ev == "terminate" then
      break
    end
  end
end

local ok, err = pcall(main)
if not ok then
  term.setTextColor(colors.red)
  print("Runtime error: " .. tostring(err))
end

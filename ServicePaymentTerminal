local function addEvent(ev)
  state.events = state.events or {}
  ev.time = ev.time or now()
  state.events[#state.events + 1] = ev
  local keep = {}
  local cutoff = now() - (30 * 60 * 1000)
  for _, e in ipairs(state.events) do
    if tonumber(e.time) and tonumber(e.time) >= cutoff then keep[#keep + 1] = e end
  end
  state.events = keep
end

local function totalReceivables()
  local total = 0
  for _, n in pairs(state.receivables or {}) do total = total + (tonumber(n) or 0) end
  return total
end

local function chargeCitizenMeal(citizen_id, name, amount, label, gain, company_id)
  company_id = company_id or active_company_id or TARGET_COMPANY
  local ok, res = bankReq({
    type = "hospitality_meal_payment",
    citizen_id = citizen_id,
    company_id = company_id,
    amount = amount,
    item = label,
    memo = "Dining Hall " .. label .. " (sat +" .. string.format("%.1f", gain) .. ", CPI x" .. string.format("%.3f", pricing.effective_index) .. ")",
  }, 6)

  if ok and type(res) == "table" then
    local paid = tonumber(res.paid) or 0
    local shortfall = tonumber(res.shortfall) or 0

    stats.meals_charged = stats.meals_charged + 1
    stats.charged = stats.charged + paid
    stats.unpaid = stats.unpaid + shortfall
    stats.last_charge = paid

    if shortfall > 0 then
      state.receivables = state.receivables or {}
      state.receivables[citizen_id] = (tonumber(state.receivables[citizen_id]) or 0) + shortfall
    end

    addEvent({
      type = "meal_charge",
      citizen_id = citizen_id,
      company_id = company_id,
      name = name,
      label = label,
      gain = gain,
      amount = amount,
      paid = paid,
      shortfall = shortfall,
      normal_meal = pricing.normal_meal,
      food_index = pricing.food_index,
      general_index = pricing.general_index,
      effective_index = pricing.effective_index,
    })

    if paid > 0 then
      setMsg("Charged " .. tostring(name) .. " " .. money(paid) .. " to " .. tostring(company_id), colors.lime)
    else
      setMsg(tostring(name) .. " could not pay " .. money(amount) .. " for " .. label, colors.orange)
    end
    return true
  end

  setMsg("Meal charge failed: " .. tostring(res), colors.red)
  return false
end

local function processCitizen(z, dining)
  local cid = citizenAccountId(z)
  if not cid then return end

  local name = citizenName(z, cid)
  local sat = citizenSaturation(z)
  local pos = getPos(z)
  local near = false
  local nearBuilding = nil
  local nearDistance = nil

  if #dining > 0 then
    near, nearBuilding, nearDistance = isNearDining(pos, dining)
  else
    near = true
  end

  local t = now()
  state.citizens = state.citizens or {}
  local rec = state.citizens[cid] or {}
  rec.name = name
  rec.dining_staff = isDiningStaffCitizen(z) and true or false

  if near then
    rec.near_at = t
    rec.near_building = nearBuilding and nearBuilding.name or "proximity disabled"
    rec.near_company_id = nearBuilding and nearBuilding.company_id or active_company_id or TARGET_COMPANY
    rec.near_distance = nearDistance
    stats.near_dining = stats.near_dining + 1
  end

  local oldSat = tonumber(rec.sat)
  if oldSat ~= nil then
    local gain = sat - oldSat
    if gain > 0 then
      stats.saturation_rises = stats.saturation_rises + 1
      stats.last_gain = gain

      -- Current bring-up rule requested:
      -- ANY positive saturation increase means the last citizen who changed ate
      -- the current food item. Charge them the fixed base salmon price.
      -- No staff exemption, no near-dining gate, no tiering, no CPI pricing.
      local amount, label = priceMeal(gain)
      if amount > 0 then
        local company_id = rec.near_company_id or active_company_id or TARGET_COMPANY
        if chargeCitizenMeal(cid, name, amount, label, gain, company_id) then
          rec.last_charge_at = t
          rec.last_charge_amount = amount
          rec.last_charge_label = label
          rec.last_gain = gain
        end
      end
    end
  end

  rec.sat = sat
  rec.last_seen = t
  state.citizens[cid] = rec
end

local function pruneMissingCitizens(seen)
  local cutoff = now() - (60 * 60 * 1000)
  for cid, rec in pairs(state.citizens or {}) do
    if not seen[cid] and tonumber(rec.last_seen or 0) < cutoff then
      state.citizens[cid] = nil
    end
  end
end

local function poll()
  if not connectColony() then
    setMsg("No local colonyIntegrator on this terminal.", colors.red)
    return false
  end
  if not db_id then discoverBank() end
  refreshPricing()

  local citizens = getLiveCitizens()
  local buildings = getLiveBuildings()
  local dining = diningBuildings(buildings)

  local resolved_company, resolved_source = resolveHospitalityCompany(dining)
  active_company_id = resolved_company or TARGET_COMPANY
  active_company_source = resolved_source or "fallback"

  if #dining > 0 then
    active_dining_name = dining[1].name or "Dining Hall"
  else
    active_dining_name = "fallback target"
  end

  for _, d in ipairs(dining or {}) do
    d.company_id = active_company_id
  end

  stats.citizens_seen = #citizens
  stats.dining_buildings = #dining
  stats.near_dining = 0

  local seen = {}
  for _, z in ipairs(citizens) do
    local cid = citizenAccountId(z)
    if cid then seen[cid] = true end
    processCitizen(z, dining)
  end

  pruneMissingCitizens(seen)
  writeFile(STATE_FILE, state)
  return true
end

-- =============================================================================
-- DISPLAY
-- =============================================================================
local function cls()
  W, H = term.getSize()
  term.setCursorBlink(false)
  term.setBackgroundColor(colors.black)
  term.setTextColor(colors.white)
  term.clear()
  term.setCursorPos(1, 1)
end

local function at(x, y, text, fg, bg)
  W, H = term.getSize()
  if y < 1 or y > H or x > W then return end
  if x < 1 then x = 1 end
  term.setCursorPos(x, y)
  term.setTextColor(fg or colors.white)
  term.setBackgroundColor(bg or colors.black)
  local maxw = W - x + 1
  if maxw > 0 then term.write(tostring(text or ""):sub(1, maxw)) end
end

local function fill(x, y, w, h, bg)
  W, H = term.getSize()
  if w <= 0 or h <= 0 then return end
  term.setBackgroundColor(bg or colors.black)
  local row = string.rep(" ", w)
  for yy = y, y + h - 1 do
    if yy >= 1 and yy <= H then
      term.setCursorPos(math.max(1, x), yy)
      term.write(row:sub(1, math.max(0, W - x + 1)))
    end
  end
end

local function button(x, y, w, label, bg, fg)
  fill(x, y, w, 1, bg or colors.gray)
  local tx = x + math.floor((w - #label) / 2)
  at(tx, y, label, fg or colors.white, bg or colors.gray)
  return { x1 = x, x2 = x + w - 1, y1 = y, y2 = y }
end

local function hit(b, x, y)
  return b and x >= b.x1 and x <= b.x2 and y >= b.y1 and y <= b.y2
end

local function draw()
  cls()
  fill(1, 1, W, 1, colors.purple)
  at(2, 1, "SERVICE PAYMENT TERMINAL", colors.white, colors.purple)
  at(math.max(2, W - #VERSION), 1, VERSION, colors.lightGray, colors.purple)

  at(2, 3, "Source:       any sat change = salmon charge", colors.white)
  at(2, 4, "Bank:         " .. tostring(db_id or "not connected"), db_id and colors.lime or colors.red)
  at(2, 5, "Colony:       " .. tostring(colony and "connected" or "missing"), colony and colors.lime or colors.red)
  at(2, 6, "Company:      " .. tostring(active_company_id or TARGET_COMPANY), colors.lime)
  at(2, 7, "Dining area:  " .. tostring(active_dining_name or "unknown"), colors.lightGray)
  at(2, 8, "Target via:   " .. tostring(active_company_source or "fallback"), colors.gray)
  at(2, 9, "Auto:         " .. (auto_charge and "ON" or "OFF"), auto_charge and colors.lime or colors.orange)

  at(2, 11,  "Citizens:     " .. tostring(stats.citizens_seen) .. "   Near dining: " .. tostring(stats.near_dining), colors.lightGray)
  at(2, 12, "Dining halls: " .. tostring(stats.dining_buildings) .. "   Radius: " .. tostring(DINING_RADIUS), stats.dining_buildings > 0 and colors.lime or colors.orange)
  at(2, 13, "Food item:    salmon", colors.cyan)
  at(2, 14, "Charge price: " .. money(SALMON_BASE_PRICE) .. " per sat-rise event", colors.cyan)
  at(2, 15, "Pricing:      fixed base food price", colors.lightGray)

  at(2, 17, "Sat rises:    " .. tostring(stats.saturation_rises) .. "   Last gain: +" .. string.format("%.1f", stats.last_gain), colors.lightGray)
  at(2, 18, "Meals:        " .. tostring(stats.meals_charged) .. "   Charged: " .. money(stats.charged) .. "   Unpaid: " .. money(stats.unpaid), colors.lime)
  at(2, 19, "Mode:         charge any positive sat change; no staff/near/tier filter", colors.orange)
  at(2, 20, "Receivables:  " .. money(totalReceivables()), totalReceivables() > 0 and colors.orange or colors.gray)

  local third = math.floor((W - 8) / 3)
  local bScan = button(2, H - 3, third, "Poll Now", colors.purple)
  local bAuto = button(4 + third, H - 3, third, auto_charge and "Auto Off" or "Auto On", colors.gray)
  local bRecon = button(6 + third * 2, H - 3, third, "Reconnect", colors.gray)

  at(2, H - 1, tostring(last_message):sub(1, W - 2), last_colour)
  return bScan, bAuto, bRecon
end

-- =============================================================================
-- MAIN
-- =============================================================================
local function loadConfig()
  local cfg = readFile(CONFIG_FILE)
  if type(cfg) ~= "table" then return end

  if tonumber(cfg.scan_seconds) then SCAN_SECONDS = math.max(1, tonumber(cfg.scan_seconds)) end
  if tonumber(cfg.dining_radius) then DINING_RADIUS = math.max(4, tonumber(cfg.dining_radius)) end
  if tonumber(cfg.near_grace_seconds) then NEAR_GRACE_SECONDS = math.max(1, tonumber(cfg.near_grace_seconds)) end
  if tonumber(cfg.meal_cooldown_seconds) then MEAL_COOLDOWN_SECONDS = math.max(1, tonumber(cfg.meal_cooldown_seconds)) end
  if tonumber(cfg.base_normal_meal_price) then BASE_NORMAL_MEAL_PRICE = math.max(0.1, tonumber(cfg.base_normal_meal_price)) end
  if cfg.target_company or cfg.company_id then
    local t = tostring(cfg.target_company or cfg.company_id)
    if t ~= "" then
      if not t:find("^company:") then t = companyIdFromName(t) or t end
      TARGET_COMPANY = t
      active_company_id = TARGET_COMPANY
      active_dining_name = "config override"
    end
  end
end

local function main()
  state = readFile(STATE_FILE) or state
  state.citizens = state.citizens or {}
  state.receivables = state.receivables or {}
  state.events = state.events or {}
  loadConfig()

  if not openModem() then
    print("No modem found.")
    return
  end

  discoverBank()
  connectColony()
  poll()

  local bScan, bAuto, bRecon = draw()
  local timer = os.startTimer(SCAN_SECONDS)

  while true do
    local ev, p1, p2, p3 = os.pullEvent()

    if ev == "timer" and p1 == timer then
      if auto_charge then poll() end
      bScan, bAuto, bRecon = draw()
      timer = os.startTimer(SCAN_SECONDS)

    elseif ev == "mouse_click" then
      if hit(bScan, p2, p3) then
        poll()
      elseif hit(bAuto, p2, p3) then
        auto_charge = not auto_charge
        setMsg("Auto " .. (auto_charge and "on" or "off"), colors.yellow)
      elseif hit(bRecon, p2, p3) then
        discoverBank()
        connectColony()
        refreshPricing()
        setMsg("Reconnected.", colors.lime)
      end
      bScan, bAuto, bRecon = draw()

    elseif ev == "terminate" then
      writeFile(STATE_FILE, state)
      break
    end
  end
end

local ok, err = pcall(main)
if not ok then
  term.setTextColor(colors.red)
  print("Runtime error: " .. tostring(err))
end

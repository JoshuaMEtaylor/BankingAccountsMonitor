local function mealTierForGain(gain)
  gain = tonumber(gain) or 0
  if gain > 0 then return 1.00, "salmon" end
  return 0, "none"
end

local function priceMeal(gain)
  local tier, label = mealTierForGain(gain)
  if tier <= 0 then return 0, label, tier end

  -- Current debug/bring-up rule:
  -- any positive sat gain = one salmon served = fixed base salmon price.
  return roundMoney(SALMON_BASE_PRICE), "salmon", 1.00
end


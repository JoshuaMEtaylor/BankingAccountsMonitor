local function now()
  if os.epoch then return os.epoch("utc") end
  return math.floor(os.clock() * 1000)
end

local function lower(s)
  return string.lower(tostring(s or ""))
end

local function trim(s)
  return tostring(s or ""):match("^%s*(.-)%s*$")
end

local function setMsg(msg, col)
  last_message = tostring(msg or "")
  last_colour = col or colors.lightGray
end

local function ensureDir(path)
  local dir = fs.getDir(path)
  if dir and dir ~= "" and not fs.exists(dir) then fs.makeDir(dir) end
end

local function readFile(path)
  if not fs.exists(path) then return nil end
  local f = fs.open(path, "r")
  if not f then return nil end
  local text = f.readAll()
  f.close()
  if not text or text == "" then return nil end
  local ok, data = pcall(textutils.unserialize, text)
  if ok then return data end
  return nil
end

local function writeFile(path, data)
  ensureDir(path)
  local f = fs.open(path, "w")
  if not f then return false end
  f.write(textutils.serialize(data))
  f.close()
  return true
end

local function money(n)
  n = tonumber(n) or 0
  local sign = ""
  if n < 0 then sign = "-"; n = math.abs(n) end
  local s = tostring(math.floor(n + 0.5))
  local out = ""
  while #s > 3 do
    out = "," .. s:sub(-3) .. out
    s = s:sub(1, -4)
  end
  return sign .. s .. out .. " Q"
end

local function roundMoney(n)
  n = tonumber(n) or 0
  if n <= 0 then return 0 end
  return math.max(MIN_CHARGE, math.floor(n + 0.5))
end

local function countRows(t)
  local n = 0
  if type(t) ~= "table" then return 0 end
  for _ in pairs(t) do n = n + 1 end
  return n
end

local function normalType(t)
  t = tostring(t or "")
  t = t:gsub("com%.minecolonies%.building%.", "")
  t = t:gsub("com%.minecolonies%.job%.", "")
  t = t:gsub("[^%w_%- ]", "")
  return lower(t)
end

local function safeKey(s)
  s = lower(s or "")
  s = s:gsub("[^%w_%-]", "_")
  s = s:gsub("_+", "_")
  s = s:gsub("^_+", "")
  s = s:gsub("_+$", "")
  if s == "" then return nil end
  return s
end

local function getPos(v)
  if type(v) ~= "table" then return nil end

  local src = v.location or v.position or v.pos or v.loc or v.blockPos or v.homeLocation or v.hutLocation or nil
  if type(src) == "table" then
    local x = tonumber(src.x or src.X or src[1])
    local y = tonumber(src.y or src.Y or src[2])
    local z = tonumber(src.z or src.Z or src[3])
    if x and y and z then return { x = x, y = y, z = z } end
  end

  local x = tonumber(v.x or v.X or v[1])
  local y = tonumber(v.y or v.Y or v[2])
  local z = tonumber(v.z or v.Z or v[3])
  if x and y and z then return { x = x, y = y, z = z } end

  return nil
end

local function dist(a, b)
  if not a or not b then return 999999 end
  local dx = (tonumber(a.x) or 0) - (tonumber(b.x) or 0)
  local dy = (tonumber(a.y) or 0) - (tonumber(b.y) or 0)
  local dz = (tonumber(a.z) or 0) - (tonumber(b.z) or 0)
  return math.sqrt((dx * dx) + (dy * dy) + (dz * dz))
end

local function mcDay()
  if os.day then
    local ok, d = pcall(os.day, "ingame")
    if ok and tonumber(d) then return math.floor(tonumber(d)) end
    ok, d = pcall(os.day)
    if ok and tonumber(d) then return math.floor(tonumber(d)) end
  end
  return math.floor(now() / 1200000)
end

local function mcHour()
  if os.time then
    local ok, t = pcall(os.time, "ingame")
    if ok and tonumber(t) then return tonumber(t) % 24 end
    ok, t = pcall(os.time)
    if ok and tonumber(t) then return tonumber(t) % 24 end
  end
  local dayMs = now() % 1200000
  return (dayMs / 1200000) * 24
end

local function isNight()
  local h = mcHour()
  if NIGHT_START_HOUR > NIGHT_END_HOUR then
    return h >= NIGHT_START_HOUR or h < NIGHT_END_HOUR
  end
  return h >= NIGHT_START_HOUR and h < NIGHT_END_HOUR
end

local function mctText()
  local h = mcHour()
  local hour = math.floor(h)
  local minute = math.floor((h - hour) * 60)
  return string.format("Day %d %02d:%02dMCT", mcDay(), hour, minute)
end

local function stableId(z)
  if type(z) ~= "table" then return nil end
  local id = z.id or z.citizen_id or z.citizenId or z.citizenID or z.uuid or z.name or z.displayName
  if id == nil then return nil end
  return tostring(id)
end

local function citizenUsername(z)
  local id = stableId(z)
  if not id then return nil end
  id = tostring(id):gsub("[^%w_%-]", "_")
  if id:find("^citizen:mc_") then return id:gsub("^citizen:", "") end
  if id:find("^citizen:") then return id:gsub("^citizen:", "") end
  if id:find("^mc_") then return id end
  return "mc_" .. id
end

local function citizenAccountId(z)
  local u = citizenUsername(z)
  if not u then return nil end
  return "citizen:" .. u
end

local function personName(z, fallback)
  return tostring(z and (z.name or z.display_name or z.displayName or z.nickname) or fallback or "guest")
end

local function visitorGuestId(z)
  local id = stableId(z) or personName(z, "guest")
  local key = safeKey(id) or ("guest_" .. tostring(now()))
  return "guest:" .. key
end

local function companySlug(text)
  text = lower(text or "")
  text = text:gsub("^company:", "")
  text = text:gsub("[^%w]+", "_")
  text = text:gsub("^_+", "")
  text = text:gsub("_+$", "")
  if text == "" then return nil end
  return text
end

local function companyIdFromName(name)
  local slug = companySlug(name)
  if not slug then return nil end
  return "company:" .. slug
end

local function isSafeCompanyId(id)
  id = tostring(id or "")
  if id == "" then return false end
  if not id:find("^company:") then return false end
  if id:find("minecolonies", 1, true) or id:find("building", 1, true) or id:find("%.") then return false end
  return true
end


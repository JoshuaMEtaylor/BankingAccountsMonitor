  local ok, res = bankReq({
    type = "quote_service_price",
    service = "dining_meal",
    tier = "normal",
    saturation_gain = 5,
    sector = "food",
  }, 4)

  if ok and type(res) == "table" then
    pricing.dining.normal_meal = roundMoney(res.total or SALMON_BASE_PRICE)
    pricing.dining.general_index = tonumber(res.general_index or res.effective_index) or 1.00
    pricing.dining.food_index = tonumber(res.sector_index or res.effective_index) or 1.00
    pricing.dining.effective_index = tonumber(res.effective_index or res.sector_index) or 1.00
    pricing.dining.source = tostring(res.source or "bank quote")
    pricing.dining.tier = tostring(res.tier or "normal meal")

-- =============================================================================
-- SERVICE PAYMENT TERMINAL
-- ServicePaymentTerminal
-- Dining Hall service payments from bank service observations.
--
-- The ColonyBusinessIntegrator observes MineColonies. This terminal does not
-- invent local colony/building variables; it consumes bank snapshots only.
-- =============================================================================

local args = {...}
if args[1] ~= "--updated" then
  print("[ Service Payment Terminal ]")
  print("Deleting old version...")
  fs.delete("startup.lua")
  print("Downloading latest from GitHub...")
  local cb = tostring(os.epoch and os.epoch("utc") or math.floor(os.clock() * 100000))
  local url = "https://raw.githubusercontent.com/JoshuaMEtaylor/BankingAccountsMonitor/refs/heads/main/ServicePaymentTerminal?cb=" .. cb
  shell.run("wget " .. url .. " startup.lua")
  if not fs.exists("startup.lua") then print("Download failed. Expected GitHub file: ServicePaymentTerminal"); return end
  print("Relaunching...")
  sleep(0.5)
  shell.run("startup.lua", "--updated")
  return
end

local VERSION = "1.1.2-SUPPLY-EVENT-POOL"
local BANK_PROTOCOL = "quid_bank"
local SERVICE_KEY = "dining_hall"
local FILE_STATE = "data/service_payment_state.db"
local SCAN_SECONDS = 2
local SAT_DELTA_MIN = 0.50

local db_id=nil
local last_message="Booting..."
local last_colour=colors.lightGray
local auto_charge=true
local obs=nil
local prev_citizens=nil
local state={ processed_supply={}, stock_pool={}, charged_sat={}, stats={matched=0,charged=0,unpaid=0,unattributed=0} }
local stats={citizens_seen=0, citizen_inventory_sources=0, stock_kinds=0, stock_units=0, supply_events=0, pool_units=0, sat_events=0, matched=0, charged=0, unpaid=0, unattributed=0}

local function now() return os.epoch("utc") end
local function lower(s) return string.lower(tostring(s or "")) end
local function setMsg(m,c) last_message=tostring(m or ""); last_colour=c or colors.lightGray end
local function ensureDir(path) local d=fs.getDir(path); if d and d~="" and not fs.exists(d) then fs.makeDir(d) end end
local function readFile(path) if not fs.exists(path) then return nil end local f=fs.open(path,"r"); if not f then return nil end local t=f.readAll(); f.close(); if not t or t=="" then return nil end local ok,d=pcall(textutils.unserialize,t); if ok then return d end return nil end
local function writeFile(path,data) ensureDir(path); local f=fs.open(path,"w"); if f then f.write(textutils.serialize(data)); f.close(); return true end return false end
local function money(n) return tostring(math.floor((tonumber(n) or 0)+0.5)).." Q" end

local function loadState()
  state=readFile(FILE_STATE) or state
  state.processed_supply=state.processed_supply or {}
  state.stock_pool=state.stock_pool or {}
  state.charged_sat=state.charged_sat or {}
  state.stats=state.stats or {matched=0,charged=0,unpaid=0,unattributed=0}
end
local function saveState() writeFile(FILE_STATE,state) end

local function openModem()
  for _,n in ipairs(peripheral.getNames()) do if peripheral.getType(n)=="modem" then rednet.open(n); return true end end
  return false
end
local function discoverBank()
  for _=1,5 do
    rednet.broadcast({type="ping"},BANK_PROTOCOL)
    local sender,msg=rednet.receive(BANK_PROTOCOL,2)
    if sender and type(msg)=="table" and (msg.type=="treasury_online" or msg.success==true) then db_id=sender; return true end
  end
  return false
end
local function bankReq(req,timeout)
  timeout=timeout or 6
  if not db_id then discoverBank() end
  if not db_id then return false,"No bank server connected" end
  rednet.send(db_id,req,BANK_PROTOCOL)
  local deadline=os.clock()+timeout
  while true do
    local rem=deadline-os.clock()
    if rem<=0 then return false,"No response from bank" end
    local sender,msg=rednet.receive(BANK_PROTOCOL,rem)
    if sender==db_id and type(msg)=="table" and msg.success~=nil then return msg.success,msg.response end
  end
end

local function unitPrice(item)
  local id=lower(item)
  if id:find("golden_carrot",1,true) or id:find("cake",1,true) or id:find("rabbit_stew",1,true) then return 4 end
  if id:find("steak",1,true) or id:find("cooked_beef",1,true) or id:find("cooked_porkchop",1,true) or id:find("cooked_salmon",1,true) then return 3 end
  if id:find("cooked_",1,true) or id:find("bread",1,true) or id:find("pie",1,true) or id:find("stew",1,true) or id:find("soup",1,true) then return 2 end
  return 1
end
local function poolUnits()
  local u=0; for _,q in pairs(state.stock_pool or {}) do u=u+(tonumber(q) or 0) end; return u
end
local function poolKinds()
  local k=0; for _,q in pairs(state.stock_pool or {}) do if (tonumber(q) or 0)>0 then k=k+1 end end; return k
end
local function addSupplyEvents(events)
  local added=0
  for _,e in ipairs(events or {}) do
    local id=tostring(e.event_id or "")
    if id~="" and not state.processed_supply[id] then
      local item=tostring(e.item or e.display or "meal")
      local qty=math.max(1,math.floor(tonumber(e.qty) or 1))
      state.stock_pool[item]=(state.stock_pool[item] or 0)+qty
      state.processed_supply[id]=true
      added=added+qty
    end
  end
  if added>0 then setMsg("Added "..tostring(added).." dining stock from fulfilled food requests.",colors.lime) end
end
local function takeFoodFromPool()
  local best=nil
  for item,qty in pairs(state.stock_pool or {}) do
    qty=tonumber(qty) or 0
    if qty>0 and (not best or tostring(item)<tostring(best)) then best=item end
  end
  if not best then return nil end
  state.stock_pool[best]=(tonumber(state.stock_pool[best]) or 0)-1
  return best
end
local function citizenMap(rows)
  local out={}
  for _,z in ipairs(rows or {}) do
    if z.citizen_id then out[z.citizen_id]={name=z.display_name or z.citizen_id,saturation=tonumber(z.saturation) or 0} end
  end
  return out
end
local function chargeForSaturation(id,name,delta)
  if not obs or not obs.company_id then setMsg("No dining company in observation.",colors.red); return end
  local item=takeFoodFromPool()
  if not item then stats.unattributed=stats.unattributed+1; state.stats.unattributed=(state.stats.unattributed or 0)+1; setMsg("Saturation rose but stock pool is empty.",colors.orange); return end
  local amount=unitPrice(item)
  local ok,res=bankReq({type="hospitality_meal_payment", citizen_id=id, company_id=obs.company_id, amount=amount, item=item, memo="Dining Hall meal: 1x "..item},6)
  if ok and type(res)=="table" then
    stats.matched=stats.matched+1; stats.charged=stats.charged+(tonumber(res.paid) or 0); stats.unpaid=stats.unpaid+(tonumber(res.shortfall) or 0)
    state.stats.matched=(state.stats.matched or 0)+1; state.stats.charged=(state.stats.charged or 0)+(tonumber(res.paid) or 0); state.stats.unpaid=(state.stats.unpaid or 0)+(tonumber(res.shortfall) or 0)
    setMsg("Charged "..tostring(name).." "..money(res.paid or 0).." for 1x "..item,colors.lime)
  else
    state.stock_pool[item]=(state.stock_pool[item] or 0)+1
    setMsg("Meal payment failed: "..tostring(res),colors.red)
  end
end
local function handleSaturationChanges(old,new)
  for id,z in pairs(new or {}) do
    local p=(old or {})[id]
    if p then
      local delta=(tonumber(z.saturation) or 0)-(tonumber(p.saturation) or 0)
      if delta>=SAT_DELTA_MIN then
        local key=id..":"..tostring(os.day and os.day() or 0)..":"..tostring(math.floor(now()/1000))
        if not state.charged_sat[key] then
          state.charged_sat[key]=true
          stats.sat_events=stats.sat_events+1
          chargeForSaturation(id,z.name,delta)
        end
      end
    end
  end
end

local function poll()
  local ok,res=bankReq({type="get_service_observations",service_key=SERVICE_KEY},6)
  if not ok then setMsg("No service observation: "..tostring(res),colors.red); return end
  obs=res.observation or res
  stats.citizens_seen=tonumber(obs.citizens_seen) or #(obs.citizens or {})
  stats.citizen_inventory_sources=tonumber(obs.citizen_inventory_sources) or 0
  stats.supply_events=#(obs.supply_events or {})
  addSupplyEvents(obs.supply_events or {})
  local cits=citizenMap(obs.citizens or {})
  handleSaturationChanges(prev_citizens,cits)
  prev_citizens=cits
  stats.stock_kinds=poolKinds(); stats.stock_units=poolUnits()
  stats.matched=state.stats.matched or stats.matched
  stats.charged=state.stats.charged or stats.charged
  stats.unpaid=state.stats.unpaid or stats.unpaid
  stats.unattributed=state.stats.unattributed or stats.unattributed
  saveState()
end

local function cls() term.setCursorBlink(false); term.setBackgroundColor(colors.black); term.setTextColor(colors.white); term.clear(); term.setCursorPos(1,1) end
local function at(x,y,text,fg,bg) local W,H=term.getSize(); if y<1 or y>H then return end; term.setCursorPos(x,y); term.setTextColor(fg or colors.white); term.setBackgroundColor(bg or colors.black); term.write(tostring(text or ""):sub(1,W-x+1)) end
local function fill(x,y,w,h,bg) term.setBackgroundColor(bg or colors.black); local row=string.rep(" ",w); for yy=y,y+h-1 do term.setCursorPos(x,yy); term.write(row) end end
local function button(x,y,w,label,bg,fg) fill(x,y,w,1,bg or colors.gray); at(x+math.floor((w-#label)/2),y,label,fg or colors.white,bg or colors.gray); return {x1=x,x2=x+w-1,y1=y,y2=y} end
local function hit(b,x,y) return b and x>=b.x1 and x<=b.x2 and y>=b.y1 and y<=b.y2 end
local function draw()
  local W,H=term.getSize(); cls(); fill(1,1,W,1,colors.purple)
  at(2,1,"SERVICE PAYMENT TERMINAL",colors.white,colors.purple); at(math.max(2,W-#VERSION),1,VERSION,colors.lightGray,colors.purple)
  at(2,3,"Source:       CBI -> Bank service observations",colors.white)
  at(2,4,"Bank:         "..tostring(db_id or "not connected"),db_id and colors.lime or colors.red)
  at(2,5,"Company:      "..tostring(obs and (obs.company_name or obs.company_id) or "unknown"),(obs and obs.company_id) and colors.lime or colors.red)
  at(2,6,"Company src:  "..tostring(obs and obs.company_source or "none"),colors.lightGray)
  at(2,8,"Citizens seen:       "..tostring(stats.citizens_seen),stats.citizens_seen>0 and colors.lime or colors.orange)
  at(2,9,"Citizen inv sources: "..tostring(stats.citizen_inventory_sources),stats.citizen_inventory_sources>0 and colors.lime or colors.orange)
  at(2,10,"Supply events:       "..tostring(stats.supply_events),stats.supply_events>0 and colors.lime or colors.orange)
  at(2,11,"Local stock pool:    "..tostring(stats.stock_kinds).." / "..tostring(stats.stock_units),stats.stock_units>0 and colors.lime or colors.orange)
  at(2,12,"Saturation events:   "..tostring(stats.sat_events),colors.cyan)
  at(2,14,"Matched: "..tostring(stats.matched).."  Charged: "..money(stats.charged).."  Unpaid: "..money(stats.unpaid),colors.lime)
  at(2,15,"Unattributed:        "..tostring(stats.unattributed),stats.unattributed>0 and colors.orange or colors.gray)
  local third=math.floor((W-8)/3)
  local bScan=button(2,H-3,third,"Poll Now",colors.purple)
  local bAuto=button(4+third,H-3,third,auto_charge and "Auto Off" or "Auto On",colors.gray)
  local bRecon=button(6+third*2,H-3,third,"Reconnect",colors.gray)
  at(2,H-1,last_message,last_colour)
  return bScan,bAuto,bRecon
end
local function main()
  loadState()
  if not openModem() then print("No modem found."); return end
  discoverBank(); poll()
  local bScan,bAuto,bRecon=draw(); local timer=os.startTimer(2)
  while true do
    local ev,p1,p2,p3=os.pullEvent()
    if ev=="timer" and p1==timer then if auto_charge then poll() end; bScan,bAuto,bRecon=draw(); timer=os.startTimer(2)
    elseif ev=="mouse_click" then if hit(bScan,p2,p3) then poll() elseif hit(bAuto,p2,p3) then auto_charge=not auto_charge; setMsg("Auto "..(auto_charge and "on" or "off"),colors.yellow) elseif hit(bRecon,p2,p3) then discoverBank(); setMsg("Reconnected.",colors.lime) end; bScan,bAuto,bRecon=draw()
    elseif ev=="terminate" then saveState(); break end
  end
end
local ok,err=pcall(main); if not ok then term.setTextColor(colors.red); print("Runtime error: "..tostring(err)) end

-- =============================================================================
-- FX SERVER API
-- =============================================================================
local function compactHistory()
  local out = {}
  local ticks = history.ticks or {}
  local start = math.max(1, #ticks - 80)
  for i = start, #ticks do out[#out + 1] = ticks[i] end
  return out
end

local function handleFxRequest(req)
  if type(req) ~= "table" then return false, "Invalid request" end
  local typ = req.type or "get_quid_strength"

  if typ == "ping" then
    return true, { message = "Forex server online", version = VERSION, id = os.getComputerID(), time = nowMs() }
  elseif typ == "get_quid_strength" or typ == "snapshot" or typ == "status" then
    if not last_snapshot then refreshSnapshot() end
    return last_snapshot ~= nil, last_snapshot or last_error
  elseif typ == "history" then
    return true, { version = VERSION, ticks = compactHistory(), count = #(history.ticks or {}) }
  elseif typ == "reconnect" then
    discoverBank()
    discoverContractServer()
    local ok, snap = refreshSnapshot()
    return ok, snap or last_error
  elseif typ == "reset_baseline" then
    state.baseline = nil
    state.last_issued_supply = nil
    state.print_shock_pressure = 0
    saveState()
    local ok, snap = refreshSnapshot()
    return ok, snap or last_error
  end

  return false, "Unknown forex request type: " .. tostring(typ)
end

local function sendSafe(to, payload, protocol)
  local safePayload = wireSafeCopy(payload)
  local okSer, serErr = pcall(textutils.serialize, safePayload)
  if not okSer then
    safePayload = { success = false, response = "Forex response not serializable after wireSafeCopy: " .. tostring(serErr), time = nowMs(), server = os.getComputerID() }
  end
  return pcall(function() rednet.send(to, safePayload, protocol) end)
end

local function broadcastTick()
  if not last_snapshot then return end
  local msg = {
    type = "quid_fx_tick",
    version = VERSION,
    time = nowMs(),
    server = os.getComputerID(),
    quality = last_snapshot.quality,
    market_state = last_snapshot.market_state,
    quid_strength_index = last_snapshot.quid_strength_index,
    reference_qusd = last_snapshot.reference_qusd,
    base_qusd = BASE_QUSD,
  }
  pcall(function() rednet.broadcast(msg, FX_PROTOCOL) end)
end

local function serverLoop()
  while true do
    local now = os.clock()
    if (now - last_refresh) >= REFRESH_SECONDS then
      refreshSnapshot()
      draw()
      last_refresh = now
    end

    if (now - last_broadcast) >= BROADCAST_SECONDS then
      broadcastTick()
      last_broadcast = now
    end

    local sender, msg = rednet.receive(FX_PROTOCOL, 0.5)
    if sender and type(msg) == "table" then
      local ok, res = handleFxRequest(msg)
      sendSafe(sender, { success = ok, response = res, time = nowMs(), server = os.getComputerID() }, FX_PROTOCOL)
    end
  end
end


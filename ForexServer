local function sparkline()
  local ticks = history.ticks or {}
  if #ticks < 2 then return "Awaiting history" end
  local start = math.max(1, #ticks - 40)
  local vals = {}
  local lo, hi = nil, nil
  for i = start, #ticks do
    local v = tonumber(ticks[i].strength) or 1
    vals[#vals + 1] = v
    lo = lo and math.min(lo, v) or v
    hi = hi and math.max(hi, v) or v
  end
  local chars = { "_", ".", "-", "=", "+", "*", "#" }
  local out = ""
  for _, v in ipairs(vals) do
    local idx = 1
    if hi and lo and hi > lo then idx = math.floor(((v - lo) / (hi - lo)) * (#chars - 1)) + 1 end
    if idx < 1 then idx = 1 end
    if idx > #chars then idx = #chars end
    out = out .. chars[idx]
  end
  return out
end


-- =============================================================================
-- HELPERS
-- =============================================================================
local function nowMs()
  if os.epoch then return os.epoch("utc") end
  return math.floor(os.time() * 1000)
end

local function mcDay()
  if os.day then
    local ok, d = pcall(os.day, "ingame")
    if ok and tonumber(d) then return math.floor(tonumber(d)) end
    ok, d = pcall(os.day)
    if ok and tonumber(d) then return math.floor(tonumber(d)) end
  end
  return math.floor(nowMs() / 1200000)
end

local function clamp(v, lo, hi)
  v = tonumber(v) or 0
  if v < lo then return lo end
  if v > hi then return hi end
  return v
end

local function safeDiv(a, b, fallback)
  a = tonumber(a)
  b = tonumber(b)
  if not a or not b or b == 0 then return fallback end
  return a / b
end

local function pow(a, b)
  a = tonumber(a) or 0
  b = tonumber(b) or 0
  if a <= 0 then return 1 end
  return a ^ b
end

local function round(n, dp)
  n = tonumber(n) or 0
  local m = 10 ^ (dp or 0)
  return math.floor(n * m + 0.5) / m
end

local function pct(n, dp)
  n = tonumber(n) or 0
  return string.format("%." .. tostring(dp or 2) .. "f%%", n * 100)
end

local function money(n, dp)
  n = tonumber(n) or 0
  dp = dp or 2
  return string.format("$%." .. tostring(dp) .. "f", n)
end

local function q(n)
  n = tonumber(n) or 0
  local sign = ""
  if n < 0 then sign = "-"; n = math.abs(n) end
  local s = tostring(math.floor(n + 0.5))
  local out = ""
  while #s > 3 do out = "," .. s:sub(-3) .. out; s = s:sub(1, -4) end
  return sign .. s .. out .. " Q"
end

local function countTable(t)
  local n = 0
  if type(t) ~= "table" then return 0 end
  for _ in pairs(t) do n = n + 1 end
  return n
end

local function ensureDir(path)
  local dir = fs.getDir(path)
  if dir and dir ~= "" and not fs.exists(dir) then fs.makeDir(dir) end
end

local function readTable(path)
  if not fs.exists(path) then return nil end
  local f = fs.open(path, "r")
  if not f then return nil end
  local text = f.readAll()
  f.close()
  if not text or text == "" then return nil end
  local ok, data = pcall(textutils.unserialize, text)
  if ok and type(data) == "table" then return data end
  return nil
end

local function wireSafeCopy(value, visiting)
  local tv = type(value)
  if tv ~= "table" then
    if tv == "function" or tv == "thread" or tv == "userdata" then return tostring(value) end
    return value
  end

  visiting = visiting or {}
  if visiting[value] then return "[cycle/repeated-table]" end
  visiting[value] = true

  local out = {}
  for k, v in pairs(value) do
    local key = k
    local tk = type(key)
    if tk == "table" or tk == "function" or tk == "thread" or tk == "userdata" then
      key = tostring(key)
    end
    out[key] = wireSafeCopy(v, visiting)
  end

  visiting[value] = nil
  return out
end

local function writeTable(path, data)
  ensureDir(path)
  local safe = wireSafeCopy(data or {})
  local okSer, text = pcall(textutils.serialize, safe)
  if not okSer then return false, tostring(text) end
  local f = fs.open(path, "w")
  if not f then return false, "open failed" end
  f.write(text)
  f.close()
  return true
end

local function loadState()
  state = readTable(STATE_FILE) or {}
  state.baseline = type(state.baseline) == "table" and state.baseline or nil
  state.last_issued_supply = tonumber(state.last_issued_supply) or nil
  state.print_shock_pressure = tonumber(state.print_shock_pressure) or 0
  state.last_refresh_ms = tonumber(state.last_refresh_ms) or nowMs()
end

local function saveState()
  -- Keep this deliberately flat/small. Never store raw snapshots here.
  local flat = {
    version = VERSION,
    baseline = state.baseline,
    last_issued_supply = tonumber(state.last_issued_supply) or 0,
    print_shock_pressure = tonumber(state.print_shock_pressure) or 0,
    last_refresh_ms = tonumber(state.last_refresh_ms) or nowMs(),
    updated = nowMs(),
  }
  return writeTable(STATE_FILE, flat)
end

local function loadHistory()
  local h = readTable(HISTORY_FILE)
  history = type(h) == "table" and h or { ticks = {} }
  history.ticks = type(history.ticks) == "table" and history.ticks or {}
end

local function saveHistory()
  writeTable(HISTORY_FILE, history)
end

local function pushHistory(snap)
  if type(snap) ~= "table" then return end
  history.ticks = history.ticks or {}
  history.ticks[#history.ticks + 1] = {
    time = tonumber(snap.time) or nowMs(),
    day = tonumber(snap.mc_day) or mcDay(),
    strength = tonumber(snap.quid_strength_index) or 1,
    qusd = tonumber(snap.reference_qusd) or BASE_QUSD,
    issued = snap.inputs and tonumber(snap.inputs.issued_supply) or nil,
    price = snap.inputs and tonumber(snap.inputs.price_index) or nil,
  }
  while #history.ticks > MAX_HISTORY do table.remove(history.ticks, 1) end
  saveHistory()
end

local function setText(col)
  if col then term.setTextColor(col) end
end

local function cls()
  term.setCursorBlink(false)
  term.setBackgroundColor(colors.black)
  term.setTextColor(colors.white)
  term.clear()
  term.setCursorPos(1, 1)
end

local function at(x, y, text, col)
  local w, h = term.getSize()
  if y < 1 or y > h or x > w then return end
  term.setCursorPos(math.max(1, x), y)
  term.setBackgroundColor(colors.black)
  term.setTextColor(col or colors.white)
  term.write(tostring(text or ""):sub(1, math.max(0, w - x + 1)))
end


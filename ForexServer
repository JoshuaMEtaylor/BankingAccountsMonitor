-- =============================================================================
-- BASIC HELPERS
-- =============================================================================
local function nowMs()
  if os.epoch then return os.epoch("utc") end
  return math.floor(os.time() * 1000)
end

local function mcDay()
  if os.day then
    local ok, d = pcall(os.day, "ingame")
    if ok and tonumber(d) then return math.floor(tonumber(d)) end
    ok, d = pcall(os.day)
    if ok and tonumber(d) then return math.floor(tonumber(d)) end
  end
  return math.floor(nowMs() / MINECRAFT_DAY_MS)
end

local function num(v, fallback)
  local n = tonumber(v)
  if n == nil then return fallback end
  return n
end

local function clamp(v, lo, hi)
  v = tonumber(v) or 0
  if v < lo then return lo end
  if v > hi then return hi end
  return v
end

local function safeDiv(a, b, fallback)
  a = tonumber(a)
  b = tonumber(b)
  if not a or not b or b == 0 then return fallback end
  return a / b
end

local function pow(a, b)
  a = tonumber(a) or 0
  b = tonumber(b) or 0
  if a <= 0 then return 1 end
  if math.pow then return math.pow(a, b) end
  return a ^ b
end

local function countTable(t)
  local c = 0
  if type(t) ~= "table" then return 0 end
  for _ in pairs(t) do c = c + 1 end
  return c
end

local function fmt(n, dp)
  n = tonumber(n)
  if not n then return "--" end
  dp = dp or 2
  return string.format("%." .. tostring(dp) .. "f", n)
end

local function fmtPct(decimal, dp)
  decimal = tonumber(decimal)
  if not decimal then return "--" end
  return string.format("%." .. tostring(dp or 2) .. "f%%", decimal * 100)
end

local function fmtMoney(n)
  n = tonumber(n)
  if not n then return "--" end
  local sign = ""
  if n < 0 then sign = "-"; n = math.abs(n) end
  local s = tostring(math.floor(n + 0.5))
  local out = ""
  while #s > 3 do
    out = "," .. s:sub(-3) .. out
    s = s:sub(1, -4)
  end
  return sign .. s .. out .. " Q"
end

local function ensureDir(path)
  local dir = fs.getDir(path)
  if dir and dir ~= "" and not fs.exists(dir) then fs.makeDir(dir) end
end

local function readFile(path)
  if not fs.exists(path) then return nil end
  local f = fs.open(path, "r")
  if not f then return nil end
  local text = f.readAll()
  f.close()
  if not text or text == "" then return nil end
  local ok, data = pcall(textutils.unserialize, text)
  if ok then return data end
  return nil
end

local function writeFile(path, data)
  ensureDir(path)
  local f = fs.open(path, "w")
  if not f then return false end
  f.write(textutils.serialize(data))
  f.close()
  return true
end

local function loadState()
  local s = readFile(STATE_FILE)
  if type(s) == "table" then state = s end
  state.print_shock_pressure = tonumber(state.print_shock_pressure) or 0
end

local function saveState()
  writeFile(STATE_FILE, state)
end

local function loadHistory()
  local h = readFile(HISTORY_FILE)
  if type(h) == "table" then history = h else history = {} end
end

local function saveHistory()
  writeFile(HISTORY_FILE, history)
end

local function pushHistory(snap)
  if type(snap) ~= "table" then return end
  history[#history + 1] = {
    time = snap.time,
    day = snap.mc_day,
    quid_strength_index = snap.quid_strength_index,
    reference_qusd = snap.reference_qusd,
    price_index = snap.inputs and snap.inputs.price_index,
    issued_supply = snap.inputs and snap.inputs.issued_supply,
    print_shock_pressure = snap.inputs and snap.inputs.print_shock_pressure,
    quality = snap.quality,
  }
  while #history > MAX_HISTORY do table.remove(history, 1) end
  saveHistory()
end

local function shortHistory(maxN)
  maxN = tonumber(maxN) or 80
  local out = {}
  local start = math.max(1, #history - maxN + 1)
  for i = start, #history do out[#out + 1] = history[i] end
  return out
end

-- =============================================================================

    at(2, 6, "FATAL: No modem found.", colors.red)
    return
  end

  loadState()
  loadHistory()

  at(2, 5, "Modem: " .. tostring(modem_name), colors.lime)
  at(2, 6, "Discovering bank...", colors.lightGray)
  discoverBank()
  discoverContractServer()

  refreshSnapshot()
  draw()
  serverLoop()
end


local function openModem()
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      local m = peripheral.wrap(name)
      if m and m.isWireless and m.isWireless() then
        rednet.open(name)
        modem_name = name
        return true
      end
    end
  end
  for _, name in ipairs(peripheral.getNames()) do
    if peripheral.getType(name) == "modem" then
      rednet.open(name)
      modem_name = name
      return true
    end
  end
  return false
end

local function isBankBroadcast(msg)
  return type(msg) == "table" and msg.type == "treasury_online"
end

local function discoverBank()
  if FORCED_BANK_ID then bank_id = FORCED_BANK_ID; return true end

  bank_id = nil
  last_error = "Finding ServerSideAccounts bank..."

  -- 1) Passive discovery first: ServerSideAccounts broadcasts treasury_online
  -- on quid_bank and quid_bank_discovery in serverLoop/main. This does not
  -- request any nested table from the bank and cannot trigger its status/oracle
  -- serialization issue.
  local deadline = os.clock() + 6
  while true do
    local rem = deadline - os.clock()
    if rem <= 0 then break end
    local sender, msg, protocol = rednet.receive(nil, rem)
    if sender and isBankBroadcast(msg) and (protocol == BANK_PROTOCOL or protocol == BANK_DISCOVERY_PROTOCOL) then
      bank_id = sender
      last_error = ""
      return true
    end
  end

  -- 2) Active fallback: do NOT ping and do NOT status. The current
  -- ServerSideAccounts has no ping handler in the uploaded script, while status
  -- can contain nested inflation/oracle structures. A broadcast supply request
  -- is flat and is defined in ServerSideAccounts as deriveMonetarySupply().
  for _ = 1, 4 do
    pcall(function() rednet.broadcast({ type = "supply" }, BANK_PROTOCOL) end)
    deadline = os.clock() + 3
    while true do
      local rem = deadline - os.clock()
      if rem <= 0 then break end
      local sender, msg, protocol = rednet.receive(BANK_PROTOCOL, rem)
      if sender and type(msg) == "table" then
        if isBankBroadcast(msg) then
          bank_id = sender
          last_error = ""
          return true
        end
        if msg.success == true and type(msg.response) == "table" then
          local r = msg.response
          if r.in_circulation ~= nil or r.total_minted ~= nil or r.treasury_balance ~= nil then
            bank_id = sender
            last_error = ""
            return true
          end
        end
      end
    end
  end

  last_error = "ServerSideAccounts bank not found on quid_bank/quid_bank_discovery"
  return false
end

local function discoverContractServer()
  contract_id = nil
  pcall(function() rednet.broadcast({ type = "ping" }, CONTRACT_PROTOCOL) end)
  local deadline = os.clock() + CONTRACT_TIMEOUT
  while true do
    local rem = deadline - os.clock()
    if rem <= 0 then return false end
    local sender, msg = rednet.receive(CONTRACT_PROTOCOL, rem)
    if sender and type(msg) == "table" then
      if msg.type == "contract_server_online" or msg.success ~= nil then
        contract_id = sender
        return true
      end
    end
  end
end

local function bankReq(req, timeout)
  timeout = timeout or DB_TIMEOUT
  if not bank_id then
    if not discoverBank() then return false, "No bank server" end
  end

  local okSend, err = pcall(function() rednet.send(bank_id, req, BANK_PROTOCOL) end)
  if not okSend then return false, "send failed: " .. tostring(err) end

  local deadline = os.clock() + timeout
  while true do
    local rem = deadline - os.clock()
    if rem <= 0 then return false, "No response from bank" end
    local sender, msg = rednet.receive(BANK_PROTOCOL, rem)
    if sender == bank_id and type(msg) == "table" and msg.success ~= nil then
      return msg.success == true, msg.response
    end
  end
end

local function contractReq(req, timeout)
  timeout = timeout or CONTRACT_TIMEOUT
  if not contract_id then return false, "No contract server" end
  local okSend, err = pcall(function() rednet.send(contract_id, req, CONTRACT_PROTOCOL) end)
  if not okSend then return false, "send failed: " .. tostring(err) end
  local deadline = os.clock() + timeout
  while true do
    local rem = deadline - os.clock()
    if rem <= 0 then return false, "No response from contracts" end
    local sender, msg = rednet.receive(CONTRACT_PROTOCOL, rem)
    if sender == contract_id and type(msg) == "table" and msg.success ~= nil then
      return msg.success == true, msg.response
    end
  end
end


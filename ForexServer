local function accountScale(accounts)
  local citizens, companies, citizenWealth, companyWealth = 0, 0, 0, 0
  local nonTreasuryPrivate = 0
  local rich = {}

  for _, acc in ipairs(accounts or {}) do
    if type(acc) == "table" and acc.status ~= "dead" and acc.status ~= "suspended" then
      local bal = tonumber(acc.balance) or 0
      local typ = tostring(acc.type or "")
      if acc.account_id ~= "treasury:quid_bank" then
        nonTreasuryPrivate = nonTreasuryPrivate + bal
      end
      if typ == "citizen" then
        citizens = citizens + 1
        citizenWealth = citizenWealth + bal
        rich[#rich + 1] = bal
      elseif typ == "company" then
        companies = companies + 1
        companyWealth = companyWealth + bal
      end
    end
  end

  table.sort(rich, function(a, b) return a > b end)
  local top1 = 0
  if #rich > 0 and citizenWealth ~= 0 then top1 = rich[1] / citizenWealth end

  return {
    citizens = citizens,
    companies = companies,
    citizen_wealth = citizenWealth,
    company_wealth = companyWealth,
    private_account_total = nonTreasuryPrivate,
    top1_share = top1,
  }
end

local function fetchPriceProxy(errors)
  local out = {
    price_index = 1,
    wage_index = 1,
    real_wage_ratio = 1,
    money_pressure = 0,
    shock_pressure = 0,
    total_pressure = 0,
    inflation_rate = 0,
    wage_cost_pressure = 0,
    source = "quote endpoints",
  }

  -- Safe quote endpoint. It returns flat price metadata from the national price
  -- oracle without returning the full nested oracle table.
  local okMeal, meal = bankReq({ type = "quote_service_price", service = "dining_meal", tier = "normal" }, 5)
  if okMeal and type(meal) == "table" then
    out.price_index = tonumber(meal.sector_index) or out.price_index
    out.money_pressure = tonumber(meal.monetary_pressure) or out.money_pressure
    out.shock_pressure = tonumber(meal.shock_pressure) or out.shock_pressure
    out.inflation_rate = tonumber(meal.bank_inflation_rate) or out.inflation_rate
  else
    errors[#errors + 1] = "meal quote: " .. tostring(meal)
  end

  local okIron, iron = bankReq({ type = "quote_item_price", item = "iron_ingot", count = 8, sector = "tools" }, 5)
  if okIron and type(iron) == "table" then
    out.price_index = math.max(out.price_index, tonumber(iron.sector_index) or 1)
    out.money_pressure = math.max(out.money_pressure, tonumber(iron.monetary_pressure) or 0)
    out.shock_pressure = math.max(out.shock_pressure, tonumber(iron.shock_pressure) or 0)
    out.inflation_rate = tonumber(iron.bank_inflation_rate) or out.inflation_rate
  else
    errors[#errors + 1] = "iron quote: " .. tostring(iron)
  end

  -- Keep this disabled until ServerSideAccounts has a dedicated flat forex
  -- snapshot endpoint. The wide endpoints can crash rednet serialization.
  if ALLOW_UNSAFE_FULL_PRICE_ENDPOINTS then
    local okFull, full = bankReq({ type = "get_price_indices" }, 5)
    if okFull and type(full) == "table" then
      local wp = type(full.wage_price) == "table" and full.wage_price or {}
      out.price_index = tonumber(full.national_price_index) or tonumber(wp.national_price_index) or out.price_index
      out.wage_index = tonumber(full.wage_index) or tonumber(wp.wage_index) or out.wage_index
      out.real_wage_ratio = safeDiv(out.wage_index, out.price_index, out.real_wage_ratio)
      out.wage_cost_pressure = tonumber(wp.wage_cost_pressure) or out.wage_cost_pressure
      out.total_pressure = tonumber(wp.total_inflation_pressure) or out.total_pressure
      out.source = "get_price_indices"
    else
      errors[#errors + 1] = "full price endpoint: " .. tostring(full)
    end
  end

  if out.price_index < 1 then out.price_index = 1 end
  -- Wage proxy: if we only know prices, assume wages lag behind price inflation.
  -- This is conservative and avoids calling unsafe wage-price endpoints.
  out.real_wage_ratio = clamp(safeDiv(out.wage_index, out.price_index, 1), 0.1, 2)
  out.total_pressure = math.max(tonumber(out.total_pressure) or 0, (tonumber(out.money_pressure) or 0) + (tonumber(out.shock_pressure) or 0))
  return out
end

local function fetchContractGdp(errors)
  if not contract_id then return 0, 0 end
  local ok, res = contractReq({ type = "status" }, 3)
  if not ok or type(res) ~= "table" then
    errors[#errors + 1] = "contract status: " .. tostring(res)
    return 0, 0
  end
  local gdp = tonumber(res.gdp or res.total_gdp or res.fulfilled_value or res.paid_value) or 0
  local count = tonumber(res.fulfilled or res.paid or res.contracts_fulfilled) or 0
  return gdp, count
end

local function rawEconomy()
  local errors = {}

  if not bank_id and not discoverBank() then return nil, "Bank server not found" end

  local okSupply, supply = bankReq({ type = "supply" }, 5)
  if not okSupply or type(supply) ~= "table" then
    errors[#errors + 1] = "supply: " .. tostring(supply)
    supply = {}
  end

  local okAcc, accRes = bankReq({ type = "list_accounts" }, 6)
  if not okAcc or type(accRes) ~= "table" then
    errors[#errors + 1] = "accounts: " .. tostring(accRes)
    accRes = { accounts = {} }
  end
  local accounts = type(accRes.accounts) == "table" and accRes.accounts or {}
  local scale = accountScale(accounts)

  local okTx, txRes = bankReq({ type = "transaction_stats" }, 5)
  if not okTx or type(txRes) ~= "table" then
    errors[#errors + 1] = "tx: " .. tostring(txRes)
    txRes = {}
  end

  local okGdp, gdpRes = bankReq({ type = "economic_gdp", days = GDP_DAYS, exclude_contracts = true }, 6)
  if not okGdp or type(gdpRes) ~= "table" then
    errors[#errors + 1] = "gdp: " .. tostring(gdpRes)
    gdpRes = {}
  end

  local price = fetchPriceProxy(errors)
  local contractGdp, contractCount = fetchContractGdp(errors)

  local issued = tonumber(supply.in_circulation or supply.issued_supply or supply.total_supply) or 0
  local treasury = tonumber(supply.treasury_balance) or 0
  local citizenHoldings = tonumber(supply.citizen_holdings) or scale.citizen_wealth or 0
  local companyHoldings = tonumber(supply.company_holdings) or scale.company_wealth or 0
  local escrowHeld = tonumber(supply.escrow_held) or 0
  local privateSupply = citizenHoldings + companyHoldings + escrowHeld

  local population = tonumber(gdpRes.population) or tonumber(scale.citizens) or 0
  local bankGdp = tonumber(gdpRes.private_gdp or gdpRes.gdp or gdpRes.service_gdp or gdpRes.economic_gdp) or 0
  local gdp = bankGdp + contractGdp
  local gdpCap = tonumber(gdpRes.gdp_per_capita) or safeDiv(gdp, population, 0) or 0

  local today = type(txRes.today) == "table" and txRes.today or {}
  local week = type(txRes.last_7_days) == "table" and txRes.last_7_days or {}

  return {
    time = nowMs(),
    mc_day = mcDay(),
    issued_supply = issued,
    total_minted = tonumber(supply.total_minted) or 0,
    total_burned = tonumber(supply.total_burned) or 0,
    treasury_balance = treasury,
    citizen_holdings = citizenHoldings,
    company_holdings = companyHoldings,
    escrow_held = escrowHeld,
    private_supply = privateSupply,
    treasury_share = safeDiv(treasury, issued, 0),
    private_float = safeDiv(privateSupply, issued, 0),
    price_index = tonumber(price.price_index) or 1,
    inflation_rate = tonumber(price.inflation_rate) or 0,
    money_pressure = tonumber(price.money_pressure) or 0,
    shock_pressure = tonumber(price.shock_pressure) or 0,
    total_pressure = tonumber(price.total_pressure) or 0,
    wage_index = tonumber(price.wage_index) or 1,
    real_wage_ratio = tonumber(price.real_wage_ratio) or 1,
    wage_cost_pressure = tonumber(price.wage_cost_pressure) or 0,
    price_source = price.source,
    population = population,
    companies = tonumber(scale.companies) or 0,
    gdp = gdp,
    bank_gdp = bankGdp,
    contract_gdp = contractGdp,
    contract_count = contractCount,
    gdp_per_capita = gdpCap,
    tx_today = tonumber(today.total) or 0,
    tx_value_today = tonumber(today.value) or 0,
    tx_economic_today = tonumber(today.economic) or 0,
    tx_week = tonumber(week.total) or 0,
    top1_share = tonumber(scale.top1_share) or 0,
    account_count = #accounts,
    errors = errors,
  }
end

-- =============================================================================
-- STRENGTH MODEL
-- =============================================================================
local function ensureBaseline(raw)
  if type(state.baseline) == "table" then return end

  local issued = math.max(1, tonumber(raw.issued_supply) or 1)
  local price = math.max(1, tonumber(raw.price_index) or 1)
  local gdpCap = tonumber(raw.gdp_per_capita) or 0
  if gdpCap <= 0 then gdpCap = 1 end

  state.baseline = {
    created = nowMs(),
    day = mcDay(),
    base_qusd = BASE_QUSD,
    issued_supply = issued,
    price_index = price,
    gdp_per_capita = gdpCap,
    treasury_share = clamp(tonumber(raw.treasury_share) or 0.70, 0.01, 1),
    private_float = clamp(tonumber(raw.private_float) or 0.25, 0.01, 1),
    tx_today = math.max(1, tonumber(raw.tx_today) or 1),
    note = "Foundation state for Quid FX. 1 Q = $3.40 at this baseline.",
  }
  state.last_issued_supply = issued
  state.print_shock_pressure = tonumber(state.print_shock_pressure) or 0
  state.last_refresh_ms = nowMs()
  saveState()
end

local function updatePrintShock(raw)
  local now = nowMs()
  local issued = math.max(0, tonumber(raw.issued_supply) or 0)
  local lastIssued = tonumber(state.last_issued_supply) or issued
  local oldPressure = tonumber(state.print_shock_pressure) or 0
  local lastMs = tonumber(state.last_refresh_ms) or now

  -- Time decay. Roughly: frequent refresh = slow fade, not instant amnesia.
  local elapsedSeconds = math.max(0, (now - lastMs) / 1000)
  local decay = 0.985 ^ math.max(1, elapsedSeconds / REFRESH_SECONDS)
  local pressure = oldPressure * decay
  local newGrowth = 0

  if lastIssued > 0 and issued > lastIssued then
    newGrowth = (issued - lastIssued) / lastIssued
    local distribution = 0.75 + (clamp(tonumber(raw.private_float) or 0, 0, 1) * 1.25)
    pressure = pressure + (newGrowth * 2.50 * distribution)
  end

  pressure = clamp(pressure, 0, 10)
  state.print_shock_pressure = pressure
  state.last_issued_supply = issued
  state.last_refresh_ms = now
  saveState()

  return pressure, newGrowth
end

local function factorClamped(v, lo, hi)
  return clamp(tonumber(v) or 1, lo, hi)
end

local function calculateStrength(raw)
  ensureBaseline(raw)
  local b = state.baseline or {}
  local printShockPressure, supplyGrowth = updatePrintShock(raw)

  local priceIndex = math.max(0.01, tonumber(raw.price_index) or 1)
  local purchasingPower = 1 / priceIndex

  local printShockFactor = 1 / (1 + printShockPressure)

  local pressure = math.max(0, tonumber(raw.total_pressure) or 0)
  local moneyPressure = math.max(0, tonumber(raw.money_pressure) or 0)
  local bankShock = math.max(0, tonumber(raw.shock_pressure) or 0)
  local pressureFactor = 1 / (1 + (pressure * 3.0) + (moneyPressure * 2.0) + (bankShock * 1.0))

  local realWage = clamp(tonumber(raw.real_wage_ratio) or 1, 0.10, 2)
  local wageGap = math.max(0, 1 - realWage)
  local wageFactor = 1 / (1 + (wageGap * 0.18) + ((tonumber(raw.wage_cost_pressure) or 0) * 4))

  local baseGdpCap = math.max(1, tonumber(b.gdp_per_capita) or 1)
  local currGdpCap = math.max(0, tonumber(raw.gdp_per_capita) or 0)
  local outputFactor = factorClamped(pow(math.max(0.05, currGdpCap / baseGdpCap), 0.10), 0.82, 1.22)

  local baseTreasury = clamp(tonumber(b.treasury_share) or 0.70, 0.01, 1)
  local treasuryShare = clamp(tonumber(raw.treasury_share) or 0, 0.001, 1)
  local treasuryFactor = factorClamped(pow(treasuryShare / baseTreasury, 0.08), 0.90, 1.12)

  local basePrivate = clamp(tonumber(b.private_float) or 0.25, 0.01, 1)
  local privateFloat = clamp(tonumber(raw.private_float) or 0.25, 0.001, 1)
  local privateFloatFactor = factorClamped(pow(basePrivate / privateFloat, 0.06), 0.90, 1.10)

  local baseTx = math.max(1, tonumber(b.tx_today) or 1)
  local txNow = math.max(0, tonumber(raw.tx_today) or 0)
  local activityFactor = factorClamped(pow(math.max(0.10, txNow / baseTx), 0.025), 0.96, 1.05)

  local inflationRate = tonumber(raw.inflation_rate) or 0
  local stabilityFactor = factorClamped(1 / (1 + math.abs(inflationRate) * 0.55), 0.88, 1.03)
  local deflationRecovery = 1 + math.min(0.04, math.max(0, -inflationRate) * 0.35)

  local inequalityPenalty = 1 / (1 + math.max(0, (tonumber(raw.top1_share) or 0) - 0.55) * 0.08)

  local strength = purchasingPower
    * printShockFactor
    * pressureFactor
    * wageFactor
    * outputFactor
    * treasuryFactor
    * privateFloatFactor
    * activityFactor
    * stabilityFactor
    * deflationRecovery
    * inequalityPenalty

  strength = factorClamped(strength, 0.02, 5.00)

  local qusd = BASE_QUSD * strength

  local errors = raw.errors or {}
  local quality = "LIVE"
  if #errors > 0 then quality = "PARTIAL" end
  if not bank_id then quality = "OFFLINE" end

  local marketState = "STABLE"
  if supplyGrowth > 0.20 or printShockPressure > 0.75 then marketState = "MONETARY SHOCK"
  elseif strength < 0.70 then marketState = "QUID WEAK"
  elseif strength > 1.10 then marketState = "QUID STRONG"
  elseif inflationRate < -0.003 then marketState = "DEFLATION RECOVERY"
  elseif inflationRate > 0.003 then marketState = "INFLATION PRESSURE"
  end

  return {
    type = "quid_fx_snapshot",
    version = VERSION,
    quality = quality,
    market_state = marketState,
    time = nowMs(),
    mc_day = mcDay(),
    bank_id = bank_id,
    contract_id = contract_id,
    base_qusd = BASE_QUSD,
    quid_strength_index = strength,
    reference_qusd = qusd,
    formula_hint = "final_QUSD = base_qusd * quid_strength_index / usd_strength_index",
    inputs = {
      issued_supply = tonumber(raw.issued_supply) or 0,
      treasury_balance = tonumber(raw.treasury_balance) or 0,
      private_supply = tonumber(raw.private_supply) or 0,
      treasury_share = tonumber(raw.treasury_share) or 0,
      private_float = tonumber(raw.private_float) or 0,
      price_index = priceIndex,
      inflation_rate = inflationRate,
      money_pressure = tonumber(raw.money_pressure) or 0,
      bank_shock_pressure = tonumber(raw.shock_pressure) or 0,
      total_pressure = tonumber(raw.total_pressure) or 0,
      wage_index = tonumber(raw.wage_index) or 1,
      real_wage_ratio = realWage,
      wage_cost_pressure = tonumber(raw.wage_cost_pressure) or 0,
      gdp = tonumber(raw.gdp) or 0,
      gdp_per_capita = tonumber(raw.gdp_per_capita) or 0,
      population = tonumber(raw.population) or 0,
      companies = tonumber(raw.companies) or 0,
      tx_today = tonumber(raw.tx_today) or 0,
      tx_value_today = tonumber(raw.tx_value_today) or 0,
      top1_share = tonumber(raw.top1_share) or 0,
      price_source = tostring(raw.price_source or "unknown"),
    },
    drivers = {
      purchasing_power = purchasingPower,
      print_shock = printShockFactor,
      print_shock_pressure = printShockPressure,
      supply_growth_tick = supplyGrowth,
      pressure = pressureFactor,
      wage = wageFactor,
      output = outputFactor,
      treasury = treasuryFactor,
      private_float = privateFloatFactor,
      activity = activityFactor,
      stability = stabilityFactor,
      deflation_recovery = deflationRecovery,
      inequality = inequalityPenalty,
    },
    baseline = state.baseline,
    errors = errors,
  }
end

local function refreshSnapshot()
  local raw, err = rawEconomy()
  if not raw then
    last_error = tostring(err or "refresh failed")
    return false, last_error
  end

  local snap = wireSafeCopy(calculateStrength(raw))
  last_snapshot = snap
  last_error = (#(snap.errors or {}) > 0) and table.concat(snap.errors, "; "):sub(1, 100) or ""
  pushHistory(snap)
  return true, snap
end


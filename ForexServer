-- =============================================================================
-- QUID STRENGTH SERVER
-- QuidStrengthServer
--
-- Read-only FX/economic oracle for the Quid.
--
-- Purpose:
--   Pulls live internal economy data from ServerSideAccounts + optional
--   ContractServer, converts it into a single dynamic Quid Strength Index,
--   then broadcasts that index for a separate display/market terminal.
--
-- This script DOES NOT trade, mint, burn, grant, or move money.
-- It only reads the economy and publishes a calculated strength figure.
--
-- Protocol served: quid_fx
-- Bank protocol:    quid_bank
-- Contract protocol: quid_contracts
--
-- Display terminal should request:
--   rednet.send(fxServerId, { type = "get_quid_strength" }, "quid_fx")
--
-- Returned response includes:
--   base_qusd             -- foundation value, default 3.40
--   quid_strength_index   -- dynamic Quid side multiplier
--   reference_qusd        -- base_qusd * quid_strength_index, before USD index
--   formula_hint          -- display should do base_qusd * quid_strength_index / usd_strength_index
-- =============================================================================

-- =============================================================================
-- CONFIG
-- =============================================================================
local VERSION = "0.1.0-QUID-STRENGTH-ORACLE"

local FX_PROTOCOL       = "quid_fx"
local BANK_PROTOCOL     = "quid_bank"
local CONTRACT_PROTOCOL = "quid_contracts"

local DB_TIMEOUT       = 4
local CONTRACT_TIMEOUT = 4
local REFRESH_SECONDS  = 8
local BROADCAST_SECONDS = 5

local GDP_PERIOD_MC_DAYS = 365
local MINECRAFT_DAY_MS   = 20 * 60 * 1000
local GDP_PERIOD_MS      = GDP_PERIOD_MC_DAYS * MINECRAFT_DAY_MS

local BASE_QUSD = 3.40

local STATE_FILE   = "data/quid_strength_state.db"
local HISTORY_FILE = "data/quid_strength_history.db"
local MAX_HISTORY  = 240

-- How hard sudden monetary expansion hits Quid FX confidence.
-- 1.00 = mild. 2.50 = visible currency crisis on big printing.
local PRINT_SHOCK_SEVERITY = 2.50

-- Print shock decays over time, but it is not erased instantly. CPI/price_index
-- should carry longer term consequences once the economy catches up.
local PRINT_SHOCK_HALF_LIFE_SECONDS = 600 -- 10 minutes real time

-- Weight limits stop tiny early-economy baselines from causing absurd numbers.
local MIN_STRENGTH = 0.05
local MAX_STRENGTH = 5.00


-- =============================================================================
-- EMPLOYEE INVENTORY PROBE
-- EmployeeInventoryProbe
-- Version: 1.0.1-STRICT-ITEM-STACKS
--
-- Run this ON THE COLONY BUSINESS INTEGRATOR TERMINAL.
--
-- This does not guess buildings, industries, or fake local variables.
--
-- It uses only:
--   1. colonyIntegrator.getCitizens()
--   2. bank get_service_observations("dining_hall") to get the current company_id
--   3. bank list_employee_mappings to get the employees for that company
--
-- Then it dumps the raw citizen table for those employees and recursively searches
-- that raw table for item-stack-looking fields.
--
-- Output:
--   data/employee_inventory_probe.txt
-- =============================================================================

local BANK_PROTOCOL = "quid_bank"
local OUT = "data/employee_inventory_probe.txt"

local db_id = nil
local colony = nil
local lines = {}

local function log(s)
  lines[#lines + 1] = tostring(s or "")
end

local function ensureDir(path)
  local dir = fs.getDir(path)
  if dir and dir ~= "" and not fs.exists(dir) then fs.makeDir(dir) end
end

local function writeOut()
  ensureDir(OUT)
  local f = fs.open(OUT, "w")
  if not f then
    print("Failed to write " .. OUT)
    return false
  end
  for _, line in ipairs(lines) do f.writeLine(line) end
  f.close()
  return true
end

local function safeSerialize(v)
  local ok, res = pcall(textutils.serialize, v)
  if ok then return res end
  return "<unserializable>"
end

local function lower(s)
  return string.lower(tostring(s or ""))
end

local function openModem()
  for _, n in ipairs(peripheral.getNames()) do
    if peripheral.getType(n) == "modem" then
      rednet.open(n)
      return true, n
    end
  end
  return false, nil
end

local function discoverBank()
  for _ = 1, 5 do
    rednet.broadcast({ type = "ping" }, BANK_PROTOCOL)
    local sender, msg = rednet.receive(BANK_PROTOCOL, 2)
    if sender and type(msg) == "table" and (msg.type == "treasury_online" or msg.success == true) then
      db_id = sender
      return true
    end
  end
  return false
end

local function bankReq(req, timeout)
  timeout = timeout or 6
  if not db_id then discoverBank() end
  if not db_id then return false, "No bank server connected" end

  rednet.send(db_id, req, BANK_PROTOCOL)
  local deadline = os.clock() + timeout

  while true do
    local rem = deadline - os.clock()
    if rem <= 0 then return false, "No response from bank" end
    local sender, msg = rednet.receive(BANK_PROTOCOL, rem)
    if sender == db_id and type(msg) == "table" and msg.success ~= nil then
      return msg.success, msg.response
    end
  end
end

local function citizenAccountId(z)
  if type(z) ~= "table" then return nil end
  local id = z.id or z.citizen_id or z.citizenId or z.uuid or z.name
  if id == nil then return nil end

  local sid = tostring(id):gsub("[^%w_%-]", "_")
  if sid:find("^citizen:") then return sid end
  if sid:find("^mc_") then return "citizen:" .. sid end
  return "citizen:mc_" .. sid
end

local function simpleItemName(name)
  name = tostring(name or "")
  name = name:gsub("^minecraft:", "")
  name = name:gsub("^minecolonies:", "")
  name = name:gsub("^%w+:", "")
  return lower(name)
end

local function isCoalOrCharcoal(item)
  local id = simpleItemName(item)
  return id == "coal"
    or id == "charcoal"
    or id == "coal_block"
    or id == "block_of_coal"
    or id:find("coal_block", 1, true)
    or id:find("charcoal", 1, true)
end

local function scanForItemLikeTables(v, path, out, depth, seen)
  if type(v) ~= "table" then return end
  depth = depth or 0
  if depth > 7 then return end
  seen = seen or {}
  if seen[v] then return end
  seen[v] = true

  -- These are the common shapes used by CC inventories and serialized item stacks.
  local item_name = v.name or v.item or v.id or v.item_id or v.itemName or v.displayName or v.display
  local qty = v.count or v.qty or v.amount or v.size or v.quantity

  if item_name ~= nil and qty ~= nil then
    out[#out + 1] = {
      path = path,
      name = item_name,
      qty = qty,
      chargeable = item_name ~= nil and not isCoalOrCharcoal(item_name) or false,
      raw = v,
    }
  end

  -- Explicitly inspect common inventory container keys.
  local keys = {
    "inventory", "items", "stacks", "contents", "mainInventory",
    "main_inventory", "heldItems", "held_items", "food", "foods",
    "slots", "backpack", "equipment", "armor", "offhand",
    "hand", "mainHand", "mainhand", "heldItem", "held_item"
  }

  for _, k in ipairs(keys) do
    if type(v[k]) == "table" then
      scanForItemLikeTables(v[k], path .. "." .. k, out, depth + 1, seen)
    end
  end

  -- Also scan numeric arrays because inventories often serialize as slot-indexed tables.
  for k, child in pairs(v) do
    if type(k) == "number" and type(child) == "table" then
      scanForItemLikeTables(child, path .. "[" .. tostring(k) .. "]", out, depth + 1, seen)
    end
  end
end

local function tableKeys(t)
  local keys = {}
  if type(t) ~= "table" then return keys end
  for k, _ in pairs(t) do keys[#keys + 1] = tostring(k) end
  table.sort(keys)
  return keys
end

local function main()
  term.clear()
  term.setCursorPos(1, 1)
  term.setTextColor(colors.yellow)
  print("Employee Inventory Probe")
  term.setTextColor(colors.white)
  print("Scanning...")

  log("EMPLOYEE INVENTORY PROBE")
  log("Time: " .. tostring(os.epoch and os.epoch("utc") or os.clock()))
  log("Computer: " .. tostring(os.getComputerLabel() or os.getComputerID()))
  log("")

  local modem_ok, modem_name = openModem()
  log("Modem: " .. tostring(modem_ok) .. " " .. tostring(modem_name or ""))
  local bank_ok = discoverBank()
  log("Bank: " .. tostring(bank_ok) .. " id=" .. tostring(db_id or ""))
  log("")

  colony = peripheral.find("colonyIntegrator") or peripheral.find("colony_integrator")
  log("Colony integrator found: " .. tostring(colony ~= nil))

  if not colony or type(colony.getCitizens) ~= "function" then
    log("No usable colony.getCitizens on this terminal.")
    writeOut()
    print("No colony integrator/getCitizens. Saved " .. OUT)
    return
  end

  local okC, citizens = pcall(colony.getCitizens)
  log("getCitizens ok: " .. tostring(okC))
  if not okC or type(citizens) ~= "table" then
    log("getCitizens result/error: " .. tostring(citizens))
    writeOut()
    print("getCitizens failed. Saved " .. OUT)
    return
  end

  log("Citizen count: " .. tostring(#citizens))
  log("")

  local okObs, obsRes = bankReq({ type = "get_service_observations", service_key = "dining_hall" }, 6)
  log("get_service_observations ok: " .. tostring(okObs))
  local company_id = nil
  if okObs and type(obsRes) == "table" then
    local obs = obsRes.observation or obsRes
    company_id = obs.company_id
    log("Observation company_id: " .. tostring(company_id))
    log("Observation company_name: " .. tostring(obs.company_name))
    log("Observation company_source: " .. tostring(obs.company_source))
  else
    log("Observation error: " .. tostring(obsRes))
  end

  local employee_set = {}
  local employee_rows = {}

  if company_id then
    local okEmp, empRes = bankReq({ type = "list_employee_mappings", include_inactive = false }, 6)
    log("list_employee_mappings ok: " .. tostring(okEmp))
    if okEmp and type(empRes) == "table" and type(empRes.employees) == "table" then
      for _, e in ipairs(empRes.employees) do
        if type(e) == "table" and tostring(e.company_id or "") == tostring(company_id) and e.active ~= false then
          local cid = tostring(e.citizen_id or "")
          if cid ~= "" then
            employee_set[cid] = e
            employee_rows[#employee_rows + 1] = e
          end
        end
      end
    else
      log("list_employee_mappings result/error: " .. safeSerialize(empRes))
    end
  else
    log("No company_id from service observation, cannot filter payroll employees.")
  end

  log("Payroll employees for company: " .. tostring(#employee_rows))
  for _, e in ipairs(employee_rows) do
    log("  " .. tostring(e.citizen_id) .. " | " .. tostring(e.display_name) .. " | " .. tostring(e.job_text) .. " | " .. tostring(e.company_id))
  end
  log("")

  local matched_live = 0
  for i, z in ipairs(citizens) do
    local cid = citizenAccountId(z)
    if cid and employee_set[cid] then
      matched_live = matched_live + 1

      log("========================================================================")
      log("LIVE EMPLOYEE CITIZEN #" .. tostring(i))
      log("citizen_id: " .. tostring(cid))
      log("name: " .. tostring(z.name or z.display_name))
      log("top-level keys: " .. table.concat(tableKeys(z), ", "))
      log("saturation-like fields: saturation=" .. tostring(z.saturation) .. " food=" .. tostring(z.food) .. " foodLevel=" .. tostring(z.foodLevel) .. " food_level=" .. tostring(z.food_level))
      log("")
      log("RAW CITIZEN TABLE:")
      log(safeSerialize(z))
      log("")

      local found = {}
      scanForItemLikeTables(z, "citizen", found, 0, {})

      log("ITEM-LIKE TABLES FOUND: " .. tostring(#found))
      local chargeable_units = 0
      for _, f in ipairs(found) do
        local qty = tonumber(f.qty) or 0
        if f.chargeable then chargeable_units = chargeable_units + qty end
        log("  path=" .. tostring(f.path)
          .. " name=" .. tostring(f.name)
          .. " qty=" .. tostring(f.qty)
          .. " chargeable=" .. tostring(f.chargeable))
      end
      log("Chargeable units found for this employee: " .. tostring(chargeable_units))
      log("")
    end
  end

  log("Matched live payroll employees: " .. tostring(matched_live))
  writeOut()

  term.clear()
  term.setCursorPos(1, 1)
  term.setTextColor(colors.lime)
  print("Probe complete.")
  term.setTextColor(colors.white)
  print("")
  print("Saved:")
  print(OUT)
  print("")
  print("Open with:")
  print("edit " .. OUT)
end

local ok, err = pcall(main)
if not ok then
  term.setTextColor(colors.red)
  print("Runtime error: " .. tostring(err))
end
